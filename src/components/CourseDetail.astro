    }

    .detail-header-block {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-bottom: 8px;
    }

    .course-badge {
        display: inline-block;
        width: fit-content;
        padding: 6px 14px;
        border-radius: var(--radius-pill);
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .course-badge.open {
        background: color-mix(in srgb, var(--brand-lime), transparent 80%);
        color: var(--brand-lime);
    }

    .course-badge.closed {
        background: color-mix(in srgb, #ef4444, transparent 80%);
        color: #ef4444;
    }

    .detail-title {
        font-size: 42px;
