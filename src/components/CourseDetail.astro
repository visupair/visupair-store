    }

    .instructor-avatar-large {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: var(--brand-violet);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 700;
