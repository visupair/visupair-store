---
import type { Course } from "../lib/store-data";
import type { Currency } from "../lib/server-currency";

interface Props {
    course: Course;
    onClose: () => void;
    serverCurrency?: Currency; // Currency detected on server (from Cloudflare)
}

const { course, onClose, serverCurrency } = Astro.props;

// Helper to generate placeholder image
const getPlaceholderImage = (text: string, seed: number = 0) => {
    const encodedText = encodeURIComponent(text);
    const bg = seed === 0 ? "151128" : seed === 1 ? "1a1635" : "221d3a";
    return `https://placehold.co/1200x750/${bg}/CBFF62?text=${encodedText}+${seed + 1}&font=roboto`;
};

const details = course.details || {};
const instructor = course.instructor || { name: "Instructor", title: "Expert" };
const curriculum = course.curriculum || [];
const courseImage =
    course.mainImage || course.image || getPlaceholderImage(course.name);
const registrationOpen = course.registrationOpen !== false;

// Select appropriate price to display
const displayPrice =
    serverCurrency === "PLN" && course.pricePLN
        ? `${course.pricePLN}zł`
        : `€${course.price}`;

// Helper function to get initials for avatar
const getInitials = (name: string) => {
    return name.split(" ").map((word) => word[0]);
};
---

<div class="course-detail-panel">
    <!-- Close Button -->
    <button
        class="detail-close-btn"
        onclick="window.history.back()"
        aria-label="Close"
    >
        <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </button>

    <div class="course-detail-layout">
        <!-- LEFT: Image & Instructor (Aligned via Flex) -->
        <div class="detail-gallery-column">
            <div class="detail-large-image">
                <img src={courseImage} alt={course.name} loading="lazy" />
            </div>

            <!-- Instructor Card -->
            <div class="instructor-card">
                {
                    instructor.avatar ? (
                        <img
                            src={instructor.avatar}
                            alt={instructor.name}
                            class="instructor-avatar-large-img"
                        />
                    ) : (
                        <div class="instructor-avatar-large">
                            {getInitials(instructor.name)}
                        </div>
                    )
                }
                <div class="instructor-info">
                    <div class="instructor-label">Instructed By</div>
                    <div class="instructor-name">{instructor.name}</div>
                    <div class="instructor-title">{instructor.title}</div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Content & Actions -->
        <div class="detail-info-column">
            <div class="detail-header-block">
                <span
                    class={`course-badge ${registrationOpen ? "open" : "closed"}`}
                >
                    {
                        registrationOpen
                            ? "Registration Open"
                            : "Registration Closed"
                    }
                </span>
                <h1 class="detail-title">{course.name}</h1>
                <div class="price-tag">
                    <span
                        class="price-amount"
                        data-price-eur={course.price}
                        data-price-pln={course.pricePLN ||
                            Math.round(course.price * 4.3)}
                        data-server-currency={serverCurrency || ""}
                    >
                        €{course.price}
                    </span>
                    <span class="price-sub">/ lifetime access</span>
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="stats-container">
                <div class="stat-box">
                    <span class="stat-label">Duration</span>
                    <span class="stat-value">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <circle cx="12" cy="12" r="10"></circle>
                            <polyline points="12 6 12 12 16 14"></polyline>
                        </svg>
                        {
                            details.duration ||
                                (details as any)["Duration"] ||
                                "Self-Paced"
                        }
                    </span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Level</span>
                    <span class="stat-value">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <line x1="18" y1="20" x2="18" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="6" y1="20" x2="6" y2="14"></line>
                        </svg>
                        {
                            details.level ||
                                (details as any)["Level"] ||
                                "All Levels"
                        }
                    </span>
                </div>
                <div class="stat-box">
                    <span class="stat-label">Tools</span>
                    <span class="stat-value">
                        <svg
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <polygon points="12 2 2 7 12 12 22 7 12 2"
                            ></polygon>
                            <polyline points="2 17 12 22 22 17"></polyline>
                            <polyline points="2 12 12 17 22 12"></polyline>
                        </svg>
                        {
                            details.software ||
                                (details as any)["Software"] ||
                                (details as any)["Format"] ||
                                "Standard"
                        }
                    </span>
                </div>
            </div>

            <p class="detail-desc">{course.description}</p>

            <!-- Curriculum Section -->
            {
                curriculum.length > 0 && (
                    <div>
                        <details style={{ width: "100%" }} open>
                            <summary class="accordion-header">
                                <span>Curriculum & Schedule</span>
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <polyline points="6 9 12 15 18 9" />
                                </svg>
                            </summary>
                            <div class="curriculum-list">
                                {curriculum.map((item) => (
                                    <div class="curriculum-item">
                                        <span class="curr-week">
                                            {item.week}
                                        </span>
                                        <span class="curr-title">
                                            {item.title}
                                        </span>
                                    </div>
                                ))}
                            </div>
                        </details>
                    </div>
                )
            }

            <!-- Enroll Button -->
            {
                (course.price || course.pricePLN) && registrationOpen ? (
                    <button
                        id="enroll-btn"
                        class="btn-enroll"
                        data-product-id={course._id}
                        data-stripe-price-id={course.stripePriceId}
                        data-product-type="course"
                        data-enroll-eur={course.price}
                        data-enroll-pln={
                            course.pricePLN || Math.round(course.price * 4.3)
                        }
                        data-server-currency={serverCurrency || ""}
                    >
                        <span>Enroll Now for {displayPrice}</span>
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <line x1="5" y1="12" x2="19" y2="12" />
                            <polyline points="12 5 19 12 12 19" />
                        </svg>
                    </button>
                ) : (
                    <button
                        class="btn-enroll"
                        disabled
                        style="opacity: 0.5; cursor: not-allowed;"
                    >
                        <span>
                            {registrationOpen
                                ? "Enrollment Link Coming Soon"
                                : "Registration Closed"}
                        </span>
                    </button>
                )
            }
        </div>
    </div>
</div>

<!-- Stripe Checkout is handled on the server (redirect) -->

<style>
    .course-detail-panel {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        min-height: calc(100vh - 520px);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .course-detail-layout {
        display: flex;
        width: 100%;
        min-height: 600px;
        align-items: stretch;
        gap: 40px;
    }

