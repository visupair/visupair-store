    }

    .price-tag {
        font-size: 28px;
        font-weight: 500;
        color: var(--brand-violet);
        display: flex;
        align-items: baseline;
        gap: 8px;
        flex-wrap: wrap;
    }

    .price-divider {
        opacity: 0.4;
        font-weight: 400;
    }

    .price-sub {
        font-size: 15px;
        font-weight: 400;
        opacity: 0.6;
        color: var(--foreground);
    }

    .detail-desc {
        font-size: 15px;
        line-height: 1.7;
        opacity: 0.8;
    }

    .instructor-card {
        display: flex;
