</style>

<script>
    // Stable handlers so we can removeEventListener before re-bind (astro:page-load).
    let coursePageshowHooked = false;
    let courseRegSubmitHandler: ((e: SubmitEvent) => void) | null = null;
    let donationListenersBound = false;

    function onCoursePageshow() {
        updatePrices();
    }

    function handleDetailClose() {
        window.location.href = "/courses";
    }

    function handleRegisterBtnClick() {
        showRegistrationForm();
    }

    function handleRegBackBtnClick() {
        showCourseDetail();
    }

    function handleSuccessBackBtnClick() {
        showCourseDetail();
    }

    function handleDonationDocumentClick(e: Event) {
        const chip = (e.target as HTMLElement).closest(".donation-chip");
        const section = document.getElementById("donation-section");
        if (!chip || !section || !section.contains(chip)) return;

        const chips = section.querySelectorAll(".donation-chip");
        const customWrap = section.querySelector(".donation-custom-wrap");
        const customInput = section.querySelector("#donation-custom-input") as HTMLInputElement | null;
        const hiddenDonationEur = document.getElementById("selected-donation-eur") as HTMLInputElement | null;

        chips.forEach((c) => c.classList.remove("selected"));
        if (customWrap) customWrap.classList.remove("selected");
        if (customInput) customInput.value = "";
        chip.classList.add("selected");
        if (hiddenDonationEur) hiddenDonationEur.value = chip.getAttribute("data-donation-eur") || "0";
        updateSubmitBtnText();
    }

    function handleDonationFocusIn(e: Event) {
        const t = e.target as HTMLElement;
        if (t.id !== "donation-custom-input") return;
        const section = document.getElementById("donation-section");
        if (!section || !section.contains(t)) return;
        const chips = section.querySelectorAll(".donation-chip");
        const customWrap = section.querySelector(".donation-custom-wrap");
        const hiddenDonationEur = document.getElementById("selected-donation-eur") as HTMLInputElement | null;
        chips.forEach((c) => c.classList.remove("selected"));
        if (customWrap) customWrap.classList.add("selected");
        if (hiddenDonationEur) hiddenDonationEur.value = "";
    }

    function handleDonationInput(e: Event) {
        const t = e.target as HTMLElement;
        if (t.id !== "donation-custom-input") return;
        const section = document.getElementById("donation-section");
        if (!section || !section.contains(t)) return;
        const chips = section.querySelectorAll(".donation-chip");
        const customWrap = section.querySelector(".donation-custom-wrap");
        const hiddenDonationEur = document.getElementById("selected-donation-eur") as HTMLInputElement | null;
        chips.forEach((c) => c.classList.remove("selected"));
        if (customWrap) customWrap.classList.add("selected");
        if (hiddenDonationEur) hiddenDonationEur.value = "";
        updateSubmitBtnText();
    }

    // ── Toast Utility ──────────────────────────────────────────
    function showToast(message: string, type: 'error' | 'success' = 'error') {
        document.getElementById("vs-checkout-toast")?.remove();

        if (!document.getElementById("vs-toast-styles")) {
            const s = document.createElement("style");
            s.id = "vs-toast-styles";
            s.textContent = `
                #vs-checkout-toast {
                    position: fixed; bottom: 28px; right: 28px; z-index: 9999;
                    max-width: 400px; width: calc(100vw - 48px);
                    background: var(--surface);
                    border: 1px solid rgba(239,68,68,0.2);
                    border-left: 4px solid #ef4444;
                    border-radius: var(--radius-xl);
                    box-shadow: var(--shadow-dropdown);
                    padding: 16px 16px 16px 14px;
                    font-family: var(--font-family);
                    animation: vsToastIn 0.28s cubic-bezier(.4,0,.2,1);
                    transition: opacity 0.2s;
                }
                #vs-checkout-toast.toast-success {
                    border-color: rgba(34,197,94,0.2);
                    border-left-color: #22c55e;
                }
                @keyframes vsToastIn {
                    from { transform: translateY(14px) scale(0.97); opacity: 0; }
                    to   { transform: translateY(0) scale(1); opacity: 1; }
                }
                .vs-toast-inner { display: flex; align-items: flex-start; gap: 12px; }
                .vs-toast-icon  { flex-shrink: 0; margin-top: 1px; line-height: 0; }
                .vs-toast-body  { flex: 1; display: flex; flex-direction: column; gap: 3px; min-width: 0; }
                .vs-toast-title { font-size: 14px; font-weight: 600; color: var(--foreground); line-height: 1.3; }
                .vs-toast-msg   { font-size: 13px; color: var(--foreground); opacity: 0.65; line-height: 1.45; word-break: break-word; }
                .vs-toast-close { background: none; border: none; cursor: pointer; color: var(--foreground); opacity: 0.45; padding: 0; flex-shrink: 0; line-height: 0; transition: opacity 0.15s; align-self: flex-start; margin-top: 1px; }
                .vs-toast-close:hover { opacity: 0.9; }
                @media (max-width: 480px) {
                    #vs-checkout-toast { bottom: 20px; right: 16px; left: 16px; width: auto; }
                }
            `;
            document.head.appendChild(s);
        }

        const isSuccess = type === 'success';
        const toast = document.createElement("div");
        toast.id = "vs-checkout-toast";
        if (isSuccess) toast.classList.add("toast-success");
        toast.setAttribute("role", "alert");

        const inner = document.createElement("div");
        inner.className = "vs-toast-inner";

        const iconWrap = document.createElement("div");
        iconWrap.className = "vs-toast-icon";
        iconWrap.style.color = isSuccess ? "#22c55e" : "#ef4444";
        iconWrap.innerHTML = isSuccess
            ? '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
            : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';

        const body = document.createElement("div");
        body.className = "vs-toast-body";
        const titleEl = document.createElement("span");
        titleEl.className = "vs-toast-title";
        titleEl.textContent = isSuccess ? "Success" : "Error";
        const msgEl = document.createElement("span");
        msgEl.className = "vs-toast-msg";
        msgEl.textContent = message;
        body.appendChild(titleEl);
        body.appendChild(msgEl);

        const closeBtn = document.createElement("button");
        closeBtn.className = "vs-toast-close";
        closeBtn.setAttribute("aria-label", "Close notification");
        closeBtn.innerHTML =
            '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

        inner.appendChild(iconWrap);
        inner.appendChild(body);
        inner.appendChild(closeBtn);
        toast.appendChild(inner);
        document.body.appendChild(toast);

        const dismiss = () => {
            toast.style.opacity = "0";
            setTimeout(() => toast.remove(), 220);
        };
        closeBtn.addEventListener("click", dismiss);
        setTimeout(dismiss, 7000);
    }

    // ── Currency ───────────────────────────────────────────────
    type Currency = "EUR" | "PLN";

    function detectUserCurrency(): Currency {
        const urlParams = new URLSearchParams(window.location.search);
        const debugCurrency = urlParams.get("currency");
        if (debugCurrency === "EUR" || debugCurrency === "PLN") return debugCurrency;

        const panel = document.querySelector(".course-detail-panel");
        const scoped = panel
            ?.getAttribute("data-server-currency")
            ?.trim();
        if (scoped === "EUR" || scoped === "PLN") return scoped;

        try {
            const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
            if (tz && (tz.includes("Warsaw") || tz === "Europe/Warsaw")) return "PLN";
        } catch {}
        const locale = navigator.language || (navigator as any).userLanguage;
        if (locale && locale.toLowerCase().startsWith("pl")) return "PLN";
        return "EUR";
    }

    const EUR_TO_PLN_RATE = 4.3;

    function updateDonationLabels() {
        const section = document.getElementById("donation-section");
        if (!section) return;
        const cur = detectUserCurrency();
        section.querySelectorAll(".donation-chip-label[data-eur-amt]").forEach((el) => {
            const eur = el.getAttribute("data-eur-amt");
            const pln = el.getAttribute("data-pln-amt");
            if (!eur || !pln) return;
            el.textContent = cur === "PLN" ? `${pln}zł` : `€${eur}`;
        });
        const pref = document.getElementById("donation-custom-prefix");
        const suff = document.getElementById("donation-custom-suffix");
        if (pref && suff) {
            if (cur === "PLN") {
                pref.textContent = "";
                suff.textContent = "zł";
                suff.style.display = "";
            } else {
                pref.textContent = "€";
                suff.textContent = "";
                suff.style.display = "none";
            }
        }
    }

    function getDonationCheckoutAmount(): { amount: number; currency: Currency } | null {
        const pt = (document.getElementById("reg-pricingType") as HTMLInputElement)?.value;
        if (pt !== "donation") return null;

        const cur = detectUserCurrency();
        const customWrap = document.querySelector(".donation-custom-wrap");
        const customInput = document.getElementById("donation-custom-input") as HTMLInputElement;
        const hiddenEur = document.getElementById("selected-donation-eur") as HTMLInputElement;
        const customVal = customInput ? parseFloat(customInput.value || "0") : 0;
        const usingCustom =
            customWrap?.classList.contains("selected") && customVal > 0;

        if (usingCustom && customInput) {
            const v = Math.round(customVal * 100) / 100;
            if (v > 0) return { amount: v, currency: cur };
        }

        const eurVal = parseFloat(hiddenEur?.value || "0");
        if (eurVal > 0) {
            const amount =
                cur === "PLN"
                    ? Math.round(eurVal * EUR_TO_PLN_RATE * 100) / 100
                    : eurVal;
            return { amount, currency: cur };
        }
        return null;
    }

    function getPaidCheckoutAmount(): { amount: number; currency: Currency } | null {
        const pt = (document.getElementById("reg-pricingType") as HTMLInputElement)?.value;
        if (pt !== "paid") return null;

        const eurEl = document.getElementById("reg-enroll-eur") as HTMLInputElement | null;
        const plnEl = document.getElementById("reg-enroll-pln") as HTMLInputElement | null;
        const eur = parseFloat(eurEl?.value || "0");
        const pln = parseFloat(plnEl?.value || "0");
        if (!(eur > 0) || !(pln > 0)) return null;

        const cur = detectUserCurrency();
        if (cur === "PLN") return { amount: Math.round(pln * 100) / 100, currency: "PLN" };
        return { amount: Math.round(eur * 100) / 100, currency: "EUR" };
    }

    function updatePrices() {
        const currency = detectUserCurrency();
        // Scope to this component only. A document-wide selector also matched store
        // product buttons (data-price-eur on Add to Cart) after View Transitions.
        const panel = document.querySelector(".course-detail-panel");
        if (!panel) return;

        panel.querySelectorAll("[data-price-eur][data-price-pln]").forEach((el) => {
            const eur = el.getAttribute("data-price-eur");
            const pln = el.getAttribute("data-price-pln");
            if (!eur || !pln) return;
            el.textContent = currency === "PLN" ? `${pln}zł` : `€${eur}`;
        });
        updateDonationLabels();
        updateSubmitBtnText();
    }

    // ── View switching (detail <-> registration form) ──────────
    function showRegistrationForm() {
        const detailView = document.getElementById("course-detail-view");
        const formView = document.getElementById("registration-form-view");
        if (!detailView || !formView) return;

        detailView.style.animation = "fadeOut 0.25s ease forwards";
        setTimeout(() => {
            detailView.style.display = "none";
            formView.style.display = "block";
            formView.style.animation = "fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
            window.scrollTo({ top: 0, behavior: "smooth" });
        }, 250);
    }

    function showCourseDetail() {
        const detailView = document.getElementById("course-detail-view");
        const formView = document.getElementById("registration-form-view");
        const successView = document.getElementById("reg-success");
        const regForm = document.getElementById("course-reg-form") as HTMLFormElement;

        if (!detailView || !formView) return;

        formView.style.animation = "fadeOut 0.25s ease forwards";
        setTimeout(() => {
            formView.style.display = "none";
            if (successView) successView.style.display = "none";
            if (regForm) {
                regForm.style.display = "flex";
                regForm.reset();
            }
            // Reset donation section
            const donationSection = document.getElementById("donation-section");
            if (donationSection) donationSection.style.display = "flex";
            document.querySelectorAll(".donation-chip").forEach(c => c.classList.remove("selected"));
            const customWrap = document.querySelector(".donation-custom-wrap");
            if (customWrap) customWrap.classList.remove("selected");
            const customInput = document.getElementById("donation-custom-input") as HTMLInputElement;
            if (customInput) customInput.value = "";
            const hiddenDonationEur = document.getElementById("selected-donation-eur") as HTMLInputElement;
            if (hiddenDonationEur) hiddenDonationEur.value = "0";

            detailView.style.display = "block";
            detailView.style.animation = "fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
            updateDonationLabels();
            updateSubmitBtnText();
        }, 250);
    }

    // ── Donation chips (single document delegation — avoids duplicate handlers on astro:page-load)
    function initDonationChips() {
        const section = document.getElementById("donation-section");
        if (!section) return;

        if (!donationListenersBound) {
            donationListenersBound = true;
            document.addEventListener("click", handleDonationDocumentClick);
            document.addEventListener("focusin", handleDonationFocusIn);
            document.addEventListener("input", handleDonationInput);
        }

        const chips = section.querySelectorAll(".donation-chip");
        const customWrap = section.querySelector(".donation-custom-wrap");
        const customInput = section.querySelector("#donation-custom-input") as HTMLInputElement | null;
        const hiddenDonationEur = document.getElementById("selected-donation-eur") as HTMLInputElement | null;

        chips.forEach((c) => c.classList.remove("selected"));
        if (customWrap) customWrap.classList.remove("selected");
        if (customInput) customInput.value = "";
        const freeChip = chips[0];
        if (freeChip) freeChip.classList.add("selected");
        if (hiddenDonationEur) hiddenDonationEur.value = "0";

        updateDonationLabels();
        updateSubmitBtnText();
    }

    function updateSubmitBtnText() {
        const submitText = document.getElementById("reg-submit-text");
        if (!submitText) return;
        const pt = (document.getElementById("reg-pricingType") as HTMLInputElement)?.value;
        if (pt === "paid") {
            submitText.textContent = "Continue to payment";
            return;
        }
        if (pt !== "donation") {
            submitText.textContent = "Register";
            return;
        }
        const d = getDonationCheckoutAmount();
        if (d && d.amount > 0) {
            submitText.textContent = "Register & donate";
        } else {
            submitText.textContent = "Register";
        }
    }

    // ── Registration form submit ───────────────────────────────
    function initRegistrationForm() {
        const form = document.getElementById("course-reg-form") as HTMLFormElement;
        const submitBtn = document.getElementById("reg-submit-btn") as HTMLButtonElement;
        const submitText = document.getElementById("reg-submit-text");

        if (!form) return;

        if (courseRegSubmitHandler) form.removeEventListener("submit", courseRegSubmitHandler);

        courseRegSubmitHandler = async function onCourseRegSubmit(e: SubmitEvent) {
            e.preventDefault();
            if (submitBtn) submitBtn.disabled = true;
            if (submitText) submitText.textContent = "Registering...";

            const firstName = (document.getElementById("reg-firstName") as HTMLInputElement).value;
            const lastName = (document.getElementById("reg-lastName") as HTMLInputElement).value;
            const email = (document.getElementById("reg-email") as HTMLInputElement).value;
            const phone = (document.getElementById("reg-phone") as HTMLInputElement).value;
            const courseId = (document.getElementById("reg-courseId") as HTMLInputElement).value;
            const courseName = (document.getElementById("reg-courseName") as HTMLInputElement).value;
            const pricingType = (document.getElementById("reg-pricingType") as HTMLInputElement).value;
            const donationCheckout = getDonationCheckoutAmount();

            const resetSubmitState = () => {
                if (submitBtn) submitBtn.disabled = false;
                updateSubmitBtnText();
            };

            const ensureSignedInForCheckout = async (): Promise<boolean> => {
                const { authClient } = await import("../lib/auth-client");
                const s = await authClient.getSession();
                if (s.data?.user?.email) return true;
                window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname + window.location.search)}`;
                return false;
            };

            try {
                if (pricingType === "paid") {
                    if (!(await ensureSignedInForCheckout())) {
                        resetSubmitState();
                        return;
                    }
                    const paid = getPaidCheckoutAmount();
                    if (!paid || paid.amount <= 0) {
                        throw new Error("Could not determine course price. Please refresh and try again.");
                    }
                    if (submitText) submitText.textContent = "Redirecting to checkout...";
                    const stripePriceIdEl = document.getElementById("reg-stripePriceId") as HTMLInputElement | null;
                    const stripePriceId = stripePriceIdEl?.value?.trim() || undefined;
                    const response = await fetch("/api/create-checkout", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            productId: courseId,
                            priceId: paid.currency === "EUR" ? stripePriceId : undefined,
                            productName: courseName,
                            productType: "course",
                            firstName,
                            lastName,
                            phone: phone || "",
                            price: paid.amount,
                            currency: paid.currency,
                            courseName,
                        }),
                    });
                    const data = await response.json();
                    if (!response.ok || !data.url) {
                        throw new Error(data.error || "Could not start checkout");
                    }
                    window.location.href = data.url;
                    return;
                }

                if (pricingType === "donation" && donationCheckout && donationCheckout.amount > 0) {
                    if (!(await ensureSignedInForCheckout())) {
                        resetSubmitState();
                        return;
                    }
                    if (submitText) submitText.textContent = "Redirecting to checkout...";
                    const response = await fetch("/api/create-checkout", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            productType: "course_donation",
                            productId: courseId,
                            productName: `Course donation — ${courseName}`,
                            price: donationCheckout.amount,
                            currency: donationCheckout.currency,
                            firstName,
                            lastName,
                            phone: phone || "",
                            courseName,
                        }),
                    });
                    const data = await response.json();
                    if (!response.ok || !data.url) {
                        throw new Error(data.error || "Could not start donation checkout");
                    }
                    window.location.href = data.url;
                    return;
                }

                const response = await fetch("/api/course-register", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        firstName,
                        lastName,
                        email,
                        phone: phone || undefined,
                        courseId,
                        courseName,
                        pricingType,
                    }),
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || "Registration failed");
                }

                form.style.display = "none";
                const donationSection = document.getElementById("donation-section");
                if (donationSection) donationSection.style.display = "none";

                const successView = document.getElementById("reg-success");
                const successText = document.getElementById("success-text");
                if (successView) successView.style.display = "flex";

                if (successText) {
                    if (pricingType === "payAtDoor") {
                        successText.textContent = `Remember to bring payment to the venue. We'll send a confirmation to ${email}.`;
                    } else {
                        successText.textContent = `We'll send a confirmation to ${email}. See you at the course!`;
                    }
                }
            } catch (err: any) {
                console.error("Registration error:", err);
                showToast(err.message || "Registration failed. Please try again.", "error");
            } finally {
                if (submitBtn) submitBtn.disabled = false;
                updateSubmitBtnText();
            }
        };
        form.addEventListener("submit", courseRegSubmitHandler);
    }

    // ── Init ───────────────────────────────────────────────────
    function initCourseDetail() {
        if (!document.querySelector(".course-detail-panel")) return;

        updatePrices();

        if (!coursePageshowHooked) {
            window.addEventListener("pageshow", onCoursePageshow);
            coursePageshowHooked = true;
        }

        const closeBtn = document.getElementById("detail-close-btn");
        if (closeBtn) {
            closeBtn.removeEventListener("click", handleDetailClose);
            closeBtn.addEventListener("click", handleDetailClose);
        }

        const registerBtn = document.getElementById("register-btn");
        if (registerBtn) {
            registerBtn.removeEventListener("click", handleRegisterBtnClick);
            registerBtn.addEventListener("click", handleRegisterBtnClick);
        }

        const backBtn = document.getElementById("reg-back-btn");
        if (backBtn) {
            backBtn.removeEventListener("click", handleRegBackBtnClick);
            backBtn.addEventListener("click", handleRegBackBtnClick);
        }

        const backToCourse = document.getElementById("btn-back-to-course");
        if (backToCourse) {
            backToCourse.removeEventListener("click", handleSuccessBackBtnClick);
            backToCourse.addEventListener("click", handleSuccessBackBtnClick);
        }

        initDonationChips();
        initRegistrationForm();
    }

    initCourseDetail();
    document.addEventListener("astro:page-load", initCourseDetail);
</script>
