    }

    .instructor-avatar-large-img {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .instructor-info {
        flex: 1;
    }

    .instructor-label {
        font-size: 11px;
        text-transform: uppercase;
        font-weight: 700;
        opacity: 0.5;
        letter-spacing: 0.1em;
        margin-bottom: 4px;
    }

    .instructor-name {
        font-size: 18px;
        font-weight: 700;
        line-height: 1.2;
        color: var(--foreground);
    }

