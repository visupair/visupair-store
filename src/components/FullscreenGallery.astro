---
// Global Fullscreen Gallery Component
// Persists across page transitions and receives images via custom events
---

<div class="fullscreen-overlay" id="fullscreen-overlay" style="display: none;">
    <div
        class="fs-loader"
        id="fs-loader"
        role="status"
        aria-live="polite"
        aria-label="Loading image"
        hidden
    >
        <div class="fs-loader-inner">
            <svg
                class="fs-loader-mark"
                width="67"
                height="33"
                viewBox="0 0 67 33"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
            >
                <path
                    d="M32.489 29.283L54.0977 29.8267C54.7934 29.8442 55.3418 29.2398 55.2556 28.5503L54.2167 20.2401C54.1338 19.5775 53.4991 19.1288 52.8454 19.2707L31.9362 23.8126C31.3691 23.9358 30.9857 24.4652 31.0463 25.0415L31.3858 28.266C31.4456 28.8335 31.9176 29.2686 32.489 29.283Z"
                    fill="currentColor"
                />
                <path
                    d="M34.511 2.74744L12.9023 2.20366C12.2065 2.18616 11.6582 2.79065 11.7444 3.48008L12.7833 11.7903C12.8662 12.4529 13.5009 12.9016 14.1546 12.7597L35.0638 8.21779C35.6309 8.0946 36.0143 7.56513 35.9537 6.98893L35.6142 3.7644C35.5544 3.19699 35.0824 2.76181 34.511 2.74744Z"
                    fill="currentColor"
                />
                <path
                    d="M56.3459 0.998994L59.0673 0.0588497C59.6838 -0.154124 60.3374 0.230814 60.4839 0.89311L66.9703 30.2179C67.1615 31.0822 66.398 31.8521 65.586 31.6138L60.4075 30.0943C59.9935 29.9729 59.6859 29.6092 59.6188 29.1621L55.5896 2.29705C55.5045 1.72985 55.8256 1.17874 56.3459 0.998994Z"
                    fill="currentColor"
                />
                <path
                    d="M10.6541 31.0315L7.93272 31.9716C7.31624 32.1846 6.66259 31.7996 6.5161 31.1373L0.0297008 1.81256C-0.161497 0.94817 0.601976 0.17827 1.41404 0.416558L6.59251 1.93611C7.00649 2.05758 7.31408 2.42118 7.38115 2.86831L11.4104 29.7333C11.4955 30.3006 11.1744 30.8517 10.6541 31.0315Z"
                    fill="currentColor"
                />
                <path
                    d="M52.2415 15.3689L41.6392 17.5957C40.979 17.7343 40.3436 17.2725 40.2731 16.6027L38.911 3.66592C38.8418 3.00836 39.3475 2.43092 40.0095 2.41157L50.4785 2.10553C51.0604 2.08852 51.5614 2.51267 51.6395 3.08857L53.1349 14.1046C53.215 14.6946 52.8252 15.2464 52.2415 15.3689Z"
                    fill="currentColor"
                />
                <path
                    d="M14.7585 16.6608L25.3608 14.4341C26.021 14.2954 26.6564 14.7573 26.7269 15.427L28.089 28.3638C28.1582 29.0214 27.6525 29.5988 26.9905 29.6182L16.5215 29.9242C15.9396 29.9412 15.4386 29.5171 15.3605 28.9412L13.8651 17.9251C13.785 17.3351 14.1748 16.7834 14.7585 16.6608Z"
                    fill="currentColor"
                />
            </svg>
        </div>
    </div>

    <div class="fullscreen-image-container" id="fullscreen-container">
        <img
            id="fullscreen-img"
            src=""
            alt="Fullscreen view"
            class="fullscreen-img"
        />
    </div>

    <!-- Fullscreen Toolbar (Bottom Center) -->
    <div class="fs-toolbar">
        <button class="fs-btn fs-nav-btn" id="fs-prev-btn" aria-label="Previous image">
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M15 19l-7-7 7-7"></path>
            </svg>
        </button>

        <button class="fs-btn close fs-close-btn" id="fs-close-btn" aria-label="Close fullscreen">
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>

        <button class="fs-btn fs-nav-btn" id="fs-next-btn" aria-label="Next image">
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M9 5l7 7-7 7"></path>
            </svg>
        </button>
    </div>
</div>

<style>
    /* ===============================
       FULLSCREEN IMAGE OVERLAY
       =============================== */
    .fullscreen-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.95);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.3s ease-out;
    }

    .fullscreen-image-container {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        cursor: grab;
    }

    .fullscreen-image-container.grabbing {
        cursor: grabbing;
    }

    .fullscreen-img {
        object-fit: contain;
        box-shadow: 0 0 40px rgba(0, 0, 0, 0.5);
        transform-origin: center center;
        user-select: none;
        -webkit-user-drag: none;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
    }

    .fullscreen-img.fs-img-loading {
        opacity: 0;
    }

    /* After load: simple fade-in (opacity only — transform is driven by pan/zoom JS) */
    @keyframes fsImageReveal {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    .fullscreen-img.fs-img-reveal {
        animation: fsImageReveal 0.42s ease-out forwards;
    }

    /* Loader: nav mark, brand violet — same bouncy easing as .logo:hover, spin → pause ×3 */
    .fs-loader {
        position: absolute;
        inset: 0;
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

    .fs-loader[hidden] {
        display: none !important;
    }

    .fs-loader-inner {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
    }

    .fs-loader-mark {
        width: 30px;
        height: auto;
        display: block;
        color: var(--brand-violet, #8480ff);
        opacity: 0.5;
        transform-origin: 50% 50%;
        animation: fsLoaderLogoNav 3.5s infinite;
    }

    /**
     * Matches navbar logo hover: cubic-bezier(0.34, 1.56, 0.64, 1) per ~360° burst.
     * Three turns, pauses between; loops invisibly (1080° ≡ 0°).
     */
    @keyframes fsLoaderLogoNav {
        0% {
            transform: rotate(0deg);
            animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        23% {
            transform: rotate(360deg);
            animation-timing-function: linear;
        }
        32% {
            transform: rotate(360deg);
            animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        55% {
            transform: rotate(720deg);
            animation-timing-function: linear;
        }
        64% {
            transform: rotate(720deg);
            animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        87% {
            transform: rotate(1080deg);
            animation-timing-function: linear;
        }
        100% {
            transform: rotate(1080deg);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .fs-loader-mark {
            animation: none;
            opacity: 0.5;
        }

        .fullscreen-img.fs-img-reveal {
            animation: none;
            opacity: 1;
        }
    }

    /* Unified Fullscreen Toolbar (Bottom Center) */
    .fs-toolbar {
        position: absolute;
        bottom: 32px;
        left: 50%;
        transform: translateX(-50%);

        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;

        background: rgba(20, 20, 20, 0.9);
        backdrop-filter: blur(12px);
        padding: 10px;
        border-radius: var(--radius-pill);
        border: 1px solid rgba(255, 255, 255, 0.15);
        z-index: 10001;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        pointer-events: auto;
    }

    .fs-btn {
        background: transparent;
        border: none;
        color: #ffffff;
        font-family: var(--font-family);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
        border-radius: var(--radius-pill);
        cursor: pointer;
        transition: all 0.2s ease;
        min-width: 44px;
        min-height: 44px;
    }

    .fs-btn:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .fs-btn.close {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: var(--brand-lime);
    }

    .fs-btn.close:hover {
        background: rgba(255, 255, 255, 0.2);
        border-color: #EF4444;
        transform: rotate(90deg);
        color: #EF4444;
    }

    .fs-nav-btn svg {
        width: 24px;
        height: 24px;
    }

    .fs-close-btn svg {
        width: 20px;
        height: 20px;
    }

    @media (max-width: 768px) {
        .fs-toolbar {
            bottom: 20px;
            gap: 12px;
            padding: 8px;
        }

        .fs-btn {
            min-width: 40px;
            min-height: 40px;
            padding: 8px;
        }

        .fs-nav-btn svg {
            width: 22px;
            height: 22px;
        }

        .fs-close-btn svg {
            width: 18px;
            height: 18px;
        }
    }

    @media (max-width: 480px) {
        .fs-toolbar {
            bottom: 16px;
            gap: 10px;
            padding: 6px;
        }

        .fs-btn {
            min-width: 36px;
            min-height: 36px;
            padding: 6px;
        }

        .fs-nav-btn svg {
            width: 20px;
            height: 20px;
        }

        .fs-close-btn svg {
            width: 16px;
            height: 16px;
        }
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
</style>

<script>
    // ==========================================
    // FULLSCREEN GALLERY GLOBAL HANDLER
    // ==========================================

    interface FullscreenEventDetail {
        images: string[];
        startIndex?: number;
        productName?: string;
    }

    const fullscreenOverlay = document.getElementById("fullscreen-overlay");
    const fullscreenContainer = document.getElementById(
        "fullscreen-container",
    );
    const fullscreenImg = document.getElementById("fullscreen-img") as HTMLImageElement;
    const fsLoader = document.getElementById("fs-loader");

    const fsCloseBtn = document.getElementById("fs-close-btn");
    const fsPrevBtn = document.getElementById("fs-prev-btn");
    const fsNextBtn = document.getElementById("fs-next-btn");

    let galleryImageUrls: string[] = [];
    let currentFullscreenIndex = 0;
    let scale = 1;
    let translateX = 0;
    let translateY = 0;
    let isDragging = false;
    let startX = 0;
    let startY = 0;

    // Touch gesture tracking
    let touchStartX = 0;
    let touchStartY = 0;
    let touchStartDistance = 0;
    let isGesture = false;
    const BASE_PAN_OFFSET = 300; // Базовое ограничение
    let fullscreenLoadToken = 0;

    function showFsLoader() {
        fsLoader?.removeAttribute("hidden");
        fullscreenImg?.classList.remove("fs-img-reveal");
        fullscreenImg?.classList.add("fs-img-loading");
    }

    function hideFsLoader() {
        fsLoader?.setAttribute("hidden", "");
        if (!fullscreenImg) return;
        fullscreenImg.classList.remove("fs-img-loading");

        const reduceMotion =
            typeof window !== "undefined" &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reduceMotion) {
            return;
        }

        fullscreenImg.classList.remove("fs-img-reveal");
        void fullscreenImg.offsetWidth;
        const onRevealEnd = (ev: AnimationEvent) => {
            if (ev.animationName !== "fsImageReveal") return;
            fullscreenImg.removeEventListener("animationend", onRevealEnd);
            fullscreenImg.classList.remove("fs-img-reveal");
        };
        fullscreenImg.addEventListener("animationend", onRevealEnd);
        fullscreenImg.classList.add("fs-img-reveal");
    }

    /** Load high-res URL; show mark until decode, avoid stale onload races. */
    function bindFullscreenImageSrc(url: string) {
        if (!fullscreenImg) return;
        const token = ++fullscreenLoadToken;
        showFsLoader();

        let settled = false;
        const finish = () => {
            if (token !== fullscreenLoadToken || settled) return;
            settled = true;
            hideFsLoader();
            resetZoomPan();
        };

        fullscreenImg.onload = finish;
        fullscreenImg.onerror = finish;
        fullscreenImg.src = url;

        fullscreenImg
            .decode()
            .then(() => {
                if (token !== fullscreenLoadToken) return;
                finish();
            })
            .catch(() => finish());

        if (fullscreenImg.complete && fullscreenImg.naturalWidth > 0) {
            queueMicrotask(finish);
        }
    }

    function updateImageTransform() {
        if (!fullscreenImg) return;
        fullscreenImg.style.transform = `translate(calc(-50% + ${translateX}px), calc(-50% + ${translateY}px)) scale(${scale})`;
    }

    function clampPan() {
        // Динамический лимит в зависимости от масштаба
        // scale = 1: 300px | scale = 2: 600px | scale = 3: 900px
        const dynamicLimit = BASE_PAN_OFFSET * scale;
        
        translateX = Math.max(-dynamicLimit, Math.min(dynamicLimit, translateX));
        translateY = Math.max(-dynamicLimit, Math.min(dynamicLimit, translateY));
    }

    function resetZoomPan() {
        scale = 1;
        translateX = 0;
        translateY = 0;
        clampPan();
        updateImageTransform();
    }

    function openFullscreen(index: number) {
        if (!fullscreenOverlay || !fullscreenImg || galleryImageUrls.length === 0)
            return;
        currentFullscreenIndex = index;
        fullscreenImg.alt = `Fullscreen view ${index + 1}`;
        fullscreenOverlay.style.display = "flex";
        document.body.style.overflow = "hidden";
        resetZoomPan();
        bindFullscreenImageSrc(galleryImageUrls[index]);
    }

    function closeFullscreen() {
        if (!fullscreenOverlay) return;
        fullscreenLoadToken += 1;
        fullscreenImg?.classList.remove("fs-img-reveal", "fs-img-loading");
        fsLoader?.setAttribute("hidden", "");
        fullscreenOverlay.style.display = "none";
        document.body.style.overflow = "";
        resetZoomPan();
    }

    function changeImage(index: number) {
        if (galleryImageUrls.length === 0) return;
        currentFullscreenIndex = Math.max(0, Math.min(index, galleryImageUrls.length - 1));
        fullscreenImg.alt = `Fullscreen view ${currentFullscreenIndex + 1}`;
        resetZoomPan();
        bindFullscreenImageSrc(galleryImageUrls[currentFullscreenIndex]);
    }

    // Listen for custom event from ProductDetail
    window.addEventListener(
        "open-fullscreen-gallery",
        (event: any) => {
            const detail: FullscreenEventDetail = event.detail;
            galleryImageUrls = detail.images || [];
            openFullscreen(detail.startIndex || 0);
        },
    );

    // Navigation buttons
    fsPrevBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        changeImage(currentFullscreenIndex - 1);
    });

    fsNextBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        changeImage(currentFullscreenIndex + 1);
    });

    // Close button
    fsCloseBtn?.addEventListener("click", closeFullscreen);

    // Click on overlay or outside image to close
    fullscreenOverlay?.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        // Закрываем если кликнули на сам оверлей или на контейнер (пустое место)
        if (target === fullscreenOverlay || target === fullscreenContainer) {
            closeFullscreen();
        }
    });

    // Keyboard shortcuts
    document.addEventListener("keydown", (e) => {
        if (fullscreenOverlay?.style.display !== "flex") return;

        if (e.key === "Escape") closeFullscreen();
        else if (e.key === "ArrowLeft") fsPrevBtn?.click();
        else if (e.key === "ArrowRight") fsNextBtn?.click();
    });

    // Mouse wheel zoom
    document.addEventListener(
        "wheel",
        (e) => {
            if (fullscreenOverlay?.style.display !== "flex") return;
            e.preventDefault();
            if (e.deltaY < 0) {
                scale = Math.min(scale + 0.1, 3);
            } else {
                scale = Math.max(scale - 0.1, 1);
                if (scale === 1) {
                    resetZoomPan();
                }
            }
            updateImageTransform();
        },
        { passive: false },
    );

    // ========== MOUSE DRAG & PAN ==========
    fullscreenImg?.addEventListener("mousedown", (e) => {
        if (e.button !== 0 || scale === 1) return;

        isDragging = true;
        startX = e.clientX - translateX;
        startY = e.clientY - translateY;
        fullscreenContainer?.classList.add("grabbing");
        e.preventDefault();
    });

    document.addEventListener("mousemove", (e) => {
        if (!isDragging) return;

        translateX = e.clientX - startX;
        translateY = e.clientY - startY;
        clampPan();
        updateImageTransform();
    });

    document.addEventListener("mouseup", () => {
        if (isDragging) {
            isDragging = false;
            fullscreenContainer?.classList.remove("grabbing");
        }
    });

    // ========== TOUCH GESTURES ==========
    fullscreenContainer?.addEventListener(
        "touchstart",
        (e) => {
            if (fullscreenOverlay?.style.display !== "flex") return;

            if (e.touches.length === 1) {
                // Single touch - swipe or drag
                touchStartX = e.touches[0].clientX;
                touchStartY = e.touches[0].clientY;
                isGesture = false;
            } else if (e.touches.length === 2) {
                // Two fingers - pinch zoom
                isGesture = true;
                const dx =
                    e.touches[0].clientX - e.touches[1].clientX;
                const dy =
                    e.touches[0].clientY - e.touches[1].clientY;
                touchStartDistance = Math.sqrt(dx * dx + dy * dy);
            }
        },
        { passive: true },
    );

    fullscreenContainer?.addEventListener(
        "touchmove",
        (e) => {
            if (fullscreenOverlay?.style.display !== "flex") return;

            if (e.touches.length === 1 && !isGesture) {
                // Single touch - allow drag if zoomed
                if (scale > 1) {
                    const deltaX = e.touches[0].clientX - touchStartX;
                    const deltaY = e.touches[0].clientY - touchStartY;
                    // Добавляем дельту к текущему положению, а не заменяем его
                    translateX += deltaX;
                    translateY += deltaY;
                    clampPan();
                    // Обновляем стартовую позицию для следующего движения
                    touchStartX = e.touches[0].clientX;
                    touchStartY = e.touches[0].clientY;
                    updateImageTransform();
                }
            } else if (e.touches.length === 2) {
                // Two finger - pinch zoom
                isGesture = true;
                const dx =
                    e.touches[0].clientX - e.touches[1].clientX;
                const dy =
                    e.touches[0].clientY - e.touches[1].clientY;
                const distance = Math.sqrt(dx * dx + dy * dy);
                const ratio = distance / (touchStartDistance || 1);

                scale = Math.max(
                    1,
                    Math.min(3, scale * ratio),
                );
                touchStartDistance = distance;
                updateImageTransform();
                e.preventDefault();
            }
        },
        { passive: false },
    );

    fullscreenContainer?.addEventListener(
        "touchend",
        (e) => {
            if (fullscreenOverlay?.style.display !== "flex") return;

            if (e.touches.length === 0 && !isGesture) {
                // Single touch ended - check for swipe
                const touchEndX =
                    e.changedTouches[0]?.clientX || touchStartX;
                const touchEndY =
                    e.changedTouches[0]?.clientY || touchStartY;

                const deltaX = touchEndX - touchStartX;
                const deltaY = touchEndY - touchStartY;
                const absDeltaX = Math.abs(deltaX);
                const absDeltaY = Math.abs(deltaY);

                // Swipe detection (horizontal movement > 50px)
                if (absDeltaX > 50 && absDeltaX > absDeltaY) {
                    if (deltaX > 0) {
                        // Swipe right - previous image
                        changeImage(currentFullscreenIndex - 1);
                    } else {
                        // Swipe left - next image
                        changeImage(currentFullscreenIndex + 1);
                    }
                }
            }

            // Reset gesture
            if (scale === 1) {
                resetZoomPan();
            }
            isGesture = false;
        },
        { passive: true },
    );
</script>
