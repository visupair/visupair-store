<script>
  // Theme Management
  function setTheme(theme: string) {
    if (theme === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
    } else {
      document.documentElement.removeAttribute("data-theme");
    }
    localStorage.setItem("theme", theme);
  }

  // Apply saved theme immediately
  const savedTheme = localStorage.getItem("theme") || "dark";
  setTheme(savedTheme);

  function toggleTheme() {
    const currentTheme =
      document.documentElement.getAttribute("data-theme") === "dark"
        ? "dark"
        : "light";
    const newTheme = currentTheme === "dark" ? "light" : "dark";
    setTheme(newTheme);
  }

  // Account Session Management
  let userSession: any = null;
  let sessionChecked = false;

  async function checkSession() {
    if (sessionChecked) return userSession !== null;
    try {
      const response = await fetch("/api/auth/get-session", {
        credentials: "include",
      });

      if (!response.ok) {
        sessionChecked = true;
        return false;
      }

      const data = await response.json();
      if (data?.user) {
        userSession = data;
        sessionChecked = true;

        // Update AccountSidebar with user data
        if (window.updateAccountSidebar) {
          window.updateAccountSidebar({
            name: data.user.name || "User",
            email: data.user.email || "",
          });
        }

        return true;
      }
      sessionChecked = true;
      return false;
    } catch (error) {
      console.error("Session check failed:", error);
      sessionChecked = true;
      return false;
    }
  }

  // Pre-check session on initial load
  checkSession();

  // Account button handler (uses event delegation, safe to add once)
  document.addEventListener("click", (e) => {
    const accountBtn = (e.target as HTMLElement)?.closest?.(".account-btn");
    if (!accountBtn) return;

    if (!sessionChecked) {
      checkSession().then((isLoggedIn) => {
        if (isLoggedIn && userSession) {
          (window as any).toggleAccountSidebar?.();
        } else {
          window.location.href = "/login";
        }
      });
    } else {
      if (userSession) {
        (window as any).toggleAccountSidebar?.();
      } else {
        window.location.href = "/login";
      }
    }
  });

  // Initialize on every page load (including View Transitions)
  document.addEventListener("astro:page-load", () => {
    const body = document.body;
    const menuToggle = document.getElementById(
      "menu-toggle",
    ) as HTMLButtonElement | null;
    const mobileMenu = document.getElementById(
      "mobile-menu",
    ) as HTMLDivElement | null;
    const storeAccordion = document.getElementById(
      "store-accordion",
    ) as HTMLButtonElement | null;
    const storeContentWrapper = document.getElementById(
      "store-content-wrapper",
    ) as HTMLDivElement | null;
    const desktopStoreLink = document.getElementById("desktop-store-link");
    const themeToggleDesktop = document.getElementById("theme-toggle-desktop");
    const themeToggleMobile = document.getElementById("theme-toggle-mobile");

    // Theme Toggle Handlers
    if (themeToggleDesktop) {
      themeToggleDesktop.addEventListener("click", toggleTheme);
    }
    if (themeToggleMobile) {
      themeToggleMobile.addEventListener("click", toggleTheme);
    }

    // Active Menu Item Logic
    function setActiveMenuItem() {
      const currentPath = window.location.pathname;

      // Desktop menu links
      const desktopLinks = document.querySelectorAll(
        ".navbar-center .nav-link",
      );
      desktopLinks.forEach((link) => {
        const href = link.getAttribute("href");

        if (link.id === "desktop-store-link") {
          const isActive = currentPath.startsWith("/store");
          link.classList.toggle("active", isActive);
        } else if (href && href !== "#") {
          const isActive =
            currentPath === href ||
            (currentPath.startsWith(href + "/") && href !== "/");
          link.classList.toggle("active", isActive);
        }
      });

      // Dropdown links
      const dropdownLinks = document.querySelectorAll(
        ".store-dropdown .dropdown-link",
      );
      dropdownLinks.forEach((link) => {
        const href = link.getAttribute("href");
        if (href) {
          link.classList.toggle("active", currentPath === href);
        }
      });

      // Mobile menu links
      const mobileLinks = document.querySelectorAll(
        ".mobile-nav-list .mobile-link",
      );
      mobileLinks.forEach((link) => {
        const href = link.getAttribute("href");

        if (link.id === "store-accordion") {
          const isActive = currentPath.startsWith("/store");
          link.classList.toggle("active", isActive);
        } else if (href && href !== "#") {
          const isActive =
            currentPath === href ||
            (currentPath.startsWith(href + "/") && href !== "/");
          link.classList.toggle("active", isActive);
        }
      });

      // Mobile accordion dropdown links
      const mobileDropdownLinks = document.querySelectorAll(
        ".mobile-accordion-content a",
      );
      mobileDropdownLinks.forEach((link) => {
        const href = link.getAttribute("href");
        if (href) {
          link.classList.toggle("active", currentPath === href);
        }
      });

      // Favorites Button
      const favoritesBtn = document.querySelector(".favorites-btn");
      if (favoritesBtn) {
        const isActive = currentPath.startsWith("/account/favorites");
        favoritesBtn.classList.toggle("active", isActive);
      }

      // Cart Button
      const cartBtn = document.querySelector(".cart-btn");
      if (cartBtn) {
        const isActive = currentPath === "/cart" || currentPath.startsWith("/cart/");
        cartBtn.classList.toggle("active", isActive);
      }
    }

    setActiveMenuItem();

    // Cart Badge Update
    async function updateCartBadge() {
      try {
        const { cartCount, initCart } = await import("../lib/cartStore");
        initCart();
        const badge = document.getElementById("cart-badge");
        if (!badge) return;

        function render(count: number) {
          if (count > 0) {
            badge!.textContent = count > 99 ? "99+" : String(count);
            badge!.style.display = "";
          } else {
            badge!.style.display = "none";
          }
        }

        render(cartCount.get());
        cartCount.subscribe(render);
      } catch {}
    }
    updateCartBadge();

    // Mobile Menu Logic
    function closeMenu() {
      if (mobileMenu && menuToggle) {
        mobileMenu.classList.remove("active");
        menuToggle.setAttribute("aria-expanded", "false");
        body.classList.remove("no-scroll");
      }
    }

    function openMenu() {
      if (mobileMenu && menuToggle) {
        mobileMenu.classList.add("active");
        menuToggle.setAttribute("aria-expanded", "true");
        body.classList.add("no-scroll");
      }
    }

    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener("click", (e) => {
        e.stopPropagation();
        if (mobileMenu.classList.contains("active")) {
          closeMenu();
        } else {
          openMenu();
        }
      });

      // Close menu when clicking outside
      const handleOutsideClick = (e: Event) => {
        const isClickInside =
          mobileMenu.contains(e.target as Node) ||
          menuToggle.contains(e.target as Node);
        if (!isClickInside && mobileMenu.classList.contains("active")) {
          closeMenu();
        }
      };
      document.addEventListener("click", handleOutsideClick);

      // Close on ESC key
      const handleEscape = (e: KeyboardEvent) => {
        if (e.key === "Escape" && mobileMenu.classList.contains("active")) {
          closeMenu();
        }
      };
      document.addEventListener("keydown", handleEscape);

      // Close mobile menu when resizing to desktop
      const handleResize = () => {
        if (
          window.innerWidth > 968 &&
          mobileMenu.classList.contains("active")
        ) {
          closeMenu();
        }
      };
      window.addEventListener("resize", handleResize);
    }

    // Accordion Logic
    if (storeAccordion && storeContentWrapper) {
      storeAccordion.addEventListener("click", () => {
        const isOpen = storeAccordion.classList.toggle("open");
        storeContentWrapper.classList.toggle("open");
        storeAccordion.setAttribute("aria-expanded", isOpen.toString());
      });
    }

    // Prevent navigation on desktop "Store" click
    if (desktopStoreLink) {
      desktopStoreLink.addEventListener("click", (e) => {
        e.preventDefault();
      });
    }
  });
</script>

