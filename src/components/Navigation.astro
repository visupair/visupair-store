    <!-- Right Actions -->
    <div class="navbar-right">
      <!-- CAPSULE TOGGLE SWITCH (Desktop) -->
      <button
        id="theme-toggle-desktop"
        type="button"
        class="theme-switch desktop-theme-toggle"
        aria-label="Toggle Theme"
      >
        <svg
          class="switch-track-icon icon-sun-track"
          viewBox="0 0 24 24"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="switch-track-icon icon-moon-track"
          viewBox="0 0 24 24"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <div class="switch-knob"></div>
      </button>

      <!-- Favorites (Heart Beat Animation) -->
      <a
        href="/account/favorites"
        class="icon-button favorites-btn"
        aria-label="Favorites"
      >
        <svg
          viewBox="0 0 22 19"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
