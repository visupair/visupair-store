              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M1 1L5 5L9 1"></path>
            </svg>
          </button>
          <div class="mobile-accordion-wrapper" id="store-content-wrapper">
            <div class="mobile-accordion-inner">
              <div class="mobile-accordion-content" id="store-content">
