---
import type { PortfolioCategory } from "../lib/store-data";

interface Props {
    categories: PortfolioCategory[];
    selectedCategoryId: string | null;
    sectionId: string;
}

const { categories, selectedCategoryId, sectionId } = Astro.props;
---

<aside class="portfolio-sidebar">
    <div class="sidebar-header">
        <h2 class="sidebar-title">Filter by Category</h2>
    </div>

    <nav class="category-tree" aria-label="Portfolio categories">
        <a
            href="/portfolio"
            class:list={[
                "category-item",
                { active: selectedCategoryId === null },
            ]}
            aria-current={selectedCategoryId === null ? "page" : undefined}
        >
            <span class="category-text">All Works</span>
        </a>

        {
            categories.map((category) => (
                <a
                    href={`/portfolio/category/${category.slug}`}
                    class:list={[
                        "category-item",
                        { active: selectedCategoryId === category.slug },
                    ]}
                    aria-current={
                        selectedCategoryId === category.slug
                            ? "page"
                            : undefined
                    }
                >
                    <span class="category-text">{category.title}</span>
                </a>
            ))
        }
    </nav>
</aside>

<style>
    .portfolio-sidebar {
        width: 280px;
        flex-shrink: 0;
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        height: 100%;
    }

    .sidebar-header {
        padding: 20px;
        border-bottom: 1px solid var(--border-subtle);
    }

    .sidebar-title {
        font-size: 16px;
        font-weight: 600;
        color: var(--foreground);
        margin: 0;
    }

    .category-tree {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .category-item {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        width: 100%;
        padding: 14px 20px;
        background: transparent;
        border: none;
        border-radius: 0;
        color: var(--foreground);
        font-family: var(--font-family);
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        box-sizing: border-box;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
        gap: 12px;
    }

    .category-item:focus-visible {
        outline: 2px solid var(--brand-violet);
        outline-offset: 2px;
    }

    .category-item:focus:not(:focus-visible) {
        outline: none;
    }

    .category-text {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .category-item:hover {
        background: var(--surface-muted);
        color: var(--brand-violet);
        padding-left: 24px;
    }

    .category-item.active {
        background: var(--surface-muted);
        color: var(--brand-violet);
        border-left: 3px solid var(--brand-violet);
        padding-left: 17px;
    }

    @media (max-width: 768px) {
        .portfolio-sidebar {
            width: 100%;
            height: auto;
        }

        .sidebar-header {
            text-align: left;
            padding: 16px 12px 14px;
        }

        .category-item {
            min-width: 0;
            padding: 12px 16px;
            border-radius: var(--radius-md);
            justify-content: flex-start;
            text-align: left;
        }

        .category-text {
            white-space: normal;
            overflow: visible;
            text-overflow: unset;
            line-height: 1.35;
            word-break: break-word;
            hyphens: auto;
            text-align: left;
        }
    }

    /* Phone — one column */
    @media (max-width: 640px) {
        .category-tree {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 12px;
        }

        .category-item:hover,
        .category-item.active {
            padding-left: 16px;
            padding-right: 16px;
        }

        .category-item.active {
            border-left: none;
            border-bottom: 3px solid var(--brand-violet);
        }
    }

    /* Tablet (stacked portfolio layout) — two columns */
    @media (min-width: 641px) and (max-width: 768px) {
        .category-tree {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px 8px;
            padding: 12px;
        }

        .category-item:first-child {
            grid-column: 1 / -1;
        }

        .category-item {
            justify-content: flex-start;
            text-align: left;
        }

        .category-item:hover,
        .category-item.active {
            padding-left: 10px;
            padding-right: 10px;
        }

        .category-item.active {
            border-left: none;
            border-bottom: 3px solid var(--brand-violet);
        }
    }
</style>
