---
import type { Product, Category } from "../lib/store-data";
import { EUR_TO_PLN_RATE, type Currency } from "../lib/server-currency";
import { slugify } from "../utils/slugs";
import { urlFor } from "../lib/sanity";

interface Props {
    products: Product[];
    baseUrl?: string;
    preserveCategory?: string | null;
    categoryMode?: boolean;
    categories?: Category[];
    serverCurrency?: Currency;
    /** When set (e.g. `2` for favorites), use this many columns between ~641–1024px width. */
    tabletGridColumns?: number;
}

const {
    products,
    baseUrl = "/store/fashion-design",
    preserveCategory,
    categoryMode = false,
    categories = [],
    serverCurrency,
    tabletGridColumns,
} = Astro.props;

// Helper to generate placeholder image
const getPlaceholderImage = (text: string) => {
    const encodedText = encodeURIComponent(text);
    return `https://placehold.co/600x600/1A1635/CBFF62?text=${encodedText}&font=roboto`;
};

// Generate product link with preserved category
const getProductLink = (product: Product) => {
    // Priority: use explicit slug from CMS, fallback to name slugification
    const slug = product.slug || slugify(product.name);

    const baseLink = `${baseUrl}/${slug}`;
    if (preserveCategory && categoryMode) {
        // In category mode, use path-based URL: /store/section/category/categoryId/product-slug
        return `${baseUrl}/category/${preserveCategory}/${slug}`;
    } else if (preserveCategory) {
        // Fallback for query-based mode
        return `${baseLink}?category=${preserveCategory}`;
    }
    return baseLink;
};

// Helper to determine product groups based on section
// Helper to determine product groups based on section
const getProductGroups = (products: Product[]) => {
    if (products.length === 0) return [];

    // Detect section from the first product (assuming homogeneous list per page)
    const sectionId = products[0].categoryPath?.[0];

    // Garments section (fashion-design): physical vs digital product types
    if (sectionId === "fashion-design") {
        const physical = products.filter(
            (p) => !p.productType || p.productType === "physical",
        );
        const digital = products.filter((p) => p.productType === "digital");

        const groups = [];
        if (physical.length > 0)
            groups.push({ title: "Physical Products", products: physical });
        if (digital.length > 0)
            groups.push({ title: "Digital Products", products: digital });
        // Return single group if only one type exists to avoid unnecessary headers if not needed,
        if (groups.length === 0) return [{ title: "", products: products }];
        return groups;
    }

    // Dynamic Grouping for other sections (3D Models, Artworks) based on passed Categories
    if (categories && categories.length > 0) {
        const groups: { title: string; products: Product[] }[] = [];
        const usedProductIds = new Set<string>();

        categories.forEach((cat) => {
            // Find products belonging to this category
            // We check if the product's categoryPath INCLUDES the category ID (slug)
            const catProducts = products.filter((p) =>
                p.categoryPath?.includes(cat.id),
            );

            if (catProducts.length > 0) {
                groups.push({ title: cat.title, products: catProducts });
                catProducts.forEach((p) => usedProductIds.add(p.id));
            }
        });

        // Find products that didn't fit into any of the top-level categories
        const others = products.filter((p) => !usedProductIds.has(p.id));
        if (others.length > 0) {
            groups.push({ title: "Other", products: others });
        }

        if (groups.length > 0) return groups;
    }

    // Fallback: Return as single group
    return [{ title: "", products: products }];
};

const groups = getProductGroups(products);

// Determine if we should show headers (if more than 1 group, OR specific sections that always want headers)
// Garments (fashion-design): mixed physical/digital handling when needed.
const showHeaders = groups.length > 1;

// However, for single-group lists in specific sections, we might still want the title if it's a specific subset?
// Actually simpler: if title is present, show it. If we fallback to default, title is empty.
---

<div
    class="product-grid-container"
    data-tablet-cols={tabletGridColumns ?? undefined}
    style={
        tabletGridColumns != null
            ? `--pg-tablet-cols: ${tabletGridColumns}`
            : undefined
    }
>
    {
        products.length === 0 ? (
            <div class="empty-state">
                <p>No products found.</p>
            </div>
        ) : (
            <>
                {groups.map((group) => (
                    <div class="product-group">
                        {group.title &&
                            (groups.length > 1 || group.title !== "") && (
                                <div class="section-header">
                                    <span class="section-title">
                                        {group.title}
                                    </span>
                                </div>
                            )}
                        <div class="product-grid">
                            {group.products.map((product, index) => (
                                <div
                                    class:list={[
                                        "product-card",
                                        product.isFree && "product-card--free",
                                    ]}
                                    data-product-id={product.id}
                                    style={`--animation-delay: ${index * 50}ms`}
                                    transition:name={`product-${product.id}`}
                                >
                                    <a
                                        class="product-card-hit"
                                        href={getProductLink(product)}
                                        aria-label={`View ${product.name}`}
                                    >
                                    </a>
                                    <div class="product-card-inner">
                                    <div class="product-image">
                                        <img
                                            src={
                                                product.mainImage
                                                    ? urlFor(product.mainImage)
                                                          .width(600)
                                                          .height(600)
                                                          .url()
                                                    : product.image ||
                                                      getPlaceholderImage(
                                                          product.name,
                                                      )
                                            }
                                            alt={product.name}
                                            loading="lazy"
                                        />
                                        <button
                                            class="fav-btn"
                                            aria-label="Add to favorites"
                                            onclick="event.preventDefault(); event.stopPropagation();"
                                        >
                                            <svg
                                                width="18"
                                                height="16"
                                                viewBox="0 0 22 19"
                                                fill="none"
                                                xmlns="http://www.w3.org/2000/svg"
                                            >
                                                <path fill="currentColor" d="M16.2411 0.0134513H16.245C18.0116 0.125081 19.6479 0.999001 20.7444 2.41344L20.7434 2.41442C22.6101 4.83522 22.3595 8.38062 20.0895 10.6616L12.7129 18.0285C12.2257 18.5155 11.6058 18.7487 10.9931 18.7449C10.3805 18.7487 9.76058 18.5155 9.27343 18.0285L1.8968 10.6616C-0.373292 8.38061 -0.623868 4.83523 1.24288 2.41442L1.2419 2.41344C2.33836 0.999009 3.97469 0.125067 5.74127 0.0134513H5.74518C7.40844 -0.0978413 9.06029 0.485407 10.3002 1.6219C10.6899 1.98734 11.2964 1.98734 11.6861 1.6219C12.926 0.485418 14.5779 -0.0978554 16.2411 0.0134513Z"/>
                                            </svg>
                                        </button>
                                        {product.inStock !== undefined && (
                                            <span
                                                class={`stock-indicator ${product.isFree || product.inStock ? "in-stock" : "out-of-stock"}`}
                                                transition:name={`stock-${product.id}`}
                                            >
                                                <span class="stock-text">
                                                    {product.isFree
                                                        ? "Free"
                                                        : product.inStock
                                                          ? "In Stock"
                                                          : "Sold Out"}
                                                </span>
                                            </span>
                                        )}
                                    </div>
                                    <div class="product-info">
                                        <div class="product-row">
                                            <h3 class="product-name">
                                                {product.name}
                                            </h3>
                                            {product.isFree ? (
                                                <span class="product-price product-price--free">
                                                    Free
                                                </span>
                                            ) : (
                                                <span
                                                    class="product-price product-price-grid"
                                                    data-price-eur={product.price}
                                                    data-price-pln={(
                                                        typeof product.pricePLN ===
                                                            "number" &&
                                                        product.pricePLN > 0
                                                            ? product.pricePLN
                                                            : Math.round(
                                                                  Number(
                                                                      product.price,
                                                                  ) *
                                                                      EUR_TO_PLN_RATE,
                                                              )
                                                    ).toFixed(2)}
                                                    data-server-currency={
                                                        serverCurrency || ""
                                                    }
                                                >
                                                    €{product.price}
                                                </span>
                                            )}
                                        </div>
                                        <div class="product-desc-row">
                                            <p class="product-desc">
                                                {product.description}
                                            </p>
                                            {product.isFree &&
                                                product.productType ===
                                                    "digital" &&
                                                product.inStock !== false && (
                                                    <button
                                                        type="button"
                                                        class="grid-claim-free-btn"
                                                        aria-label="Add free download to your library"
                                                        data-product-id={
                                                            product.id
                                                        }
                                                        onclick="event.preventDefault(); event.stopPropagation();"
                                                    >
                                                        <span
                                                            class="grid-claim-free-btn__icons"
                                                            aria-hidden="true"
                                                        >
                                                            <svg
                                                                class="grid-claim-free-btn__icon grid-claim-free-btn__icon--download"
                                                                width="15"
                                                                height="15"
                                                                viewBox="0 0 152 152"
                                                                fill="none"
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                aria-hidden="true"
                                                            >
                                                                <path
                                                                    d="M141.547 98.3721C146.809 98.3723 151 102.489 151 107.791V140.581C151 145.883 146.809 150 141.547 150H9.45312C4.19107 150 0 145.883 0 140.581V107.791C0 102.489 4.19107 98.3723 9.45312 98.3721C14.7153 98.3721 18.9072 102.489 18.9072 107.791V129.163C18.9072 130.268 19.8027 131.163 20.9072 131.163H130.093C131.197 131.163 132.093 130.268 132.093 129.163V107.791C132.093 102.489 136.285 98.3721 141.547 98.3721Z"
                                                                    fill="currentColor"
                                                                />
                                                                <path
                                                                    d="M75.5 0C80.7622 0 84.9531 4.11652 84.9531 9.41895V66.3782C84.9531 67.2673 86.0267 67.7143 86.6577 67.0878L93.6289 60.166C97.2657 56.3857 103.138 56.5764 106.763 60.0312C106.786 60.0523 106.808 60.0755 106.831 60.0967C106.855 60.1203 106.881 60.1421 106.905 60.166C110.781 63.8415 110.534 69.8352 106.905 73.4385L82.1377 98.0312C80.299 99.8569 77.8367 100.813 75.5 100.813C73.1633 100.813 70.701 99.8569 68.8623 98.0312L44.0947 73.4385C40.2511 69.7923 40.4631 63.8657 44.0088 60.2539C47.6855 56.3319 53.7317 56.5523 57.3711 60.166L64.3423 67.0878C64.9733 67.7143 66.0469 67.2673 66.0469 66.3782V9.41895C66.0469 4.11652 70.2378 0 75.5 0Z"
                                                                    fill="currentColor"
                                                                />
                                                            </svg>
                                                            <svg
                                                                class="grid-claim-free-btn__icon grid-claim-free-btn__icon--check"
                                                                width="14"
                                                                height="10"
                                                                viewBox="-0.12 -0.12 12.35 8.82"
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                fill="none"
                                                                aria-hidden="true"
                                                            >
                                                                <path
                                                                    fill="currentColor"
                                                                    d="M11.7202 1.70725L5.16025 8.26725C4.97225 8.45525 4.71825 8.56025 4.45325 8.56025C4.18825 8.56025 3.93325 8.45525 3.74625 8.26725L0.29325 4.81425C-0.0977499 4.42325 -0.0977499 3.79125 0.29325 3.40025C0.68425 3.00925 1.31625 3.00925 1.70725 3.40025L4.45325 6.14625L10.3062 0.29325C10.6972 -0.0977499 11.3292 -0.0977499 11.7202 0.29325C12.1112 0.68425 12.1112 1.31625 11.7202 1.70725Z"
                                                                />
                                                            </svg>
                                                            <svg
                                                                class="grid-claim-free-btn__icon grid-claim-free-btn__icon--arrow"
                                                                width="9"
                                                                height="14"
                                                                viewBox="0 0 5 9"
                                                                fill="none"
                                                                xmlns="http://www.w3.org/2000/svg"
                                                                aria-hidden="true"
                                                            >
                                                                <path
                                                                    d="M1.21094 5.2932e-08C1.11683 5.68338e-05 1.02324 0.0190967 0.936521 0.0556641C0.850421 0.0920381 0.773421 0.146145 0.708011 0.212891L0.707031 0.211914C0.574971 0.346297 0.501011 0.527418 0.500981 0.715821C0.500981 0.857096 0.542661 0.993965 0.619141 1.11035L0.707031 1.21973L3.56543 4.125L0.70605 7.0293C0.57408 7.1637 0.500001 7.34581 0.500001 7.53418C0.500111 7.72236 0.57421 7.90283 0.70605 8.03711L0.70703 8.03613C0.77261 8.10327 0.850071 8.15781 0.936521 8.19434C0.980091 8.21272 1.02517 8.22702 1.07129 8.23633L1.21094 8.25L1.35156 8.23633C1.39753 8.227 1.44291 8.21268 1.48633 8.19434L1.60937 8.12695C1.64823 8.10041 1.68481 8.07004 1.71777 8.03613L4.59766 5.11035C4.85574 4.84746 4.99996 4.4934 5 4.125C5 3.75662 4.85568 3.40256 4.59766 3.13965L1.7168 0.212891L1.60937 0.123047L1.48535 0.0556641L1.35156 0.0136719C1.30555 0.0043579 1.25811 5.08698e-08 1.21094 5.2932e-08Z"
                                                                    fill="currentColor"
                                                                />
                                                            </svg>
                                                        </span>
                                                    </button>
                                                )}
                                            {product.inStock !== false &&
                                                !product.isFree && (
                                                <button
                                                    type="button"
                                                    class="grid-add-cart-btn"
                                                    aria-label="Add to cart"
                                                    data-product-id={product.id}
                                                    data-product-url={getProductLink(
                                                        product,
                                                    )}
                                                    data-product-name={
                                                        product.name
                                                    }
                                                    data-product-type={
                                                        product.productType ||
                                                        "physical"
                                                    }
                                                    data-price-eur={product.price}
                                                    data-price-pln={(
                                                        typeof product.pricePLN ===
                                                            "number" &&
                                                        product.pricePLN > 0
                                                            ? product.pricePLN
                                                            : Math.round(
                                                                  Number(
                                                                      product.price,
                                                                  ) *
                                                                      EUR_TO_PLN_RATE,
                                                              )
                                                    ).toFixed(2)}
                                                    data-product-image={
                                                        product.mainImage
                                                            ? urlFor(
                                                                  product.mainImage,
                                                              )
                                                                  .width(400)
                                                                  .url()
                                                            : product.image ||
                                                              ""
                                                    }
                                                    data-shipping-weight={
                                                        product.shipping
                                                            ?.weight ?? ""
                                                    }
                                                    data-shipping-length={
                                                        product.shipping
                                                            ?.length ?? ""
                                                    }
                                                    data-shipping-width={
                                                        product.shipping
                                                            ?.width ?? ""
                                                    }
                                                    data-shipping-height={
                                                        product.shipping
                                                            ?.height ?? ""
                                                    }
                                                    data-requires-size={
                                                        product.sizes &&
                                                        product.sizes.length > 0
                                                            ? "true"
                                                            : undefined
                                                    }
                                                    onclick="event.preventDefault(); event.stopPropagation();"
                                                >
                                                    <span
                                                        class="grid-add-cart-btn__icons"
                                                        aria-hidden="true"
                                                    >
                                                        <svg
                                                            class="grid-add-cart-btn__icon grid-add-cart-btn__icon--cart"
                                                            width="16"
                                                            height="16"
                                                            viewBox="0 0 22 22"
                                                            fill="currentColor"
                                                            xmlns="http://www.w3.org/2000/svg"
                                                        >
                                                            <path
                                                                fill-rule="evenodd"
                                                                clip-rule="evenodd"
                                                                d="M10.9931 0C13.6631 0 15.8765 2.03316 16.1664 4.62858C16.1816 4.81653 16.1896 5.10071 16.1939 5.39511C16.1985 5.7138 16.4564 5.97161 16.7751 5.97161H17.936C19.2731 5.97161 20.386 6.97443 20.526 8.30511L21.9725 19.0918C22.0482 19.8231 21.81 20.557 21.317 21.1043C20.8235 21.6515 20.1188 21.9654 19.3824 21.9654H2.60384C1.8675 21.9653 1.16208 21.6521 0.669242 21.1055C0.175875 20.557 -0.0619183 19.8229 0.0138284 19.0918L1.46026 8.30511C1.60026 6.97398 2.71342 5.97186 4.05027 5.97161H5.21174C5.53047 5.97161 5.7883 5.71381 5.79277 5.39511C5.79689 5.10072 5.80466 4.81653 5.81989 4.62858C6.1098 2.03325 8.32334 0.00016274 10.9931 0ZM10.9931 1.73572C9.06591 1.73589 7.52171 3.27988 7.52171 5.20715V5.39304C7.52171 5.71258 7.78074 5.97161 8.10028 5.97161H13.886C14.2055 5.97161 14.4646 5.71258 14.4646 5.39304V5.20715C14.4646 3.27976 12.9205 1.73572 10.9931 1.73572Z"
                                                            />
                                                        </svg>
                                                        <svg
                                                            class="grid-add-cart-btn__icon grid-add-cart-btn__icon--plus"
                                                            width="16"
                                                            height="16"
                                                            viewBox="0 0 24 24"
                                                            fill="none"
                                                            stroke="currentColor"
                                                            stroke-width="2"
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                        >
                                                            <line
                                                                x1="12"
                                                                y1="5"
                                                                x2="12"
                                                                y2="19"
                                                            />
                                                            <line
                                                                x1="5"
                                                                y1="12"
                                                                x2="19"
                                                                y2="12"
                                                            />
                                                        </svg>
                                                        <svg
                                                            class="grid-add-cart-btn__icon grid-add-cart-btn__icon--check"
                                                            width="14"
                                                            height="10"
                                                            viewBox="-0.12 -0.12 12.35 8.82"
                                                            xmlns="http://www.w3.org/2000/svg"
                                                            fill="none"
                                                            aria-hidden="true"
                                                        >
                                                            <path
                                                                fill="currentColor"
                                                                d="M11.7202 1.70725L5.16025 8.26725C4.97225 8.45525 4.71825 8.56025 4.45325 8.56025C4.18825 8.56025 3.93325 8.45525 3.74625 8.26725L0.29325 4.81425C-0.0977499 4.42325 -0.0977499 3.79125 0.29325 3.40025C0.68425 3.00925 1.31625 3.00925 1.70725 3.40025L4.45325 6.14625L10.3062 0.29325C10.6972 -0.0977499 11.3292 -0.0977499 11.7202 0.29325C12.1112 0.68425 12.1112 1.31625 11.7202 1.70725Z"
                                                            />
                                                        </svg>
                                                        <svg
                                                            class="grid-add-cart-btn__icon grid-add-cart-btn__icon--trash"
                                                            width="16"
                                                            height="16"
                                                            viewBox="0 0 24 24"
                                                            fill="none"
                                                            stroke="currentColor"
                                                            stroke-width="2"
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            aria-hidden="true"
                                                        >
                                                            <polyline points="3 6 5 6 21 6" />
                                                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                                        </svg>
                                                    </span>
                                                </button>
                                            )}
                                        </div>
                                    </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </>
        )
    }
</div>

<style>
    .product-grid-container {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 24px;
        display: flex;
        flex-direction: column;
    }

    .section-header {
        display: flex;
        align-items: center;
        width: 100%;
        margin: 0 0 16px 0;
        gap: 16px;
    }

    .section-header::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border-subtle);
    }

    .section-title {
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--foreground);
        opacity: 0.7;
        white-space: nowrap;
    }

    .product-group {
        display: flex;
        flex-direction: column;
    }

    .product-group + .product-group {
        margin-top: 48px;
    }

    .empty-state {
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 48px 24px;
        min-height: 200px;
    }

    .empty-state p {
        margin: 0;
        font-size: 1rem;
        line-height: 1.5;
        font-weight: 400;
        color: var(--foreground);
        opacity: 0.5;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 24px;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .product-card {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
            transform 0.2s,
            box-shadow 0.2s,
            border-color 0.2s;
        cursor: pointer;
        opacity: 0;
        animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: var(--animation-delay);
        position: relative;
    }

    /* Full-card link behind content; buttons opt in with pointer-events: auto */
    .product-card-hit {
        position: absolute;
        inset: 0;
        z-index: 1;
        border-radius: inherit;
        display: block;
    }

    .product-card-hit:focus {
        outline: none;
    }

    .product-card-hit:focus-visible {
        outline: 2px solid var(--brand-violet);
        outline-offset: -2px;
    }

    .product-card-inner {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        flex: 1;
        min-height: 0;
        pointer-events: none;
    }

    .product-card-inner .fav-btn,
    .product-card-inner .grid-add-cart-btn,
    .product-card-inner .grid-claim-free-btn {
        pointer-events: auto;
    }

    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(132, 128, 255, 0.15);
        border-color: var(--brand-violet);
    }

    /* Free items — same card language as courses (green trust / “safe” cue) */
    .product-card--free:hover {
        border-color: color-mix(in srgb, #22c55e 45%, var(--border-subtle));
        box-shadow: 0 12px 28px color-mix(in srgb, #22c55e 16%, transparent);
    }

    .product-card--free .product-card-hit:focus-visible {
        outline: 2px solid #22c55e;
        outline-offset: -2px;
    }

    .product-image {
        width: 100%;
        aspect-ratio: 1/1;
        background: var(--surface-muted);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .product-card:hover .product-image img {
        transform: scale(1.05);
    }

    .fav-btn {
        position: absolute;
        top: 9px;
        right: 9px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(4px);
        border: none;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition:
            opacity 0.2s,
            background 0.25s ease;
        cursor: pointer;
        z-index: 10;
    }

    .stock-indicator {
        position: absolute;
        top: 8px;
        left: 8px;
        font-size: 11px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: var(--radius-pill);
        display: inline-flex;
        align-items: center;
        overflow: hidden;
        white-space: nowrap;
        opacity: 1;
        max-width: 20px;
        /* Shrunk dot — scales down from top-left corner */
        transform: scale(0.6);
        transform-origin: top left;
        transition:
            max-width 0.25s ease-out,
            transform 0.25s ease-out;
        z-index: 10;
        pointer-events: none;
        letter-spacing: 0.03em;
    }

    .stock-indicator.in-stock {
        background: #b5e765;
        color: #446512;
        animation: stock-glow 2s ease-in-out infinite;
    }

    .stock-indicator.out-of-stock {
        background: #ef4444;
        color: #ffffff;
        animation: stock-glow-red 2s ease-in-out infinite;
    }

    /* Text hidden and nudged left by default */
    .stock-text {
        opacity: 0;
        transform: translateX(-4px);
        transition:
            opacity 0.15s ease,
            transform 0.15s ease;
    }

    @media (hover: hover) {
        .product-card:hover .fav-btn {
            opacity: 1;
        }

        /*
         * Expand: springy easing — snappy open, then settle.
         * Overrides the base ease-out only while hovered.
         */
        .product-card:hover .stock-indicator {
            max-width: 120px;
            transform: scale(1);
            transition:
                max-width 0.4s cubic-bezier(0.2, 1.3, 0.4, 1),
                transform 0.35s cubic-bezier(0.2, 1.3, 0.4, 1);
        }

        /* Text fades + slides in after the pill has expanded (0.2s delay) */
        .product-card:hover .stock-text {
            opacity: 1;
            transform: translateX(0);
            transition:
                opacity 0.2s ease 0.2s,
                transform 0.2s ease 0.2s;
        }
    }

    /* On touch devices — full size, text always visible, no animation */
    @media (max-width: 1024px), (hover: none) {
        .stock-indicator {
            transform: scale(1) !important;
        }
        .stock-text {
            opacity: 1 !important;
            transform: none !important;
        }
    }

    .fav-btn svg {
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .fav-btn:hover svg {
        transform: scale(1.15);
    }

    .fav-btn:active svg {
        transform: scale(0.9);
    }


    /* Mobile & Tablet: Show fav button and badge always, move badge to bottom */
    @media (max-width: 1024px), (hover: none) {
        .fav-btn {
            opacity: 1 !important;
        }

        .fav-btn {
            background: rgba(14, 10, 35, 0.6);
        }

        .stock-indicator {
            max-width: none !important;
            top: auto;
            bottom: 8px;
            font-size: 9px;
        }
    }

    .product-info {
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .product-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
