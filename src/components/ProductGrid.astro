    /* Owned / link to My Purchases: arrow only (matches public/images/icons/arrow2.svg). */
    .grid-claim-free-btn--purchases-link .grid-claim-free-btn__icon--download,
    .grid-claim-free-btn--purchases-link .grid-claim-free-btn__icon--check {
        opacity: 0;
        transform: scale(0.85);
    }

    .grid-claim-free-btn--purchases-link .grid-claim-free-btn__icon--arrow {
        opacity: 1;
        transform: scale(1);
    }

    .grid-claim-free-btn--purchases-link:hover {
        background: color-mix(in srgb, #22c55e 14%, var(--surface-muted));
        border-color: color-mix(in srgb, #22c55e 62%, var(--border-subtle));
