    /*
     * Tablet — explicit columns so the shop doesn’t collapse to 1-up with auto-fill.
     * 641–833px: 2 columns (iPad mini / smaller tablets).
     * 834–1024px: 3 columns (iPad Pro 11" portrait = 834pt, 12.9" = 1024pt).
     */
    @media (min-width: 641px) and (max-width: 1024px) {
        .product-grid-container:not([data-tablet-cols]) .product-grid {
