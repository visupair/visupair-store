    }

    .checkbox-label input[type="checkbox"]:checked::before {
        transform: scale(1);
    }

    .checkbox-label input[type="checkbox"]:hover {
        border-color: var(--brand-violet);
        box-shadow: 0 0 0 2px rgba(139, 92, 246, 0.1); /* Subtle glow */
