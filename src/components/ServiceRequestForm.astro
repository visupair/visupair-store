        -webkit-text-fill-color: var(--foreground);
        touch-action: manipulation;
    }

    #service-request-form .date-input-inner input.form-input.date-field:read-only {
        background: var(--surface-muted) !important;
        color: var(--foreground);
        cursor: pointer;
        opacity: 1;
    }

    #service-request-form .date-input-inner input.form-input.date-field:focus {
        outline: none;
        border-color: var(--brand-violet);
        box-shadow: 0 0 0 3px rgba(132, 128, 255, 0.1);
    }

    #service-request-form .date-input-inner input.form-input.date-field::placeholder {
        opacity: 0.4;
        color: var(--foreground);
    }

</style>

<script>
    import flatpickr from 'flatpickr';

    type InputWithFp = HTMLInputElement & {
        _flatpickr?: { destroy: () => void };
    };

    type FpInstance = {
        calendarContainer: HTMLElement;
        innerContainer?: HTMLElement;
        currentYear: number;
        currentMonth: number;
        changeMonth: (delta: number) => void;
        changeYear: (y: number) => void;
        redraw: () => void;
        monthElements: HTMLElement[];
        yearElements: HTMLInputElement[];
        prevMonthNav: HTMLElement;
        nextMonthNav: HTMLElement;
        config: { minDate?: Date; maxDate?: Date };
        l10n: { months: { shorthand: string[]; longhand: string[] } };
        _visuAbort?: AbortController;
        set: (key: string, val: unknown) => void;
        input: HTMLInputElement;
        altInput?: HTMLInputElement;
        clear: (triggerChange?: boolean, toInitial?: boolean) => void;
        close: () => void;
        isOpen: boolean;
    };

    let formVisibilityObserver: MutationObserver | null = null;

    function formIsVisible(root: HTMLElement) {
        return getComputedStyle(root).display !== 'none';
    }

    function monthStart(y: number, m: number) {
        return new Date(y, m, 1);
    }

    function isMonthAllowed(fp: FpInstance, year: number, month: number) {
        const t = monthStart(year, month);
        const min = fp.config.minDate;
        const max = fp.config.maxDate;
        if (min) {
            const b = monthStart(min.getFullYear(), min.getMonth());
            if (t < b) return false;
        }
        if (max) {
            const e = monthStart(max.getFullYear(), max.getMonth());
            if (t > e) return false;
        }
        return true;
    }

    function yearLimits(fp: FpInstance) {
        const minY = fp.config.minDate?.getFullYear() ?? 1900;
        const maxY = fp.config.maxDate?.getFullYear() ?? 2100;
        return { minY, maxY };
    }

    function isYearDisabled(fp: FpInstance, y: number) {
        const { minY, maxY } = yearLimits(fp);
        return y < minY || y > maxY;
    }

    function decadeLimits(fp: FpInstance) {
        const minDec = fp.config.minDate
            ? Math.floor(fp.config.minDate.getFullYear() / 10) * 10
            : -Infinity;
        const maxDec = fp.config.maxDate
            ? Math.floor(fp.config.maxDate.getFullYear() / 10) * 10
            : Infinity;
        return { minDec, maxDec };
    }

    function hideVisuOverlay(fp: FpInstance) {
        const o = fp.calendarContainer.querySelector('.visu-fp-overlay');
        if (o) (o as HTMLElement).hidden = true;
    }

    type DayCell = HTMLElement & { dateObj?: Date };

    function startOfCalendarDay(d: Date) {
        return new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
    }

    function classifyVisuDayCell(fp: FpInstance, el: DayCell) {
        el.classList.remove('visu-fp-future-cell', 'visu-fp-past-muted-cell');
        const d = el.dateObj;
        const rawMin = fp.config.minDate;
        if (!d || !rawMin) return;
        const min = rawMin instanceof Date ? rawMin : new Date(rawMin);
        const tDay = startOfCalendarDay(d);
        const tMin = startOfCalendarDay(min);
        if (tDay < tMin) {
            el.classList.add('visu-fp-past-muted-cell');
            return;
        }
        if (el.classList.contains('flatpickr-disabled')) return;
        el.classList.add('visu-fp-future-cell');
    }

    function trimMonthLabel(fp: FpInstance) {
        const el = fp.monthElements[0];
        if (el?.textContent) el.textContent = el.textContent.trim();
    }

    function syncDateClearButton(fp: FpInstance) {
        const visible = fp.altInput ?? fp.input;
        const btn = fp.input
            .closest('.date-input-inner')
            ?.querySelector('.date-field-clear');
        if (!(btn instanceof HTMLButtonElement)) return;
        const has = Boolean(
            visible.value?.trim() || fp.input.value?.trim(),
        );
        btn.hidden = !has;
        btn.disabled = !has;
    }

    function syncAltInputPlaceholder(fp: FpInstance) {
        if (fp.altInput && fp.input?.placeholder) {
            fp.altInput.placeholder = fp.input.placeholder;
        }
    }

    function wireDateClearButton(fp: FpInstance) {
        const input = fp.input;
        const btn = input
            .closest('.date-input-inner')
            ?.querySelector('.date-field-clear');
        if (!(btn instanceof HTMLButtonElement)) return;
        if (btn.dataset.visuClearBound === '1') return;
        btn.dataset.visuClearBound = '1';
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            fp.clear();
            if (fp.isOpen) fp.close();
            syncDateClearButton(fp);
        });
        syncDateClearButton(fp);
    }

    function visuPickerTeardown(fp: FpInstance) {
        fp._visuAbort?.abort();
    }

    function setupVisuMonthYearGrids(fp: FpInstance) {
        const inner = fp.innerContainer;
        const rCont = inner?.querySelector('.flatpickr-rContainer');
        if (!inner || !rCont || inner.querySelector('.visu-fp-overlay')) return;

        const ac = new AbortController();
        fp._visuAbort = ac;
        const sig = ac.signal;

        const overlay = document.createElement('div');
        overlay.className = 'visu-fp-overlay';
        overlay.hidden = true;

        const monthPart = document.createElement('div');
        const yearPart = document.createElement('div');
        yearPart.hidden = true;

        const monthHead = document.createElement('div');
        monthHead.className = 'visu-fp-panel-head';
        const myPrev = document.createElement('button');
        myPrev.type = 'button';
        myPrev.setAttribute('aria-label', 'Previous year');
        myPrev.textContent = '\u2039';
        const myTitle = document.createElement('div');
        myTitle.className = 'visu-fp-panel-title';
        const myNext = document.createElement('button');
        myNext.type = 'button';
        myNext.setAttribute('aria-label', 'Next year');
        myNext.textContent = '\u203a';
        monthHead.append(myPrev, myTitle, myNext);

        const monthGrid = document.createElement('div');
        monthGrid.className = 'visu-fp-grid';

        const yearHead = document.createElement('div');
        yearHead.className = 'visu-fp-panel-head';
        const yyPrev = document.createElement('button');
        yyPrev.type = 'button';
        yyPrev.setAttribute('aria-label', 'Previous decade');
        yyPrev.textContent = '\u2039';
        const yyTitle = document.createElement('div');
        yyTitle.className = 'visu-fp-panel-title';
        const yyNext = document.createElement('button');
        yyNext.type = 'button';
        yyNext.setAttribute('aria-label', 'Next decade');
        yyNext.textContent = '\u203a';
        yearHead.append(yyPrev, yyTitle, yyNext);

        const yearGrid = document.createElement('div');
        yearGrid.className = 'visu-fp-grid';

        monthPart.append(monthHead, monthGrid);
        yearPart.append(yearHead, yearGrid);
        overlay.append(monthPart, yearPart);
        inner.insertBefore(overlay, rCont);

        let decadeBase = Math.floor(fp.currentYear / 10) * 10;

        function closePanels() {
            overlay.hidden = true;
            yearPart.hidden = true;
            monthPart.hidden = false;
        }

        function openMonthPanel() {
            yearPart.hidden = true;
            monthPart.hidden = false;
            renderMonthGrid();
            overlay.hidden = false;
        }

        function openYearPanel() {
            decadeBase = Math.floor(fp.currentYear / 10) * 10;
            monthPart.hidden = true;
            yearPart.hidden = false;
            renderYearGrid();
            overlay.hidden = false;
        }

        function renderMonthGrid() {
            const { minY, maxY } = yearLimits(fp);
            myTitle.textContent = String(fp.currentYear);
            myPrev.disabled = fp.currentYear <= minY;
            myNext.disabled = fp.currentYear >= maxY;

            monthGrid.replaceChildren();
            const labels = fp.l10n.months.shorthand;
            for (let m = 0; m < 12; m++) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.textContent = labels[m] ?? String(m + 1);
                const allowed = isMonthAllowed(fp, fp.currentYear, m);
                if (!allowed) btn.disabled = true;
                if (m === fp.currentMonth && allowed) btn.classList.add('is-selected');
                btn.addEventListener(
                    'click',
                    () => {
                        if (!isMonthAllowed(fp, fp.currentYear, m)) return;
                        fp.changeMonth(m - fp.currentMonth);
                        fp.redraw();
                        closePanels();
                    },
                    { signal: sig },
                );
                monthGrid.appendChild(btn);
            }
        }

        function renderYearGrid() {
            const { minDec, maxDec } = decadeLimits(fp);
            yyTitle.textContent = `${decadeBase}\u2009\u2013\u2009${decadeBase + 9}`;
            yyPrev.disabled = decadeBase <= minDec;
            yyNext.disabled = decadeBase >= maxDec;

            yearGrid.replaceChildren();
            for (let i = 0; i < 12; i++) {
                const y = decadeBase - 1 + i;
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.textContent = String(y);
                if (y === decadeBase - 1 || y === decadeBase + 10)
                    btn.classList.add('is-edge');
                if (isYearDisabled(fp, y)) btn.disabled = true;
                if (y === fp.currentYear && !btn.disabled)
                    btn.classList.add('is-selected');
                btn.addEventListener(
                    'click',
                    () => {
                        if (isYearDisabled(fp, y)) return;
                        fp.changeYear(y);
                        fp.redraw();
                        closePanels();
                    },
                    { signal: sig },
                );
                yearGrid.appendChild(btn);
            }
        }

        myPrev.addEventListener(
            'click',
            (e) => {
                e.stopPropagation();
                const { minY } = yearLimits(fp);
                if (fp.currentYear <= minY) return;
                fp.changeYear(fp.currentYear - 1);
                fp.redraw();
                renderMonthGrid();
            },
            { signal: sig },
        );
        myNext.addEventListener(
            'click',
            (e) => {
                e.stopPropagation();
                const { maxY } = yearLimits(fp);
                if (fp.currentYear >= maxY) return;
                fp.changeYear(fp.currentYear + 1);
                fp.redraw();
                renderMonthGrid();
            },
            { signal: sig },
        );

        yyPrev.addEventListener(
            'click',
            (e) => {
                e.stopPropagation();
                const { minDec } = decadeLimits(fp);
                if (decadeBase <= minDec) return;
                decadeBase -= 10;
                renderYearGrid();
            },
            { signal: sig },
        );
        yyNext.addEventListener(
            'click',
            (e) => {
                e.stopPropagation();
                const { maxDec } = decadeLimits(fp);
                if (decadeBase >= maxDec) return;
                decadeBase += 10;
                renderYearGrid();
            },
            { signal: sig },
        );

        fp.monthElements[0].addEventListener(
            'click',
            (e) => {
                e.preventDefault();
                e.stopPropagation();
                openMonthPanel();
            },
            { signal: sig },
        );
        fp.monthElements[0].addEventListener(
            'keydown',
            (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    openMonthPanel();
                }
            },
            { signal: sig },
        );

        const yearEl = fp.yearElements[0];
        yearEl.readOnly = true;
        yearEl.addEventListener(
            'click',
            (e) => {
                e.preventDefault();
                e.stopPropagation();
                openYearPanel();
            },
            { signal: sig },
        );
        yearEl.addEventListener(
            'keydown',
            (e) => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    openYearPanel();
                }
            },
            { signal: sig },
        );

        const navClose = () => closePanels();
        fp.prevMonthNav.addEventListener('click', navClose, { signal: sig });
        fp.nextMonthNav.addEventListener('click', navClose, { signal: sig });

        document.addEventListener(
            'keydown',
            (e) => {
                if (e.key === 'Escape' && !overlay.hidden) closePanels();
            },
            { signal: sig },
        );

        trimMonthLabel(fp);
        fp.monthElements[0].setAttribute('role', 'button');
        fp.monthElements[0].setAttribute('tabindex', '0');
        fp.yearElements[0].setAttribute('role', 'button');
        fp.yearElements[0].setAttribute('aria-label', 'Choose year');
    }

    function commonPickerOptions(
        extra: Record<string, unknown> = {},
    ): Record<string, unknown> {
        const userReady = extra.onReady as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userClose = extra.onClose as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userDestroy = extra.onDestroy as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userOpen = extra.onOpen as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userMonthChange = extra.onMonthChange as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userYearChange = extra.onYearChange as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userOnChange = extra.onChange as
            | ((d: Date[], s: string, fp: FpInstance) => void)
            | undefined;
        const userDayCreate = extra.onDayCreate as
            | ((
                  d: Date[],
                  s: string,
                  fp: FpInstance,
                  dayElem: HTMLElement,
              ) => void)
            | undefined;
        const {
            onReady: _or,
            onClose: _oc,
            onDestroy: _od,
            onOpen: _oo,
            onMonthChange: _omc,
            onYearChange: _oyc,
            onChange: _och,
            onDayCreate: _odc,
            ...rest
        } = extra;

        return {
            mode: 'single',
            /* Stored value for the form + API (ISO-like, sortable) */
            dateFormat: 'Y-m-d',
            /* Visible field: day / month / year (European order) */
            altInput: true,
            altFormat: 'd/m/Y',
            altInputClass: 'form-input date-field',
            minDate: 'today',
            disableMobile: true,
            appendTo: document.body,
            monthSelectorType: 'static',
            shorthandCurrentMonth: true,
            ...rest,
            position: 'above left',
            onReady(d: Date[], s: string, fp: FpInstance) {
                setupVisuMonthYearGrids(fp);
                syncAltInputPlaceholder(fp);
                wireDateClearButton(fp);
                userReady?.(d, s, fp);
            },
            onOpen(d: Date[], s: string, fp: FpInstance) {
                trimMonthLabel(fp);
                /* Sit slightly higher so the date input + placeholder stay visible underneath */
                requestAnimationFrame(() => {
                    const cal = fp.calendarContainer;
                    const t = cal?.style?.top;
                    if (!t) return;
                    const n = parseFloat(t);
                    if (!Number.isNaN(n)) cal.style.top = `${n - 40}px`;
                });
                userOpen?.(d, s, fp);
            },
            onMonthChange(d: Date[], s: string, fp: FpInstance) {
                trimMonthLabel(fp);
                userMonthChange?.(d, s, fp);
            },
            onYearChange(d: Date[], s: string, fp: FpInstance) {
                trimMonthLabel(fp);
                userYearChange?.(d, s, fp);
            },
            onDayCreate(
                d: Date[],
                s: string,
                fp: FpInstance,
                dayElem: HTMLElement,
            ) {
                classifyVisuDayCell(fp, dayElem as DayCell);
                userDayCreate?.(d, s, fp, dayElem);
            },
            onChange(d: Date[], s: string, fp: FpInstance) {
                syncDateClearButton(fp);
                userOnChange?.(d, s, fp);
            },
            onClose(d: Date[], s: string, fp: FpInstance) {
                hideVisuOverlay(fp);
                syncDateClearButton(fp);
                userClose?.(d, s, fp);
            },
            onDestroy(d: Date[], s: string, fp: FpInstance) {
                visuPickerTeardown(fp);
                userDestroy?.(d, s, fp);
            },
        };
    }

    function attachDatePickers(root: HTMLElement) {
        const startDateInput = root.querySelector(
            'input[name="startDate"]',
        ) as InputWithFp | null;
        const endDateInput = root.querySelector(
            'input[name="endDate"]',
        ) as InputWithFp | null;
        if (!startDateInput || !endDateInput) return;
        if (startDateInput._flatpickr || endDateInput._flatpickr) return;

        const endPicker = flatpickr(
            endDateInput,
            commonPickerOptions(),
        ) as unknown as FpInstance;

        flatpickr(
            startDateInput,
            commonPickerOptions({
                onChange(selectedDates: Date[]) {
                    if (selectedDates[0]) {
                        endPicker.set('minDate', selectedDates[0]);
                    } else {
                        endPicker.set('minDate', 'today');
                    }
                },
            }),
        );
    }

    function tryAttachPickersWhenVisible(root: HTMLElement) {
        if (!formIsVisible(root)) return;
        attachDatePickers(root);
    }

    function initServiceRequestFormUi() {
        const root = document.getElementById('service-request-form');
        if (!root) return;

        const submitButton = root.querySelector('.btn-submit') as
            | HTMLButtonElement
            | undefined;
        if (submitButton) {
            submitButton.style.cursor = 'pointer';
        }

        formVisibilityObserver?.disconnect();
        tryAttachPickersWhenVisible(root);

        formVisibilityObserver = new MutationObserver(() => {
            tryAttachPickersWhenVisible(root);
        });
        formVisibilityObserver.observe(root, {
            attributes: true,
            attributeFilter: ['style'],
        });
    }

    document.addEventListener('astro:page-load', initServiceRequestFormUi);
</script>
