---
interface Props {
    title: string;
    description: string;
    href: string;
    processSteps?: string[];
}

const { title, description, href, processSteps } = Astro.props;

const iconMap = {
    "Logo Design": "/images/icons/logo-design-icon.svg",
    "Web Design": "/images/icons/web-design-icon.svg",
    "Brand Identity": "/images/icons/brand-design-icon.svg"
};

const iconPath = iconMap[title as keyof typeof iconMap] || "/images/icons/logo-design-icon.svg";
---

<a href={href} class="service-card animate-text">
    <div class="service-icon-wrapper">
        <img src={iconPath} alt={title} class="service-icon" loading="lazy" width="36" height="36" />
    </div>

    <div class="service-content">
        <h3 class="service-title">{title}</h3>
        <p class="service-description">{description}</p>

        {processSteps && processSteps.length > 0 && (
            <div class="service-process">
                {processSteps.map((step: string, index: number) => 
                    <div class="process-item">
                        <span class="process-number">{index + 1}</span>
                        <span class="process-text">{step}</span>
                    </div>
                )}
            </div>
        )}

        <div class="service-footer">
            <span class="learn-more">Learn More</span>
            <span class="arrow-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </span>
        </div>
    </div>
</a>

<style>
    /* ═══════════════════════════════════════
       SERVICE PROMO CARD
       ═══════════════════════════════════════ */

    .service-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 24px;
        padding: 32px;
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-subtle);
        background: var(--surface);
        text-decoration: none;
        color: inherit;
        cursor: pointer;
        transition:
            border-color 0.3s cubic-bezier(0.16, 1, 0.3, 1),
            box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
    }

    .service-card::before {
        content: "";
        position: absolute;
        top: -50%;
        right: -50%;
        width: 300px;
        height: 300px;
        background: radial-gradient(
            circle,
            rgba(132, 128, 255, 0.15) 0%,
            rgba(132, 128, 255, 0.05) 40%,
            transparent 70%
        );
        border-radius: 50%;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    /* Hover polish only on devices that support real hover (avoids “sticky” hover on touch) */
    @media (hover: hover) and (pointer: fine) {
        .service-card:hover::before {
            opacity: 1;
        }

        .service-card:hover {
            border-color: rgba(132, 128, 255, 0.3);
            box-shadow: 0 12px 48px rgba(132, 128, 255, 0.15);
            transform: translateY(-4px);
        }

        .service-card:hover .service-icon-wrapper {
            background: rgba(132, 128, 255, 0.15);
            transform: scale(1.05);
        }

        :global([data-theme="dark"]) .service-card:hover .service-icon-wrapper {
            background: rgba(132, 128, 255, 0.2);
        }

        .service-card:hover .service-icon {
            filter: saturate(15.3) brightness(0.4);
        }

        :global([data-theme="dark"]) .service-card:hover .service-icon {
            filter: brightness(1.3) drop-shadow(0 0 16px rgba(132, 128, 255, 0.8));
        }

        .service-card:hover .service-footer {
            gap: 14px;
        }

        .service-card:hover .arrow-icon {
            opacity: 1;
            transform: translateX(4px);
        }
    }

    /* ── Icon ── */
    .service-icon-wrapper {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-lg);
        background: rgba(132, 128, 255, 0.08);
        transition:
            background 0.3s ease,
            transform 0.3s ease;
    }

    :global([data-theme="dark"]) .service-icon-wrapper {
        background: rgba(132, 128, 255, 0.12);
    }

    .service-icon {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--brand-violet);
        flex-shrink: 0;
        filter: saturate(15.2) brightness(0.35);
        transition:
            filter 0.3s ease,
            transform 0.3s ease;
        object-fit: contain;
    }

    :global([data-theme="dark"]) .service-icon {
        filter: brightness(1.2) drop-shadow(0 0 8px rgba(132, 128, 255, 0.6));
    }

    /* ── Content ── */
    .service-content {
        position: relative;
        z-index: 1;
        flex: 1;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .service-title {
        font-size: clamp(18px, 2vw, 22px);
        font-weight: 600;
        line-height: 1.2;
        color: var(--foreground);
        margin: 0;
        letter-spacing: -0.01em;
    }

    .service-description {
        font-size: clamp(14px, 1.5vw, 16px);
        line-height: 1.6;
        color: var(--foreground);
        opacity: 0.7;
        margin: 0;
    }

    :global([data-theme="dark"]) .service-title,
    :global([data-theme="dark"]) .service-description {
        color: #ffffff;
    }

    /* ── Process Steps ── */
    .service-process {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin: 8px 0;
    }

    .process-item {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        line-height: 1.5;
        color: var(--foreground);
        opacity: 0.65;
    }

    :global([data-theme="dark"]) .process-item {
        color: #e9e8ff;
    }

    .process-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: rgba(132, 128, 255, 0.15);
        color: var(--brand-violet);
        font-weight: 600;
        font-size: 11px;
        flex-shrink: 0;
    }

    /* ── Footer ── */
    .service-footer {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
        flex-shrink: 0;
        transition: gap 0.3s ease;
    }

    .learn-more {
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--brand-violet);
        white-space: nowrap;
    }

    .arrow-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        color: var(--brand-violet);
        opacity: 0.7;
        transition:
            opacity 0.3s ease,
            transform 0.3s ease;
        flex-shrink: 0;
    }

    .arrow-icon svg {
        width: 18px;
        height: 18px;
        stroke-width: 2.5;
    }

    /*
      Homepage 3-col row (desktop / iPad Pro width): equal card heights without
      flex-basis:0 + min-height:0 on .service-content (that clips text under overflow:hidden).
      Middle block keeps natural height; footer uses margin-top:auto to sit on the bottom edge.
    */
    @media (min-width: 1024px) {
        :global(.services-grid) .service-card .service-content {
            flex: 1 1 auto;
            min-height: min-content;
        }

        :global(.services-grid) .service-card .service-footer {
            margin-top: auto;
        }
    }

    @media (max-width: 1023px) {
        .service-card {
            align-items: center;
        }

        .service-content {
            align-items: center;
            text-align: center;
        }

        .service-description {
            text-align: center;
        }

        .service-title {
            text-align: center;
        }

        .service-process {
            align-self: center;
            width: fit-content;
            max-width: 100%;
            align-items: flex-start;
            text-align: left;
        }

        .process-item {
            justify-content: flex-start;
            text-align: left;
        }

        .service-footer {
            justify-content: center;
        }
    }

    @media (max-width: 600px) {
        .service-card {
            padding: 24px;
            gap: 18px;
        }

        .service-title {
            font-size: 18px;
        }

        .service-icon-wrapper {
            width: 52px;
            height: 52px;
        }

        .service-icon {
            width: 32px;
            height: 32px;
        }

        .service-description {
            font-size: 14px;
        }
    }
</style>
