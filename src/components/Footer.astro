<div
  id="footer-copy-toast"
  class="footer-copy-toast"
  role="status"
  aria-live="polite"
  aria-atomic="true"></div>

<script is:inline>
  (function () {
    var MQ = "(max-width: 767.98px)";

    function isPhoneTapToCall() {
      return window.matchMedia(MQ).matches;
    }

    function setPhoneTitles() {
      document.querySelectorAll(".js-footer-phone").forEach(function (el) {
        el.title = isPhoneTapToCall() ? "Call us" : "Copy phone number";
      });
    }

    function showCopyToast() {
      var toastEl = document.getElementById("footer-copy-toast");
      if (!toastEl) return;
      toastEl.textContent = "Phone number copied";
      toastEl.classList.add("is-visible");
      window.clearTimeout(showCopyToast._hide);
      showCopyToast._hide = window.setTimeout(function () {
        toastEl.classList.remove("is-visible");
        window.setTimeout(function () {
          toastEl.textContent = "";
        }, 320);
      }, 2600);
    }

    function copyPhoneNumber(phoneEl) {
      var text = phoneEl.getAttribute("data-copy-text") || "";
      function fallback() {
        var ta = document.createElement("textarea");
        ta.value = text;
        ta.setAttribute("readonly", "");
        ta.style.position = "fixed";
        ta.style.left = "-9999px";
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand("copy");
          showCopyToast();
        } catch (_) {}
        document.body.removeChild(ta);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(showCopyToast).catch(fallback);
      } else {
        fallback();
      }
    }

    /** Delegation: works on first paint and after Astro view transitions replace the footer. */
    document.addEventListener(
      "click",
      function (e) {
        var phoneEl = e.target && e.target.closest(".js-footer-phone");
        if (!phoneEl) return;
        if (isPhoneTapToCall()) return;
        e.preventDefault();
        copyPhoneNumber(phoneEl);
      },
      false,
    );

    window.matchMedia(MQ).addEventListener("change", setPhoneTitles);

    function onReady() {
      setPhoneTitles();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", onReady);
    } else {
      onReady();
    }

    document.addEventListener("astro:page-load", setPhoneTitles);
  })();
</script>

<style>
  /* ===============================
     FOOTER — Island Style
     =============================== */
  .site-footer {
    /* Island Logic: Floating container similar to navbar */
    width: calc(100% - 24px);
    margin: 12px auto 12px; /* Top margin for page separation, bottom for floating look */
    border: 1px solid var(--border-subtle);
    background-color: var(--surface);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-island);
    padding: 60px 48px 32px; /* Generous internal padding */
    color: var(--foreground);
    transition:
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    position: relative;
    /* Avoid clipping grid / columns on tablets (was hiding part of the footer) */
    overflow: visible;
    opacity: 0;
    animation: footerSlideIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes footerSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .footer-container {
    width: 100%;
    height: 100%;
  }

  /* Grid Layout */
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr; /* Adjusted for better spacing */
    gap: 48px;
    margin-bottom: 80px;
    min-width: 0;
  }

  /* Brand Column */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-right: 24px;
    position: relative;
    min-width: 0;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--foreground);
    transition: transform 0.3s ease;
  }

  .footer-logo:hover {
    transform: translateY(-2px);
  }

  .footer-logo svg {
    height: 32px; /* Slightly larger in footer */
    width: auto;
    fill: var(--foreground);
    transition: transform 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .footer-logo:hover svg {
    transform: rotate(360deg);
  }

  .footer-logo:hover svg path {
    fill: var(--brand-violet);
    transition: fill 0.3s ease;
  }

  .footer-logo-text {
    font-family: "Visupair", var(--font-family);
    font-size: 30px;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--foreground);
    transition: color 0.3s ease;
    position: relative;
  }

  .footer-logo:hover .footer-logo-text {
    color: var(--brand-violet);
  }

  .footer-desc {
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.7;
    max-width: 320px;
  }

  /* Desktop: fixed size (original look). Mobile: flexible row — see media query below. */
  .footer-connect-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 10px;
    min-width: 0;
    width: auto;
  }

  .footer-copy-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    max-width: min(calc(100vw - 32px), 300px);
    padding: 14px 18px;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-dropdown);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--foreground);
    opacity: 0;
    transform: translateX(calc(100% + 28px));
    pointer-events: none;
    transition:
      opacity 0.22s ease,
      transform 0.34s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .footer-copy-toast.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  .footer-icon-link {
    flex: 0 0 auto;
    width: 44px;
    height: 44px;
