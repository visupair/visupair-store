    </a>

    <a
      href="/account/purchases"
      class:list={[
        "user-nav-item",
        isAccountNavActive("/account/purchases") && "active",
      ]}
      aria-current={isAccountNavActive("/account/purchases") ? "page" : undefined}
      data-account-nav="purchases"
    >
      <svg
        class="user-nav-icon"
        viewBox="0 0 21 19"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
