          fill="currentColor"></path></svg
      >
      <span>Profile</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </a>

    <a
      href="/cart"
      class:list={[
        "user-nav-item",
        isAccountNavActive("/cart") && "active",
      ]}
      aria-current={isAccountNavActive("/cart") ? "page" : undefined}
      data-account-nav="cart"
    >
      <svg
        class="user-nav-icon"
