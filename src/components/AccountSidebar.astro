---
import { getUserProfilePhotoUrl } from "../lib/user-avatar-url";

interface Props {
  userName: string;
  userEmail: string;
  userInitials: string;
  /** OAuth avatar URL (e.g. Google). When absent, initials are shown. */
  userImageUrl?: string | null;
}

const { userName, userEmail, userInitials, userImageUrl = null } = Astro.props;
const photoUrl = getUserProfilePhotoUrl(userImageUrl);

const pathname = Astro.url.pathname;

function isAccountNavActive(href: string): boolean {
  if (href === "/account/profile") {
    return pathname === "/account/profile" || pathname.startsWith("/account/profile/");
  }
  if (href === "/cart") {
    return pathname === "/cart" || pathname.startsWith("/cart/");
  }
  if (href === "/account/favorites") {
    return pathname.startsWith("/account/favorites");
  }
  if (href === "/account/purchases") {
    return pathname.startsWith("/account/purchases");
  }
  if (href === "/support") {
    return pathname.startsWith("/support");
  }
  return false;
}

const profileActive = isAccountNavActive("/account/profile");
---

<div class="island-sidebar-backdrop" id="sidebar-backdrop"></div>
<aside class="island-sidebar" id="account-sidebar">
  <a
    href="/account/profile"
    class:list={["user-profile-section", "user-profile-section-link", profileActive && "active"]}
    aria-label="Profile and account settings"
    data-account-nav="profile"
  >
    <div class:list={["user-avatar", photoUrl && "user-avatar--photo"]}>
      {
        photoUrl ? (
          <img
            class="user-avatar-photo"
            src={photoUrl}
            alt=""
            width="48"
            height="48"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        ) : (
          userInitials
        )
      }
    </div>
    <div class="user-info">
      <h3>{userName}</h3>
      <p>{userEmail}</p>
    </div>
  </a>

  <nav class="user-nav-group">
    <a
      href="/account/profile"
      class:list={["user-nav-item", profileActive && "active"]}
      aria-current={profileActive ? "page" : undefined}
      data-account-nav="profile"
    >
      <svg
        class="user-nav-icon"
        viewBox="0 0 18 22"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
