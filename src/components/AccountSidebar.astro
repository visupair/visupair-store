---
interface Props {
  userName: string;
  userEmail: string;
  userInitials: string;
}

const { userName, userEmail, userInitials } = Astro.props;
---

<div class="island-sidebar-backdrop" id="sidebar-backdrop"></div>
<aside class="island-sidebar" id="account-sidebar">
  <div class="user-profile-section">
    <div class="user-avatar">{userInitials}</div>
    <div class="user-info">
      <h3>{userName}</h3>
      <p>{userEmail}</p>
    </div>
  </div>

  <nav class="user-nav-group">
    <a href="/cart" class="user-nav-item">
      <svg
        class="user-nav-icon"
        viewBox="0 -960 960 960"
        fill="currentColor"
        stroke="none"
        ><path
          d="M240-80q-33 0-56.5-23.5T160-160v-480q0-33 23.5-56.5T240-720h80q0-66 47-113t113-47q66 0 113 47t47 113h80q33 0 56.5 23.5T800-640v480q0 33-23.5 56.5T720-80H240Zm0-80h480v-480h-80v80q0 17-11.5 28.5T600-520q-17 0-28.5-11.5T560-560v-80H400v80q0 17-11.5 28.5T360-520q-17 0-28.5-11.5T320-560v-80h-80v480Zm160-560h160q0-33-23.5-56.5T480-800q-33 0-56.5 23.5T400-720ZM240-160v-480 480Z"
        ></path></svg
      >
      <span>My Cart</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </a>

    <a href="/account/favorites" class="user-nav-item">
      <svg
        class="user-nav-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path
          d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
        ></path></svg
      >
      <span>My Favorites</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </a>

    <a href="/account/purchases" class="user-nav-item">
      <svg
        class="user-nav-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"
        ></path><line x1="3" y1="6" x2="21" y2="6"></line><path
          d="M16 10a4 4 0 0 1-8 0"></path></svg
      >
      <span>My Purchases</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </a>

    <a href="/account/profile" class="user-nav-item">
      <svg
        class="user-nav-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
          cx="12"
          cy="7"
          r="4"></circle></svg
      >
      <span>Profile</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </a>

    <a href="#" class="user-nav-item">
      <svg
        class="user-nav-icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><circle cx="12" cy="12" r="10"></circle><path
          d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line
          x1="12"
          y1="17"
          x2="12.01"
          y2="17"></line></svg
      >
      <span>Support</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
      >
    </a>
  </nav>

  <button class="sign-out-btn" id="logout-btn">
    <span>Sign out</span>
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline
        points="16 17 21 12 16 7"></polyline><line
        x1="21"
        y1="12"
        x2="9"
        y2="12"></line></svg
    >
  </button>
</aside>

<style>
  /* Sidebar Island */
  .island-sidebar-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    z-index: 900;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease;
  }
  .island-sidebar-backdrop.active {
    opacity: 1;
    visibility: visible;
  }

  .island-sidebar {
    position: fixed;
    top: 12px;
    right: 12px;
    bottom: 12px;
    width: 320px;
    background: var(--surface);
    border-radius: var(--radius-xl);
    box-shadow:
      -10px 0 40px rgba(0, 0, 0, 0.1),
      var(--shadow-island);
    border: 1px solid var(--border-subtle);
    padding: 32px;
    display: flex;
    flex-direction: column;
    z-index: 1000;
    transform: translateX(120%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .island-sidebar.active {
    transform: translateX(0);
  }

  /* User Profile Section */
  .user-profile-section {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .user-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(
      135deg,
      var(--brand-violet),
      var(--brand-light-lavender)
    );
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(132, 128, 255, 0.3);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .user-info {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .user-info h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--foreground);
  }

  .user-info p {
    font-size: 13px;
    opacity: 0.6;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Navigation Items */
  .user-nav-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .user-nav-item {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    padding: 14px 16px;
    background: transparent;
    border: none;
    border-radius: var(--radius-lg);
    color: var(--foreground);
    font-family: var(--font-family);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.2, 0, 0, 1);
    gap: 12px;
    text-decoration: none;
  }

  .user-nav-icon {
    width: 20px;
    height: 20px;
    opacity: 0.6;
    transition: all 0.2s;
  }

  .user-nav-chevron {
    margin-left: auto;
    width: 16px;
    height: 16px;
    opacity: 0.3;
    transition: all 0.2s;
  }

  .user-nav-item:hover {
    background: var(--surface-muted);
    color: var(--brand-violet);
    transform: translateX(4px);
  }

  .user-nav-item:hover .user-nav-icon {
    opacity: 1;
    stroke: var(--brand-violet);
  }

  .user-nav-item:hover .user-nav-chevron {
    opacity: 1;
    transform: translateX(2px);
    stroke: var(--brand-violet);
  }

  /* Sign Out Button */
  .sign-out-btn {
    margin-top: auto;
    width: 100%;
    padding: 14px 16px;
    background: transparent;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    color: var(--foreground);
    font-family: var(--font-family);
    font-weight: 500;
    font-size: 15px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s ease;
  }

  .sign-out-btn:hover {
    background: rgba(239, 68, 68, 0.08);
    border-color: #ef4444;
    color: #ef4444;
  }

  .sign-out-btn svg {
    width: 18px;
    height: 18px;
    transition: transform 0.2s;
    opacity: 0.6;
  }

  .sign-out-btn:hover svg {
    transform: translateX(2px);
    stroke: #ef4444;
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .island-sidebar {
      width: 280px;
      padding: 24px;
    }
  }
</style>

<script>
  declare global {
    interface Window {
      toggleAccountSidebar?: () => void;
      updateAccountSidebar?: (user: {
        name: string;
        email: string;
      }) => void;
    }
  }

  // Helper to get user initials
  function getUserInitials(name: string): string {
    if (!name) return "U";
    const parts = name.trim().split(" ");
    return parts.length >= 2
      ? (parts[0][0] + parts[1][0]).toUpperCase()
      : name[0].toUpperCase();
  }

  // Initialize sidebar functionality once
  const initSidebar = () => {
    const sidebar = document.getElementById("account-sidebar");
    const backdrop = document.getElementById("sidebar-backdrop");
    const logoutBtn = document.getElementById("logout-btn");

    if (!sidebar || !backdrop) return;

    // Expose toggle function globally
    window.toggleAccountSidebar = () => {
      sidebar.classList.toggle("active");
      backdrop.classList.toggle("active");
    };

    // Expose update function globally (for Navigation.astro to call)
    window.updateAccountSidebar = (user: { name: string; email: string }) => {
      const avatar = sidebar.querySelector(".user-avatar");
      const nameEl = sidebar.querySelector(".user-info h3");
      const emailEl = sidebar.querySelector(".user-info p");

      if (avatar) avatar.textContent = getUserInitials(user.name);
      if (nameEl) nameEl.textContent = user.name;
      if (emailEl) emailEl.textContent = user.email;
    };

    // Close when clicking backdrop
    backdrop.addEventListener("click", () => {
      sidebar.classList.remove("active");
      backdrop.classList.remove("active");
    });

    // Close sidebar when clicking navigation links
    const navLinks = sidebar.querySelectorAll(".user-nav-item");
    navLinks.forEach((link) => {
      link.addEventListener("click", () => {
        sidebar.classList.remove("active");
        backdrop.classList.remove("active");
      });
    });

    // Logout handler
    logoutBtn?.addEventListener("click", async () => {
      try {
        // Use Better Auth client method
        const { signOut } = await import("../lib/auth-client");

        await signOut({
          fetchOptions: {
            onSuccess: () => {
              sidebar.classList.remove("active");
              backdrop.classList.remove("active");
              window.location.href = "/";
            },
            onError: (ctx) => {
              console.error("Logout error:", (ctx as any).error);
              alert("Failed to log out. Please try again.");
            },
          },
        });
      } catch (error) {
        console.error("Logout error:", error);
        alert("An error occurred. Please try again.");
      }
    });
  };

  // Initialize on first load
  initSidebar();

  // Reinitialize on View Transitions
  document.addEventListener("astro:after-swap", initSidebar);
</script>
