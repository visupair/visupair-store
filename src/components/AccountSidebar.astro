    </a>

    <a
      href="/account/favorites"
      class:list={[
        "user-nav-item",
        isAccountNavActive("/account/favorites") && "active",
      ]}
      aria-current={isAccountNavActive("/account/favorites") ? "page" : undefined}
      data-account-nav="favorites"
    >
      <svg
        class="user-nav-icon"
        viewBox="0 0 22 19"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
