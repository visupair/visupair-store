          fill="currentColor"></path></svg
      >
      <span>My Favorites</span>
      <svg
        class="user-nav-chevron"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"><path d="M9 18l6-6-6-6"></path></svg
