---
import type { Course } from "../lib/store-data";
import type { Currency } from "../lib/server-currency";
import { formatCourseStartsAt } from "../lib/format-course-start";

interface Props {
    courses: Course[];
    serverCurrency?: Currency;
}

const { courses, serverCurrency } = Astro.props;

const priceColorMap: Record<string, string> = {
    paid: "var(--brand-violet)",
    free: "#22c55e",
    donation: "#22c55e",
    payAtDoor: "var(--brand-violet)",
};

// Helper to generate placeholder image
const getPlaceholderImage = (text: string, seed: number = 0) => {
    const encodedText = encodeURIComponent(text);
    const bg = seed === 0 ? "151128" : seed === 1 ? "1a1635" : "221d3a";
    return `https://placehold.co/1200x675/${bg}/CBFF62?text=${encodedText}&font=roboto`;
};

// Helper to get instructor initials
const getInitials = (name: string) => {
    return name
        .split(" ")
        .map((word) => word[0])
        .join("")
        .toUpperCase()
        .slice(0, 2);
};
---

<div
    id="course-catalog-root"
    class="course-catalog-root"
    data-server-currency={serverCurrency ?? ""}
>
<div class="course-grid">
    {
        courses.map((course) => {
            const details = course.details || {};
            const instructor = course.instructor || {
                name: "Instructor",
                title: "Expert",
            };
            const courseSlug = course.slug || course.id || "";
            const courseImage =
                course.mainImage ||
                course.image ||
                getPlaceholderImage(course.name);

            const registrationOpen = course.registrationOpen !== false;
            const pricingType = (course as any).pricingType || "paid";
            const startsAtLabel = formatCourseStartsAt(
                course.startsAt,
                "compact",
            );

            return (
                <a href={`/courses/${courseSlug}`} class="course-card">
                    <div class="course-image-wrapper">
                        <img
                            src={courseImage}
                            alt={course.name}
                            loading="lazy"
                        />
                        <span
                            class={`course-reg-indicator ${registrationOpen ? "reg-open" : "reg-closed"}`}
                            transition:name={`course-reg-${course.id || courseSlug}`}
                        >
                            <span class="course-reg-text">
                                {registrationOpen ? "Open" : "Closed"}
                            </span>
                        </span>
                    </div>

                    <div class="course-content">
                        <div class="course-meta-tags">
                            {startsAtLabel && (
                                <span class="course-tag course-tag-start" title="Course start">
                                    {startsAtLabel}
                                </span>
                            )}
                            <span class="course-tag">
                                {details.level ||
                                    (details as any)["Level"] ||
                                    "All Levels"}
                            </span>
                            <span class="course-tag">
                                {details.duration ||
                                    (details as any)["Duration"] ||
                                    "Self-Paced"}
                            </span>
                            {pricingType !== "paid" && (
                                <span class={`course-tag course-tag-${pricingType}`}>
                                    {pricingType === "free" && "Free"}
                                    {pricingType === "donation" && "Donation"}
                                    {pricingType === "payAtDoor" && "Pay at Door"}
                                </span>
                            )}
                        </div>

                        <h3 class="course-title">{course.name}</h3>
                        <p class="course-desc">{course.description}</p>

                        <div class="course-footer">
                            <div class="instructor-mini">
                                {instructor.avatar ? (
                                    <img
                                        src={instructor.avatar}
                                        alt={instructor.name}
                                        class="instructor-mini-avatar-img"
                                    />
                                ) : (
                                    <div class="instructor-mini-avatar">
                                        {getInitials(instructor.name || "IN")}
                                    </div>
                                )}
                                <span>
                                    {instructor.name || "Instructor Name"}
                                </span>
                            </div>
                            {(pricingType === "paid" || pricingType === "payAtDoor") ? (
                                <span
                                    class="course-price"
                                    style={{
                                        fontWeight: "700",
                                        color: priceColorMap[pricingType],
                                    }}
                                    data-price-eur={course.price}
                                    data-price-pln={course.pricePLN || Math.round(course.price * 4.3)}
                                    data-server-currency={serverCurrency || ''}
                                >
                                    €{course.price}
                                </span>
                            ) : (
                                <span
                                    class="course-price-label"
                                    style={{
                                        fontWeight: "700",
                                        color: priceColorMap[pricingType],
                                    }}
                                >
                                    Free
                                </span>
                            )}
                        </div>
                    </div>
                </a>
            );
        })
    }
</div>
</div>

<style>
    /* Wrapper for reliable server currency hint; does not affect layout */
    .course-catalog-root {
        display: contents;
    }

    .course-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        width: 100%;
    }

    .course-card {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-lg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
            transform 0.2s,
            box-shadow 0.2s,
            border-color 0.2s;
        cursor: pointer;
        height: 100%;
        text-decoration: none;
        color: inherit;
    }

    .course-card:hover {
        transform: translateY(-4px);
        border-color: var(--brand-violet);
        box-shadow: 0 12px 24px rgba(132, 128, 255, 0.15);
    }

    .course-image-wrapper {
        width: 100%;
        aspect-ratio: 16/9;
        background: var(--surface-muted);
        position: relative;
        overflow: hidden;
    }

    .course-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Registration indicator */
    .course-reg-indicator {
        position: absolute;
        top: 8px;
        left: 8px;
        font-size: 11px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: var(--radius-pill);
        display: inline-flex;
        align-items: center;
        overflow: hidden;
        white-space: nowrap;
        opacity: 1;
        max-width: 20px;
        transform: scale(0.6);
        transform-origin: top left;
        transition:
            max-width 0.25s ease-out,
            transform 0.25s ease-out;
        z-index: 10;
        pointer-events: none;
        letter-spacing: 0.03em;
    }

    .course-reg-indicator.reg-open {
        background: #83bf24;
        color: #0e0a23;
        animation: course-reg-glow 2s ease-in-out infinite;
    }

    .course-reg-indicator.reg-closed {
        background: #ef4444;
        color: #ffffff;
        animation: course-reg-glow-red 2s ease-in-out infinite;
    }

    .course-reg-text {
        opacity: 0;
        transform: translateX(-4px);
        transition:
            opacity 0.15s ease,
            transform 0.15s ease;
    }

    @media (hover: hover) {
        .course-card:hover .course-reg-indicator {
            max-width: 120px;
            transform: scale(1);
            transition:
                max-width 0.4s cubic-bezier(0.2, 1.3, 0.4, 1),
                transform 0.35s cubic-bezier(0.2, 1.3, 0.4, 1);
        }

        .course-card:hover .course-reg-text {
            opacity: 1;
            transform: translateX(0);
            transition:
                opacity 0.2s ease 0.2s,
                transform 0.2s ease 0.2s;
        }
    }

    @media (max-width: 1024px), (hover: none) {
        .course-reg-indicator {
            max-width: none !important;
            transform: scale(1) !important;
            top: auto;
            bottom: 8px;
            font-size: 9px;
        }
        .course-reg-text {
            opacity: 1 !important;
            transform: none !important;
        }
    }

    .course-content {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        flex: 1;
    }

    .course-meta-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .course-tag {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--brand-violet);
        background: rgba(132, 128, 255, 0.1);
        padding: 4px 8px;
        border-radius: var(--radius-sm);
    }

    /* Start date/time: readable casing, not all-caps */
    .course-tag-start {
        text-transform: none;
        font-weight: 600;
        letter-spacing: 0.02em;
        color: var(--foreground);
        background: color-mix(in srgb, var(--foreground) 8%, transparent);
    }

    .course-tag-free {
        background: rgba(34, 197, 94, 0.1);
        color: #22c55e;
    }

    .course-tag-donation {
        background: rgba(34, 197, 94, 0.1);
        color: #22c55e;
    }

    .course-tag-payAtDoor {
        background: rgba(132, 128, 255, 0.1);
        color: var(--brand-violet);
    }

    .course-price-label {
        font-size: 14px;
        white-space: nowrap;
    }

    .course-title {
        font-size: 18px;
        font-weight: 700;
        line-height: 1.3;
        color: var(--foreground);
    }

    .course-desc {
        font-size: 14px;
        opacity: 0.7;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }

    .course-footer {
        margin-top: auto;
        padding-top: 16px;
        border-top: 1px dashed var(--border-subtle);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .instructor-mini {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 500;
    }

    .instructor-mini-avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--surface-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        border: 1px solid var(--border-subtle);
    }

    .instructor-mini-avatar-img {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid var(--border-subtle);
    }

    @media (max-width: 900px) {
        .course-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>

<style is:global>
    @keyframes course-reg-glow {
        0%, 100% { box-shadow: 0 0 0 2px rgba(131, 191, 36, 0.5); }
        50%       { box-shadow: 0 0 0 6px rgba(131, 191, 36, 0); }
    }
    @keyframes course-reg-glow-red {
        0%, 100% { box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.45); }
        50%       { box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
    }
</style>

<script>
    // Client-side currency detection for course grid (aligned with ProductGrid / CourseDetail)
    type Currency = "EUR" | "PLN";

    function detectUserCurrency(): Currency {
        const urlParams = new URLSearchParams(window.location.search);
        const debugCurrency = urlParams.get("currency");
        if (debugCurrency === "EUR" || debugCurrency === "PLN") {
            return debugCurrency;
        }

        // Prefer this catalog’s server hint — avoids reading another page’s
        // [data-server-currency] after View Transitions (store vs courses).
        const catalogRoot = document.getElementById("course-catalog-root");
        const catalogHint = catalogRoot
            ?.getAttribute("data-server-currency")
            ?.trim();
        if (catalogHint === "EUR" || catalogHint === "PLN") {
            return catalogHint;
        }

        // Any price cell on this catalog (fallback if root attribute missing)
        const nestedHint = catalogRoot
            ?.querySelector("[data-server-currency]")
            ?.getAttribute("data-server-currency")
            ?.trim();
        if (nestedHint === "EUR" || nestedHint === "PLN") {
            return nestedHint;
        }

        try {
            const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
            if (
                timezone &&
                (timezone.includes("Warsaw") ||
                    timezone === "Europe/Warsaw" ||
                    timezone === "Poland")
            ) {
                return "PLN";
            }
        } catch (e) {}

        const locale = navigator.language || (navigator as any).userLanguage;
        if (locale && locale.toLowerCase().startsWith("pl")) {
            return "PLN";
        }

        return "EUR";
    }

    function updateCoursePrices() {
        const catalogRoot = document.getElementById("course-catalog-root");
        if (!catalogRoot) return;

        const currency = detectUserCurrency();
        const priceElements = catalogRoot.querySelectorAll(
            ".course-price[data-price-eur][data-price-pln]",
        );

        priceElements.forEach((element) => {
            const priceEUR = element.getAttribute("data-price-eur");
            const pricePLN = element.getAttribute("data-price-pln");

            if (!priceEUR || !pricePLN) return;

            if (currency === "PLN") {
                element.textContent = `${pricePLN}zł`;
            } else {
                element.textContent = `€${priceEUR}`;
            }
        });
    }

    updateCoursePrices();
    document.addEventListener("astro:page-load", updateCoursePrices);
</script>
