---
import { createAuth } from "../lib/auth";
import StarRating from "./StarRating.astro";
import { drizzle } from "drizzle-orm/d1";
import { review, user } from "../lib/auth-schema";
import { eq, desc } from "drizzle-orm";

interface Props {
    productId: string;
}

const { productId } = Astro.props;

// Get Database and Auth context
interface Review {
    id: string;
    rating: number;
    comment: string | null;
    createdAt: Date;
    userId: string | null;
    userName: string | null;
    userImage: string | null;
}

// @ts-ignore
const { env: cfEnv } = await import("cloudflare:workers").catch(() => ({
    env: {},
}));
let dbBinding = cfEnv?.visupair_store;
let envData = cfEnv || {};

try {
    if (
        !dbBinding &&
        Astro.locals.runtime &&
        typeof Astro.locals.runtime === "object"
    ) {
        const descriptor = Object.getOwnPropertyDescriptor(
            Astro.locals.runtime,
            "env",
        );
        if (descriptor && typeof descriptor.get !== "function") {
            dbBinding = (Astro.locals.runtime as any).env?.visupair_store;
            envData = (Astro.locals.runtime as any).env || {};
        }
    }
} catch (e) {}

let session = null;
let reviews: Review[] = [];

if (dbBinding) {
    // 1. Get Session
    const auth = createAuth(dbBinding, envData as any);
    session = await auth.api.getSession({ headers: Astro.request.headers });

    // 2. Fetch Reviews
    const db = drizzle(dbBinding);
    reviews = await db
        .select({
            id: review.id,
            rating: review.rating,
            comment: review.comment,
            createdAt: review.createdAt,
            userId: review.userId,
            userName: user.name,
            userImage: user.image,
        })
        .from(review)
        .leftJoin(user, eq(review.userId, user.id))
        .where(eq(review.productId, productId))
        .orderBy(desc(review.createdAt));
}
const currentUserId = session?.user?.id;
const ADMIN_EMAILS = ["visupair@gmail.com"];
const isAdmin = session && ADMIN_EMAILS.includes(session.user.email);
---

<div class="review-section" id="reviews">
    <h2 class="section-title">Reviews ({reviews.length})</h2>

    <!-- Review Form for Logged-In Users -->
    {
        session ? (
            <form
                class="review-form"
                id="review-form"
                method="POST"
                action="/api/reviews"
            >
                <input type="hidden" name="productId" value={productId} />

                <div class="form-group">
                    <fieldset class="review-rating-fieldset">
                        <legend>Rating</legend>
                        <StarRating
                            rating={0}
                            interactive={true}
                            size={24}
                            name="rating"
                        />
                    </fieldset>
                </div>

                <div class="form-group">
                    <label for="comment">Comment</label>
                    <textarea
                        id="comment"
                        name="comment"
                        rows="4"
                        placeholder="Share your thoughts about this product..."
                        class="review-textarea"
                    />
                </div>

                <button type="submit" class="btn-submit-review">
                    Submit Review
                </button>
                <p class="form-message" id="form-message" />
            </form>
        ) : (
            <div class="login-prompt">
                <p>
                    Please <a href="/login?redirect=/store">log in</a> to leave
                    a review.
                </p>
            </div>
        )
    }

    <!-- Reviews List -->
    <div class="reviews-list">
        {
            reviews.length > 0 ? (
                reviews.map((rev) => (
                    <div class="review-card" id={`review-${rev.id}`}>
                        <div class="review-header">
                            <div class="reviewer-info">
                                {rev.userImage ? (
                                    <img
                                        src={rev.userImage}
                                        alt={
                                            rev.userName
                                                ? `${rev.userName}`
                                                : "Reviewer"
                                        }
                                        class="reviewer-avatar"
                                    />
                                ) : (
                                    <div class="reviewer-avatar-placeholder">
                                        {rev.userName
                                            ? rev.userName
                                                  .charAt(0)
                                                  .toUpperCase()
                                            : "U"}
                                    </div>
                                )}
                                <div class="reviewer-meta">
                                    <span class="reviewer-name">
                                        {rev.userName}
                                    </span>
                                    <span class="review-date">
                                        {new Date(
                                            rev.createdAt,
                                        ).toLocaleDateString()}
                                    </span>
                                </div>
                            </div>

                            <div class="review-header-actions">
                                <div class="review-rating">
                                    <StarRating rating={rev.rating} size={16} />
                                </div>
                                {(currentUserId === rev.userId || isAdmin) && (
                                    <button
                                        class="btn-delete-review"
                                        data-review-id={rev.id}
                                        aria-label="Delete review"
                                        title="Delete your review"
                                    >
                                        <svg
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <line
                                                x1="18"
                                                y1="6"
                                                x2="6"
                                                y2="18"
                                            />
                                            <line
                                                x1="6"
                                                y1="6"
                                                x2="18"
                                                y2="18"
                                            />
                                        </svg>
                                    </button>
                                )}
                            </div>
                        </div>
                        <p class="review-text">{rev.comment}</p>
                    </div>
                ))
            ) : (
                <p class="no-reviews">
                    No reviews yet. Be the first to verify this product!
                </p>
            )
        }
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal-overlay" id="delete-modal">
    <div class="modal-content">
        <h3 class="modal-title">Delete Review?</h3>
        <p class="modal-text">
            Are you sure you want to delete this review? This action cannot be
            undone.
        </p>
        <div class="modal-actions">
            <button class="btn-modal btn-cancel" id="cancel-delete"
                >Cancel</button
            >
            <button class="btn-modal btn-confirm-delete" id="confirm-delete"
                >Delete</button
            >
        </div>
    </div>
</div>

<script>
    /**
     * Document-level handlers so review UI works after View Transitions
     * (`ClientRouter`): inline listeners on a replaced DOM never run again.
     */
    let reviewIdToDelete: string | null = null;
    let cardToDelete: HTMLElement | null = null;

    function closeReviewDeleteModal() {
        const modal = document.getElementById("delete-modal");
        if (modal) {
            modal.classList.remove("visible");
            setTimeout(() => modal.classList.remove("open"), 300);
        }
        reviewIdToDelete = null;
        cardToDelete = null;
    }

    function openReviewDeleteModal(id: string) {
        reviewIdToDelete = id;
        cardToDelete = document.getElementById(`review-${id}`);
        const modal = document.getElementById("delete-modal");
        if (modal) {
            modal.classList.add("open");
            requestAnimationFrame(() => modal.classList.add("visible"));
        }
    }

    async function handleReviewFormSubmit(form: HTMLFormElement) {
        const messageEl = document.getElementById("form-message");
        const submitBtn = form.querySelector(
            'button[type="submit"]',
        ) as HTMLButtonElement | null;
        if (!submitBtn) return;

        try {
            submitBtn.disabled = true;
            submitBtn.textContent = "Submitting...";

            const response = await fetch("/api/reviews", {
                method: "POST",
                body: new FormData(form),
                credentials: "include",
            });

            const raw = await response.text();
            let result: { error?: string } = {};
            try {
                if (raw) result = JSON.parse(raw) as { error?: string };
            } catch {
                result = {};
            }

            if (response.ok) {
                if (messageEl) {
                    messageEl.textContent =
                        "Review submitted successfully! Reload to see.";
                    messageEl.className = "form-message success";
                }
                form.reset();
                setTimeout(() => window.location.reload(), 1500);
            } else {
                if (messageEl) {
                    messageEl.textContent =
                        result.error || "Failed to submit review.";
                    messageEl.className = "form-message error";
                }
            }
        } catch (err) {
            console.error(err);
            const el = document.getElementById("form-message");
            if (el) {
                el.textContent = "An error occurred.";
                el.className = "form-message error";
            }
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = "Submit Review";
        }
    }

    function onDocumentSubmit(e: SubmitEvent) {
        const form = e.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (form.id !== "review-form") return;
        e.preventDefault();
        void handleReviewFormSubmit(form);
    }

    function onDocumentClick(e: MouseEvent) {
        const t = e.target as HTMLElement | null;
        if (!t) return;

        const delBtn = t.closest(".btn-delete-review");
        if (delBtn) {
            e.preventDefault();
            const id = (delBtn as HTMLElement).dataset.reviewId;
            if (id) openReviewDeleteModal(id);
            return;
        }

        if (t.closest("#cancel-delete")) {
            e.preventDefault();
            closeReviewDeleteModal();
            return;
        }

        const confirmBtn = t.closest("#confirm-delete") as
            | HTMLButtonElement
            | null;
        if (confirmBtn) {
            e.preventDefault();
            void runConfirmDelete(confirmBtn);
            return;
        }

        const modal = document.getElementById("delete-modal");
        if (modal && e.target === modal) closeReviewDeleteModal();
    }

    async function runConfirmDelete(confirmBtn: HTMLButtonElement) {
        if (!reviewIdToDelete) return;

        const originalText = confirmBtn.textContent;
        const toRemove = cardToDelete;
        confirmBtn.textContent = "Deleting...";
        confirmBtn.disabled = true;

        try {
            const response = await fetch(`/api/review/${reviewIdToDelete}`, {
                method: "DELETE",
                credentials: "include",
            });

            if (response.ok) {
                if (toRemove) {
                    toRemove.style.transition = "opacity 0.3s, height 0.3s";
                    toRemove.style.opacity = "0";
                    setTimeout(() => {
                        toRemove.remove();
                        window.location.reload();
                    }, 300);
                }
                closeReviewDeleteModal();
            } else {
                alert("Failed to delete review");
            }
        } catch (err) {
            console.error(err);
            alert("Error deleting review");
        } finally {
            confirmBtn.textContent = originalText || "Delete";
            confirmBtn.disabled = false;
            closeReviewDeleteModal();
        }
    }

    const w = window as Window & { __visupairReviewUiBound?: boolean };
    if (!w.__visupairReviewUiBound) {
        w.__visupairReviewUiBound = true;
        document.addEventListener("submit", onDocumentSubmit);
        document.addEventListener("click", onDocumentClick);
    }
</script>

