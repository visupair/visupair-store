<script>
  import { authClient } from "../lib/auth-client";
  import {
    favoritesStore,
    toggleFavorite,
    initFavorites,
  } from "../lib/favoritesStore";
  import { showCheckoutToast } from "../lib/checkout-toast";

  // ==========================================
  // WISHLIST / FAVORITES LOGIC
  // ==========================================

  function updateWishlistBtn(favorites: readonly string[]) {
    const btn = document.getElementById(
      "wishlist-btn",
    ) as HTMLButtonElement | null;
    if (!btn) return;
    const productId = btn.getAttribute("data-product-id");
    if (!productId) return;

    const svg = btn.querySelector("svg");
    const isFav = favorites.includes(productId);

    if (isFav) {
      svg?.setAttribute("fill", "currentColor");
      svg?.removeAttribute("opacity");
      btn.classList.add("active");
      btn.setAttribute("aria-pressed", "true");
    } else {
      svg?.setAttribute("fill", "currentColor");
      btn.classList.remove("active");
      btn.setAttribute("aria-pressed", "false");
    }
  }

  function handleWishlistClick(e: Event) {
    e.preventDefault();
    e.stopPropagation();
    const btn = document.getElementById("wishlist-btn");
    const productId = btn?.getAttribute("data-product-id");
    if (productId) {
      toggleFavorite(productId);
    }
  }

  // Subscribe once — keeps button in sync whenever store changes
  favoritesStore.subscribe(updateWishlistBtn);

  // Define interface for Shipping Data
  interface ShippingData {
    email: string;
    firstName: string;
    lastName: string;
    address: string;
    city: string;
    postalCode: string;
    country: string;
    phone?: string;
  }
  // ==========================================
  // ==========================================
  // CLIENT-SIDE INTERACTIVITY
  // ==========================================

  // Currency detection
  type Currency = "EUR" | "PLN";

  function detectUserCurrency(): Currency {
    // PRIORITY 0: Check URL params (for testing/overriding)
    const urlParams = new URLSearchParams(window.location.search);
    const debugCurrency = urlParams.get("currency");
    if (debugCurrency === "EUR" || debugCurrency === "PLN") {
      return debugCurrency;
    }

    // PRIORITY 1: Server-detected currency (Cloudflare)
    const priceElement = document.querySelector("[data-server-currency]");
    const serverCurrency = priceElement?.getAttribute("data-server-currency");

    if (
      serverCurrency &&
      (serverCurrency === "EUR" || serverCurrency === "PLN")
    ) {
      return serverCurrency as Currency;
    }

    // FALLBACK 1: Check timezone
    try {
      const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
      if (
        timezone &&
        (timezone.includes("Warsaw") ||
          timezone === "Europe/Warsaw" ||
          timezone === "Poland")
      ) {
        return "PLN";
      }
    } catch (e) {}

    // FALLBACK 2: Check browser language
    const locale = navigator.language || (navigator as any).userLanguage;
    if (locale && locale.toLowerCase().startsWith("pl")) {
      return "PLN";
    }

    return "EUR";
  }

  function updateProductPrices() {
    const userCurrency = detectUserCurrency();

    // Always update all dynamic price elements on the page first
    const priceElements = document.querySelectorAll(
      ".product-price-dynamic[data-price-eur][data-price-pln]",
    );
    priceElements.forEach((element) => {
      const priceEUR = element.getAttribute("data-price-eur");
      const pricePLN = element.getAttribute("data-price-pln");
      if (!priceEUR || !pricePLN) return;
      if (userCurrency === "PLN") {
        element.textContent = `${pricePLN} zł`;
      } else {
        element.textContent = `€${priceEUR}`;
      }
    });

    // Shipping modal currency update (only relevant when buy-btn exists)
    const buyBtn = document.getElementById("buy-btn");
    if (!buyBtn) return;

    const priceEur = parseFloat(buyBtn.getAttribute("data-price-eur") || "0");
    const pricePln = parseFloat(buyBtn.getAttribute("data-price-pln") || "0");

    const modalTotal = document.getElementById("total-amount-display");
    const modalProductPrice = document.querySelector(
      ".shipping-modal .product-price",
    );
    const modalCostBreakdownSubtotal = document.querySelector(
      ".cost-breakdown .cost-row:first-child span:last-child",
    );

    if (modalTotal && modalProductPrice) {
      const newPrice = userCurrency === "PLN" ? pricePln : priceEur;
      const symbol = userCurrency === "PLN" ? "zł" : "€";
      const formattedPrice =
        userCurrency === "PLN"
          ? `${newPrice.toFixed(2)} zł`
          : `€${newPrice.toFixed(2)}`;

      modalTotal.dataset.currencySymbol = symbol;
      modalTotal.innerHTML = `<span class="currency-code">${userCurrency}</span> ${formattedPrice}`;
      // @ts-ignore
      modalProductPrice.dataset.basePrice = newPrice;
      modalProductPrice.textContent = formattedPrice;

      if (modalCostBreakdownSubtotal) {
        modalCostBreakdownSubtotal.textContent = formattedPrice;
      }
    }
  }

  // Run currency detection on load
  updateProductPrices();

  function markDetailGalleryImagesLoaded(root: ParentNode = document) {
    root.querySelectorAll(".detail-large-image--image img").forEach((img) => {
      const wrap = img.closest(".detail-large-image--image");
      if (!wrap) return;
      const done = () => wrap.classList.add("is-loaded");
      if (
        img instanceof HTMLImageElement &&
        img.complete &&
        img.naturalHeight > 0
      ) {
        done();
      } else {
        img.addEventListener("load", done, { once: true });
        img.addEventListener("error", done, { once: true });
      }
    });
  }

  const initProductDetail = () => {
    // Check if product detail panel exists on this page
    const productDetailPanel = document.querySelector("#product-detail-panel");
    if (!productDetailPanel) {
      return;
    }

    markDetailGalleryImagesLoaded(productDetailPanel);

    // Refresh EUR / PLN on the detail price after View Transitions (only
    // .product-price-dynamic — never the Add to Cart button).
    updateProductPrices();

    console.log("Initializing Product Detail interactions...");

    const galleryImages = document.querySelectorAll(".detail-large-image");
    const sizeBtns = document.querySelectorAll(".size-btn");
    const galleryColumn = document.querySelector(".detail-gallery-column");
    const paginationDots = document.querySelectorAll(".pagination-dot");
    const productNameElement = document.querySelector(".detail-title");
    const productName = productNameElement
      ? productNameElement.textContent
      : "Product";

    if (!galleryImages.length) {
      console.log("No gallery images found, skipping initialization.");
      return;
    }

    let currentMobileIndex = 0;

    // Get Image URLs from DOM
    const galleryImageUrls = Array.from(galleryImages)
      .map((div) => {
        const img = div.querySelector("img") as HTMLImageElement | null;
        if (!img) return "";
        const full = img.dataset.fullscreenSrc?.trim();
        return full || img.src;
      })
      .filter(Boolean);

    // Size Selection
    sizeBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        sizeBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        // Hide error if visible
        const err = document.getElementById("size-error");
        const sizeOptions = document.getElementById("size-options");

        if (err) err.style.display = "none";
        if (sizeOptions) sizeOptions.classList.remove("error");
      });
    });

    // Image Gallery Click -> Dispatch event to global Fullscreen component
    galleryImages.forEach((imgDiv, idx) => {
      imgDiv.addEventListener("click", () => {
        window.dispatchEvent(
          new CustomEvent("open-fullscreen-gallery", {
            detail: {
              images: galleryImageUrls,
              startIndex: idx,
              productName: productName,
            },
          }),
        );
      });
    });

    // Mobile Gallery: Scroll Detection
    galleryColumn?.addEventListener("scroll", () => {
      // @ts-ignore
      const scrollLeft = galleryColumn.scrollLeft;
      // @ts-ignore
      const clientWidth = galleryColumn.clientWidth;
      const newIndex = Math.round(scrollLeft / clientWidth);

      if (newIndex !== currentMobileIndex) {
        currentMobileIndex = newIndex;
        updatePaginationDots();
      }
    });

    function updatePaginationDots() {
      paginationDots.forEach((dot, idx) => {
        if (idx === currentMobileIndex) {
          dot.classList.add("active");
        } else {
          dot.classList.remove("active");
        }
      });
    }

    // Restock Notification Form Handler
    const restockForm = document.getElementById("restock-form");
    if (restockForm) {
      restockForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const formElement = e.target as HTMLFormElement;
        const emailInput = formElement.querySelector(
          "#restock-email",
        ) as HTMLInputElement;
        const submitBtn = formElement.querySelector(
          ".btn-restock",
        ) as HTMLButtonElement;
        const messageDiv = document.getElementById(
          "restock-message",
        ) as HTMLDivElement;
        const productId = formElement.dataset.productId;
        const productName = formElement.dataset.productName;
        const productUrl = formElement.dataset.productUrl;

        if (!emailInput || !submitBtn || !messageDiv) return;

        const email = emailInput.value.trim();
        if (!email) return;

        // Disable button and show loading state
        submitBtn.disabled = true;
        const originalBtnText = submitBtn.innerHTML;
        submitBtn.innerHTML =
          '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin"><circle cx="12" cy="12" r="10" opacity="0.25"></circle><path d="M4 12a8 8 0 018-8" opacity="0.75"></path></svg> Sending...';

        try {
          const response = await fetch("/api/restock-notification", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              email,
              productId,
              productName,
              productUrl,
            }),
          });

          const data = await response.json();

          if (response.ok) {
            messageDiv.className = "restock-message success";
            messageDiv.textContent =
              "✓ Thank you! We'll notify you when this item is back in stock.";
            messageDiv.style.display = "block";
            emailInput.value = "";
          } else {
            throw new Error(data.error || "Failed to submit");
          }
        } catch (error) {
          console.error("Restock notification error:", error);
          messageDiv.className = "restock-message error";
          messageDiv.textContent = "✗ Something went wrong. Please try again.";
          messageDiv.style.display = "block";
        } finally {
          // Re-enable button
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalBtnText;

          // Hide message after 5 seconds
          setTimeout(() => {
            messageDiv.style.display = "none";
          }, 5000);
        }
      });
    }

    if (paginationDots.length > 0) {
      paginationDots[0].classList.add("active");
    }

    // define load3dViewer globally to handle re-initialization if needed, but primarily here
    const btnLoad3d = document.getElementById("btn-load-3d");
    const wrapper3d = document.getElementById("clo3d-wrapper");

    if (btnLoad3d && wrapper3d) {
      btnLoad3d.addEventListener("click", () => {
        const url = wrapper3d.dataset.embedUrl;
        if (!url) return;

        // Create iframe
        const iframe = document.createElement("iframe");
        iframe.src = url;
        iframe.allowFullscreen = true;
        iframe.title = "3D Viewer";

        // Clear placeholder and append iframe
        wrapper3d.innerHTML = "";
        wrapper3d.appendChild(iframe);
      });
    }

    // --- NEW: Scroll to Reviews Handler ---
    // --- NEW: Scroll to Reviews Handler ---
    const reviewTriggers = productDetailPanel.querySelectorAll(
      ".rating-scroll-trigger",
    );
    const reviewsSection = productDetailPanel.querySelector("#reviews");

    if (reviewsSection && reviewTriggers.length > 0) {
      reviewTriggers.forEach((trigger) => {
        trigger.addEventListener("click", (e) => {
          e.preventDefault();
          // Don't stop propagation completely if clicking interactive elements inside,
          // but we want scroll behavior on the container click.
          // However, clicking label inside StarRating triggers input change and bubbles click.

          // Simple and robust: Scroll to the very bottom of the panel.
          productDetailPanel.scrollTo({
            top: productDetailPanel.scrollHeight,
            behavior: "smooth",
          });
        });
      });
    }

    // --- Add to Cart Handler ---
    const addToCartBtn = document.getElementById("add-to-cart-btn");

    if (addToCartBtn) {
      (async () => {
        const {
          addToCart,
          isInCart,
          initCart: initCartStore,
          cartStore,
          removeFromCart,
        } = await import("../lib/cartStore");
        initCartStore();

        const cartBtnEl = addToCartBtn as HTMLElement;
        const cartProductId = cartBtnEl.dataset.productId || "";
        const initialAddToCartHTML = addToCartBtn!.innerHTML;

        function getSelectedSize(): string | undefined {
          const active = document.querySelector(
            ".size-btn.active",
          ) as HTMLElement | null;
          return active?.dataset.size;
        }

        const removeFromCartIcon = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>`;

        function switchToAddToCartUI() {
          addToCartBtn!.innerHTML = initialAddToCartHTML;
          addToCartBtn!.classList.remove(
            "added",
            "go-to-cart",
            "remove-from-cart",
          );
          addToCartBtn!.removeAttribute("aria-label");
          addToCartBtn!.removeEventListener("click", handleRemoveFromCart);
          addToCartBtn!.removeEventListener("click", handleAddToCart);
          addToCartBtn!.addEventListener("click", handleAddToCart);
        }

        function switchToRemoveFromCartUI() {
          addToCartBtn!.innerHTML = `${removeFromCartIcon}<span class="remove-cart-label-desktop">Remove from cart</span><span class="remove-cart-label-mobile">Remove item</span>`;
          addToCartBtn!.classList.remove("added", "go-to-cart");
          addToCartBtn!.classList.add("remove-from-cart");
          addToCartBtn!.setAttribute(
            "aria-label",
            "Remove this item from your cart",
          );
          addToCartBtn!.removeEventListener("click", handleAddToCart);
          addToCartBtn!.removeEventListener("click", handleRemoveFromCart);
          addToCartBtn!.addEventListener("click", handleRemoveFromCart);
        }

        function handleRemoveFromCart() {
          const size = getSelectedSize();
          removeFromCart(cartProductId, size);
          switchToAddToCartUI();
        }

        function checkIfInCart() {
          const size = getSelectedSize();
          const sizeBtns = document.querySelectorAll(".size-btn");

          if (sizeBtns.length > 0 && !size) {
            // No size selected yet — check if any size of this product is in the cart
            const cartItem = cartStore
              .get()
              .find((i: any) => i.productId === cartProductId);
            if (cartItem?.selectedSize) {
              // Pre-select the size that was added to cart
              sizeBtns.forEach((b) => b.classList.remove("active"));
              const match = Array.from(sizeBtns).find(
                (b) =>
                  (b as HTMLElement).dataset.size === cartItem.selectedSize,
              );
              if (match) match.classList.add("active");
              switchToRemoveFromCartUI();
            } else {
              switchToAddToCartUI();
            }
            return;
          }

          if (isInCart(cartProductId, size)) {
            switchToRemoveFromCartUI();
          } else {
            switchToAddToCartUI();
          }
        }

        // Re-check when size changes
        document.querySelectorAll(".size-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            setTimeout(checkIfInCart, 50);
          });
        });

        async function handleAddToCart() {
          const currentSizeBtns = document.querySelectorAll(".size-btn");
          let selectedSize: string | undefined;

          if (currentSizeBtns.length > 0) {
            let hasSelection = false;
            currentSizeBtns.forEach((btn) => {
              if (btn.classList.contains("active")) {
                hasSelection = true;
                selectedSize = (btn as HTMLElement).dataset.size;
              }
            });

            if (!hasSelection) {
              const err = document.getElementById("size-error");
              const sizeOptions = document.getElementById("size-options");
              if (sizeOptions) sizeOptions.classList.add("error");
              if (err) {
                err.style.display = "block";
                err.textContent = "Please select a size";
              }
              return;
            }
          }

          const productType = (cartBtnEl.dataset.productType || "physical") as
            | "physical"
            | "digital";
          const shippingWeight = parseFloat(
            cartBtnEl.dataset.shippingWeight || "0",
          );
          const shippingLength = parseFloat(
            cartBtnEl.dataset.shippingLength || "0",
          );
          const shippingWidth = parseFloat(
            cartBtnEl.dataset.shippingWidth || "0",
          );
          const shippingHeight = parseFloat(
            cartBtnEl.dataset.shippingHeight || "0",
          );
          const hasShipping =
            shippingWeight > 0 &&
            shippingLength > 0 &&
            shippingWidth > 0 &&
            shippingHeight > 0;

          const added = addToCart({
            productId: cartBtnEl.dataset.productId || "",
            name: cartBtnEl.dataset.productName || "",
            price: parseFloat(cartBtnEl.dataset.priceEur || "0"),
            pricePLN: parseFloat(cartBtnEl.dataset.pricePln || "0"),
            image: cartBtnEl.dataset.productImage || "",
            productType,
            selectedSize,
            shipping: hasShipping
              ? {
                  weight: shippingWeight,
                  length: shippingLength,
                  width: shippingWidth,
                  height: shippingHeight,
                }
              : undefined,
          });

          if (added) {
            addToCartBtn!.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Added!`;
            addToCartBtn!.classList.add("added");
            setTimeout(() => switchToRemoveFromCartUI(), 1200);
          } else {
            switchToRemoveFromCartUI();
          }
        }

        checkIfInCart();
      })();
    }

    // --- Shipping Form Handler ---
    const shippingModal = document.getElementById("shipping-modal");
    const closeShippingBtn = document.getElementById("close-shipping");
    const shippingForm = document.getElementById("shipping-form");

    // Move Shipping Modal to Body to avoid z-index/stacking context issues with Sidebar/Navbar
    if (shippingModal && document.body) {
      document.body.appendChild(shippingModal);
    }

    // Cleanup Shipping Modal on page swap
    document.addEventListener("astro:before-swap", () => {
      if (shippingModal && document.body.contains(shippingModal)) {
        shippingModal.remove();
      }
    });

    if (shippingModal && closeShippingBtn && shippingForm) {
      // Close Modal
      closeShippingBtn.addEventListener("click", () => {
        shippingModal.classList.remove("active");
        document.body.style.overflow = "";
      });

      // Close on click outside (Optional, user might lose data)
      // shippingModal.addEventListener('click', (e) => {
      //     if (e.target === shippingModal) {
      //         shippingModal.classList.remove('active');
      //         document.body.style.overflow = '';
      //     }
      // });

      // Handle Form Submission
      shippingForm.addEventListener("submit", async (e) => {
        e.preventDefault();

        const submitBtn = shippingForm.querySelector('button[type="submit"]');
        const originalText = submitBtn ? submitBtn.textContent : "Continue";

        // === CRITICAL VALIDATION: Check if shipping service is selected ===
        const selectedShippingId = (
          document.getElementById("selected-shipping-id") as HTMLInputElement
        )?.value;
        const selectedShippingAmount = (
          document.getElementById(
            "selected-shipping-amount",
          ) as HTMLInputElement
        )?.value;

        // Check if product has shipping dimensions (for physical products)
        const buyBtn = document.getElementById("buy-btn");
        const productType = buyBtn?.dataset.productType;

        if (productType === "physical") {
          const specsEl = document.getElementById("product-shipping-specs");
          const weight = specsEl?.dataset.weight;
          const length = specsEl?.dataset.length;
          const width = specsEl?.dataset.width;
          const height = specsEl?.dataset.height;

          // Validate shipping dimensions exist
          if (!weight || !length || !width || !height) {
            alert(
              "⚠️ This product is missing shipping dimensions in the database. Please contact support.",
            );
            console.error("Missing shipping dimensions:", {
              weight,
              length,
              width,
              height,
            });
            return;
          }

          // Validate shipping service is selected
          if (!selectedShippingId || !selectedShippingAmount) {
            alert(
              "⚠️ Please select a shipping method before proceeding to payment.",
            );
            return;
          }
        }

        if (submitBtn) {
          submitBtn.textContent = "Processing...";
          // @ts-ignore
          submitBtn.disabled = true;
        }

        // Collect Form Data
        const formData = new FormData(shippingForm as HTMLFormElement);
        const shippingData = Object.fromEntries(formData.entries());

        // Get Product Data from the Buy Button
        const productId = buyBtn?.dataset.productId;

        if (!productId || !productType) {
          alert("Product ID missing");
          if (submitBtn) {
            submitBtn.textContent = originalText;
            // @ts-ignore
            submitBtn.disabled = false;
          }
          return;
        }

        try {
          const session = await authClient.getSession();
          if (!session.data?.user?.email) {
            window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname + window.location.search)}`;
            if (submitBtn) {
              submitBtn.textContent = originalText || "";
              // @ts-ignore
              submitBtn.disabled = false;
            }
            return;
          }

          await initiateCheckout(
            productId,
            productType,
            shippingData as unknown as ShippingData,
          );

          // Note: initiateCheckout handles the UI transition to Stripe
          // We just need to close the shipping modal
          shippingModal.classList.remove("active");
        } catch (err: any) {
          console.error("Shipping submission error:", err);
          alert("Error proceeding to payment: " + err.message);
          if (submitBtn) {
            submitBtn.textContent = originalText;
            // @ts-ignore
            submitBtn.disabled = false;
          }
        }
      });
    }

    // Reusable Checkout Function for Stripe
    async function initiateCheckout(
      productId: string | undefined,
      productType: string | undefined,
      shippingAddress?: ShippingData,
    ) {
      console.log("initiateCheckout called", {
        productId,
        productType,
      });

      const button = document.getElementById("buy-btn");
      if (button) button.textContent = "Redirecting to Checkout...";

      if (!productId) {
        console.error("No productId provided to initiateCheckout");
        return;
      }

      const stripePriceId = button?.dataset.stripePriceId;
      const priceEur = parseFloat(button?.dataset.priceEur || "0");
      const pricePln = parseFloat(button?.dataset.pricePln || "0");

      // Use the same currency detection used for UI display
      const userCurrency = detectUserCurrency();
      const selectedPrice = userCurrency === "PLN" ? pricePln : priceEur;

      const shippingAmtInput = document.getElementById(
        "selected-shipping-amount",
      ) as HTMLInputElement;
      const selectedShippingId = (
        document.getElementById("selected-shipping-id") as HTMLInputElement
      )?.value;
      const shippingAmount = shippingAmtInput?.value || "0";

      const sizeBtnActive = document.querySelector(
        ".size-btn.active",
      ) as HTMLElement | null;
      const checkoutSelectedSize = sizeBtnActive?.dataset.size;

      try {
        const response = await fetch("/api/create-checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            productId,
            priceId: stripePriceId || undefined,
            productName:
              document.querySelector(".detail-product-name")?.textContent ||
              "Product",
            productType,
            price: selectedPrice,
            currency: userCurrency,
            shippingAddress: shippingAddress || null,
            selectedShippingId: selectedShippingId || null,
            selectedShippingAmount: shippingAmount,
            selectedSize: checkoutSelectedSize || undefined,
          }),
        });

        const data = await response.json();

        if (!response.ok || !data.url) {
          throw new Error(data.error || "Failed to create checkout session");
        }

        window.location.href = data.url;
      } catch (err: any) {
        console.error("Checkout error:", err);
        showCheckoutToast(
          err.message || "Unable to start checkout. Please try again shortly.",
        );
        if (button)
          button.textContent = button.dataset.originalText || "Buy Now";
      }
    }
  };

  // Run on every page navigation
  document.addEventListener("astro:page-load", () => {
    initProductDetail();

    // Wishlist button setup
    initFavorites();
    updateWishlistBtn(favoritesStore.get());

    const wishlistBtn = document.getElementById("wishlist-btn");
    if (wishlistBtn) {
      wishlistBtn.removeEventListener("click", handleWishlistClick);
      wishlistBtn.addEventListener("click", handleWishlistClick);
    }
  });
</script>
