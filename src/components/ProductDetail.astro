---
import type { Product } from "../lib/store-data";
import {
  EUR_TO_PLN_RATE,
  type Currency,
} from "../lib/server-currency";
import {
  urlFor,
  urlForDetailGalleryPreview,
  urlForFullscreen,
} from "../lib/sanity";
import StarRating from "./StarRating.astro";
import ShippingForm from "./checkout/ShippingForm.astro";
import ReviewSection from "./ReviewSection.astro";
import { drizzle } from "drizzle-orm/d1";
import { review } from "../lib/auth-schema";
import { eq } from "drizzle-orm";
import { buildProductJsonLd } from "../lib/product-jsonld";

interface Props {
  product: Product;
  backLink?: string;
  serverCurrency?: Currency;
  /** Absolute canonical product URL (should use `site` origin for SEO). */
  canonicalProductUrl?: string;
  /**
   * When the signed-in user already bought this digital product, the buy CTA
   * becomes a link to My Purchases (downloads).
   */
  userOwnsDigital?: boolean;
}

const {
  product,
  backLink = "/store/fashion-design",
  serverCurrency,
  canonicalProductUrl,
  userOwnsDigital = false,
} = Astro.props;
// Extract section ID from product category path or backLink logic
const sectionId = product.categoryPath[0] || "fashion-design";

const siteBase = Astro.site?.origin ?? Astro.url.origin;

// Public product URL (notifications, JSON-LD) — prefer canonical from parent
const productUrl =
  canonicalProductUrl ??
  `${siteBase}/store/${sectionId}/${product.slug || product.id}`;

/** PLN from Sanity when set; else same rule as checkout: round(EUR × 4.3). */
const effectivePln =
  typeof product.pricePLN === "number" && product.pricePLN > 0
    ? product.pricePLN
    : Math.round(Number(product.price) * EUR_TO_PLN_RATE);

// Select appropriate price to display (server-detected currency on first paint)
const displayPrice =
  serverCurrency === "PLN"
    ? `${effectivePln.toFixed(2)}zł`
    : `€${Number(product.price).toFixed(2)}`;

// Helper to generate placeholder image
const getPlaceholderImage = (text: string, seed: number = 0) => {
  const encodedText = encodeURIComponent(text);
  const bg = seed === 0 ? "1A1635" : seed === 1 ? "221D3A" : "151128";
  return `https://placehold.co/1000x1200/${bg}/CBFF62?text=${encodedText}+${seed + 1}&font=roboto`;
};

// Preview URLs are resized; fullscreen uses full Sanity resolution (see data-fullscreen-src).
const gallerySlides: { preview: string; fullscreen: string }[] =
  product.gallery && product.gallery.length > 0
    ? product.gallery.map((img: any) => ({
        preview: urlForDetailGalleryPreview(img),
        fullscreen: urlForFullscreen(img),
      }))
    : product.images && product.images.length > 0
      ? product.images.map((u: string) => ({
          preview: u,
          fullscreen: u,
        }))
      : product.image
        ? [{ preview: product.image, fullscreen: product.image }]
        : [
            {
              preview: getPlaceholderImage(product.name),
              fullscreen: getPlaceholderImage(product.name),
            },
          ];

// Product Details (Specifications)
const productDetails = product.details || {};

// Sizes
const productSizes = product.sizes || [];
const inStock =
  product.inStock !== false &&
  (product.stock === undefined ||
    product.stock === null ||
    (product.stock as number) > 0);
const stockCount = product.stock ?? 1;

const showDigitalLibraryCta =
  product.productType === "digital" && userOwnsDigital;

// Digital Twin Visibility
const hasTwin = !!product.twinProduct;
const showTwinLink = product.showDigitalTwinLink !== false; // Default true if undefined
const twinProduct = product.twinProduct;

// Fetch ratings (Server Side)
let averageRating = 0;
let reviewCount = 0;

try {
  // @ts-ignore
  const { env: cfEnv } = await import("cloudflare:workers").catch(() => ({
    env: {},
  }));
  let dbBinding = cfEnv?.visupair_store;

  try {
    if (
      !dbBinding &&
      Astro.locals.runtime &&
      typeof Astro.locals.runtime === "object"
    ) {
      const descriptor = Object.getOwnPropertyDescriptor(
        Astro.locals.runtime,
        "env",
      );
      if (descriptor && typeof descriptor.get !== "function") {
        dbBinding = (Astro.locals.runtime as any).env?.visupair_store;
      }
    }
  } catch (e) {}
  if (dbBinding) {
    const db = drizzle(dbBinding);
    const productReviews = await db
      .select({ rating: review.rating })
      .from(review)
      .where(eq(review.productId, product.id));

    if (productReviews.length > 0) {
      const total = productReviews.reduce((acc, r) => acc + r.rating, 0);
      averageRating = total / productReviews.length;
      reviewCount = productReviews.length;
    }
  }
} catch (error) {
  console.warn("Failed to fetch reviews:", error);
}

const jsonLdImageUrls = gallerySlides.map((s) =>
  String(s.preview).startsWith("http")
    ? String(s.preview)
    : new URL(s.preview, siteBase).href,
);

const jsonLd = buildProductJsonLd({
  product,
  productPageUrl: productUrl,
  currency:
    (product.currency as string | undefined)?.toUpperCase() || "EUR",
  price: typeof product.price === "number" ? product.price : 0,
  inStock,
  imageUrls: jsonLdImageUrls,
  aggregateRating:
    reviewCount > 0
      ? { ratingValue: averageRating, reviewCount }
      : undefined,
});
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<div class="product-detail-panel" id="product-detail-panel">
  <!-- Close Button (Top Right, Sticky) -->
  <a
    href={backLink}
    class="detail-close-btn"
    id="close-detail-btn"
    aria-label="Close"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </a>

  <div class="detail-layout">
    <!-- Left Column: Vertical Gallery (Desktop) / Horizontal Slider (Mobile) -->
    <div class="detail-gallery-column" id="detail-gallery">
      {
        gallerySlides.map((slide, idx) => (
          <div
            class="detail-large-image detail-large-image--image"
            data-image-index={idx}
          >
            <img
              src={slide.preview}
              data-fullscreen-src={slide.fullscreen}
              alt={`${product.name} view ${idx + 1}`}
              loading="lazy"
            />
          </div>
        ))
      }
      {/* Clo 3D Viewer Embed - Only if URL is present (Digital Fashion) */}
      {
        product.clo3dEmbedUrl && (
          <div
            class="detail-3d-wrapper"
            id="clo3d-wrapper"
            data-embed-url={product.clo3dEmbedUrl}
          >
            <div class="clo3d-placeholder">
              <button class="btn-load-3d" id="btn-load-3d">
                <svg
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z" />
                  <path d="M12 12l8-4.5" />
                  <path d="M12 12v9" />
                  <path d="M12 12L4 7.5" />
                </svg>
                <span>Load 3D Viewer</span>
              </button>
            </div>
          </div>
        )
      }
    </div>

    <!-- Mobile Pagination Dots -->
    <div class="mobile-pagination" id="mobile-pagination">
      {
        gallerySlides.map((_, idx) => (
          <div class="pagination-dot" data-dot-index={idx} />
        ))
      }
    </div>

    <!-- Right Column: Product Info (Sticky on Desktop) -->
    <div class="detail-info-column">
      <div class="detail-info-content">
        <!-- Header: Title & Price -->
        <div class="detail-header">
          <h1 class="detail-title">{product.name}</h1>
          <span
            class="detail-price product-price-dynamic"
            data-price-eur={Number(product.price).toFixed(2)}
            data-price-pln={effectivePln.toFixed(2)}
            data-server-currency={serverCurrency || ""}
          >
            €{Number(product.price).toFixed(2)}
          </span>
        </div>

        <!-- Star Rating -->
        <!-- Star Rating -->
        <div
          class="detail-rating-summary rating-scroll-trigger"
          style="cursor: pointer;"
        >
          <StarRating
            rating={averageRating}
            size={18}
            interactive={true}
            name="header-rating"
          />
          <span class="rating-count">
            ({reviewCount} review{reviewCount !== 1 ? "s" : ""})
          </span>
        </div>

        <!-- Stock Status -->
        <div class="detail-stock">
          <span
            class={`stock-indicator ${showDigitalLibraryCta ? "in-stock" : inStock ? "in-stock" : "out-of-stock"}`}
          >
            {
              showDigitalLibraryCta
                ? "Purchased"
                : inStock
                  ? "In Stock"
                  : "Sold Out"
            }
          </span>
        </div>

        <!-- Description -->
        <p class="detail-description">{product.description}</p>

        <!-- Specifications (Conditional by Product Type) -->
        {
          Object.keys(productDetails).length > 0 && (
            <div class="detail-specs">
              <h3 class="detail-section-title">Specifications</h3>
              <div class="specs-grid">
                {Object.entries(productDetails).map(([key, value]) => (
                  <div class="spec-row">
                    <span class="spec-key">{key}</span>
                    <span class="spec-value">{String(value)}</span>
                  </div>
                ))}
              </div>
            </div>
          )
        }

        <!-- Size Selector (Only for Physical Fashion) -->
        {
          productSizes.length > 0 && (
            <div class="detail-selector-section">
              <h3 class="detail-section-title">Select Size</h3>
              <div class="size-options" id="size-options">
                {productSizes.map((size) => (
                  <button class="size-btn" data-size={size}>
                    {size}
                  </button>
                ))}
              </div>
              <p
                id="size-error"
                class="error-text"
                style="display: none; color: #ef4444; font-size: 14px; margin-top: 8px;"
              >
                Please select a size
              </p>
            </div>
          )
        }

        <!-- Action Buttons: digital (already bought) → My Purchases; else stock -->
        {
          showDigitalLibraryCta ? (
            <div class="detail-actions-row">
              <a
                href="/account/purchases"
                class="btn-brand btn-equal"
                id="digital-purchases-link"
                style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;"
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                  <path d="M8 7h8" />
                  <path d="M8 11h8" />
                </svg>
                Go to My Purchases
              </a>
            </div>
          ) : inStock ? (
            <div class="detail-actions-row">
              <button
                class="btn-brand btn-equal"
                id="add-to-cart-btn"
                data-product-id={product.id}
                data-product-name={product.name}
                data-product-type={product.productType}
                data-price-eur={product.price}
                data-price-pln={effectivePln.toFixed(2)}
                data-product-image={
                  product.mainImage
                    ? urlFor(product.mainImage).width(400).url()
                    : product.image || ""
                }
                data-shipping-weight={product.shipping?.weight || ""}
                data-shipping-length={product.shipping?.length || ""}
                data-shipping-width={product.shipping?.width || ""}
                data-shipping-height={product.shipping?.height || ""}
                style="display: flex; align-items: center; justify-content: center; gap: 8px;"
              >
                <svg width="18" height="18" viewBox="0 0 22 22" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M10.9931 0C13.6631 0 15.8765 2.03316 16.1664 4.62858C16.1816 4.81653 16.1896 5.10071 16.1939 5.39511C16.1985 5.7138 16.4564 5.97161 16.7751 5.97161H17.936C19.2731 5.97161 20.386 6.97443 20.526 8.30511L21.9725 19.0918C22.0482 19.8231 21.81 20.557 21.317 21.1043C20.8235 21.6515 20.1188 21.9654 19.3824 21.9654H2.60384C1.8675 21.9653 1.16208 21.6521 0.669242 21.1055C0.175875 20.557 -0.0619183 19.8229 0.0138284 19.0918L1.46026 8.30511C1.60026 6.97398 2.71342 5.97186 4.05027 5.97161H5.21174C5.53047 5.97161 5.7883 5.71381 5.79277 5.39511C5.79689 5.10072 5.80466 4.81653 5.81989 4.62858C6.1098 2.03325 8.32334 0.00016274 10.9931 0ZM10.9931 1.73572C9.06591 1.73589 7.52171 3.27988 7.52171 5.20715V5.39304C7.52171 5.71258 7.78074 5.97161 8.10028 5.97161H13.886C14.2055 5.97161 14.4646 5.71258 14.4646 5.39304V5.20715C14.4646 3.27976 12.9205 1.73572 10.9931 1.73572Z" />
                </svg>
                Add to Cart
              </button>
              <button
                class="btn-brand-outline btn-equal"
                id="wishlist-btn"
                data-product-id={product.id}
              >
                <svg width="18" height="16" viewBox="0 0 22 19" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16.2411 0.0134513H16.245C18.0116 0.125081 19.6479 0.999001 20.7444 2.41344L20.7434 2.41442C22.6101 4.83522 22.3595 8.38062 20.0895 10.6616L12.7129 18.0285C12.2257 18.5155 11.6058 18.7487 10.9931 18.7449C10.3805 18.7487 9.76058 18.5155 9.27343 18.0285L1.8968 10.6616C-0.373292 8.38061 -0.623868 4.83523 1.24288 2.41442L1.2419 2.41344C2.33836 0.999009 3.97469 0.125067 5.74127 0.0134513H5.74518C7.40844 -0.0978413 9.06029 0.485407 10.3002 1.6219C10.6899 1.98734 11.2964 1.98734 11.6861 1.6219C12.926 0.485418 14.5779 -0.0978554 16.2411 0.0134513Z" />
                </svg>
                Wish List
              </button>
            </div>
          ) : (
            <div class="restock-notification-section">
              <h3 class="restock-title">Get Notified When Back in Stock</h3>
              <p class="restock-description">
                This item is currently out of stock. Enter your email below and
                we'll notify you when it becomes available again.
              </p>
              <form
                class="restock-form"
                id="restock-form"
                data-product-id={product.id}
                data-product-name={product.name}
                data-product-url={productUrl}
              >
                <div class="restock-input-group">
                  <input
                    type="email"
                    id="restock-email"
                    name="email"
                    placeholder="Enter your email address"
                    required
                    class="restock-email-input"
                  />
                  <button type="submit" class="btn-brand btn-restock">
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M22 2L11 13" />
                      <path d="M22 2L15 22L11 13L2 9L22 2Z" />
                    </svg>
                    Notify Me
                  </button>
                </div>
                <div
                  class="restock-message"
                  id="restock-message"
                  style="display: none;"
                />
              </form>
            </div>
          )
        }

        <!-- Digital Twin Card (Conditional) -->
        {
          hasTwin && showTwinLink && twinProduct && (
            <a
              href={`/store/${sectionId}/${twinProduct.slug}`}
              class="digital-twin-card interactive"
              style="text-decoration: none;"
            >
              <div class="twin-image">
                <img
                  src={
                    twinProduct.image ||
                    getPlaceholderImage(
                      twinProduct.productType === "digital"
                        ? "Digital Twin"
                        : "Physical Twin",
                      3,
                    )
                  }
                  alt="Twin Asset"
                />
              </div>
              <div class="twin-info">
                <span class="twin-tag">
                  View{" "}
                  {twinProduct.productType === "digital"
                    ? "Digital Twin"
                    : "Physical Twin"}
                </span>
                <h4>{twinProduct.name}</h4>
              </div>
              <div class="twin-arrow">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M5 12h14" />
                  <path d="M12 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          )
        }

        <!-- Conditional: Shipping & Returns OR License & Usage -->
        {
          product.productType === "digital" ? (
            <details class="detail-accordion-section">
              <summary class="accordion-header">
                <span>License & Usage</span>
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="accordion-chevron"
                >
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </summary>
              <div class="accordion-content">
                <p>
                  <strong>File Formats:</strong> This digital product includes
                  industry-standard formats (.blend, .fbx, .obj, .gltf)
                  compatible with Blender, Maya, Cinema 4D, and Unreal Engine.
                </p>
                <p style="margin-top: 8px;">
                  <strong>License:</strong> Personal and commercial use allowed.
                  You may not redistribute, resell, or share the source files.
                  Final renders and integrated works are unrestricted.
                </p>
                <p style="margin-top: 8px;">
                  <strong>Download:</strong> Instant access upon purchase. Files
                  are available in your account dashboard with lifetime download
                  access.
                </p>
              </div>
            </details>
          ) : (
            <details class="detail-accordion-section">
              <summary class="accordion-header">
                <span>Shipping & Returns</span>
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="accordion-chevron"
                >
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </summary>
              <div class="accordion-content">
                <p>
                  <strong>Shipping:</strong> Free standard shipping on all
                  orders over $200. Standard delivery takes 3-5 business days.
                  Express shipping options available at checkout.
                </p>
                <p style="margin-top: 8px;">
                  <strong>Returns:</strong> We accept returns within 14 days of
                  delivery. Items must be unworn, unwashed, and in original
                  packaging with tags attached.
                </p>
              </div>
            </details>
          )
        }
      </div>

      <!-- Customer Reviews Section -->
      <ReviewSection productId={product.id} />
    </div>
  </div>
</div>

<ShippingForm
  product={{
    name: product.name,
    price: product.price, // Uses defaults, but Form component handles display logic if passed props
    image: urlFor(product.mainImage).width(200).url(),
    shipping: product.shipping, // Pass shipping specs
  }}
  currency={serverCurrency || "EUR"}
/>

<!-- Stripe Checkout is handled on the server (redirect) -->

<style>
  /* ===============================
       PRODUCT DETAIL VIEW
       =============================== */

  /* Main Container: The ONLY scrollable element */
  .product-detail-panel {
    flex: 1;
    height: 100%;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    position: relative;

    /* Vertical Scroll for the whole page/panel */
    overflow-y: auto;
    overflow-x: hidden;

    display: flex;
    flex-direction: column;
    animation: fadeIn 0.3s ease-out;

    /* Allow clicks to pass through to fixed elements like AccountSidebar */
    pointer-events: auto;
  }

  /* Re-enable pointer events for interactive elements */
  .product-detail-panel a,
  .product-detail-panel button,
  .product-detail-panel input,
  .product-detail-panel textarea,
  .product-detail-panel [role="button"],
  .product-detail-panel details,
  .product-detail-panel summary {
    pointer-events: auto;
  }

  /* Scrollbar Styling - Thin & Subtle */

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .animate-spin {
    animation: spin 1s linear infinite;
  }

  /* Close Button at Top Right (FIXED: Sticky) */
  .detail-close-btn {
    position: sticky;
    top: 16px;

    align-self: flex-end;
    margin-right: 16px;
    margin-bottom: -36px;

    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
    border-radius: 50%;
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    color: var(--foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 50;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .detail-close-btn:hover {
    background: var(--brand-violet);
    color: white;
    border-color: var(--brand-violet);
    transform: rotate(90deg);
  }

  /* Inner Layout */
  .detail-layout {
    display: flex;
    width: 100%;
    min-height: min-content;
    position: relative;
    align-items: flex-start;
  }

  /* Left: Gallery Column */
  .detail-gallery-column {
    flex: 6;
    width: 60%;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-right: 1px solid var(--border-subtle);
    overflow: visible;
  }

  .detail-large-image {
    width: 100%;
    height: auto;
    background: var(--surface-muted);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    flex-shrink: 0;
    cursor: zoom-in;
    transition:
      transform 0.2s,
      opacity 0.4s ease-out;
  }

  .detail-large-image--image:not(.is-loaded) {
    opacity: 0;
    pointer-events: none;
  }

  .detail-large-image--image.is-loaded {
    opacity: 1;
    pointer-events: auto;
  }

  .detail-large-image:hover {
    transform: scale(1.01);
  }

  .detail-large-image img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  @media (prefers-reduced-motion: reduce) {
    .detail-large-image--image:not(.is-loaded) {
      opacity: 1;
      pointer-events: auto;
      transition: transform 0.2s;
    }
  }

  /* Right: Info Column (Sticky) */
  .detail-info-column {
    flex: 4;
    width: 40%;

    position: sticky;
    top: 0;

    height: auto;
    align-self: flex-start;
    overflow: visible;

    background: var(--surface);
    display: flex;
    flex-direction: column;
  }

  .detail-info-content {
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    height: auto;
    overflow: visible;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Info Typography */
