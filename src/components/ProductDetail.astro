---
import type { Product } from "../lib/store-data";
import type { Currency } from "../lib/server-currency";
import { urlFor } from "../lib/sanity";
import StarRating from "./StarRating.astro";
import ShippingForm from "./checkout/ShippingForm.astro";
import ReviewSection from "./ReviewSection.astro";
import { drizzle } from "drizzle-orm/d1";
import { review } from "../lib/auth-schema";
import { eq } from "drizzle-orm";

interface Props {
    product: Product;
    backLink?: string;
    serverCurrency?: Currency;
}

const {
    product,
    backLink = "/store/fashion-design",
    serverCurrency,
} = Astro.props;
// Extract section ID from product category path or backLink logic
const sectionId = product.categoryPath[0] || "fashion-design";

// Construct product URL for notifications
const productUrl = `${Astro.url.origin}/store/${sectionId}/${product.slug || product.id}`;

// Select appropriate price to display
const displayPrice =
    serverCurrency === "PLN" && product.pricePLN
        ? `${product.pricePLN}zł`
        : `€${product.price}`;

// Helper to generate placeholder image
const getPlaceholderImage = (text: string, seed: number = 0) => {
    const encodedText = encodeURIComponent(text);
    const bg = seed === 0 ? "1A1635" : seed === 1 ? "221D3A" : "151128";
    return `https://placehold.co/1000x1200/${bg}/CBFF62?text=${encodedText}+${seed + 1}&font=roboto`;
};

// Use gallery images from Sanity or fallback to main image
// Optimization: Prefer raw 'gallery' objects to request specific 1200px width
const galleryImages =
    product.gallery && product.gallery.length > 0
        ? product.gallery.map((img: any) => urlFor(img).width(1200).url())
        : product.images && product.images.length > 0
          ? product.images
          : product.image
            ? [product.image]
            : [getPlaceholderImage(product.name)];

// Product Details (Specifications)
const productDetails = product.details || {};

// Sizes
const productSizes = product.sizes || [];
const inStock = product.inStock;

// Digital Twin Visibility
const hasTwin = !!product.twinProduct;
const showTwinLink = product.showDigitalTwinLink !== false; // Default true if undefined
const twinProduct = product.twinProduct;

// Fetch ratings (Server Side)
let averageRating = 0;
let reviewCount = 0;

try {
    // @ts-ignore
    const { env: cfEnv } = await import("cloudflare:workers").catch(() => ({
        env: {},
    }));
    let dbBinding = cfEnv?.visupair_store;

    try {
        if (
            !dbBinding &&
            Astro.locals.runtime &&
            typeof Astro.locals.runtime === "object"
        ) {
            const descriptor = Object.getOwnPropertyDescriptor(
                Astro.locals.runtime,
                "env",
            );
            if (descriptor && typeof descriptor.get !== "function") {
                dbBinding = (Astro.locals.runtime as any).env?.visupair_store;
            }
        }
    } catch (e) {}
    if (dbBinding) {
        const db = drizzle(dbBinding);
        const productReviews = await db
            .select({ rating: review.rating })
            .from(review)
            .where(eq(review.productId, product.id));

        if (productReviews.length > 0) {
            const total = productReviews.reduce((acc, r) => acc + r.rating, 0);
            averageRating = total / productReviews.length;
            reviewCount = productReviews.length;
        }
    }
} catch (error) {
    console.warn("Failed to fetch reviews:", error);
}
---

<div class="product-detail-panel" id="product-detail-panel">
    <!-- Close Button (Top Right, Sticky) -->
    <a
        href={backLink}
        class="detail-close-btn"
        id="close-detail-btn"
        aria-label="Close"
    >
        <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
    </a>

    <div class="detail-layout">
        <!-- Left Column: Vertical Gallery (Desktop) / Horizontal Slider (Mobile) -->
        <div class="detail-gallery-column" id="detail-gallery">
            {
                galleryImages.map((img, idx) => (
                    <div class="detail-large-image" data-image-index={idx}>
                        <img
                            src={img}
                            alt={`${product.name} view ${idx + 1}`}
                            loading="lazy"
                        />
                    </div>
                ))
            }
            {
                /* Clo 3D Viewer Embed - Only if URL is present (Digital Fashion) */
            }
            {
                product.clo3dEmbedUrl && (
                    <div
                        class="detail-3d-wrapper"
                        id="clo3d-wrapper"
                        data-embed-url={product.clo3dEmbedUrl}
                    >
                        <div class="clo3d-placeholder">
                            <button class="btn-load-3d" id="btn-load-3d">
                                <svg
                                    width="24"
                                    height="24"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z" />
                                    <path d="M12 12l8-4.5" />
                                    <path d="M12 12v9" />
                                    <path d="M12 12L4 7.5" />
                                </svg>
                                <span>Load 3D Viewer</span>
                            </button>
                        </div>
                    </div>
                )
            }
        </div>

        <!-- Mobile Pagination Dots -->
        <div class="mobile-pagination" id="mobile-pagination">
            {
                galleryImages.map((_, idx) => (
                    <div class="pagination-dot" data-dot-index={idx} />
                ))
            }
        </div>

        <!-- Right Column: Product Info (Sticky on Desktop) -->
        <div class="detail-info-column">
            <div class="detail-info-content">
                <!-- Header: Title & Price -->
                <div class="detail-header">
                    <h1 class="detail-title">{product.name}</h1>
                    <span
                        class="detail-price product-price-dynamic"
                        data-price-eur={product.price.toFixed(2)}
                        data-price-pln={(
                            product.pricePLN || Math.round(product.price * 4.3)
                        ).toFixed(2)}
                        data-server-currency={serverCurrency || ""}
                    >
                        €{product.price.toFixed(2)}
                    </span>
                </div>

                <!-- Star Rating -->
                <!-- Star Rating -->
                <div
                    class="detail-rating-summary rating-scroll-trigger"
                    style="cursor: pointer;"
                >
                    <StarRating
                        rating={averageRating}
                        size={18}
                        interactive={true}
                        name="header-rating"
                    />
                    <span class="rating-count">
                        ({reviewCount} review{reviewCount !== 1 ? "s" : ""})
                    </span>
                </div>

                <!-- Stock Status -->
                {
                    inStock !== undefined && (
                        <div class="detail-stock">
                            <span
                                class={`stock-indicator ${inStock ? "in-stock" : "out-of-stock"}`}
                            >
                                {inStock ? "In Stock" : "Out of Stock"}
                            </span>
                        </div>
                    )
                }

                <!-- Description -->
                <p class="detail-description">{product.description}</p>

                <!-- Specifications (Conditional by Product Type) -->
                {
                    Object.keys(productDetails).length > 0 && (
                        <div class="detail-specs">
                            <h3 class="detail-section-title">Specifications</h3>
                            <div class="specs-grid">
                                {Object.entries(productDetails).map(
                                    ([key, value]) => (
                                        <div class="spec-row">
                                            <span class="spec-key">{key}</span>
                                            <span class="spec-value">
                                                {String(value)}
                                            </span>
                                        </div>
                                    ),
                                )}
                            </div>
                        </div>
                    )
                }

                <!-- Size Selector (Only for Physical Fashion) -->
                {
                    productSizes.length > 0 && (
                        <div class="detail-selector-section">
                            <h3 class="detail-section-title">Select Size</h3>
                            <div class="size-options" id="size-options">
                                {productSizes.map((size) => (
                                    <button class="size-btn" data-size={size}>
                                        {size}
                                    </button>
                                ))}
                            </div>
                            <p
                                id="size-error"
                                class="error-text"
                                style="display: none; color: #ef4444; font-size: 14px; margin-top: 8px;"
                            >
                                Please select a size
                            </p>
                        </div>
                    )
                }

                <!-- Action Buttons: Conditional based on stock status -->
                {
                    inStock ? (
                        <div class="detail-actions-row">
                            <button
                                class="btn-brand btn-equal"
                                id="buy-btn"
                                data-product-id={product.id}
                                data-stripe-price-id={product.stripePriceId}
                                data-product-type={product.productType}
                                data-price-eur={product.price}
                                data-price-pln={
                                    product.pricePLN ||
                                    (product.price * 4.3).toFixed(2)
                                }
                                style="display: flex; align-items: center; justify-content: center;"
                            >
                                Buy Now
                            </button>
                            <button
                                class="btn-brand-outline btn-equal"
                                id="wishlist-btn"
                                data-product-id={product.id}
                            >
                                <svg
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                </svg>
                                Wish List
                            </button>
                        </div>
                    ) : (
                        <div class="restock-notification-section">
                            <h3 class="restock-title">
                                Get Notified When Back in Stock
                            </h3>
                            <p class="restock-description">
                                This item is currently out of stock. Enter your
                                email below and we'll notify you when it becomes
                                available again.
                            </p>
                            <form
                                class="restock-form"
                                id="restock-form"
                                data-product-id={product.id}
                                data-product-name={product.name}
                                data-product-url={productUrl}
                            >
                                <div class="restock-input-group">
                                    <input
                                        type="email"
                                        id="restock-email"
                                        name="email"
                                        placeholder="Enter your email address"
                                        required
                                        class="restock-email-input"
                                    />
                                    <button
                                        type="submit"
                                        class="btn-brand btn-restock"
                                    >
                                        <svg
                                            width="18"
                                            height="18"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path d="M22 2L11 13" />
                                            <path d="M22 2L15 22L11 13L2 9L22 2Z" />
                                        </svg>
                                        Notify Me
                                    </button>
                                </div>
                                <div
                                    class="restock-message"
                                    id="restock-message"
                                    style="display: none;"
                                />
                            </form>
                        </div>
                    )
                }

                <!-- Digital Twin Card (Conditional) -->
                {
                    hasTwin && showTwinLink && twinProduct && (
                        <a
                            href={`/store/${sectionId}/${twinProduct.slug}`}
                            class="digital-twin-card interactive"
                            style="text-decoration: none;"
                        >
                            <div class="twin-image">
                                <img
                                    src={
                                        twinProduct.image ||
                                        getPlaceholderImage(
                                            twinProduct.productType ===
                                                "digital"
                                                ? "Digital Twin"
                                                : "Physical Twin",
                                            3,
                                        )
                                    }
                                    alt="Twin Asset"
                                />
                            </div>
                            <div class="twin-info">
                                <span class="twin-tag">
                                    View{" "}
                                    {twinProduct.productType === "digital"
                                        ? "Digital Twin"
                                        : "Physical Twin"}
                                </span>
                                <h4>{twinProduct.name}</h4>
                            </div>
                            <div class="twin-arrow">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M5 12h14" />
                                    <path d="M12 5l7 7-7 7" />
                                </svg>
                            </div>
                        </a>
                    )
                }

                <!-- Conditional: Shipping & Returns OR License & Usage -->
                {
                    product.productType === "digital" ? (
                        <details class="detail-accordion-section">
                            <summary class="accordion-header">
                                <span>License & Usage</span>
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    class="accordion-chevron"
                                >
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </summary>
                            <div class="accordion-content">
                                <p>
                                    <strong>File Formats:</strong> This digital
                                    product includes industry-standard formats
                                    (.blend, .fbx, .obj, .gltf) compatible with
                                    Blender, Maya, Cinema 4D, and Unreal Engine.
                                </p>
                                <p style="margin-top: 8px;">
                                    <strong>License:</strong> Personal and
                                    commercial use allowed. You may not
                                    redistribute, resell, or share the source
                                    files. Final renders and integrated works
                                    are unrestricted.
                                </p>
                                <p style="margin-top: 8px;">
                                    <strong>Download:</strong> Instant access
                                    upon purchase. Files are available in your
                                    account dashboard with lifetime download
                                    access.
                                </p>
                            </div>
                        </details>
                    ) : (
                        <details class="detail-accordion-section">
                            <summary class="accordion-header">
                                <span>Shipping & Returns</span>
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    class="accordion-chevron"
                                >
                                    <path d="M6 9l6 6 6-6" />
                                </svg>
                            </summary>
                            <div class="accordion-content">
                                <p>
                                    <strong>Shipping:</strong> Free standard
                                    shipping on all orders over $200. Standard
                                    delivery takes 3-5 business days. Express
                                    shipping options available at checkout.
                                </p>
                                <p style="margin-top: 8px;">
                                    <strong>Returns:</strong> We accept returns
                                    within 14 days of delivery. Items must be
                                    unworn, unwashed, and in original packaging
                                    with tags attached.
                                </p>
                            </div>
                        </details>
                    )
                }
            </div>

            <!-- Customer Reviews Section -->
            <ReviewSection productId={product.id} />
        </div>
    </div>
</div>

<ShippingForm
    product={{
        name: product.name,
        price: product.price, // Uses defaults, but Form component handles display logic if passed props
        image: urlFor(product.mainImage).width(200).url(),
        shipping: product.shipping, // Pass shipping specs
    }}
    currency={serverCurrency || "EUR"}
/>

<!-- Stripe Checkout is handled on the server (redirect) -->

<style>
    /* ===============================
       PRODUCT DETAIL VIEW
       =============================== */

    /* Main Container: The ONLY scrollable element */
    .product-detail-panel {
        flex: 1;
        height: 100%;
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        position: relative;

        /* Vertical Scroll for the whole page/panel */
        overflow-y: auto;
        overflow-x: hidden;

        display: flex;
        flex-direction: column;
        animation: fadeIn 0.3s ease-out;

        /* Allow clicks to pass through to fixed elements like AccountSidebar */
        pointer-events: auto;
    }

    /* Re-enable pointer events for interactive elements */
    .product-detail-panel a,
    .product-detail-panel button,
    .product-detail-panel input,
    .product-detail-panel textarea,
    .product-detail-panel [role="button"],
    .product-detail-panel details,
    .product-detail-panel summary {
        pointer-events: auto;
    }

    /* Scrollbar Styling - Thin & Subtle */

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    .animate-spin {
        animation: spin 1s linear infinite;
    }

    /* Close Button at Top Right (FIXED: Sticky) */
    .detail-close-btn {
        position: sticky;
        top: 16px;

        align-self: flex-end;
        margin-right: 16px;
        margin-bottom: -36px;

        width: 36px;
        height: 36px;
        min-width: 36px;
        min-height: 36px;
        border-radius: 50%;
        background: var(--surface-hover);
        border: 1px solid var(--border-subtle);
        color: var(--foreground);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 50;
        transition: all 0.2s;
        flex-shrink: 0;
    }

    .detail-close-btn:hover {
        background: var(--brand-violet);
        color: white;
        border-color: var(--brand-violet);
        transform: rotate(90deg);
    }

    /* Inner Layout */
    .detail-layout {
        display: flex;
        width: 100%;
        min-height: min-content;
        position: relative;
        align-items: flex-start;
    }

    /* Left: Gallery Column */
    .detail-gallery-column {
        flex: 6;
        width: 60%;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        border-right: 1px solid var(--border-subtle);
        overflow: visible;
    }

    .detail-large-image {
        width: 100%;
        height: auto;
        background: var(--surface-muted);
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--border-subtle);
        flex-shrink: 0;
        cursor: zoom-in;
        transition: transform 0.2s;
    }

    .detail-large-image:hover {
        transform: scale(1.01);
    }

    .detail-large-image img {
        display: block;
        width: 100%;
        height: auto;
        object-fit: cover;
    }

    /* Right: Info Column (Sticky) */
    .detail-info-column {
        flex: 4;
        width: 40%;

        position: sticky;
        top: 0;

        height: auto;
        align-self: flex-start;
        overflow: visible;

        background: var(--surface);
        display: flex;
        flex-direction: column;
    }

    .detail-info-content {
        padding: 32px 24px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        height: auto;
        overflow: visible;
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }

    /* Info Typography */
    .detail-header {
        border-bottom: 1px solid var(--border-subtle);
        padding-bottom: 20px;
        padding-right: 40px;
    }

    .detail-title {
        font-size: 32px;
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 8px;
        color: var(--foreground);
    }

    .detail-price {
        font-size: 24px;
        font-weight: 600;
        color: var(--brand-violet);
    }

    /* Stock */
    .detail-rating-summary {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px; /* Space before stock */
    }

    .rating-count {
        font-size: 13px;
        color: var(--foreground);
        opacity: 0.7;
        text-decoration: none;
    }

    .rating-count:hover {
        text-decoration: underline;
        color: var(--brand-violet);
    }

    .detail-stock {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .stock-indicator {
        font-size: 13px;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: var(--radius-pill);
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .stock-indicator::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
    }

    .stock-indicator.in-stock {
        background: color-mix(in srgb, var(--brand-lime), transparent 80%);
        color: var(--brand-lime);
    }

    /* Keep it subtle in Dark Mode */
    :global([data-theme="dark"]) .stock-indicator.in-stock {
        background: color-mix(in srgb, var(--brand-lime), transparent 90%);
    }

    .stock-indicator.out-of-stock {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
    }

    .detail-description {
        font-size: 15px;
        line-height: 1.6;
        opacity: 0.8;
        color: var(--foreground);
    }

    /* Specs & Sizes */
    .detail-section-title {
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        opacity: 0.5;
        margin-bottom: 12px;
        color: var(--foreground);
    }

    .specs-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: var(--surface-muted);
        padding: 16px;
        border-radius: var(--radius-lg);
    }

    .spec-row {
        display: flex;
        justify-content: space-between;
        font-size: 14px;
        border-bottom: 1px dashed var(--border-subtle);
        padding-bottom: 8px;
        color: var(--foreground);
    }

    .spec-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .spec-key {
        opacity: 0.6;
    }

    .spec-value {
        font-weight: 600;
    }

    .size-options {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .size-btn {
        min-width: 48px;
        height: 40px;
        padding: 0 12px;
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-sm);
        color: var(--foreground);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        font-family: var(--font-family);
    }

    .size-btn:hover {
        border-color: var(--brand-violet);
    }

    .size-btn.active {
        background: var(--foreground);
        color: var(--page-bg);
        border-color: var(--foreground);
    }

    /* Error State for Size Selector */
    .size-options.error {
        animation: shake 0.4s ease-in-out;
    }

    .size-options.error .size-btn {
        border-color: #ef4444;
        background-color: rgba(239, 68, 68, 0.05);
        color: #ef4444;
    }

    @keyframes shake {
        0%,
        100% {
            transform: translateX(0);
        }
        25% {
            transform: translateX(-4px);
        }
        75% {
            transform: translateX(4px);
        }
    }

    /* Actions: Equal Sized Buttons */
    .detail-actions-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 8px;
    }

    .btn-equal {
        flex: 1;

        height: 52px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin: 0;
        padding: 0 24px;
    }

    .btn-brand {
        width: 100%;
        padding: 14px;
        background: var(--brand-violet);
        color: #ffffff;
        border: none;
        border-radius: var(--radius-md);
        font-family: var(--font-family);
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition:
            transform 0.2s,
            background-color 0.2s,
            box-shadow 0.2s;
        box-shadow: 0 4px 12px rgba(132, 128, 255, 0.3); /* Added initial shadow to match others */
