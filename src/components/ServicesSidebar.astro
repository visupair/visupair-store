---
import { getServices } from "../lib/sanity";

interface Props {
    selectedServiceId: string | null;
}

const { selectedServiceId } = Astro.props;

interface Service {
    id: string; // or slug depending on getServices
    title: string;
    // add other properties if needed
}

// Fetch services from Sanity
let services: Service[] = [];
try {
    services = await getServices();
} catch (error) {
    console.error("Sidebar: Failed to fetch services", error);
}
---

<aside class="services-sidebar">
    <div class="sidebar-header">
        <h3 class="sidebar-title">Services</h3>
    </div>

    <div class="category-tree">
        {
            services && services.length > 0 ? (
                services.map((service) => (
                    <a
                        href={`/services/${service.id}`}
                        class={`category-item ${selectedServiceId === service.id ? "active" : ""}`}
                    >
                        {service.title}
                    </a>
                ))
            ) : (
                <div class="empty-state">
                    <p>No services available</p>
                </div>
            )
        }
    </div>
</aside>

<style>
    .services-sidebar {
        width: 280px;
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        padding: 24px;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        height: 100%;
    }

    .sidebar-header {
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border-subtle);
    }

    .sidebar-title {
        font-size: 18px;
        font-weight: 700;
        margin: 0;
        color: var(--foreground);
    }

    .category-tree {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .category-item {
        padding: 12px 16px;
        border-radius: var(--radius-md);
        font-size: 15px;
        font-weight: 500;
        color: var(--foreground);
        text-decoration: none;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .category-item:hover {
        background: var(--surface-hover);
        border-color: var(--border-subtle);
    }

    .category-item.active {
        background: var(--brand-violet);
        color: white;
        font-weight: 600;
    }

    .empty-state {
        padding: 24px 16px;
        text-align: center;
        color: var(--foreground);
        opacity: 0.6;
        font-size: 14px;
    }

    @media (max-width: 768px) {
        .services-sidebar {
            width: 100%;
            position: static;
            padding: 16px;
        }

        .sidebar-header {
            padding-bottom: 12px;
        }

        .sidebar-title {
            font-size: 16px;
        }

        .category-tree {
            gap: 6px;
        }

        .category-item {
            padding: 10px 14px;
            font-size: 14px;
        }

        .empty-state {
            padding: 16px 12px;
            font-size: 13px;
        }
    }
</style>
