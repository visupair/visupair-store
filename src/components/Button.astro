---
/**
 * Button.astro — Visupair reusable button component
 * Props: href, variant ("primary"|"secondary"), label, icon (bool), type, class
 */

interface Props {
    href?: string;
    variant?: "primary" | "secondary";
    label: string;
    icon?: boolean;
    type?: "button" | "submit" | "reset";
    class?: string;
    [key: string]: any;
}

const {
    href,
    variant = "primary",
    label,
    icon,
    type = "button",
    class: extraClass = "",
    ...rest
} = Astro.props;
const showIcon = icon !== undefined ? icon : variant === "primary";
const Tag = href ? "a" : "button";
const tagProps = href ? { href, ...rest } : { type, ...rest };
---

<Tag class:list={["vp-btn", `vp-btn--${variant}`, extraClass]} {...tagProps}>
    <span class="vp-btn__label">{label}</span>
    {
        showIcon && (
            <span class="vp-btn__icon" aria-hidden="true">
                <svg
                    height="20"
                    width="20"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path d="M0 0h24v24H0z" fill="none" />
                    <path
                        d="M16.172 11l-5.364-5.364 1.414-1.414L20 12l-7.778 7.778-1.414-1.414L16.172 13H4v-2z"
                        fill="currentColor"
                    />
                </svg>
            </span>
        )
    }
</Tag>

<style>
    /* ── Base ── */
    .vp-btn {
        display: inline-flex;
        align-items: center;
        position: relative; /* containing block for the absolute icon pill */
        overflow: hidden;
        height: 2.8em;
        padding: 0.35em 3.3em 0.35em 1.2em;
        font-family: var(--font-family);
        font-size: clamp(14px, 1.5vw, 17px);
        font-weight: 500;
        letter-spacing: 0.05em;
        text-decoration: none;
        white-space: nowrap;
        border-radius: var(--radius-md);
        border: none;
        cursor: pointer;
    }

    .vp-btn:not(:has(.vp-btn__icon)) {
        padding-right: 1.2em;
    }

    .vp-btn__label {
        position: relative;
        z-index: 1;
    }

    /* ── Icon pill ──
       Always spans the full button width (inset 0.3em each side).
       clip-path reveals only the right 2.2em by default, then opens fully on hover.
       clip-path is compositor-only → zero layout reflow, pure GPU.
    ── */
    .vp-btn__icon {
        position: absolute;
        inset: 0.3em; /* pill fills button minus 0.3em gap on each side */
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        /* 0.55em = (2.2em - 1.1em) / 2 — centers arrow in the visible 2.2em clip area */
        padding-right: 0.55em;
        border-radius: 4px; /* --radius-md(6px) - 2px */
        background: #ffffff;
        clip-path: inset(0 0 0 calc(100% - 2.2em) round 4px);
        /* Both transitions run in sync so arrow glides to center as clip opens */
        transition:
            clip-path 0.2s cubic-bezier(0.4, 0, 0, 1),
            padding-right 0.2s cubic-bezier(0.4, 0, 0, 1);
    }

    .vp-btn__icon svg {
        width: 1.1em;
        height: 1.1em;
        flex-shrink: 0;
        color: var(--brand-violet);
        transition: transform 0.2s ease;
    }

    /* Hover: clip opens fully + padding-right shifts arrow to pill center
       calc(50% - 0.85em): 50% = half of btn width (padding % base), 0.85em = correction
       Result: arrow center lands exactly at pill midpoint for any button width */
    .vp-btn:hover .vp-btn__icon {
        clip-path: inset(0 round 4px);
        padding-right: calc(50% - 0.85em);
    }
    .vp-btn:hover .vp-btn__icon svg {
        transform: translateX(0.1em);
    }
    .vp-btn:active .vp-btn__icon {
        transform: scale(0.95);
    }

    /* ── PRIMARY ── */
    .vp-btn--primary {
        background: var(--brand-violet);
        color: #ffffff;
        box-shadow: inset 0 0 1.6em -0.6em rgba(60, 56, 180, 0.7);
    }

    .vp-btn--primary .vp-btn__icon {
        box-shadow: 0.1em 0.1em 0.6em 0.2em rgba(60, 56, 180, 0.35);
    }

    :global([data-theme="dark"]) .vp-btn--primary {
        box-shadow: inset 0 0 1.6em -0.6em rgba(100, 96, 255, 0.55);
    }

    :global([data-theme="dark"]) .vp-btn--primary .vp-btn__icon {
        box-shadow: 0.1em 0.1em 0.6em 0.2em rgba(80, 76, 220, 0.45);
    }

    /* ── SECONDARY ── */
    .vp-btn--secondary {
        background: transparent;
        color: var(--foreground);
        border: 1.5px solid var(--brand-violet);
        padding-right: 1.2em;
        transition:
            background 0.2s ease,
            color 0.2s ease;
    }

    .vp-btn--secondary:has(.vp-btn__icon) {
        padding-right: 3.3em;
    }
    .vp-btn--secondary .vp-btn__icon {
        background: var(--surface);
    }
    .vp-btn--secondary .vp-btn__icon svg {
        color: var(--brand-violet);
    }
    .vp-btn--secondary:hover {
        background: rgba(132, 128, 255, 0.2);
    }

    :global([data-theme="dark"]) .vp-btn--secondary {
        color: rgba(255, 255, 255, 0.9);
    }
    :global([data-theme="dark"]) .vp-btn--secondary .vp-btn__icon {
        background: rgba(132, 128, 255, 0.15);
    }
    :global([data-theme="dark"]) .vp-btn--secondary:hover {
        background: rgba(132, 128, 255, 0.25);
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
        .vp-btn__icon,
        .vp-btn__icon svg {
            transition: none !important;
        }
        /* Keep pill collapsed — don't animate for users who prefer no motion */
        .vp-btn:hover .vp-btn__icon {
            clip-path: inset(0 0 0 calc(100% - 2.2em) round 4px) !important;
            padding-right: 0.55em !important;
        }
        .vp-btn:hover .vp-btn__icon svg {
            transform: none !important;
        }
    }
</style>
