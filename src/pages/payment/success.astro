---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Payment Successful – Visupair">
  <div class="payment-layout">
    <div class="payment-card">

      <!-- Animated checkmark icon -->
      <div class="state-icon state-icon--success">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
             class="check-svg">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <!-- Text -->
      <h1>Payment Successful!</h1>
      <p class="subtitle">
        Thank you for your purchase. You'll receive a confirmation email shortly.
      </p>

      <!-- Actions -->
      <div class="actions">
        <a href="/account/purchases" class="btn-primary">
          View My Orders
        </a>
        <a href="/store" class="btn-secondary">Continue Shopping</a>
      </div>

      <!-- Support hint -->
      <p class="hint">
        Questions?
        <a href="/contact" class="hint-link">Contact support</a>
        and we'll help you out.
      </p>

    </div>
  </div>
</Layout>

<style>
  .payment-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 120px);
    padding: 48px 24px;
  }

  .payment-card {
    width: 100%;
    max-width: 460px;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-island);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    animation: cardIn 0.5s cubic-bezier(.4,0,.2,1);
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(16px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }

  /* State Icon */
  .state-icon {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;
    flex-shrink: 0;
  }

  .state-icon--success {
    background: rgba(34, 197, 94, 0.08);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.18);
  }

  .check-svg {
    animation: checkDraw 0.55s ease-out 0.2s both;
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
  }

  @keyframes checkDraw {
    to { stroke-dashoffset: 0; }
  }

  /* Typography */
  h1 {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--foreground);
    margin: 0 0 12px;
  }

  .subtitle {
    font-size: 15px;
    line-height: 1.6;
    color: var(--foreground);
    opacity: 0.6;
    margin: 0 0 36px;
    max-width: 340px;
  }

  /* Buttons */
  .actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    margin-bottom: 28px;
  }

  .btn-primary,
  .btn-secondary {
    width: 100%;
    padding: 13px 20px;
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: opacity 0.15s, transform 0.15s;
  }

  .btn-primary {
    background: var(--foreground);
    color: var(--page-bg);
    border: none;
  }

  .btn-primary:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--surface-muted);
    color: var(--foreground);
    border: 1px solid var(--border-subtle);
  }

  .btn-secondary:hover {
    background: var(--surface-hover);
    transform: translateY(-1px);
  }

  /* Hint */
  .hint {
    font-size: 13px;
    color: var(--foreground);
    opacity: 0.5;
    margin: 0;
  }

  .hint-link {
    color: var(--brand-violet);
    text-decoration: none;
    font-weight: 500;
    opacity: 1;
  }

  .hint-link:hover {
    text-decoration: underline;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .payment-card {
      padding: 36px 24px;
    }

    h1 {
      font-size: 22px;
    }
  }
</style>
