---
import Layout from "../../layouts/Layout.astro";
import PortfolioDetail from "../../components/PortfolioDetail.astro";
import PortfolioSidebar from "../../components/PortfolioSidebar.astro";
import {
    getPortfolioCategories,
    getPortfolioProject,
} from "../../lib/portfolio";
import {
    metaDescriptionFromPortfolioBody,
    portfolioProjectCanonicalPath,
} from "../../lib/portfolio-seo";

export const prerender = false;

const { slug } = Astro.params;

// Find the portfolio item matching the slug
const item = await getPortfolioProject(slug);

if (!item) {
    return Astro.redirect("/portfolio");
}

const sectionId = "portfolio";
const categories = await getPortfolioCategories();

// Get the category ID from the item (using slug as ID now)
const categoryId = item.categorySlug;

const detailMetaFallback = `${item.title} — Visupair portfolio project.`;
const detailDescription = metaDescriptionFromPortfolioBody(
    item.description,
    detailMetaFallback,
);
const detailCanonical = portfolioProjectCanonicalPath(item);
const detailOgImage =
    typeof item.mainImage === "string" && item.mainImage.trim()
        ? item.mainImage.trim()
        : undefined;
---

<Layout
    title={`${item.title} | Portfolio | Visupair`}
    description={detailDescription}
    canonicalURL={detailCanonical}
    ogImage={detailOgImage}
>
    <div class="portfolio-layout">
        <div transition:persist="portfolio-sidebar">
            <PortfolioSidebar
                categories={categories}
                selectedCategoryId={categoryId}
                sectionId={sectionId}
            />
        </div>

        <PortfolioDetail item={item} backLink="/portfolio" />
    </div>
</Layout>

<style>
    .portfolio-layout {
        display: flex;
        gap: 12px;
        width: 100%;
        padding: 0 12px;
        height: calc(100vh - 120px);
    }

    @media (max-width: 768px) {
        .portfolio-layout {
            flex-direction: column;
            height: auto;
            padding: 0 12px;
            gap: 12px;
        }
    }
</style>
