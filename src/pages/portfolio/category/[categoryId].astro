---
import Layout from "../../../layouts/Layout.astro";
import PortfolioSidebar from "../../../components/PortfolioSidebar.astro";
import PortfolioGrid from "../../../components/PortfolioGrid.astro";
import {
    getPortfolioCategories,
    getPortfolioProjects,
} from "../../../lib/portfolio";
import { pickPortfolioListOgImage } from "../../../lib/portfolio-seo";
import { stripHtml, truncateMetaDescription } from "../../../lib/seo-utils";

export const prerender = false;

const { categoryId } = Astro.params;

if (!categoryId) {
    return Astro.redirect("/portfolio");
}

const sectionId = "portfolio";
const categories = await getPortfolioCategories();
const allItems = await getPortfolioProjects();

const filteredItems = allItems.filter(
    (item: { categorySlug?: string }) => item.categorySlug === categoryId,
);

const categoryMeta = categories.find((c) => c.slug === categoryId);
const categoryListTitle = categoryMeta
    ? `${categoryMeta.title} | Portfolio | Visupair`
    : `Portfolio | Visupair`;
const categoryDescFallback = categoryMeta
    ? `Selected work in ${categoryMeta.title} from the Visupair portfolio.`
    : "Selected work from the Visupair portfolio.";
const categoryDescription = categoryMeta?.description
    ? truncateMetaDescription(stripHtml(categoryMeta.description))
    : categoryDescFallback;
const categoryOgImage = pickPortfolioListOgImage(filteredItems);
---

<Layout
    title={categoryListTitle}
    description={categoryDescription}
    canonicalURL={`/portfolio/category/${categoryId}`}
    ogImage={categoryOgImage}
>
    <div class="portfolio-layout">
        <PortfolioSidebar
            categories={categories}
            selectedCategoryId={categoryId === "all" ? null : categoryId}
            sectionId={sectionId}
        />
        <div class="portfolio-wrapper">
            <PortfolioGrid
                items={filteredItems}
                baseUrl="/portfolio"
                preserveCategory={categoryId === "all" ? null : categoryId}
                categoryMode={true}
            />
        </div>
    </div>
</Layout>

<style>
    .portfolio-layout {
        display: flex;
        gap: 12px;
        width: 100%;
        padding: 0 12px;
        height: calc(100vh - 120px);
    }

    .portfolio-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .portfolio-layout {
            flex-direction: column;
            height: auto;
            padding: 0 12px;
            gap: 12px;
        }

        .portfolio-wrapper {
            border-radius: var(--radius-md);
        }
    }
</style>
