---
import Layout from "../../layouts/Layout.astro";
import PortfolioSidebar from "../../components/PortfolioSidebar.astro";
import PortfolioGrid from "../../components/PortfolioGrid.astro";
import {
    getPortfolioCategories,
    getPortfolioProjects,
} from "../../lib/portfolio";
import {
    PORTFOLIO_INDEX_DEFAULT_DESC,
    pickPortfolioListOgImage,
} from "../../lib/portfolio-seo";
import { truncateMetaDescription } from "../../lib/seo-utils";

const sectionId = "portfolio";
const categories = await getPortfolioCategories();
const allItems = await getPortfolioProjects();

const indexDescription =
    allItems.length > 0
        ? truncateMetaDescription(
              `Browse ${allItems.length} projects in the Visupair portfolio — design, 3D, fashion, digital work, and more.`,
          )
        : PORTFOLIO_INDEX_DEFAULT_DESC;

const portfolioOgImage = pickPortfolioListOgImage(allItems);
---

<Layout
    title="Portfolio | Visupair"
    description={indexDescription}
    canonicalURL="/portfolio"
    ogImage={portfolioOgImage}
>
    <div class="portfolio-layout">
        <PortfolioSidebar
            categories={categories}
            selectedCategoryId={null}
            sectionId={sectionId}
        />
        <div class="portfolio-wrapper">
            <PortfolioGrid items={allItems} categories={categories} />
        </div>
    </div>
</Layout>

<style>
    .portfolio-layout {
        display: flex;
        gap: 12px;
        width: 100%;
        padding: 0 12px;
        height: calc(100vh - 120px);
    }

    .portfolio-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .portfolio-layout {
            flex-direction: column;
            height: auto;
            padding: 0 12px;
            gap: 12px;
        }

        .portfolio-wrapper {
            border-radius: var(--radius-md);
        }
    }
</style>
