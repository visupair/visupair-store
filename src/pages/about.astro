---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import { Image, getImage } from "astro:assets";
import gulDark from "../assets/about/Gul-dark.svg";
import gulLight from "../assets/about/Gul-light.svg";
import valiDark from "../assets/about/Vali-dark.svg";
import valiLight from "../assets/about/Vali-light.svg";
import aboutUs from "../assets/about/aboutus.webp";
import aboutServices from "../assets/about/aboutservices.webp";
import aboutCourses from "../assets/about/aboutcourses.webp";

export const prerender = true;

const gulDarkSrc = (await getImage({ src: gulDark })).src;
const gulLightSrc = (await getImage({ src: gulLight })).src;
const valiDarkSrc = (await getImage({ src: valiDark })).src;
const valiLightSrc = (await getImage({ src: valiLight })).src;
---

<Layout
  title="About Us — Visupair"
  description="We're two artists selling our own work — fashion, illustrations, 3D models, and more. No middlemen, just art."
>
  <Fragment slot="head">
    <script
      is:inline
      define:vars={{
        gulDarkSrc,
        gulLightSrc,
        valiDarkSrc,
        valiLightSrc,
      }}
    >
      (function () {
        try {
          var t = window.visupairGetTheme
            ? window.visupairGetTheme()
            : "dark";
          function preload(href) {
            var l = document.createElement("link");
            l.rel = "preload";
            l.as = "image";
            l.href = href;
            document.head.appendChild(l);
          }
          var gulUrl = t === "dark" ? gulDarkSrc : gulLightSrc;
          var valiUrl = t === "dark" ? valiDarkSrc : valiLightSrc;
          preload(gulUrl);
          preload(valiUrl);
        } catch (e) {}
      })();
    </script>
  </Fragment>

  <div class="about-wrapper">
    <div class="about-island">
      <!-- Lamp Lottie — top center -->
      <div class="about-lamp" id="about-lamp-container" aria-hidden="true">
      </div>

      <!-- Three-column layout -->
      <div class="about-grid">
        <!-- Left: Gul character (theme variants via CSS; no runtime src swap) -->
        <div class="about-char about-char--left">
          <div class="about-char__stack">
            <Image
              src={gulDark}
              alt="Gul — artist and co-founder of Visupair"
              class="about-char__img about-char__theme about-char__theme--dark"
              width={1352}
              height={1761}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              draggable={false}
            />
            <Image
              src={gulLight}
              alt="Gul — artist and co-founder of Visupair"
              class="about-char__img about-char__theme about-char__theme--light"
              width={1352}
              height={1761}
              loading="eager"
              fetchpriority="low"
              decoding="async"
              draggable={false}
            />
          </div>
        </div>

        <!-- Center: text content -->
        <div class="about-content">
          <div class="about-badge animate-text above-fold-reveal" style="--anim-delay: 0s;">
            About Us
          </div>

          <h1 class="about-title animate-text above-fold-reveal" style="--anim-delay: 0.1s;">
            Who We Are
          </h1>

          <p class="about-subtitle animate-text above-fold-reveal" style="--anim-delay: 0.2s;">
            We are Gul and Vali; Two multidisciplinary designers who have spent years making things they truly care about. 
            VisuPair is where we decided to stop keeping it to ourselves and collaborate.
          </p>

          <div class="about-actions animate-text above-fold-reveal" style="--anim-delay: 0.3s;">
            <Button href="/portfolio" variant="primary" label="See Our Work" />
            <Button
              href="/contact"
              variant="secondary"
              label="Contact Us"
              icon={false}
            />
          </div>
        </div>

        <!-- Right: Vali character -->
        <div class="about-char about-char--right">
          <div class="about-char__stack">
            <Image
              src={valiDark}
              alt="Vali — artist and co-founder of Visupair"
              class="about-char__img about-char__theme about-char__theme--dark"
              width={1352}
              height={1815}
              loading="eager"
              fetchpriority="high"
              decoding="async"
              draggable={false}
            />
            <Image
              src={valiLight}
              alt="Vali — artist and co-founder of Visupair"
              class="about-char__img about-char__theme about-char__theme--light"
              width={1352}
              height={1815}
              loading="eager"
              fetchpriority="low"
              decoding="async"
              draggable={false}
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Story section: image (left, TBD) + narrative (right) -->
  <div class="about-dual-wrapper">
    <div class="about-dual-layout">
      <div class="about-dual-panel about-dual-panel--media">
        <div class="about-dual-media-frame" data-about-media-spotlight>
          <Image
            src={aboutUs}
            class="about-dual-media-img"
            alt="Gul and Vali — Visupair co-founders"
            width={1200}
            height={800}
            loading="lazy"
            decoding="async"
          />
          <div class="about-dual-media-overlay" aria-hidden="true"></div>
        </div>
      </div>

      <article
        class="about-dual-panel about-dual-panel--story"
        aria-labelledby="about-story-heading"
      >
        <h2
          class="about-story-heading animate-text"
          id="about-story-heading"
          style="--anim-delay: 0s;"
        >
          This space didn't start as a business idea.
          <br />
          <span class="about-story-heading__accent"
            >It started as a life built around art.</span
          >
        </h2>

        <div
          class="about-story-body animate-text"
          style="--anim-delay: 0.08s;"
        >
          <p>
            For years, painting has been part of our everyday life. 
            Canvases, oils, long quiet hours, learning how light works, 
            how texture carries feeling, how color can say things that 
            words simply can not. That foundation never left us. It 
            shaped everything that came after.
          </p>
          <p>
            Curiosity kept moving us forward. Six years ago we 
            discovered digital design and fell in love with a whole new 
            way of creating, combining visuals, technology, and the 
            excitement of building something that didn't exist before. 
            Then came fashion. Not as a change of direction, but as a 
            natural next step. For us, clothing has always been 
            another form of art, just one you can wear.
          </p>
          <p>
            <strong>Visupair</strong> is where all of it comes together.
          </p>
          <p>
            We design in 3D, build digital patterns, and turn them into real 
            garments and objects. But those same pieces can also exist entirely 
            in the digital world as 3D models, wearable avatars, or digital 
            collectibles. We are just as excited about both. We call this 
            phygital creation: the ability to take an idea from screen to 
            material, and back again, without losing what makes it special.
            We make our own pieces, garments, accessories, paintings, digital 
            works. Some of them are available to find a home with you.
          </p>
          <p>
            We create our own pieces &dash; garments, accessories, paintings, 
            digital works. Some of them are available to find a home with you
          </p>
        </div>

        <div
          class="about-story-actions animate-text"
          style="--anim-delay: 0.16s;"
        >
          <Button href="/store" variant="primary" label="Visit Store" />
          <Button
            href="/contact"
            variant="secondary"
            label="Contact Us"
            icon={false}
          />
        </div>
      </article>
    </div>
  </div>

  <!-- Services & collaboration -->
  <div class="about-dual-wrapper">
    <div class="about-dual-layout about-dual-layout--reverse-desktop">
      <div class="about-dual-panel about-dual-panel--media">
        <div class="about-dual-media-frame" data-about-media-spotlight>
          <Image
            src={aboutServices}
            class="about-dual-media-img"
            alt="Visupair creative services — collaboration with artists and brands"
            width={1200}
            height={800}
            loading="lazy"
            decoding="async"
          />
          <div class="about-dual-media-overlay" aria-hidden="true"></div>
        </div>
      </div>

      <article
        class="about-dual-panel about-dual-panel--story"
        aria-labelledby="about-services-heading"
      >
        <h2
          class="about-story-heading animate-text"
          id="about-services-heading"
          style="--anim-delay: 0s;"
        >
          We work with artists, designers, and brands.
          <br />
          <span class="about-story-heading__accent"
            >We know what it feels like to be <br />the artist on the other
            side.</span
          >
        </h2>

        <div
          class="about-story-body animate-text"
          style="--anim-delay: 0.08s;"
        >
          <p>
            We help artists, independent designers, and brands build a 
            visual presence that actually reflects their work. That means logos, 
            websites, color palettes, creative direction, lookbooks, 
            and full visual identities, everything that shapes how people 
            experience what you do for the first time.
          </p>
          <p>
            What makes us different is not the list of things we offer.
            It's where we come from.We know what it feels like to be the artist 
            on the other side, to have work that matters deeply and not know how 
            to show it in a way that feels honest. 
          </p>
          <p>
            That understanding is at the heart of every project we take on. We don't just 
            design for you. We listen, we understand how you think creatively, and we build 
            something that genuinely feels like yours.
            For artists and independent designers, we get how hard it is to present 
            your work without it feeling over-produced or disconnected from who you really are. 
            Whether you need a portfolio, a brand identity, or a full digital home for your 
            practice, we build it in a way that stays true to your vision.
          </p>
          <p>
            For brands, we bring an artistic way of thinking that goes beyond just making 
            things look good. We think about meaning, consistency, and the kind of visual 
            language that builds real recognition over time.
          </p>
        </div>

        <div
          class="about-story-actions about-story-actions--stacked animate-text"
          style="--anim-delay: 0.16s;"
        >
          <Button href="/services" variant="primary" label="Explore Services" />
          <Button
            href="/contact"
            variant="secondary"
            label="Contact Us"
            icon={false}
          />
        </div>
      </article>
    </div>
  </div>

  <!-- Workshops & courses: image left + story (same layout as first dual section) -->
  <div class="about-dual-wrapper about-dual-wrapper--courses">
    <div class="about-dual-layout">
      <div class="about-dual-panel about-dual-panel--media">
        <div class="about-dual-media-frame" data-about-media-spotlight>
          <Image
            src={aboutCourses}
            class="about-dual-media-img"
            alt="Visupair workshops and courses — oil painting, digital design, and creative sessions"
            width={1200}
            height={800}
            loading="lazy"
            decoding="async"
          />
          <div class="about-dual-media-overlay" aria-hidden="true"></div>
        </div>
      </div>

      <article
        class="about-dual-panel about-dual-panel--story"
        aria-labelledby="about-courses-heading"
      >
        <h2
          class="about-story-heading animate-text"
          id="about-courses-heading"
          style="--anim-delay: 0s;"
        >
          We trust that knowledge grows when it is shared.
          <br />
          <span class="about-story-heading__accent"
            >We learned by doing and now we teach the same way.</span
          >
        </h2>

        <div
          class="about-story-body animate-text"
          style="--anim-delay: 0.08s;"
        >
          <p>
            We love sharing what we know and we believe that opening up a creative 
            process is just as valuable as the finished work. We organise workshops 
            and courses in oil painting, digital design, and 3D & phygital creation 
            as well as art nights, where creativity happens in a relaxed, open atmosphere. 
          </p>
          <p>
            Whether you're a complete beginner or simply curious, there's a place for you here.
          </p>
        </div>

        <div
          class="about-story-actions about-story-actions--stacked animate-text"
          style="--anim-delay: 0.16s;"
        >
          <Button href="/courses" variant="primary" label="Explore Courses" />
          <Button
            href="/contact"
            variant="secondary"
            label="Contact Us"
            icon={false}
          />
        </div>
      </article>
    </div>
  </div>

  <!-- Theme-aware SVG + Lottie switching -->
  <script>
    type Theme = "dark" | "light";

    let lottie: any = null;
    let lampAnim: any = null;
    let currentTheme: Theme | null = null;
    let themeObserver: MutationObserver | null = null;
    let intersectionObserver: IntersectionObserver | null = null;
    let hasCompletedAboutClientNav = false;
    let aboutSpotlightCleanup: (() => void) | null = null;

    const getTheme = (): Theme =>
      document.documentElement.hasAttribute("data-theme") ? "dark" : "light";

    const loadLamp = async (theme: Theme) => {
      const container = document.getElementById("about-lamp-container");
      if (!container) return;

      // Destroy animation if theme changed
      if (lampAnim && theme !== currentTheme) {
        lampAnim.destroy();
        lampAnim = null;
        container.innerHTML = "";
        container.classList.remove("lamp-loaded");
      }

      // Already loaded for this theme — just show it
      const hasAnimationInDOM = container.querySelector("svg") !== null;
      if (currentTheme === theme && lampAnim && hasAnimationInDOM) {
        container.classList.add("lamp-loaded");
        return;
      }

      try {
        // Preserve the lottie library across page transitions —
        // only the animation instance is destroyed, not the library
        if (!lottie) {
          const module = await import("lottie-web/build/player/lottie_light");
          lottie = module.default || module;
        }

        container.innerHTML = "";
        lampAnim = lottie.loadAnimation({
          container,
          renderer: "svg",
          autoplay: true,
          loop: true,
          path: `/images/hero/lamp-${theme}.json`,
        });

        // Fade in smoothly only after SVG is ready in DOM
        lampAnim.addEventListener("DOMLoaded", () => {
          container.classList.add("lamp-loaded");
        });

        currentTheme = theme;
      } catch (e) {
        console.error("Failed to load Lottie lamp:", e);
      }
    };

    const applyTheme = (theme: Theme) => {
      void loadLamp(theme);
    };

    const onThemeChange = () => {
      const theme = getTheme();
      void loadLamp(theme);
    };

    // Only disconnect observers when user navigates away.
    // The animation KEEPS PLAYING during the transition — same as index.astro.
    const cleanupObservers = () => {
      aboutSpotlightCleanup?.();
      aboutSpotlightCleanup = null;
      themeObserver?.disconnect();
      themeObserver = null;
      intersectionObserver?.disconnect();
      intersectionObserver = null;
    };

    const initAboutMediaSpotlight = () => {
      aboutSpotlightCleanup?.();
      const frames = document.querySelectorAll<HTMLElement>(
        "[data-about-media-spotlight]",
      );
      if (!frames.length) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      const mqMobile = window.matchMedia("(max-width: 900px)");
      const isMobileLayout = () => mqMobile.matches;

      const GROW_MS = 4200;
      const GROW_MS_MOBILE = 3200;
      const TOP_BOOST = 0.55;
      const TOP_BOOST_MOBILE = 0.35;

      const disposers: (() => void)[] = [];

      frames.forEach((frame) => {
        let active = false;
        let t0 = 0;
        let py = 0;
        let raf = 0;
        let scrollYAtInteract = 0;

        const reset = () => {
          active = false;
          cancelAnimationFrame(raf);
          frame.style.removeProperty("--spotlight-r");
          frame.classList.remove("is-spotlight-active");
        };

        const syncSpot = (cx: number, cy: number) => {
          const r = frame.getBoundingClientRect();
          py = cy;
          frame.style.setProperty("--spot-x", `${Math.round(cx - r.left)}px`);
          frame.style.setProperty("--spot-y", `${Math.round(cy - r.top)}px`);
        };

        const tick = () => {
          if (!active) return;
          const r = frame.getBoundingClientRect();
          const w = r.width;
          const h = r.height;
          const mobile = isMobileLayout();
          const growMs = mobile ? GROW_MS_MOBILE : GROW_MS;
          const topBoost = mobile ? TOP_BOOST_MOBILE : TOP_BOOST;
          const elapsed = performance.now() - t0;
          const time = Math.min(1, elapsed / growMs);
          const yN =
            h > 0 ? Math.max(0, Math.min(1, (py - r.top) / h)) : 0.5;
          const boost = (1 - yN) * topBoost;
          const mix = Math.min(1, time + boost * time);
          const tEase = 1 - (1 - mix) * (1 - mix);
          const minR = Math.max(64, Math.min(w, h) * (mobile ? 0.14 : 0.11));
          const maxR = Math.max(w, h) * (mobile ? 0.98 : 0.92);
          const radiusPx = minR + (maxR - minR) * tEase;
          frame.style.setProperty("--spotlight-r", `${Math.round(radiusPx)}px`);
          if (mix < 0.999) raf = requestAnimationFrame(tick);
        };

        const begin = () => {
          active = true;
          t0 = performance.now();
          scrollYAtInteract = window.scrollY;
          frame.classList.add("is-spotlight-active");
          cancelAnimationFrame(raf);
          const r = frame.getBoundingClientRect();
          const w = r.width;
          const h = r.height;
          const mobile = isMobileLayout();
          const minR = Math.max(64, Math.min(w, h) * (mobile ? 0.14 : 0.11));
          frame.style.setProperty("--spotlight-r", `${Math.round(minR)}px`);
          tick();
        };

        const onEnter = () => {
          if (isMobileLayout()) return;
          const r = frame.getBoundingClientRect();
          syncSpot(r.left + r.width / 2, r.top + r.height / 2);
          begin();
        };

        const onMove = (e: MouseEvent) => {
          if (isMobileLayout()) return;
          syncSpot(e.clientX, e.clientY);
        };

        const onTouchStart = (e: TouchEvent) => {
          const touch = e.touches[0];
          if (!touch) return;
          syncSpot(touch.clientX, touch.clientY);
          if (isMobileLayout()) begin();
          else if (!active) begin();
        };

        const onTouchMove = (e: TouchEvent) => {
          const touch = e.touches[0];
          if (!touch) return;
          syncSpot(touch.clientX, touch.clientY);
        };

        const onTouchEnd = () => {
          if (!isMobileLayout()) reset();
        };

        const onLeave = () => {
          if (isMobileLayout()) return;
          reset();
        };

        const onWindowScroll = () => {
          if (!isMobileLayout() || !active) return;
          if (window.scrollY > scrollYAtInteract + 28) reset();
        };

        frame.addEventListener("mouseenter", onEnter);
        frame.addEventListener("mousemove", onMove);
        frame.addEventListener("mouseleave", onLeave);
        frame.addEventListener("touchstart", onTouchStart, { passive: true });
        frame.addEventListener("touchmove", onTouchMove, { passive: true });
        frame.addEventListener("touchend", onTouchEnd);
        frame.addEventListener("touchcancel", onTouchEnd);
        window.addEventListener("scroll", onWindowScroll, { passive: true });

        disposers.push(() => {
          window.removeEventListener("scroll", onWindowScroll);
          reset();
          frame.removeEventListener("mouseenter", onEnter);
          frame.removeEventListener("mousemove", onMove);
          frame.removeEventListener("mouseleave", onLeave);
          frame.removeEventListener("touchstart", onTouchStart);
          frame.removeEventListener("touchmove", onTouchMove);
          frame.removeEventListener("touchend", onTouchEnd);
          frame.removeEventListener("touchcancel", onTouchEnd);
        });
      });

      aboutSpotlightCleanup = () => {
        disposers.forEach((d) => d());
        disposers.length = 0;
      };
    };

    // Called after the old DOM is fully replaced — safe to destroy animation now.
    const cleanupAnimation = () => {
      if (lampAnim) {
        lampAnim.destroy();
        lampAnim = null;
      }
      currentTheme = null;
    };

    const restartAboveFoldReveal = (selector: string) => {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        return;
      }
      document.querySelectorAll(selector).forEach((el) => {
        const h = el as HTMLElement;
        h.style.animation = "none";
        void h.offsetHeight;
        h.style.removeProperty("animation");
      });
    };

    const init = () => {
      // Full reset before re-initialising on new page visit
      cleanupObservers();
      cleanupAnimation();
      applyTheme(getTheme());

      themeObserver = new MutationObserver(onThemeChange);
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      // Text animation observer
      const textObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              textObserver.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".animate-text").forEach((el) => {
        if (
          el.classList.contains("is-visible") ||
          el.classList.contains("above-fold-reveal")
        ) {
          return;
        }
        textObserver.observe(el);
      });

      const container = document.getElementById("about-lamp-container");
      if (container) {
        intersectionObserver = new IntersectionObserver(
          (entries) => {
            if (entries[0].isIntersecting) {
              if (lampAnim) lampAnim.play();
            } else {
              if (lampAnim) lampAnim.pause();
            }
          },
          { threshold: 0.7 },
        );
        intersectionObserver.observe(container);
      }

      initAboutMediaSpotlight();

      if (hasCompletedAboutClientNav) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            restartAboveFoldReveal(
              ".about-content .animate-text.above-fold-reveal",
            );
          });
        });
      }
      hasCompletedAboutClientNav = true;
    };

    // Before transition starts: stop observing, but let animation finish visually
    document.addEventListener("astro:before-preparation", cleanupObservers);
    // After DOM swap: destroy old animation instance
    document.addEventListener("astro:after-swap", cleanupAnimation);
    // New page ready: boot everything up fresh
    document.addEventListener("astro:page-load", init);
  </script>

  <style>
    /* ── Reuse same blob keyframes as Home page ── */
    @keyframes blobDrift1 {
      0% {
        transform: translate(0%, 0%) scale(1);
      }
      20% {
        transform: translate(-12%, 18%) scale(1.08);
      }
      45% {
        transform: translate(8%, -20%) scale(1.04);
      }
      70% {
        transform: translate(-18%, -8%) scale(1.12);
      }
      100% {
        transform: translate(0%, 0%) scale(1);
      }
    }

    @keyframes blobDrift2 {
      0% {
        transform: translate(0%, 0%) scale(1);
      }
      25% {
        transform: translate(15%, -15%) scale(1.06);
      }
      55% {
        transform: translate(-10%, 20%) scale(1.1);
      }
      80% {
        transform: translate(12%, 10%) scale(1.04);
      }
      100% {
        transform: translate(0%, 0%) scale(1);
      }
    }

    /* ═══════════════════════════════════════
       TEXT ANIMATIONS (Slide Up & Fade In)
       ═══════════════════════════════════════ */
    .animate-text {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: var(--anim-delay, 0s);
      will-change: opacity, transform;
    }

    .animate-text.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .about-content .animate-text.above-fold-reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: none;
      animation: aboutTextReveal 0.72s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      animation-delay: var(--anim-delay, 0s);
    }

    @keyframes aboutTextReveal {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .about-content .animate-text.above-fold-reveal {
        animation: none;
        opacity: 1;
        transform: none;
      }
    }

    @keyframes islandFadeIn {
      from {
        opacity: 0;
        transform: translateY(12px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* ── Island wrapper ── */
    .about-wrapper {
      width: 100%;
      padding: 0 12px;
      box-sizing: border-box;
    }

    .about-island {
      width: 100%;
      border-radius: var(--radius-xl);
      border: 1px solid var(--border-subtle);
      overflow: hidden;
      position: relative;
      background: var(--surface);
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.02),
        var(--shadow-island);
      transition: box-shadow 0.4s ease;
      animation: islandFadeIn 0.6s cubic-bezier(0.2, 0, 0, 1) both;
    }

    :global([data-theme="dark"]) .about-island {
      /* background: linear-gradient(135deg, #1a1635, #2a2442); */
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.2),
        var(--shadow-island);
    }

    /* Glow effects - shared styles */
    .about-island::before,
    .about-island::after {
      content: "";
      position: absolute;
      pointer-events: none;
      z-index: 0;
      border-radius: 50%;
      will-change: transform;
    }

    /* ── Blob base ── */
    .about-island::before {
      top: -60%;
      right: -40%;
      width: clamp(800px, 150vw, 2400px);
      aspect-ratio: 1;
      background: transparent;
    }

    .about-island::after {
      bottom: -50%;
      left: -35%;
      width: clamp(700px, 130vw, 2000px);
      aspect-ratio: 1;
      background: transparent;
    }

    :global([data-theme="dark"]) .about-island::before {
      background: radial-gradient(
        closest-side,
        rgba(163, 142, 255, 0.4) 0%,
        rgba(163, 142, 255, 0.15) 35%,
        rgba(163, 142, 255, 0.02) 70%,
        rgba(163, 142, 255, 0) 100%
      );
      opacity: 0.5;
      animation: blobDrift1 22s infinite alternate ease-in-out;
    }

    :global([data-theme="dark"]) .about-island::after {
      background: radial-gradient(
        closest-side,
        rgba(132, 128, 255, 0.35) 0%,
        rgba(132, 128, 255, 0.12) 35%,
        rgba(132, 128, 255, 0.02) 70%,
        rgba(132, 128, 255, 0) 100%
      );
      opacity: 0.5;
      animation: blobDrift2 28s infinite alternate ease-in-out;
    }

    /* ── Lamp — top center (Absolute Overlay) ── */
    .about-lamp {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 3; /* above blobs (0), chars (1) and content (1) */
      display: flex;
      justify-content: center;
      pointer-events: none;
      height: clamp(350px, 44vw, 640px);
      margin: 0;
      /* Start hidden, fade in after animation SVG is ready */
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .about-lamp.lamp-loaded {
      opacity: 1;
    }

    .about-lamp > * {
      height: 100%;
      width: auto;
    }

    /* ── Three-column grid ── */
    .about-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: flex-end;
      gap: 0;
      padding-top: clamp(180px, 28vw, 350px);
      padding-bottom: 0px;
    }

    @media (min-width: 1960px) {
      .about-grid {
        padding-top: clamp(410px, 15vw, 520px);
      }
    }

    /* ── Characters ── */
    .about-char {
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }

    .about-char--left {
      justify-content: flex-start;
    } /* Gul to left wall */
    .about-char--right {
      justify-content: flex-end;
    } /* Vali to right wall */

    .about-char__stack {
      position: relative;
      width: 100%;
      max-width: clamp(168px, 26vw, 384px);
    }

    .about-char__img {
      display: block;
      width: 100%;
      max-width: 100%;
      height: auto;
      object-fit: contain;
      object-position: bottom center;
      /* Prevent selecting, dragging and saving */
      user-select: none;
      -webkit-user-select: none;
      -webkit-user-drag: none;
      user-drag: none;
    }

    .about-char__theme--dark {
      display: none;
    }

    :global([data-theme="dark"]) .about-char__theme--dark {
      display: block;
    }

    .about-char__theme--light {
      display: block;
    }

    :global([data-theme="dark"]) .about-char__theme--light {
      display: none;
    }

    /* ── Center content ── */
    .about-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 0 clamp(20px, 3vw, 48px);
      transform: translateY(-120px);
      gap: clamp(16px, 2.5vw, 44px);
      min-width: clamp(240px, 36vw, 480px);
    }

    .about-badge {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 6px 16px;
      background: rgba(132, 128, 255, 0.1);
      border: 1px solid rgba(132, 128, 255, 0.25);
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--brand-violet);
    }

    .about-title {
      font-family: var(--font-family);
      font-size: clamp(40px, 6vw, 80px);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--foreground);
      margin: 0;
    }

    .about-subtitle {
      font-size: clamp(14px, 1.4vw, 17px);
      line-height: 1.65;
      color: var(--foreground-muted);
      max-width: 36ch;
      margin: 0;
    }

    .about-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }

    /* ── Tablet (750px–1024px): keep grid, shrink chars ── */
    @media (min-width: 750px) and (max-width: 1024px) {
      .about-char__stack {
        max-width: clamp(160px, 96vw, 320px);
      }

      .about-char__img {
        max-width: 100%;
      }
      .about-title {
        font-size: clamp(32px, 5vw, 52px);
      }
    }

    /* ── Mobile (<750px): stack vertically ── */
    @media (max-width: 749px) {
      .about-lamp {
        height: clamp(20px, 84vw, 480px);
        transform: scale(1.3);
      }

      /* Row 1: both characters side-by-side, Row 2: text content */
      .about-grid {
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto auto;
      }

      .about-char--left {
        grid-column: 1;
        grid-row: 1;
        justify-content: flex-start;
      }

      .about-char--right {
        grid-column: 2;
        grid-row: 1;
        display: flex; /* restore — hidden before */
        justify-content: flex-end;
      }

      .about-content {
        grid-column: 1 / -1; /* full width */
        grid-row: 2;
        transform: translateY(0px);
        padding: 40px 24px;
        min-width: unset;
      }

      .about-char__stack {
        max-width: 100%;
      }

      .about-char__img {
        max-width: 100%;
      }

      .about-title {
        font-size: clamp(36px, 9vw, 52px);
      }
    }

    /* ── Dual panels (match contact `.contact-form-side` — minimal, no gradients) ── */
    .about-dual-wrapper {
      width: 100%;
      padding: 12px 12px 0;
      box-sizing: border-box;
    }

    /* Desktop: equal-width columns (50% / 50%) */
    .about-dual-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
      margin: 0 auto;
      gap: 12px;
      animation: islandFadeIn 0.6s cubic-bezier(0.2, 0, 0, 1) 0.12s both;
    }

    /* Third section: text column first, image second (same 50/50 track sizes) */
    .about-dual-layout--reverse-desktop .about-dual-panel--story {
      order: 1;
    }

    .about-dual-layout--reverse-desktop .about-dual-panel--media {
      order: 2;
    }

    .about-dual-panel {
      min-width: 0;
      background: var(--surface);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-xl);
      padding: 48px;
      box-shadow: var(--shadow-island);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .about-dual-panel--media {
      justify-content: flex-start;
      align-items: stretch;
      align-self: stretch;
      padding: 0;
      overflow: hidden;
      min-height: 0;
    }

    /* flex-basis 0 so this column grows to match the story column; image fills via absolute + cover */
    .about-dual-media-frame {
      position: relative;
      flex: 1 1 0;
      width: 100%;
      min-height: clamp(220px, 38vh, 520px);
      min-width: 0;
      overflow: hidden;
      border-radius: var(--radius-xl);
    }

    .about-dual-media-img {
      position: absolute;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      transform: scale(1);
      transform-origin: center center;
    }

    @media (prefers-reduced-motion: no-preference) {
      .about-dual-media-img {
        transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .about-dual-media-frame:hover .about-dual-media-img,
      .about-dual-media-frame.is-spotlight-active .about-dual-media-img {
        transform: scale(1.045);
      }
    }

    /*
      Explore Courses: shorter copy than other dual blocks → grid row was too short
      and the image looked squeezed. Desktop only: taller minimum frame so the photo
      reads clearly without adding body text. Story column is vertically centered so
      padding feels symmetric when the row is taller than the copy.
    */
    @media (min-width: 901px) {
      .about-dual-wrapper--courses .about-dual-panel--media {
        min-height: auto;
      }

      .about-dual-wrapper--courses .about-dual-media-frame {
        flex: 1 1 auto;
        min-height: clamp(560px, 74vh, 860px);
      }

      .about-dual-wrapper--courses .about-dual-panel--story {
        justify-content: center;
      }
    }

    /* Hue blend; spotlight hole grows via --spotlight-r (JS), not opacity */
    .about-dual-media-overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      /* Same deep tint in light + dark (matches dark theme switch track) */
      background: #26203c;
      mix-blend-mode: hue;
    }

    .about-dual-media-frame.is-spotlight-active .about-dual-media-overlay {
      -webkit-mask-image: radial-gradient(
        circle var(--spotlight-r, 120px) at var(--spot-x, 50%) var(--spot-y, 50%),
        transparent 0%,
        transparent 40%,
        rgba(0, 0, 0, 0.32) 58%,
        #000 100%
      );
      mask-image: radial-gradient(
        circle var(--spotlight-r, 120px) at var(--spot-x, 50%) var(--spot-y, 50%),
        transparent 0%,
        transparent 40%,
        rgba(0, 0, 0, 0.32) 58%,
        #000 100%
      );
      -webkit-mask-repeat: no-repeat;
      mask-repeat: no-repeat;
    }

    .about-dual-panel--story {
      justify-content: flex-start;
      gap: clamp(20px, 3vw, 28px);
      text-align: left;
      align-items: stretch;
    }

    .about-story-heading {
      font-family: var(--font-family);
      font-size: clamp(22px, 2.75vw, 32px);
      font-weight: 700;
      line-height: 1.18;
      letter-spacing: -0.02em;
      color: var(--foreground);
      margin: 0;
      max-width: 42ch;
    }

    .about-story-heading__accent {
      display: inline-block;
      color: var(--brand-violet);
    }

    :global([data-theme="dark"]) .about-story-heading {
      color: #ffffff;
    }

    .about-story-body {
      display: flex;
      flex-direction: column;
      gap: 1.1em;
    }

    .about-story-body p {
      font-family: var(--font-family);
      font-size: clamp(15px, 1.2vw, 17px);
      line-height: 1.7;
      color: var(--foreground);
      opacity: 0.88;
      margin: 0;
      max-width: 62ch;
    }

    :global([data-theme="dark"]) .about-story-body p {
      color: #e9e8ff;
      opacity: 0.9;
    }

    .about-story-body strong {
      font-weight: 700;
      color: var(--foreground);
      opacity: 1;
    }

    :global([data-theme="dark"]) .about-story-body strong {
      color: #ffffff;
    }

    .about-story-body em {
      font-style: italic;
    }

    .about-story-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      justify-content: flex-start;
      margin-top: 0.25rem;
    }

    @media (max-width: 900px) {
      .about-dual-layout {
        grid-template-columns: 1fr;
      }

      /* Undo desktop column order so image stays on top on phones */
      .about-dual-layout--reverse-desktop .about-dual-panel--media {
        order: 1;
      }

      .about-dual-layout--reverse-desktop .about-dual-panel--story {
        order: 2;
      }

      .about-dual-panel {
        padding: 24px;
      }

      /* Image panel: no inner padding — photo should bleed to card edges */
      .about-dual-panel.about-dual-panel--media {
        padding: 0;
      }

      .about-dual-panel--media {
        order: 1;
      }

      .about-dual-panel--story {
        order: 2;
        text-align: center;
        align-items: center;
      }

      .about-story-body {
        align-items: center;
      }

      .about-story-body p {
        text-align: center;
      }

      .about-dual-media-frame {
        flex: 0 0 auto;
        width: 100%;
        min-height: 0;
        /* Portrait-friendly frame: image fills edge-to-edge (cover), no side gutters */
        aspect-ratio: 4 / 5;
        max-height: min(82vh, 700px);
        border-radius: var(--radius-xl);
        touch-action: manipulation;
      }

      .about-dual-media-img {
        object-fit: cover;
        object-position: center center;
      }

      .about-story-heading {
        max-width: none;
        margin-left: auto;
        margin-right: auto;
      }

      .about-story-body p {
        max-width: none;
      }

      /* Same idea as homepage .hero-actions: wrap instead of squeezing two CTAs on one row */
      .about-story-actions {
        flex-wrap: wrap;
        gap: clamp(10px, 1.5vw, 14px);
        justify-content: center;
        align-items: center;
      }

      :global(.about-story-actions .vp-btn) {
        flex: 0 0 auto;
        width: auto;
      }

      .about-story-actions.about-story-actions--stacked {
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
      }

      :global(.about-story-actions--stacked .vp-btn) {
        flex: 0 0 auto;
        width: auto;
      }
    }

    /* Narrow phones: keep CTAs on one row when they fit (like hero), not a vertical stack */
    @media (max-width: 600px) {
      .about-dual-panel {
        padding: 20px;
      }

      .about-dual-panel.about-dual-panel--media {
        padding: 0;
      }

      .about-story-actions,
      .about-story-actions.about-story-actions--stacked {
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: clamp(10px, 1.5vw, 14px);
      }

      :global(.about-story-actions .vp-btn),
      :global(.about-story-actions--stacked .vp-btn) {
        flex: 0 0 auto;
        width: auto;
      }
    }

    /* Match homepage: centered CTA row up to “large phone” / stacked hero width */
    @media (max-width: 833px) {
      .about-actions,
      .about-story-actions {
        width: 100%;
        justify-content: center;
        gap: clamp(10px, 1.5vw, 14px);
      }
    }

    @media (max-width: 767px) {
      .about-actions :global(.vp-btn),
      .about-story-actions :global(.vp-btn) {
        font-size: clamp(12px, 3.2vw, 14px);
      }
    }

    /* iPad mini / Air / Pro (portrait & smaller landscape): same band as homepage */
    @media (min-width: 768px) and (max-width: 1024px) {
      .about-actions :global(.vp-btn),
      .about-story-actions :global(.vp-btn) {
        font-size: clamp(12px, 1.35vw, 14px);
        height: 2.65em;
      }
    }

    @media (min-width: 1025px) and (max-width: 1280px) {
      .about-actions :global(.vp-btn),
      .about-story-actions :global(.vp-btn) {
        font-size: 14px;
        height: 2.8em;
      }
    }

    @media (min-width: 1281px) and (max-width: 1536px) {
      .about-actions :global(.vp-btn),
      .about-story-actions :global(.vp-btn) {
        font-size: clamp(14px, 0.95vw, 16px);
        height: 2.8em;
      }
    }

    /* ── Reduced motion ── */
    @media (prefers-reduced-motion: reduce) {
      .about-island::before,
      .about-island::after,
      .about-island {
        animation: none !important;
      }

      .about-dual-layout {
        animation: none;
      }
    }
  </style>
</Layout>
