---
import Layout from "../../layouts/Layout.astro";
import { authClient } from "../../lib/auth-client";
import { urlFor } from "../../lib/sanity";
import { createClient } from "@sanity/client";

// Non-CDN client → fresh data immediately
const sanityFresh = createClient({
  projectId: "sovnyov1",
  dataset: "production",
  useCdn: false,
  apiVersion: "2024-03-01",
  token: import.meta.env.SANITY_API_TOKEN,
});

const session = await authClient.getSession({
  fetchOptions: { headers: Astro.request.headers },
});

if (!session.data) {
  return Astro.redirect("/login");
}

const userEmail = session.data.user.email;

const query = `*[_type == "order" && customerEmail == $email] | order(createdAt desc) {
  _id,
  orderNumber,
  createdAt,
  totalAmount,
  status,
  orderType,
  selectedCourier,
  trackingNumber,
  trackingUrl,
  estimatedDelivery,
  shippingTimelineStage,
  shippingAddress,
  items[] {
    _key,
    productType,
    quantity,
    price,
    variant,
    "product": product-> {
      _id,
      name,
      "image": mainImage,
      productType,
      digitalFileKey,
      "slug": slug.current
    }
  }
}`;

const courseRegQuery = `*[_type == "courseRegistration" && email == $email] | order(createdAt desc) {
  _id,
  courseName,
  createdAt,
  pricingType,
  donationAmount,
  donationCurrency,
  paidAmount,
  paidCurrency,
  "course": course-> {
    _id,
    name,
    slug,
    mainImage,
    digitalFileKey,
    price,
    pricePLN
  }
}`;

const orders = await sanityFresh.fetch(query, { email: userEmail });
const courseRegistrations = await sanityFresh.fetch(courseRegQuery, {
  email: userEmail,
});

const courseIdsFromRegistrations = new Set(
  courseRegistrations.map((r: any) => r.course?._id).filter(Boolean),
);

/** Cart line items grouped for My Purchases sections (course lines with a registration are shown only under Courses). */
const physicalItems: { order: any; item: any; product: any }[] = [];
const digitalItems: { order: any; item: any; product: any }[] = [];
const orderOnlyCourseItems: { order: any; item: any; product: any }[] = [];

for (const order of orders) {
  for (const item of order.items || []) {
    const product = item.product;
    const pt = item.productType || product?.productType;
    if (pt === "course") {
      const cid = product?._id;
      if (cid && courseIdsFromRegistrations.has(cid)) continue;
      orderOnlyCourseItems.push({ order, item, product });
      continue;
    }
    if (pt === "digital") {
      digitalItems.push({ order, item, product });
    } else {
      physicalItems.push({ order, item, product });
    }
  }
}

const hasAnyLibrary =
  physicalItems.length > 0 ||
  digitalItems.length > 0 ||
  courseRegistrations.length > 0 ||
  orderOnlyCourseItems.length > 0;

/** Card + popup price for course registrations (pay-at-door uses course list price from CMS). */
function courseRegistrationDisplayPrice(reg: any): string {
  const pt = reg.pricingType;
  const c = reg.course;
  if (pt === "free") return "Free";
  if (pt === "payAtDoor") {
    const eur = c?.price;
    const pln = c?.pricePLN;
    if (eur != null && Number(eur) > 0) {
      if (pln != null && Number(pln) > 0) {
        return `€${eur} · ${pln} zł`;
      }
      return `€${eur}`;
    }
    if (pln != null && Number(pln) > 0) return `${pln} zł`;
    return "Pay at door";
  }
  if (pt === "donation") {
    const amt = reg.donationAmount;
    if (amt != null && Number(amt) > 0) {
      return reg.donationCurrency === "PLN" ? `${amt} zł` : `€${amt}`;
    }
    return "Free";
  }
  if (pt === "paid" && reg.paidAmount != null) {
    return reg.paidCurrency === "PLN" ? `${reg.paidAmount} zł` : `€${reg.paidAmount}`;
  }
  return "—";
}

/** Delivery steps for physical orders (timeline preferred; legacy status shipped/delivered still respected). */
function resolveDeliveryTimeline(order: any) {
  const field =
    order.shippingTimelineStage === "shipped" ||
    order.shippingTimelineStage === "delivered" ||
    order.shippingTimelineStage === "confirmed"
      ? order.shippingTimelineStage
      : null;
  const fromLegacyStatus =
    order.status === "delivered"
      ? "delivered"
      : order.status === "shipped"
        ? "shipped"
        : "confirmed";
  function rank(t: string) {
    if (t === "delivered") return 2;
    if (t === "shipped") return 1;
    return 0;
  }
  const r = Math.max(
    field != null ? rank(field) : -1,
    rank(fromLegacyStatus),
  );
  return r === 2 ? "delivered" : r === 1 ? "shipped" : "confirmed";
}

function purchaseCardBadge(order: any, isDigital: boolean, isCourse: boolean) {
  if (order.status === "cancelled")
    return { label: "Cancelled", badgeClass: "cancelled" };
  if (order.status === "refunded")
    return { label: "Refunded", badgeClass: "refunded" };
  if (!isDigital && !isCourse) {
    const stage = resolveDeliveryTimeline(order);
    const labels = {
      confirmed: "Confirmed",
      shipped: "Shipped",
      delivered: "Delivered",
    };
    const badgeClass =
      stage === "delivered"
        ? "delivered"
        : stage === "shipped"
          ? "shipped"
          : "paid";
    return { label: labels[stage], badgeClass };
  }
  if (order.status === "processing")
    return { label: "Processing", badgeClass: "processing" };
  return { label: "Paid", badgeClass: "paid" };
}

function orderAllowsDigitalDownload(order: any) {
  const s = order.status;
  if (s === "cancelled" || s === "refunded") return false;
  return (
    s === "paid" ||
    s === "processing" ||
    s === "shipped" ||
    s === "delivered"
  );
}
---

<Layout title="Purchases — Visupair">
  <main class="account-page">
    <div class="purchases-section">
      {
        !hasAnyLibrary ? (
          <div class="empty-state">
            <svg
