                fill="currentColor"
              />
            </svg>
            <h3>No purchases yet</h3>
            <p>Items you buy will appear here.</p>
            <a href="/store/fashion-design" class="btn-primary">
              Browse Products
            </a>
          </div>
        ) : (
          <div id="purchases-content">
            {
              physicalItems.length > 0 && (
                <section class="purchases-category" aria-labelledby="purchases-physical">
                  <div class="section-header">
                    <h2 id="purchases-physical" class="section-title">
                      Physical Products
                    </h2>
                  </div>
                  <div class="purchases-grid">
                    {physicalItems.map(({ order, item, product }) => {
                      const name = product?.name || item.variant || "Product";
                      const img = product?.image;
                      const isDigital = false;
                      const isCourse = false;
                      const { label: statusLabel, badgeClass } =
                        purchaseCardBadge(order, isDigital, isCourse);
                      const orderData = JSON.stringify({
                        kind: "orderItem",
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        createdAt: order.createdAt,
                        totalAmount: order.totalAmount,
                        status: order.status,
                        statusLabel,
                        badgeClass,
                        orderType: order.orderType,
                        selectedCourier: order.selectedCourier,
                        trackingNumber: order.trackingNumber,
                        trackingUrl: order.trackingUrl,
                        estimatedDelivery: order.estimatedDelivery,
                        shippingTimelineStage: order.shippingTimelineStage,
                        shippingAddress: order.shippingAddress,
                        itemName: name,
                        itemPrice: item.price,
                        itemQty: item.quantity,
                        itemVariant: item.variant,
                        itemType: item.productType || product?.productType,
                        isDigital,
                        isCourse,
                        canDownload: false,
                        fileKey: null,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class={`card-badge badge-${badgeClass}`}>
                              {statusLabel}
                            </span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            {item.variant && item.variant !== name && (
                              <span class="card-variant">{item.variant}</span>
                            )}
                            <span class="card-price">€{item.price}</span>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </section>
              )
            }

            {
              digitalItems.length > 0 && (
                <section class="purchases-category" aria-labelledby="purchases-digital">
                  <div class="section-header">
                    <h2 id="purchases-digital" class="section-title">
                      Digital Products
                    </h2>
                  </div>
                  <div class="purchases-grid">
                    {digitalItems.map(({ order, item, product }) => {
                      const name = product?.name || item.variant || "Product";
                      const img = product?.image;
                      const isDigital = true;
                      const isCourse = false;
                      const isFreeDigital = isFreeDigitalLine(
                        order,
                        item,
                        product,
                      );
                      const { label: statusLabel, badgeClass } =
                        purchaseCardBadge(
                          order,
                          isDigital,
                          isCourse,
                          isFreeDigital,
                        );
                      const canDownload =
                        orderAllowsDigitalDownload(order) && isDigital;
                      const fileKey = product?.digitalFileKey;
                      const orderData = JSON.stringify({
                        kind: "orderItem",
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        createdAt: order.createdAt,
                        totalAmount: order.totalAmount,
                        status: order.status,
                        statusLabel,
                        badgeClass,
                        orderType: order.orderType,
                        selectedCourier: order.selectedCourier,
                        trackingNumber: order.trackingNumber,
                        trackingUrl: order.trackingUrl,
                        estimatedDelivery: order.estimatedDelivery,
                        shippingTimelineStage: order.shippingTimelineStage,
                        shippingAddress: order.shippingAddress,
                        itemName: name,
                        itemPrice: item.price,
                        itemQty: item.quantity,
                        itemVariant: item.variant,
                        itemType: item.productType || product?.productType,
                        isDigital,
                        isCourse,
                        isFreeDigital,
                        canDownload,
                        fileKey,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      const lineKey = item._key || "";
                      const purchaseLineId =
                        lineKey && order._id
                          ? `purchase-line-${order._id}-${lineKey}`
                          : undefined;
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          id={purchaseLineId}
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class={`card-badge badge-${badgeClass}`}>
                              {statusLabel}
                            </span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            {item.variant && item.variant !== name && (
                              <span class="card-variant">{item.variant}</span>
                            )}
                            <span
                              class:list={[
                                "card-price",
                                isFreeDigital && "card-price--free",
                              ]}
                            >
                              {isFreeDigital ? "Free" : `€${item.price}`}
                            </span>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </section>
              )
            }

            {
              courseRegistrations.length + orderOnlyCourseItems.length > 0 && (
                <section class="purchases-category" aria-labelledby="purchases-courses">
                  <div class="section-header">
                    <h2 id="purchases-courses" class="section-title">
                      Courses
                    </h2>
                  </div>
                  <div class="purchases-grid">
                    {courseRegistrations.map((reg: any) => {
                      const name =
                        reg.course?.name || reg.courseName || "Course";
                      const img = reg.course?.mainImage;
                      const slugCurrent = reg.course?.slug?.current || "";
                      const fileKey = reg.course?.digitalFileKey || null;
                      const cardPrice = courseRegistrationDisplayPrice(reg);
                      const priceMuted =
                        cardPrice === "—" ||
                        cardPrice === "Pay at door" ||
                        cardPrice === "Free";
                      const orderData = JSON.stringify({
                        kind: "courseRegistration",
                        registrationId: reg._id,
                        courseName: name,
                        createdAt: reg.createdAt,
                        pricingType: reg.pricingType,
                        donationAmount: reg.donationAmount,
                        donationCurrency: reg.donationCurrency,
                        paidAmount: reg.paidAmount,
                        paidCurrency: reg.paidCurrency,
                        doorPriceEur: reg.course?.price ?? null,
                        doorPricePln: reg.course?.pricePLN ?? null,
                        courseSlug: slugCurrent,
                        fileKey,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class="card-badge badge-paid">Enrolled</span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            <span class="card-variant">Your registration</span>
                            <span
                              class={`card-price${priceMuted ? " card-price--muted" : ""}`}
                            >
                              {cardPrice}
                            </span>
                          </div>
                        </button>
                      );
                    })}
                    {orderOnlyCourseItems.map(({ order, item, product }) => {
                      const name = product?.name || item.variant || "Course";
                      const img = product?.image;
                      const isDigital = false;
                      const isCourse = true;
                      const { label: statusLabel, badgeClass } =
                        purchaseCardBadge(order, isDigital, isCourse);
                      const slugCurrent = product?.slug || "";
                      const fileKey = product?.digitalFileKey || null;
                      const canDownload =
                        Boolean(fileKey) && orderAllowsDigitalDownload(order);
                      const orderData = JSON.stringify({
                        kind: "orderItem",
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        createdAt: order.createdAt,
                        totalAmount: order.totalAmount,
                        status: order.status,
                        statusLabel,
                        badgeClass,
                        orderType: order.orderType,
                        selectedCourier: order.selectedCourier,
                        trackingNumber: order.trackingNumber,
                        trackingUrl: order.trackingUrl,
                        estimatedDelivery: order.estimatedDelivery,
                        shippingTimelineStage: order.shippingTimelineStage,
                        shippingAddress: order.shippingAddress,
                        itemName: name,
                        itemPrice: item.price,
                        itemQty: item.quantity,
                        itemVariant: item.variant,
                        itemType: item.productType || product?.productType,
                        isDigital,
                        isCourse,
                        canDownload,
                        fileKey,
                        courseSlug: slugCurrent,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class={`card-badge badge-${badgeClass}`}>
                              {statusLabel}
                            </span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            {item.variant && item.variant !== name && (
                              <span class="card-variant">{item.variant}</span>
                            )}
                            <span class="card-price">€{item.price}</span>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </section>
              )
            }
          </div>
        )
      }
    </div>

    <!-- Detail popup (hidden by default) -->
    <div class="popup-overlay" id="popup-overlay">
      <div class="popup-card" id="popup-card">
        <button
          type="button"
          class="popup-close"
          id="popup-close"
          aria-label="Close"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div class="popup-content" id="popup-content"></div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // @ts-nocheck
  function escapeHtml(s) {
    if (s == null || s === undefined) return "";
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function resolveTimelineStage(d) {
    const field =
      d.shippingTimelineStage === "shipped" ||
      d.shippingTimelineStage === "delivered" ||
      d.shippingTimelineStage === "confirmed"
        ? d.shippingTimelineStage
        : null;
    const fromStatus =
      d.status === "delivered"
        ? "delivered"
        : d.status === "shipped"
          ? "shipped"
          : "confirmed";
    function rank(t) {
      if (t === "delivered") return 2;
      if (t === "shipped") return 1;
      return 0;
    }
    const r = Math.max(
      field != null ? rank(field) : -1,
      rank(fromStatus),
    );
    return r === 2 ? "delivered" : r === 1 ? "shipped" : "confirmed";
  }

  function buildShippingTimeline(stage) {
    const complete = [
      true,
      stage === "shipped" || stage === "delivered",
      stage === "delivered",
    ];
    let currentIdx = -1;
    for (let i = 0; i < 3; i++) {
      if (!complete[i]) {
        currentIdx = i;
        break;
      }
    }
    const labels = ["Confirmed", "Shipped", "Delivered"];
    const check =
      '<svg class="st-check" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';

    let html =
      '<div class="ship-timeline ship-timeline--compact" role="list" aria-label="Delivery progress">';
    for (let i = 0; i < 3; i++) {
      let stepClass = "st-step";
      if (complete[i]) stepClass += " st-step--done";
      else if (i === currentIdx) stepClass += " st-step--current";
      else stepClass += " st-step--pending";

      const inner = complete[i] ? check : "";
      html += `<div class="${stepClass}" role="listitem"><span class="st-node">${inner}</span><span class="st-label">${labels[i]}</span></div>`;

      if (i < 2) {
        let connClass = "st-conn";
        if (complete[i + 1]) connClass += " st-conn--done";
        else if (complete[i] && !complete[i + 1]) connClass += " st-conn--prog";
        html += `<div class="${connClass}" aria-hidden="true"></div>`;
      }
    }
    html += "</div>";
    return html;
  }

  function isSafeTrackingUrl(url) {
    if (!url || typeof url !== "string") return false;
    try {
      const u = new URL(url);
      return u.protocol === "https:" || u.protocol === "http:";
    } catch {
      return false;
    }
  }

  function courseRegistrationPricingLabel(d) {
    const pt = d.pricingType;
    if (pt === "free") return "Free";
    if (pt === "payAtDoor") {
      const eur = d.doorPriceEur;
      const pln = d.doorPricePln;
      if (eur != null && Number(eur) > 0) {
        if (pln != null && Number(pln) > 0) {
          return `€${eur} or ${pln} zł at the door`;
        }
        return `€${eur} at the door`;
      }
      if (pln != null && Number(pln) > 0) {
        return `${pln} zł at the door`;
      }
      return "Pay at the door";
    }
    if (pt === "donation") {
      const amt = d.donationAmount;
      if (amt != null && Number(amt) > 0) {
        return d.donationCurrency === "PLN" ? `${amt} zł donated` : `€${amt} donated`;
      }
      return "Registered (no donation)";
    }
    if (pt === "paid" && d.paidAmount != null) {
      return d.paidCurrency === "PLN" ? `${d.paidAmount} zł paid` : `€${d.paidAmount} paid`;
    }
    return "—";
  }

  function downloadButtonHtml(fileKey, isFreeDigital) {
    const extra = isFreeDigital ? " popup-btn--free-download" : "";
    return `
              <div class="popup-actions">
              <a href="/api/download/${encodeURIComponent(String(fileKey))}" class="popup-btn popup-btn--primary popup-btn--block${extra}" download>
                <svg width="15" height="15" viewBox="0 0 152 152" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M141.547 98.3721C146.809 98.3723 151 102.489 151 107.791V140.581C151 145.883 146.809 150 141.547 150H9.45312C4.19107 150 0 145.883 0 140.581V107.791C0 102.489 4.19107 98.3723 9.45312 98.3721C14.7153 98.3721 18.9072 102.489 18.9072 107.791V129.163C18.9072 130.268 19.8027 131.163 20.9072 131.163H130.093C131.197 131.163 132.093 130.268 132.093 129.163V107.791C132.093 102.489 136.285 98.3721 141.547 98.3721Z" fill="currentColor"/>
                  <path d="M75.5 0C80.7622 0 84.9531 4.11652 84.9531 9.41895V66.3782C84.9531 67.2673 86.0267 67.7143 86.6577 67.0878L93.6289 60.166C97.2657 56.3857 103.138 56.5764 106.763 60.0312C106.786 60.0523 106.808 60.0755 106.831 60.0967C106.855 60.1203 106.881 60.1421 106.905 60.166C110.781 63.8415 110.534 69.8352 106.905 73.4385L82.1377 98.0312C80.299 99.8569 77.8367 100.813 75.5 100.813C73.1633 100.813 70.701 99.8569 68.8623 98.0312L44.0947 73.4385C40.2511 69.7923 40.4631 63.8657 44.0088 60.2539C47.6855 56.3319 53.7317 56.5523 57.3711 60.166L64.3423 67.0878C64.9733 67.7143 66.0469 67.2673 66.0469 66.3782V9.41895C66.0469 4.11652 70.2378 0 75.5 0Z" fill="currentColor"/>
                </svg>
                Download files
              </a>
              </div>
            `;
  }

  function initPurchases() {
    const overlay = document.getElementById("popup-overlay");
    const popupContent = document.getElementById("popup-content");
    const popupClose = document.getElementById("popup-close");
    if (!overlay || !popupContent || !popupClose) return;

    function close() {
      overlay?.classList.remove("active");
      document.body.style.overflow = "";
    }

    popupClose.addEventListener("click", close);
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });

    document.querySelectorAll(".purchase-card").forEach((card) => {
      card.addEventListener("click", () => {
        const raw = card.getAttribute("data-order");
        if (!raw) return;

        try {
          const d = JSON.parse(raw);

          if (d.kind === "courseRegistration") {
            const nameSafe = escapeHtml(d.courseName);
            const dateStr = d.createdAt
              ? new Date(d.createdAt).toLocaleDateString(undefined, {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              : "";
            const pricingSafe = escapeHtml(courseRegistrationPricingLabel(d));
            let html = `
            ${d.image ? `<img class="popup-image" src="${String(d.image).replace(/"/g, "&quot;")}" alt="${nameSafe}" />` : ""}
            <div class="popup-header">
              <h2>${nameSafe}</h2>
              <span class="popup-badge badge-paid">Enrolled</span>
            </div>
            <div class="popup-details">
              <div class="detail-row">
                <span class="detail-label">Registered</span>
                <span class="detail-value">${escapeHtml(dateStr)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Enrollment</span>
                <span class="detail-value">${pricingSafe}</span>
              </div>
            </div>`;
            if (d.courseSlug) {
              const slugEnc = encodeURIComponent(String(d.courseSlug));
              html += `<div class="popup-actions">
                <a href="/courses/${slugEnc}" class="popup-btn popup-btn--outline popup-btn--block">View course page</a>
              </div>`;
            }
            if (d.fileKey) {
              html += downloadButtonHtml(d.fileKey, Boolean(d.pricingType === "free"));
            }
            popupContent.innerHTML = html;
            overlay.classList.add("active");
            document.body.style.overflow = "hidden";
            return;
          }

          const nameSafe = escapeHtml(d.itemName);
          const variantSafe = escapeHtml(d.itemVariant);
          const statusLabelSafe = escapeHtml(d.statusLabel);

          const dateStr = d.createdAt
            ? new Date(d.createdAt).toLocaleDateString(undefined, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            : "";

          const estDeliveryFormatted = d.estimatedDelivery
            ? new Date(d.estimatedDelivery).toLocaleDateString(undefined, {
                weekday: "short",
                month: "long",
                day: "numeric",
              })
            : "";

          const estDeliveryDisplay = estDeliveryFormatted
            ? estDeliveryFormatted
            : "3–5 business days";

          const priceRowInner = d.isFreeDigital
            ? '<span class="detail-value detail-value--free">Free</span>'
            : `<span class="detail-value">€${escapeHtml(String(d.itemPrice ?? ""))}</span>`;

          let html = `
            ${d.image ? `<img class="popup-image" src="${String(d.image).replace(/"/g, "&quot;")}" alt="${nameSafe}" />` : ""}
            <div class="popup-header">
              <h2>${nameSafe}</h2>
              <span class="popup-badge badge-${escapeHtml(d.badgeClass || d.status)}">${statusLabelSafe}</span>
            </div>

            <div class="popup-details">
              <div class="detail-row">
                <span class="detail-label">Price</span>
                ${priceRowInner}
              </div>
              ${
                d.itemVariant && d.itemVariant !== d.itemName
                  ? `
                <div class="detail-row">
                  <span class="detail-label">Variant</span>
                  <span class="detail-value">${variantSafe}</span>
                </div>
              `
                  : ""
              }
              <div class="detail-row">
                <span class="detail-label">Quantity</span>
                <span class="detail-value">${escapeHtml(d.itemQty || 1)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Date</span>
                <span class="detail-value">${escapeHtml(dateStr)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Order</span>
                <span class="detail-value detail-mono">#${escapeHtml(
                  (() => {
                    const raw = String(d.orderNumber || "");
                    if (raw.startsWith("free_claim_")) return "Free claim";
                    return raw.length > 14 ? raw.slice(-12) : raw;
                  })(),
                )}</span>
              </div>
            </div>
          `;

          if (!d.isDigital && !d.isCourse) {
            const stage = resolveTimelineStage(d);
            const courier = d.selectedCourier
              ? escapeHtml(d.selectedCourier)
              : "";
            const trackingNo = d.trackingNumber
              ? escapeHtml(d.trackingNumber)
              : "";
            const trackUrl = isSafeTrackingUrl(d.trackingUrl)
              ? d.trackingUrl
              : "";

            html += `<div class="popup-section popup-section--shipping">`;
            html += `<h3>Shipping</h3>`;
            html += `<div class="shipping-surface">`;
            html += buildShippingTimeline(stage);

            html += `<div class="shipping-main-grid${d.shippingAddress ? "" : " shipping-main-grid--meta-only"}">`;
            html += `<div class="shipping-meta-col">`;
            if (courier) {
              html += `<div class="sf-item"><span class="sf-key">Courier</span><span class="sf-val">${courier}</span></div>`;
            }
            if (trackingNo) {
              html += `<div class="sf-item"><span class="sf-key">Tracking №</span><span class="sf-val sf-val--mono">${trackingNo}</span></div>`;
            }
            html += `<div class="sf-item"><span class="sf-key">Est. delivery</span><span class="sf-val">${escapeHtml(estDeliveryDisplay)}</span></div>`;
            html += `</div>`;

            if (d.shippingAddress) {
              const a = d.shippingAddress;
              const cityLine = [a.zip, a.city].filter(Boolean).join(" ").trim();
              const addrLines = [
                a.name,
                a.street,
                [cityLine, a.country].filter(Boolean).join(" · "),
              ].filter(Boolean);
              const addrHtml = addrLines
                .map((line) => `<span class="ship-to-line">${escapeHtml(line)}</span>`)
                .join("");
              html += `<div class="ship-to-block">
                <span class="ship-to-label">Ship to</span>
                <div class="ship-to-body" role="group" aria-label="Shipping address">${addrHtml}</div>
              </div>`;
            }

            html += `</div>`;

            if (
              !d.trackingNumber &&
              d.status !== "cancelled" &&
              d.status !== "refunded" &&
              resolveTimelineStage(d) === "confirmed"
            ) {
              html += `<p class="popup-hint popup-hint--shipping">Tracking details will appear once your order is dispatched.</p>`;
            }

            html += `</div></div>`;

            if (trackUrl) {
              html += `<div class="popup-actions">
              <a href="${trackUrl}" target="_blank" rel="noopener noreferrer" class="popup-btn popup-btn--outline popup-btn--block">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Track parcel
              </a>
            </div>`;
            }
          } else if (d.isCourse) {
            if (d.courseSlug) {
              const slugEnc = encodeURIComponent(String(d.courseSlug));
              html += `<div class="popup-actions">
                <a href="/courses/${slugEnc}" class="popup-btn popup-btn--outline popup-btn--block">View course page</a>
              </div>`;
            }
            if (d.canDownload && d.fileKey) {
              html += downloadButtonHtml(d.fileKey, false);
            }
          }

          if (d.isDigital && d.canDownload && d.fileKey) {
            html += downloadButtonHtml(d.fileKey, Boolean(d.isFreeDigital));
          } else if (d.isDigital && !d.canDownload) {
            html += `<p class="popup-hint popup-hint--padded">Download will be available after payment is confirmed.</p>`;
          }

          popupContent.innerHTML = html;
          overlay.classList.add("active");
          document.body.style.overflow = "hidden";
        } catch (e) {
          console.error("Popup error:", e);
        }
      });
    });
  }

  function scrollToPurchaseLineFromHash() {
    const raw = window.location.hash.replace(/^#/, "");
    if (!raw.startsWith("purchase-line-")) return;
    requestAnimationFrame(() => {
      const el = document.getElementById(raw);
      if (!el) return;
      el.scrollIntoView({ behavior: "smooth", block: "center" });
      el.classList.add("purchase-card--hash-focus");
      window.setTimeout(() => {
        el.classList.remove("purchase-card--hash-focus");
      }, 2400);
    });
  }

  initPurchases();
  document.addEventListener("astro:page-load", initPurchases);
  document.addEventListener("astro:page-load", scrollToPurchaseLineFromHash);
</script>

<style>
  /* ─── Layout (Island Block — matching favorites) ─── */
  .account-page {
    padding: 0 12px;
    margin: 0 auto;
  }

  .purchases-section {
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    min-height: calc(100vh - 420px);
    display: flex;
    flex-direction: column;
    padding: 24px;
  }

  /* Category blocks — spacing matches store ProductGrid `.product-group` */
  .purchases-category {
    display: flex;
    flex-direction: column;
  }

  .purchases-category + .purchases-category {
    margin-top: 48px;
  }

  /* Same pattern as `ProductGrid.astro`: uppercase label + flex line */
  .purchases-category .section-header {
    display: flex;
    align-items: center;
    width: 100%;
    margin: 0 0 16px;
    gap: 16px;
  }

  .purchases-category .section-header::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .purchases-category .section-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--foreground);
    opacity: 0.7;
    white-space: nowrap;
    margin: 0;
  }

  .card-price--muted {
    font-weight: 600;
    opacity: 0.45;
  }

  /* ─── Empty State ─── */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 400px;
    padding: 40px 24px;
    flex: 1;
  }

  .empty-state svg {
    width: 64px;
    height: 64px;
    opacity: 0.3;
    margin-bottom: 24px;
  }
  .empty-state h3 {
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--foreground);
  }
  .empty-state p {
    font-size: 15px;
    opacity: 0.6;
    margin-bottom: 24px;
    max-width: 400px;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: var(--brand-violet);
    color: white;
    border: none;
    border-radius: var(--radius-lg);
    font-family: var(--font-family);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(132, 128, 255, 0.3);
  }
  .btn-primary:hover {
    background: #9d9aff;
    box-shadow: 0 8px 24px rgba(132, 128, 255, 0.5);
    transform: translateY(-2px);
  }

  /* ─── Card Grid ─── */
  .purchases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px;
  }

  /* ─── Purchase Card (small, like a product card) ─── */
  .purchase-card {
    all: unset;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    min-width: 0;
    background: var(--surface-muted);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.2s;
  }

  .purchase-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    border-color: var(--brand-violet);
  }

  .purchase-card.purchase-card--hash-focus {
    outline: 2px solid #22c55e;
    outline-offset: 3px;
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.12),
      0 0 0 4px color-mix(in srgb, #22c55e 32%, transparent);
    border-color: color-mix(in srgb, #22c55e 55%, var(--border-subtle));
  }

  .card-image {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--surface);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
  }
  .card-placeholder svg {
    width: 32px;
    height: 32px;
    opacity: 0.2;
  }

  /* Badge */
  .card-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 8px;
    border-radius: var(--radius-pill);
  }

  .badge-paid {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }
  .badge-processing {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
  }
  .badge-shipped {
    background: rgba(132, 128, 255, 0.15);
    color: var(--brand-violet);
  }
  .badge-delivered {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }
  .badge-cancelled {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }
  .badge-refunded {
    background: rgba(107, 114, 128, 0.15);
    color: #6b7280;
  }

  .badge-free {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }

  .card-body {
    padding: 10px 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--foreground);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-variant {
    font-size: 11px;
    opacity: 0.5;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-price {
    font-size: 14px;
    font-weight: 700;
    color: var(--brand-violet);
  }

  .card-price--free {
    color: #22c55e;
  }

  /* ─── Popup Overlay ─── */
  .popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(6px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.25s,
      visibility 0.25s;
    padding: 24px;
  }
  .popup-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .popup-card {
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.25);
    width: 100%;
    max-width: 440px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: popIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes popIn {
    from {
      opacity: 0;
      transform: scale(0.95) translateY(12px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  /* Match ProductDetail `.detail-close-btn` icon + hover (rotate / violet). */
  .popup-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    min-width: 36px;
    min-height: 36px;
    border-radius: 50%;
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    color: var(--foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 50;
    transition: all 0.2s;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }
  .popup-close:hover {
    background: var(--brand-violet);
    color: white;
    border-color: var(--brand-violet);
    transform: rotate(90deg);
  }

  .popup-content {
    padding: 0;
