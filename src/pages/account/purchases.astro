              <line x1="3" y1="6" x2="21" y2="6" />
              <path d="M16 10a4 4 0 0 1-8 0" />
            </svg>
            <h3>No purchases yet</h3>
            <p>Items you buy will appear here.</p>
            <a href="/store/fashion-design" class="btn-primary">
              Browse Products
            </a>
          </div>
        ) : (
          <div id="purchases-content">
            {
              physicalItems.length > 0 && (
                <section class="purchases-category" aria-labelledby="purchases-physical">
                  <div class="section-header">
                    <h2 id="purchases-physical" class="section-title">
                      Physical Products
                    </h2>
                  </div>
                  <div class="purchases-grid">
                    {physicalItems.map(({ order, item, product }) => {
                      const name = product?.name || item.variant || "Product";
                      const img = product?.image;
                      const isDigital = false;
                      const isCourse = false;
                      const { label: statusLabel, badgeClass } =
                        purchaseCardBadge(order, isDigital, isCourse);
                      const orderData = JSON.stringify({
                        kind: "orderItem",
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        createdAt: order.createdAt,
                        totalAmount: order.totalAmount,
                        status: order.status,
                        statusLabel,
                        badgeClass,
                        orderType: order.orderType,
                        selectedCourier: order.selectedCourier,
                        trackingNumber: order.trackingNumber,
                        trackingUrl: order.trackingUrl,
                        estimatedDelivery: order.estimatedDelivery,
                        shippingTimelineStage: order.shippingTimelineStage,
                        shippingAddress: order.shippingAddress,
                        itemName: name,
                        itemPrice: item.price,
                        itemQty: item.quantity,
                        itemVariant: item.variant,
                        itemType: item.productType || product?.productType,
                        isDigital,
                        isCourse,
                        canDownload: false,
                        fileKey: null,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class={`card-badge badge-${badgeClass}`}>
                              {statusLabel}
                            </span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            {item.variant && item.variant !== name && (
                              <span class="card-variant">{item.variant}</span>
                            )}
                            <span class="card-price">€{item.price}</span>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </section>
              )
            }

            {
              digitalItems.length > 0 && (
                <section class="purchases-category" aria-labelledby="purchases-digital">
                  <div class="section-header">
                    <h2 id="purchases-digital" class="section-title">
                      Digital Products
                    </h2>
                  </div>
                  <div class="purchases-grid">
                    {digitalItems.map(({ order, item, product }) => {
                      const name = product?.name || item.variant || "Product";
                      const img = product?.image;
                      const isDigital = true;
                      const isCourse = false;
                      const { label: statusLabel, badgeClass } =
                        purchaseCardBadge(order, isDigital, isCourse);
                      const canDownload =
                        orderAllowsDigitalDownload(order) && isDigital;
                      const fileKey = product?.digitalFileKey;
                      const orderData = JSON.stringify({
                        kind: "orderItem",
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        createdAt: order.createdAt,
                        totalAmount: order.totalAmount,
                        status: order.status,
                        statusLabel,
                        badgeClass,
                        orderType: order.orderType,
                        selectedCourier: order.selectedCourier,
                        trackingNumber: order.trackingNumber,
                        trackingUrl: order.trackingUrl,
                        estimatedDelivery: order.estimatedDelivery,
                        shippingTimelineStage: order.shippingTimelineStage,
                        shippingAddress: order.shippingAddress,
                        itemName: name,
                        itemPrice: item.price,
                        itemQty: item.quantity,
                        itemVariant: item.variant,
                        itemType: item.productType || product?.productType,
                        isDigital,
                        isCourse,
                        canDownload,
                        fileKey,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class={`card-badge badge-${badgeClass}`}>
                              {statusLabel}
                            </span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            {item.variant && item.variant !== name && (
                              <span class="card-variant">{item.variant}</span>
                            )}
                            <span class="card-price">€{item.price}</span>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </section>
              )
            }

            {
              courseRegistrations.length + orderOnlyCourseItems.length > 0 && (
                <section class="purchases-category" aria-labelledby="purchases-courses">
                  <div class="section-header">
                    <h2 id="purchases-courses" class="section-title">
                      Courses
                    </h2>
                  </div>
                  <div class="purchases-grid">
                    {courseRegistrations.map((reg: any) => {
                      const name =
                        reg.course?.name || reg.courseName || "Course";
                      const img = reg.course?.mainImage;
                      const slugCurrent = reg.course?.slug?.current || "";
                      const fileKey = reg.course?.digitalFileKey || null;
                      const cardPrice = courseRegistrationDisplayPrice(reg);
                      const priceMuted =
                        cardPrice === "—" ||
                        cardPrice === "Pay at door" ||
                        cardPrice === "Free";
                      const orderData = JSON.stringify({
                        kind: "courseRegistration",
                        registrationId: reg._id,
                        courseName: name,
                        createdAt: reg.createdAt,
                        pricingType: reg.pricingType,
                        donationAmount: reg.donationAmount,
                        donationCurrency: reg.donationCurrency,
                        paidAmount: reg.paidAmount,
                        paidCurrency: reg.paidCurrency,
                        doorPriceEur: reg.course?.price ?? null,
                        doorPricePln: reg.course?.pricePLN ?? null,
                        courseSlug: slugCurrent,
                        fileKey,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class="card-badge badge-paid">Enrolled</span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            <span class="card-variant">Your registration</span>
                            <span
                              class={`card-price${priceMuted ? " card-price--muted" : ""}`}
                            >
                              {cardPrice}
                            </span>
                          </div>
                        </button>
                      );
                    })}
                    {orderOnlyCourseItems.map(({ order, item, product }) => {
                      const name = product?.name || item.variant || "Course";
                      const img = product?.image;
                      const isDigital = false;
                      const isCourse = true;
                      const { label: statusLabel, badgeClass } =
                        purchaseCardBadge(order, isDigital, isCourse);
                      const slugCurrent = product?.slug || "";
                      const fileKey = product?.digitalFileKey || null;
                      const canDownload =
                        Boolean(fileKey) && orderAllowsDigitalDownload(order);
                      const orderData = JSON.stringify({
                        kind: "orderItem",
                        orderId: order._id,
                        orderNumber: order.orderNumber,
                        createdAt: order.createdAt,
                        totalAmount: order.totalAmount,
                        status: order.status,
                        statusLabel,
                        badgeClass,
                        orderType: order.orderType,
                        selectedCourier: order.selectedCourier,
                        trackingNumber: order.trackingNumber,
                        trackingUrl: order.trackingUrl,
                        estimatedDelivery: order.estimatedDelivery,
                        shippingTimelineStage: order.shippingTimelineStage,
                        shippingAddress: order.shippingAddress,
                        itemName: name,
                        itemPrice: item.price,
                        itemQty: item.quantity,
                        itemVariant: item.variant,
                        itemType: item.productType || product?.productType,
                        isDigital,
                        isCourse,
                        canDownload,
                        fileKey,
                        courseSlug: slugCurrent,
                        image: img ? urlFor(img).width(400).url() : null,
                      });
                      return (
                        <button
                          type="button"
                          class="purchase-card"
                          data-order={orderData}
                        >
                          <div class="card-image">
                            {img ? (
                              <img
                                src={urlFor(img).width(400).url()}
                                alt={name}
                                loading="lazy"
                              />
                            ) : (
                              <div class="card-placeholder">
                                <svg
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.5"
                                >
                                  <rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                  />
                                  <circle cx="8.5" cy="8.5" r="1.5" />
                                  <polyline points="21 15 16 10 5 21" />
                                </svg>
                              </div>
                            )}
                            <span class={`card-badge badge-${badgeClass}`}>
                              {statusLabel}
                            </span>
                          </div>
                          <div class="card-body">
                            <h4 class="card-title">{name}</h4>
                            {item.variant && item.variant !== name && (
                              <span class="card-variant">{item.variant}</span>
                            )}
                            <span class="card-price">€{item.price}</span>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </section>
              )
            }
          </div>
        )
      }
    </div>

    <!-- Detail popup (hidden by default) -->
    <div class="popup-overlay" id="popup-overlay">
      <div class="popup-card" id="popup-card">
        <button class="popup-close" id="popup-close" aria-label="Close">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div class="popup-content" id="popup-content"></div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // @ts-nocheck
  function escapeHtml(s) {
    if (s == null || s === undefined) return "";
    return String(s)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function resolveTimelineStage(d) {
    const field =
      d.shippingTimelineStage === "shipped" ||
      d.shippingTimelineStage === "delivered" ||
      d.shippingTimelineStage === "confirmed"
        ? d.shippingTimelineStage
        : null;
    const fromStatus =
      d.status === "delivered"
        ? "delivered"
        : d.status === "shipped"
          ? "shipped"
          : "confirmed";
    function rank(t) {
      if (t === "delivered") return 2;
      if (t === "shipped") return 1;
      return 0;
    }
    const r = Math.max(
      field != null ? rank(field) : -1,
      rank(fromStatus),
    );
    return r === 2 ? "delivered" : r === 1 ? "shipped" : "confirmed";
  }

  function buildShippingTimeline(stage) {
    const complete = [
      true,
      stage === "shipped" || stage === "delivered",
      stage === "delivered",
    ];
    let currentIdx = -1;
    for (let i = 0; i < 3; i++) {
      if (!complete[i]) {
        currentIdx = i;
        break;
      }
    }
    const labels = ["Confirmed", "Shipped", "Delivered"];
    const check =
      '<svg class="st-check" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';

    let html =
      '<div class="ship-timeline ship-timeline--compact" role="list" aria-label="Delivery progress">';
    for (let i = 0; i < 3; i++) {
      let stepClass = "st-step";
      if (complete[i]) stepClass += " st-step--done";
      else if (i === currentIdx) stepClass += " st-step--current";
      else stepClass += " st-step--pending";

      const inner = complete[i] ? check : "";
      html += `<div class="${stepClass}" role="listitem"><span class="st-node">${inner}</span><span class="st-label">${labels[i]}</span></div>`;

      if (i < 2) {
        let connClass = "st-conn";
        if (complete[i + 1]) connClass += " st-conn--done";
        else if (complete[i] && !complete[i + 1]) connClass += " st-conn--prog";
        html += `<div class="${connClass}" aria-hidden="true"></div>`;
      }
    }
    html += "</div>";
    return html;
  }

  function isSafeTrackingUrl(url) {
    if (!url || typeof url !== "string") return false;
    try {
      const u = new URL(url);
      return u.protocol === "https:" || u.protocol === "http:";
    } catch {
      return false;
    }
  }

  function courseRegistrationPricingLabel(d) {
    const pt = d.pricingType;
    if (pt === "free") return "Free";
    if (pt === "payAtDoor") {
      const eur = d.doorPriceEur;
      const pln = d.doorPricePln;
      if (eur != null && Number(eur) > 0) {
        if (pln != null && Number(pln) > 0) {
          return `€${eur} or ${pln} zł at the door`;
        }
        return `€${eur} at the door`;
      }
      if (pln != null && Number(pln) > 0) {
        return `${pln} zł at the door`;
      }
      return "Pay at the door";
    }
    if (pt === "donation") {
      const amt = d.donationAmount;
      if (amt != null && Number(amt) > 0) {
        return d.donationCurrency === "PLN" ? `${amt} zł donated` : `€${amt} donated`;
      }
      return "Registered (no donation)";
    }
    if (pt === "paid" && d.paidAmount != null) {
      return d.paidCurrency === "PLN" ? `${d.paidAmount} zł paid` : `€${d.paidAmount} paid`;
    }
    return "—";
  }

  function downloadButtonHtml(fileKey) {
    return `
              <div class="popup-actions">
              <a href="/api/download/${encodeURIComponent(String(fileKey))}" class="popup-btn popup-btn--primary popup-btn--block" download>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Download files
              </a>
              </div>
            `;
  }

  function initPurchases() {
    const overlay = document.getElementById("popup-overlay");
    const popupContent = document.getElementById("popup-content");
    const popupClose = document.getElementById("popup-close");
    if (!overlay || !popupContent || !popupClose) return;

    function close() {
      overlay?.classList.remove("active");
      document.body.style.overflow = "";
    }

    popupClose.addEventListener("click", close);
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });

    document.querySelectorAll(".purchase-card").forEach((card) => {
      card.addEventListener("click", () => {
        const raw = card.getAttribute("data-order");
        if (!raw) return;

        try {
          const d = JSON.parse(raw);

          if (d.kind === "courseRegistration") {
            const nameSafe = escapeHtml(d.courseName);
            const dateStr = d.createdAt
              ? new Date(d.createdAt).toLocaleDateString(undefined, {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              : "";
            const pricingSafe = escapeHtml(courseRegistrationPricingLabel(d));
            let html = `
            ${d.image ? `<img class="popup-image" src="${String(d.image).replace(/"/g, "&quot;")}" alt="${nameSafe}" />` : ""}
            <div class="popup-header">
              <h2>${nameSafe}</h2>
              <span class="popup-badge badge-paid">Enrolled</span>
            </div>
            <div class="popup-details">
              <div class="detail-row">
                <span class="detail-label">Registered</span>
                <span class="detail-value">${escapeHtml(dateStr)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Enrollment</span>
                <span class="detail-value">${pricingSafe}</span>
              </div>
            </div>`;
            if (d.courseSlug) {
              const slugEnc = encodeURIComponent(String(d.courseSlug));
              html += `<div class="popup-actions">
                <a href="/courses/${slugEnc}" class="popup-btn popup-btn--outline popup-btn--block">View course page</a>
              </div>`;
            }
            if (d.fileKey) {
              html += downloadButtonHtml(d.fileKey);
            }
            popupContent.innerHTML = html;
            overlay.classList.add("active");
            document.body.style.overflow = "hidden";
            return;
          }

          const nameSafe = escapeHtml(d.itemName);
          const variantSafe = escapeHtml(d.itemVariant);
          const statusLabelSafe = escapeHtml(d.statusLabel);

          const dateStr = d.createdAt
            ? new Date(d.createdAt).toLocaleDateString(undefined, {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            : "";

          const estDeliveryFormatted = d.estimatedDelivery
            ? new Date(d.estimatedDelivery).toLocaleDateString(undefined, {
                weekday: "short",
                month: "long",
                day: "numeric",
              })
            : "";

          const estDeliveryDisplay = estDeliveryFormatted
            ? estDeliveryFormatted
            : "3–5 business days";

          let html = `
            ${d.image ? `<img class="popup-image" src="${String(d.image).replace(/"/g, "&quot;")}" alt="${nameSafe}" />` : ""}
            <div class="popup-header">
              <h2>${nameSafe}</h2>
              <span class="popup-badge badge-${escapeHtml(d.badgeClass || d.status)}">${statusLabelSafe}</span>
            </div>

            <div class="popup-details">
              <div class="detail-row">
                <span class="detail-label">Price</span>
                <span class="detail-value">€${escapeHtml(d.itemPrice)}</span>
              </div>
              ${
                d.itemVariant && d.itemVariant !== d.itemName
                  ? `
                <div class="detail-row">
                  <span class="detail-label">Variant</span>
                  <span class="detail-value">${variantSafe}</span>
                </div>
              `
                  : ""
              }
              <div class="detail-row">
                <span class="detail-label">Quantity</span>
                <span class="detail-value">${escapeHtml(d.itemQty || 1)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Date</span>
                <span class="detail-value">${escapeHtml(dateStr)}</span>
              </div>
              <div class="detail-row">
                <span class="detail-label">Order</span>
                <span class="detail-value detail-mono">#${escapeHtml((d.orderNumber || "").slice(-10))}</span>
              </div>
            </div>
          `;

          if (!d.isDigital && !d.isCourse) {
            const stage = resolveTimelineStage(d);
            const courier = d.selectedCourier
              ? escapeHtml(d.selectedCourier)
              : "";
            const trackingNo = d.trackingNumber
              ? escapeHtml(d.trackingNumber)
              : "";
            const trackUrl = isSafeTrackingUrl(d.trackingUrl)
              ? d.trackingUrl
              : "";

            html += `<div class="popup-section popup-section--shipping">`;
            html += `<h3>Shipping</h3>`;
            html += `<div class="shipping-surface">`;
            html += buildShippingTimeline(stage);

            html += `<div class="shipping-main-grid${d.shippingAddress ? "" : " shipping-main-grid--meta-only"}">`;
            html += `<div class="shipping-meta-col">`;
            if (courier) {
              html += `<div class="sf-item"><span class="sf-key">Courier</span><span class="sf-val">${courier}</span></div>`;
            }
            if (trackingNo) {
              html += `<div class="sf-item"><span class="sf-key">Tracking №</span><span class="sf-val sf-val--mono">${trackingNo}</span></div>`;
            }
            html += `<div class="sf-item"><span class="sf-key">Est. delivery</span><span class="sf-val">${escapeHtml(estDeliveryDisplay)}</span></div>`;
            html += `</div>`;

            if (d.shippingAddress) {
              const a = d.shippingAddress;
              const cityLine = [a.zip, a.city].filter(Boolean).join(" ").trim();
              const addrLines = [
                a.name,
                a.street,
                [cityLine, a.country].filter(Boolean).join(" · "),
              ].filter(Boolean);
              const addrHtml = addrLines
                .map((line) => `<span class="ship-to-line">${escapeHtml(line)}</span>`)
                .join("");
              html += `<div class="ship-to-block">
                <span class="ship-to-label">Ship to</span>
                <div class="ship-to-body" role="group" aria-label="Shipping address">${addrHtml}</div>
              </div>`;
            }

            html += `</div>`;

            if (
              !d.trackingNumber &&
              d.status !== "cancelled" &&
              d.status !== "refunded" &&
              resolveTimelineStage(d) === "confirmed"
            ) {
              html += `<p class="popup-hint popup-hint--shipping">Tracking details will appear once your order is dispatched.</p>`;
            }

            html += `</div></div>`;

            if (trackUrl) {
              html += `<div class="popup-actions">
              <a href="${trackUrl}" target="_blank" rel="noopener noreferrer" class="popup-btn popup-btn--outline popup-btn--block">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Track parcel
              </a>
            </div>`;
            }
          } else if (d.isCourse) {
            if (d.courseSlug) {
              const slugEnc = encodeURIComponent(String(d.courseSlug));
              html += `<div class="popup-actions">
                <a href="/courses/${slugEnc}" class="popup-btn popup-btn--outline popup-btn--block">View course page</a>
              </div>`;
            }
            if (d.canDownload && d.fileKey) {
              html += downloadButtonHtml(d.fileKey);
            }
          }

          if (d.isDigital && d.canDownload && d.fileKey) {
            html += downloadButtonHtml(d.fileKey);
          } else if (d.isDigital && !d.canDownload) {
            html += `<p class="popup-hint popup-hint--padded">Download will be available after payment is confirmed.</p>`;
          }

          popupContent.innerHTML = html;
          overlay.classList.add("active");
          document.body.style.overflow = "hidden";
        } catch (e) {
          console.error("Popup error:", e);
        }
      });
    });
  }

  initPurchases();
  document.addEventListener("astro:page-load", initPurchases);
</script>

