---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Checkout - Visupair">
  <main class="checkout-page">
    <div class="checkout-container">
      <div class="checkout-inner">
        <!-- Mobile-only: back link sits above both columns -->
        <a href="/cart" class="back-link back-link-mobile">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Back to Cart
        </a>

        <div class="checkout-layout">
          <!-- Left: Shipping Form -->
          <div class="checkout-form-column">
            <a href="/cart" class="back-link back-link-desktop">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
              Back to Cart
            </a>

            <h1 class="checkout-title">Shipping Information</h1>

            <form id="cart-shipping-form" class="shipping-form">
              <div class="form-section">
                <h3 class="section-title">Contact</h3>
                <div class="form-group">
                  <input
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                    class="form-input"
                  />
                </div>
              </div>

              <div class="form-section">
                <h3 class="section-title">Delivery</h3>
                <div class="form-row">
                  <div
                    class="custom-select-container"
                    id="country-custom-select"
                  >
                    <button
                      type="button"
                      class="custom-select-trigger"
                      id="country-trigger"
                    >
                      <span class="selected-text">Poland</span>
                      <svg
                        class="arrow-icon"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <polyline points="6 9 12 15 18 9"></polyline>
                      </svg>
                    </button>
                    <div class="custom-options">
                      <div class="custom-option selected" data-value="PL">
                        Poland
                      </div>
                      <div class="custom-option" data-value="DE">Germany</div>
                      <div class="custom-option" data-value="FR">France</div>
                      <div class="custom-option" data-value="IT">Italy</div>
                      <div class="custom-option" data-value="ES">Spain</div>
                      <div class="custom-option" data-value="NL">
                        Netherlands
                      </div>
                      <div class="custom-option" data-value="BE">Belgium</div>
                      <div class="custom-option" data-value="AT">Austria</div>
                      <div class="custom-option" data-value="SE">Sweden</div>
                      <div class="custom-option" data-value="DK">Denmark</div>
                      <div class="custom-option" data-value="FI">Finland</div>
                      <div class="custom-option" data-value="IE">Ireland</div>
                      <div class="custom-option" data-value="PT">Portugal</div>
                      <div class="custom-option" data-value="GR">Greece</div>
                      <div class="custom-option" data-value="CZ">
                        Czech Republic
                      </div>
                      <div class="custom-option" data-value="HU">Hungary</div>
                      <div class="custom-option" data-value="RO">Romania</div>
                      <div class="custom-option" data-value="BG">Bulgaria</div>
                      <div class="custom-option" data-value="HR">Croatia</div>
                      <div class="custom-option" data-value="SI">Slovenia</div>
                      <div class="custom-option" data-value="SK">Slovakia</div>
                      <div class="custom-option" data-value="GB">
                        United Kingdom
                      </div>
                      <div class="custom-option" data-value="US">
                        United States
                      </div>
                    </div>
                    <input
                      type="hidden"
                      name="country"
                      id="country-value"
                      value="PL"
                    />
                  </div>
                </div>
              </div>

              <div class="form-row two-col">
                <input
                  type="text"
                  name="firstName"
                  placeholder="First name"
                  required
                  class="form-input"
                />
                <input
                  type="text"
                  name="lastName"
                  placeholder="Last name"
                  required
                  class="form-input"
                />
              </div>

              <div class="form-row">
                <input
                  type="text"
                  name="address"
                  placeholder="Address"
                  required
                  class="form-input"
                />
              </div>

              <div class="form-row">
                <input
                  type="text"
                  name="apartment"
                  placeholder="Apartment, suite, etc. (optional)"
                  class="form-input"
                />
              </div>

              <div class="form-row two-col">
                <input
                  type="text"
                  name="postalCode"
                  placeholder="Postal code"
                  required
                  class="form-input"
                />
                <input
                  type="text"
                  name="city"
                  placeholder="City"
                  required
                  class="form-input"
                />
              </div>

              <div class="form-row">
                <input
                  type="tel"
                  name="phone"
                  placeholder="Phone (optional)"
                  class="form-input"
                />
              </div>

              <!-- Shipping Method -->
              <div
                class="form-section"
                id="shipping-options-section"
                style="display: none;"
              >
                <h3 class="section-title">Shipping Method</h3>
                <div
                  class="shipping-loading"
                  id="shipping-loading"
                  style="display: none;"
                >
                  <div class="spinner"></div> Calculating rates...
                </div>
                <div class="shipping-options-list" id="shipping-result-list">
                </div>
                <input
                  type="hidden"
                  name="shippingRateId"
                  id="selected-shipping-id"
                />
                <input
                  type="hidden"
                  name="shippingAmount"
                  id="selected-shipping-amount"
                />
                <input
                  type="hidden"
                  name="shippingLabel"
                  id="selected-shipping-label"
                />
              </div>

              <div class="form-actions">
                <button type="submit" class="btn-pay btn-pay-left" id="pay-btn"
                  >Continue to Payment</button
                >
              </div>
            </form>
          </div>

          <!-- Right: Order Summary -->
          <aside class="checkout-summary-column">
            <div class="summary-card">
              <h3>Order Summary</h3>
              <div id="checkout-items-list" class="checkout-items"></div>
              <div class="cost-breakdown">
                <div class="cost-row">
                  <span>Subtotal</span>
                  <span id="checkout-subtotal">€0</span>
                </div>
                <div class="cost-row">
                  <span>Shipping</span>
                  <span class="shipping-cost" id="checkout-shipping"
                    >Calculated below</span
                  >
                </div>
              </div>
              <div class="total-row">
                <span>Total</span>
                <span id="checkout-total">€0</span>
              </div>
              <div class="summary-pay-slot">
                <button
                  type="submit"
                  form="cart-shipping-form"
                  class="btn-pay"
                  id="pay-btn-right">Continue to Payment</button
                >
              </div>
              <p class="secure-note">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                  ></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
                Secure checkout powered by Stripe
              </p>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { cartStore, initCart } from "../../lib/cartStore";
  import type { CartItem } from "../../lib/cartStore";
  import { showCheckoutToast } from "../../lib/checkout-toast";

  async function initCheckoutPage() {
    initCart();

    const items = cartStore.get();
    if (items.length === 0) {
      window.location.href = "/cart";
      return;
    }

    try {
      const { authClient } = await import("../../lib/auth-client");
      const sessionRes = await authClient.getSession();
      if (!sessionRes.data?.user?.email) {
        window.location.href = `/login?redirect=${encodeURIComponent("/cart/checkout")}`;
        return;
      }
    } catch {
      window.location.href = `/login?redirect=${encodeURIComponent("/cart/checkout")}`;
      return;
    }

    const form = document.getElementById(
      "cart-shipping-form",
    ) as HTMLFormElement;
    if (!form) return;
    if ((form as any)._checkoutInit) return;
    (form as any)._checkoutInit = true;

    function detectUserCurrency(): "EUR" | "PLN" {
      const urlParams = new URLSearchParams(window.location.search);
      const dc = urlParams.get("currency");
      if (dc === "EUR" || dc === "PLN") return dc;
      try {
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        if (tz && (tz.includes("Warsaw") || tz === "Europe/Warsaw"))
          return "PLN";
      } catch {}
      const locale = navigator.language || (navigator as any).userLanguage;
      if (locale && locale.toLowerCase().startsWith("pl")) return "PLN";
      return "EUR";
    }

    const currency = detectUserCurrency();

    function formatPrice(eur: number, pln: number): string {
      return currency === "PLN" ? `${pln.toFixed(2)} zł` : `€${eur.toFixed(2)}`;
    }

    function formatAmount(amount: number): string {
      return currency === "PLN"
        ? `${amount.toFixed(2)} zł`
        : `€${amount.toFixed(2)}`;
    }

    const itemsListEl = document.getElementById("checkout-items-list")!;
    const subtotalEl = document.getElementById("checkout-subtotal")!;
    const totalEl = document.getElementById("checkout-total")!;
    const shippingCostEl = document.getElementById("checkout-shipping")!;

    let subtotalEur = 0;
    let subtotalPln = 0;

    itemsListEl.innerHTML = items
      .map((item: CartItem) => {
        subtotalEur += item.price;
        subtotalPln += item.pricePLN;
        return `
        <div class="checkout-item">
          <div class="checkout-item-thumb">
            <img src="${item.image}" alt="${item.name}" />
          </div>
          <div class="checkout-item-info">
            <h4>${item.name}</h4>
            ${item.selectedSize ? `<p>Size: ${item.selectedSize}</p>` : ""}
          </div>
          <span class="checkout-item-price">${formatPrice(item.price, item.pricePLN)}</span>
        </div>
      `;
      })
      .join("");

    const subtotalDisplay = currency === "PLN" ? subtotalPln : subtotalEur;
    subtotalEl.textContent = formatAmount(subtotalDisplay);
    totalEl.textContent = formatAmount(subtotalDisplay);

    // Pre-fill email
    (async () => {
      try {
        const { authClient } = await import("../../lib/auth-client");
        const session = await authClient.getSession();
        if (session.data?.user) {
          const emailInput = form.querySelector(
            'input[name="email"]',
          ) as HTMLInputElement;
          if (emailInput) emailInput.value = session.data.user.email;
          const name = session.data.user.name || "";
          const [first, ...rest] = name.split(" ");
          const firstInput = form.querySelector(
            'input[name="firstName"]',
          ) as HTMLInputElement;
          const lastInput = form.querySelector(
            'input[name="lastName"]',
          ) as HTMLInputElement;
          if (firstInput) firstInput.value = first || "";
          if (lastInput) lastInput.value = rest.join(" ") || "";
        }
      } catch {}
    })();

    // Custom select
    const customSelect = document.getElementById("country-custom-select")!;
    const trigger = document.getElementById("country-trigger")!;
    const options = customSelect.querySelectorAll(".custom-option");
    const hiddenInput = document.getElementById(
      "country-value",
    ) as HTMLInputElement;
    const selectedText = trigger.querySelector(".selected-text")!;

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      customSelect.classList.toggle("open");
    });
    options.forEach((option) => {
      option.addEventListener("click", (e) => {
        e.stopPropagation();
        selectedText.textContent = option.textContent;
        hiddenInput.value = (option as HTMLElement).dataset.value || "PL";
        options.forEach((o) => o.classList.remove("selected"));
        option.classList.add("selected");
        customSelect.classList.remove("open");
        hiddenInput.dispatchEvent(new Event("change"));
      });
    });
    document.addEventListener("click", (e) => {
      if (!customSelect.contains(e.target as Node))
        customSelect.classList.remove("open");
    });

    // Shipping rates
    const optionsSection = document.getElementById("shipping-options-section")!;
    const loading = document.getElementById("shipping-loading")!;
    const list = document.getElementById("shipping-result-list")!;
    const rateInputs = form.querySelectorAll(
      'input[name="address"], input[name="city"], input[name="postalCode"], input[name="country"]',
    );
    let rateTimeout: any;

    rateInputs.forEach((input) => {
      input.addEventListener("change", fetchRates);
      input.addEventListener("blur", fetchRates);
    });

    let currentShippingAmount = 0;

    async function fetchRates() {
      clearTimeout(rateTimeout);
      rateTimeout = setTimeout(async () => {
        const country = (
          form.querySelector('[name="country"]') as HTMLInputElement
        ).value;
        const city = (form.querySelector('[name="city"]') as HTMLInputElement)
          .value;
        const postalCode = (
          form.querySelector('[name="postalCode"]') as HTMLInputElement
        ).value;
        const address = (
          form.querySelector('[name="address"]') as HTMLInputElement
        ).value;

        if (!country || !city || !postalCode || !address) return;

        const hasPhysical = items.some(
          (i: CartItem) => i.productType === "physical",
        );
        if (!hasPhysical) return;

        const quoteLineItems = items.map((i: CartItem) => ({
          productId: i.productId,
          name: i.name,
          price: currency === "PLN" ? i.pricePLN : i.price,
          quantity: Math.max(1, i.quantity || 1),
          productType: i.productType,
          selectedSize: i.selectedSize,
        }));

        optionsSection.style.display = "block";
        loading.style.display = "flex";
        list.innerHTML = "";

        try {
          const res = await fetch("/api/shipping/rates", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({
              country,
              city,
              postalCode,
              address,
              cartItems: quoteLineItems,
            }),
          });
          const data = await res.json();
          loading.style.display = "none";

          if (data.error || !data.rates || data.rates.length === 0) {
            list.innerHTML =
              '<div class="error-msg">No shipping options available for this address.</div>';
            return;
          }

          list.innerHTML = data.rates
            .map((rate: any, index: number) => {
              const logoHtml = rate.provider_image_75
                ? `<img src="${rate.provider_image_75}" alt="${rate.provider}" class="carrier-logo-img" />`
                : `<span class="carrier-logo-fallback">${rate.provider}</span>`;

              return `
              <label class="shipping-option-row${index === 0 ? " selected" : ""}">
                <span class="shipping-radio-cell">
                  <input type="radio" class="shipping-option-row__radio" name="shipping_option" value="${rate.id}"
                    data-amount="${rate.amount}"
                    data-currency="${rate.currency}"
                    data-label="${rate.provider}"
                    ${index === 0 ? "checked" : ""} />
                  <span class="shipping-option-row__radio-box" aria-hidden="true">
                    <svg class="shipping-option-row__radio-icon" viewBox="-0.12 -0.12 12.35 8.82" xmlns="http://www.w3.org/2000/svg" fill="none" aria-hidden="true">
                      <path fill="currentColor" d="M11.7202 1.70725L5.16025 8.26725C4.97225 8.45525 4.71825 8.56025 4.45325 8.56025C4.18825 8.56025 3.93325 8.45525 3.74625 8.26725L0.29325 4.81425C-0.0977499 4.42325 -0.0977499 3.79125 0.29325 3.40025C0.68425 3.00925 1.31625 3.00925 1.70725 3.40025L4.45325 6.14625L10.3062 0.29325C10.6972 -0.0977499 11.3292 -0.0977499 11.7202 0.29325C12.1112 0.68425 12.1112 1.31625 11.7202 1.70725Z"/>
                    </svg>
                  </span>
                </span>
                <div class="carrier-logo-wrapper">${logoHtml}</div>
                <div class="option-details">
                  <span class="provider-name">${rate.provider}</span>
                  <span class="delivery-estimate">3-5 days</span>
                </div>
                <span class="option-price">${rate.currency} ${rate.amount}</span>
              </label>
            `;
            })
            .join("");

          list.querySelectorAll('input[type="radio"]').forEach((radio) => {
            radio.addEventListener("change", () => {
              list
                .querySelectorAll(".shipping-option-row")
                .forEach((r) => r.classList.remove("selected"));
              (radio as HTMLInputElement)
                .closest(".shipping-option-row")
                ?.classList.add("selected");
              updateShippingSelection(radio as HTMLInputElement);
            });
          });

          const first = list.querySelector(
            'input[type="radio"]',
          ) as HTMLInputElement;
          if (first) updateShippingSelection(first);
        } catch (e) {
          console.error(e);
          loading.style.display = "none";
          list.innerHTML = '<div class="error-msg">Failed to load rates.</div>';
        }
      }, 500);
    }

    const exchangeCache: Record<string, number> = {};

    async function getExchangeRate(from: string, to: string): Promise<number> {
      if (from === to) return 1;
      const key = `${from}_${to}`;
      if (exchangeCache[key]) return exchangeCache[key];
      try {
        const res = await fetch(`https://open.er-api.com/v6/latest/${from}`);
        const data = await res.json();
        if (data?.rates?.[to]) {
          exchangeCache[key] = data.rates[to];
          return data.rates[to];
        }
      } catch {}
      const fallbacks: Record<string, number> = { EUR_PLN: 4.3, PLN_EUR: 0.23 };
      return fallbacks[key] || 1;
    }

    async function updateShippingSelection(radio: HTMLInputElement) {
      const originalAmount = parseFloat(radio.dataset.amount || "0");
      const rateCurrency = radio.dataset.currency || "PLN";
      const label = radio.dataset.label || "";

      let amount = originalAmount;
      if (rateCurrency !== currency) {
        const rate = await getExchangeRate(rateCurrency, currency);
        amount = originalAmount * rate;
      }

      (
        document.getElementById("selected-shipping-id") as HTMLInputElement
      ).value = radio.value;
      (
        document.getElementById("selected-shipping-amount") as HTMLInputElement
      ).value = amount.toFixed(2);
      (
        document.getElementById("selected-shipping-label") as HTMLInputElement
      ).value = label;

      currentShippingAmount = amount;
      shippingCostEl.textContent = formatAmount(amount);
      totalEl.textContent = formatAmount(subtotalDisplay + amount);
    }

    // Form submission
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const selectedShippingId = (
        document.getElementById("selected-shipping-id") as HTMLInputElement
      ).value;
      const selectedShippingAmount = (
        document.getElementById("selected-shipping-amount") as HTMLInputElement
      ).value;
      const selectedShippingLabel = (
        document.getElementById("selected-shipping-label") as HTMLInputElement
      ).value;

      if (
        !selectedShippingId ||
        !selectedShippingAmount ||
        parseFloat(selectedShippingAmount) <= 0
      ) {
        showCheckoutToast(
          "Please select a shipping method before proceeding.",
          "Shipping method required",
        );
        return;
      }

      const allPayBtns = document.querySelectorAll<HTMLButtonElement>(
        "#pay-btn, #pay-btn-right",
      );
      allPayBtns.forEach((btn) => {
        btn.textContent = "Redirecting to payment...";
        btn.disabled = true;
      });

      try {
        const { authClient } = await import("../../lib/auth-client");
        const session = await authClient.getSession();
        if (!session.data?.user?.email) {
          showCheckoutToast(
            "Please sign in to continue to payment.",
            "Sign in required",
          );
          window.location.href = `/login?redirect=${encodeURIComponent("/cart/checkout")}`;
          return;
        }

        const cartItems = items.map((i: CartItem) => ({
          productId: i.productId,
          name: i.name,
          price: currency === "PLN" ? i.pricePLN : i.price,
          quantity: Math.max(1, i.quantity || 1),
          productType: i.productType,
          selectedSize: i.selectedSize,
        }));

        const res = await fetch("/api/cart-checkout", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: cartItems,
            currency,
            selectedShippingId,
            selectedShippingAmount,
            selectedShippingLabel,
            shippingAddress: {
              firstName:
                (form.querySelector('[name="firstName"]') as HTMLInputElement)
                  ?.value || "",
              lastName:
                (form.querySelector('[name="lastName"]') as HTMLInputElement)
                  ?.value || "",
              address:
                (form.querySelector('[name="address"]') as HTMLInputElement)
                  ?.value || "",
              apartment:
                (form.querySelector('[name="apartment"]') as HTMLInputElement)
                  ?.value || "",
              city:
                (form.querySelector('[name="city"]') as HTMLInputElement)
                  ?.value || "",
              postalCode:
                (form.querySelector('[name="postalCode"]') as HTMLInputElement)
                  ?.value || "",
              country:
                (form.querySelector('[name="country"]') as HTMLInputElement)
                  ?.value || "PL",
              phone:
                (form.querySelector('[name="phone"]') as HTMLInputElement)
                  ?.value || "",
            },
          }),
        });

        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          showCheckoutToast(
            data.error || "Failed to start checkout.",
            "Checkout",
          );
          allPayBtns.forEach((btn) => {
            btn.textContent = "Continue to Payment";
            btn.disabled = false;
          });
        }
      } catch (err) {
        console.error("Checkout error:", err);
        showCheckoutToast(
          "Something went wrong. Please try again.",
          "Checkout",
        );
        allPayBtns.forEach((btn) => {
          btn.textContent = "Continue to Payment";
          btn.disabled = false;
        });
      }
    });
  }

  initCheckoutPage();
  document.addEventListener("astro:after-swap", initCheckoutPage);
</script>

<!-- Static elements: scoped styles -->
<style>
  .checkout-page {
    padding: 0px 12px;
    margin: 0 auto;
  }
  .checkout-container {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    min-height: calc(100vh - 420px);
    padding: 40px;
    box-sizing: border-box;
  }
  .checkout-inner {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  .checkout-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 32px;
    align-items: start;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--foreground);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: transparent;
    opacity: 0.6;
    margin-bottom: 24px;
    transition: all 0.2s;
  }
  .back-link:hover {
    opacity: 1;
    border-color: var(--brand-violet);
    color: var(--brand-violet);
    background: rgba(132, 128, 255, 0.06);
  }

  /* Mobile: show the top link, hide the one inside the form column */
  .back-link-mobile {
    display: none;
  }
  @media (max-width: 768px) {
    .back-link-mobile {
      display: inline-flex;
    }
    .back-link-desktop {
      display: none;
    }
  }

  .checkout-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 28px;
    color: var(--foreground);
  }

  .form-section {
    margin-bottom: 12px;
  }
  .section-title {
    font-size: 16px;
    font-weight: 600;
