---
import Layout from "../../../layouts/Layout.astro";
import ProductDetail from "../../../components/ProductDetail.astro";
import StoreSidebar from "../../../components/StoreSidebar.astro";
import { storeSections } from "../../../lib/store-data";
import { getProducts } from "../../../lib/sanity";
import { stripHtml, truncateMetaDescription } from "../../../lib/seo-utils";
import { createClient } from "@sanity/client";
import { userOwnsStoreProduct } from "../../../lib/user-owns-product";

// SSR Mode: Dynamic Lookup
export const prerender = false;

const { section, slug } = Astro.params;

// Get server-detected currency from middleware
const serverCurrency = Astro.locals.currency;

// Fetch all products (cached) to find the matching one
const allProducts = await getProducts();

// Find product by slug AND section to avoid conflicts
const product = allProducts.find((p: any) => {
    return (
        p.slug === slug &&
        p.categoryPath &&
        Array.isArray(p.categoryPath) &&
        p.categoryPath.includes(section)
    );
});

// If no product found, return 404
if (!product) {
    console.error(`Product not found: slug=${slug}, section=${section}`);
    return Astro.redirect("/404");
}

// Determine sectionId if not passed (it is passed in params but good to verify)
const sectionId = section || product.categoryPath[0];
const currentSection = storeSections[sectionId];

// Get category from query params to preserve it on back navigation
const selectedCategory = Astro.url.searchParams.get("category");
const filterFree =
    (sectionId === "fashion-design" || sectionId === "3d-models") &&
    Astro.url.searchParams.get("free") === "1";

// Calculate back link - preserve category and list filters
let backLink = `/store/${sectionId}`;
{
    const qs = new URLSearchParams();
    if (selectedCategory) qs.set("category", selectedCategory);
    if (filterFree) qs.set("free", "1");
    const q = qs.toString();
    if (q) backLink += `?${q}`;
}

let userOwnsDigital = false;
const accountUser = Astro.locals.user;
if (accountUser?.email && product.productType === "digital") {
    const sanityOrders = createClient({
        projectId: "sovnyov1",
        dataset: "production",
        useCdn: false,
        apiVersion: "2024-03-01",
        token: import.meta.env.SANITY_API_TOKEN,
    });
    userOwnsDigital = await userOwnsStoreProduct(
        sanityOrders,
        accountUser.email,
        product.id,
    );
}

const siteBase = Astro.site?.origin ?? Astro.url.origin;
const productPath = `/store/${sectionId}/${product.slug || product.id}`;
const canonicalURL = new URL(productPath, siteBase);
const rawDesc = typeof product.description === "string" ? product.description : "";
const metaDescription =
    truncateMetaDescription(stripHtml(rawDesc)) ||
    `Buy ${product.name} from Visupair — handmade and digital design.`;
const firstImage =
    (typeof product.image === "string" && product.image) ||
    (product.images && product.images[0]) ||
    undefined;
const ogImage = firstImage
    ? firstImage.startsWith("http")
        ? firstImage
        : new URL(firstImage, siteBase).href
    : undefined;
---

<Layout
    title={`${product.name} | Visupair`}
    description={metaDescription}
    canonicalURL={canonicalURL}
    ogImage={ogImage}
    ogType="product"
>
    <div class="store-layout">
        <!-- Sidebar with persistence -->
        <div transition:persist="store-sidebar">
            <StoreSidebar
                categories={currentSection?.categories || []}
                selectedCategoryId={null}
                sectionId={sectionId}
                searchProducts={allProducts}
                showProductFilters={
                    sectionId === "fashion-design" || sectionId === "3d-models"
                }
                filterFree={filterFree}
            />
        </div>

        <div class="product-wrapper" transition:name={`product-${product.id}`}>
            <ProductDetail
                product={product}
                backLink={backLink}
                serverCurrency={serverCurrency}
                canonicalProductUrl={canonicalURL.href}
                userOwnsDigital={userOwnsDigital}
            />
        </div>
    </div>
</Layout>

<style>
    .store-layout {
        display: flex;
        gap: 12px;
        width: 100%;
        padding: 0 12px;
        height: calc(100vh - 120px); /* Keep consistent height with grid view */
    }

    .product-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .store-layout {
            flex-direction: column;
            height: auto;
            padding: 0 12px;
            gap: 12px;
        }
    }
</style>
