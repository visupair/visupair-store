---
import Layout from "../../../../../layouts/Layout.astro";
import ProductDetail from "../../../../../components/ProductDetail.astro";
import StoreSidebar from "../../../../../components/StoreSidebar.astro";
import { storeSections } from "../../../../../lib/store-data";
import { getProducts, getCategoriesTree } from "../../../../../lib/sanity";
import { stripHtml, truncateMetaDescription } from "../../../../../lib/seo-utils";
import { createClient } from "@sanity/client";
import { userOwnsStoreProduct } from "../../../../../lib/user-owns-product";

// SSR Mode: Dynamic Lookup
export const prerender = false;

const { section, categoryId, slug } = Astro.params;

// Validate parameters
if (!section || !categoryId || !slug) {
    return Astro.redirect("/404");
}

// Validate section exists
if (!storeSections[section]) {
    return Astro.redirect("/404");
}

// Fetch products from Sanity
let allProducts: any[] = [];
let allCategoriesTree: any[] = [];

try {
    allProducts = await getProducts();
    allCategoriesTree = await getCategoriesTree();
} catch (e) {
    console.error("Sanity fetch error:", e);
    return Astro.redirect("/404");
}

// Find the product matching the slug AND in the correct section
const product = allProducts.find((p) => {
    return (
        p.slug === slug &&
        p.categoryPath &&
        Array.isArray(p.categoryPath) &&
        p.categoryPath.includes(section)
    );
});

if (!product) {
    console.error(
        `Product not found: slug=${slug}, section=${section}, categoryId=${categoryId}`,
    );
    return Astro.redirect("/404");
}

const sectionId = section;
const currentSection = storeSections[sectionId];

// Find the category tree for this section
const sectionCategoryTree = allCategoriesTree.find(
    (cat: any) => cat.id === sectionId,
);
const categoriesToShow = sectionCategoryTree
    ? sectionCategoryTree.children
    : [];

const filterFree =
    (sectionId === "fashion-design" || sectionId === "3d-models") &&
    Astro.url.searchParams.get("free") === "1";

// Calculate back link - return to category view (preserve search + filters)
let backLink = `/store/${sectionId}/category/${categoryId}`;
{
    const qs = new URLSearchParams();
    const search = Astro.url.searchParams.get("search");
    if (search) qs.set("search", search);
    if (filterFree) qs.set("free", "1");
    const q = qs.toString();
    if (q) backLink += `?${q}`;
}

// For search autocomplete - all products in this section
const sectionProducts = allProducts.filter((p) => {
    return (
        p.categoryPath &&
        Array.isArray(p.categoryPath) &&
        p.categoryPath.includes(sectionId)
    );
});

// Get server-detected currency from middleware
const serverCurrency = Astro.locals.currency;

let userOwnsDigital = false;
const accountUser = Astro.locals.user;
if (accountUser?.email && product.productType === "digital") {
    const sanityOrders = createClient({
        projectId: "sovnyov1",
        dataset: "production",
        useCdn: false,
        apiVersion: "2024-03-01",
        token: import.meta.env.SANITY_API_TOKEN,
    });
    userOwnsDigital = await userOwnsStoreProduct(
        sanityOrders,
        accountUser.email,
        product.id,
    );
}

const siteBase = Astro.site?.origin ?? Astro.url.origin;
const productPath = `/store/${sectionId}/${product.slug || product.id}`;
const canonicalURL = new URL(productPath, siteBase);
const rawDesc = typeof product.description === "string" ? product.description : "";
const metaDescription =
    truncateMetaDescription(stripHtml(rawDesc)) ||
    `Buy ${product.name} from Visupair — handmade and digital design.`;
const firstImage =
    (typeof product.image === "string" && product.image) ||
    (product.images && product.images[0]) ||
    undefined;
const ogImage = firstImage
    ? firstImage.startsWith("http")
        ? firstImage
        : new URL(firstImage, siteBase).href
    : undefined;
---

<Layout
    title={`${product.name} | Visupair`}
    description={metaDescription}
    canonicalURL={canonicalURL}
    ogImage={ogImage}
    ogType="product"
>
    <div class="store-layout">
        <!-- Sidebar with persistence -->
        <div transition:persist="store-sidebar">
            <StoreSidebar
                categories={categoriesToShow}
                selectedCategoryId={categoryId as string}
                sectionId={sectionId}
                searchProducts={sectionProducts}
                showProductFilters={
                    sectionId === "fashion-design" || sectionId === "3d-models"
                }
                filterFree={filterFree}
            />
        </div>

        <div class="product-wrapper" transition:name={`product-${product.id}`}>
            <ProductDetail
                product={product}
                backLink={backLink}
                serverCurrency={serverCurrency}
                canonicalProductUrl={canonicalURL.href}
                userOwnsDigital={userOwnsDigital}
            />
        </div>
    </div>
</Layout>

<style>
    .store-layout {
        display: flex;
        gap: 12px;
        width: 100%;
        padding: 0 12px;
        height: calc(100vh - 120px);
    }

    .product-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    @media (max-width: 768px) {
        .store-layout {
            flex-direction: column;
            height: auto;
            padding: 0 12px;
            gap: 12px;
        }
    }
</style>
