---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Reset Password - Visupair">
  <div class="centered-auth-layout">
    <div class="centered-auth-card">
      
      <!-- STEP 3: RESET PASSWORD (with Token) -->
      <div id="reset-step" class="auth-step active">
        <div class="logo-anim-container">
          <!-- Same mark as site nav + public/images/visupair-nav-mark.svg (currentColor for dark UI) -->
          <svg
            width="67"
            height="33"
            viewBox="0 0 67 33"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M32.489 29.283L54.0977 29.8267C54.7934 29.8442 55.3418 29.2398 55.2556 28.5503L54.2167 20.2401C54.1338 19.5775 53.4991 19.1288 52.8454 19.2707L31.9362 23.8126C31.3691 23.9358 30.9857 24.4652 31.0463 25.0415L31.3858 28.266C31.4456 28.8335 31.9176 29.2686 32.489 29.283Z"
              fill="currentColor"></path>
            <path
              d="M34.511 2.74744L12.9023 2.20366C12.2065 2.18616 11.6582 2.79065 11.7444 3.48008L12.7833 11.7903C12.8662 12.4529 13.5009 12.9016 14.1546 12.7597L35.0638 8.21779C35.6309 8.0946 36.0143 7.56513 35.9537 6.98893L35.6142 3.7644C35.5544 3.19699 35.0824 2.76181 34.511 2.74744Z"
              fill="currentColor"></path>
            <path
              d="M56.3459 0.998994L59.0673 0.0588497C59.6838 -0.154124 60.3374 0.230814 60.4839 0.89311L66.9703 30.2179C67.1615 31.0822 66.398 31.8521 65.586 31.6138L60.4075 30.0943C59.9935 29.9729 59.6859 29.6092 59.6188 29.1621L55.5896 2.29705C55.5045 1.72985 55.8256 1.17874 56.3459 0.998994Z"
              fill="currentColor"></path>
            <path
              d="M10.6541 31.0315L7.93272 31.9716C7.31624 32.1846 6.66259 31.7996 6.5161 31.1373L0.0297008 1.81256C-0.161497 0.94817 0.601976 0.17827 1.41404 0.416558L6.59251 1.93611C7.00649 2.05758 7.31408 2.42118 7.38115 2.86831L11.4104 29.7333C11.4955 30.3006 11.1744 30.8517 10.6541 31.0315Z"
              fill="currentColor"></path>
            <path
              d="M52.2415 15.3689L41.6392 17.5957C40.979 17.7343 40.3436 17.2725 40.2731 16.6027L38.911 3.66592C38.8418 3.00836 39.3475 2.43092 40.0095 2.41157L50.4785 2.10553C51.0604 2.08852 51.5614 2.51267 51.6395 3.08857L53.1349 14.1046C53.215 14.6946 52.8252 15.2464 52.2415 15.3689Z"
              fill="currentColor"></path>
            <path
              d="M14.7585 16.6608L25.3608 14.4341C26.021 14.2954 26.6564 14.7573 26.7269 15.427L28.089 28.3638C28.1582 29.0214 27.6525 29.5988 26.9905 29.6182L16.5215 29.9242C15.9396 29.9412 15.4386 29.5171 15.3605 28.9412L13.8651 17.9251C13.785 17.3351 14.1748 16.7834 14.7585 16.6608Z"
              fill="currentColor"></path>
          </svg>
        </div>
        <h2>Create New Password</h2>
        <p class="instructions">
          Enter your new password below
        </p>
        <form id="reset-form" class="reset-form">
          <div class="form-group">
            <label class="form-label">New password</label>
            <div class="password-input-wrapper">
              <input 
                type="password" 
                class="form-input" 
                placeholder="At least 8 characters" 
                required 
                id="password-input"
                minlength="8"
              />
              <button type="button" class="password-toggle-btn" id="toggle-password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Confirm password</label>
            <div class="password-input-wrapper">
              <input 
                type="password" 
                class="form-input" 
                placeholder="Confirm your password" 
                required 
                id="confirm-password-input"
                minlength="8"
              />
              <button type="button" class="password-toggle-btn" id="toggle-confirm-password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              </button>
            </div>
          </div>

          <p id="password-match-hint" class="password-match-hint" hidden></p>

          <div
            class="password-strength-panel"
            id="password-strength-panel"
            aria-live="polite"
          >
            <div class="strength-track">
              <div class="strength-fill" id="strength-fill"></div>
            </div>
            <div class="strength-label-row">
              <span class="strength-label" id="strength-label"></span>
            </div>
          </div>

          <div
            id="form-feedback"
            class="form-feedback"
            role="alert"
            hidden
          ></div>

          <button type="submit" class="btn-primary" id="reset-submit-btn">Reset Password</button>
          <a href="/login" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            Back to login
          </a>
        </form>
      </div>

      <!-- STEP 4: SUCCESS -->
      <div id="success-step" class="auth-step" style="display: none;">
        <div class="state-icon-box success">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h2>Password Reset Successful</h2>
        <p class="instructions">
          Your password has been reset successfully. You can now log in with your new password.
        </p>
        
        <div class="reset-form">
          <a href="/login" class="btn-primary" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">
            Go Back to Login
          </a>
        </div>
      </div>

      <!-- ERROR STATE -->
      <div id="error-step" class="auth-step" style="display: none;">
        <div class="state-icon-box error">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
        </div>
        <h2>Reset Link Expired</h2>
        <p class="instructions">
          This password reset link has expired or is invalid. Please request a new one.
        </p>
        
        <div class="reset-form">
          <a href="/forgot-password" class="btn-primary" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">
            Request New Link
          </a>
          <a href="/login" class="btn-secondary" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">Back to Login</a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Centered Auth Layout */
  .centered-auth-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 100px);
    padding: 40px 24px;
    background: var(--page-bg);
  }

  .centered-auth-card {
    width: 100%;
    max-width: 420px;
    background: var(--surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-island);
    padding: 40px;
  }

  /* Auth Steps */
  .auth-step {
    animation: fadeIn 0.4s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .auth-step:not(.active) {
    display: none !important;
  }

  /* Logo Container */
  .logo-anim-container {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
    color: var(--foreground);
  }

  .logo-anim-container svg {
    animation: logoFloat 3s ease-in-out infinite;
  }

  @keyframes logoFloat {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  /* Typography */
  .centered-auth-card h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    text-align: center;
    color: var(--foreground);
  }

  .instructions {
    font-size: 15px;
    opacity: 0.6;
    text-align: center;
    margin-bottom: 32px;
    line-height: 1.5;
  }

  /* Form */
  .reset-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--foreground);
  }

  .password-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .form-input {
    width: 100%;
    padding: 12px 14px;
    padding-right: 40px;
    background: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-size: 15px;
    color: var(--foreground);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .form-input:focus {
    outline: none;
    border-color: var(--brand-violet);
    box-shadow: 0 0 0 3px rgba(132, 128, 255, 0.1);
  }

  .form-input::placeholder {
    color: var(--foreground);
    opacity: 0.4;
  }

  .password-toggle-btn {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--foreground);
    opacity: 0.5;
    transition: opacity 0.2s;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .password-toggle-btn:hover {
    opacity: 0.8;
  }

  .password-match-hint {
    margin: -8px 0 0;
    font-size: 13px;
    line-height: 1.45;
    color: #f87171;
  }

  .password-match-hint[hidden] {
    display: none !important;
  }

  .password-strength-panel {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 4px;
  }

  .strength-track {
    height: 4px;
    background: var(--border-subtle);
    border-radius: 4px;
    overflow: hidden;
  }

  .strength-fill {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition:
      width 0.25s ease,
      background-color 0.25s ease;
    background: var(--border-subtle);
  }

  .strength-fill.tier-none {
    width: 8%;
    background: var(--border-subtle);
  }
  .strength-fill.tier-weak {
    width: 28%;
    background: #f87171;
  }
  .strength-fill.tier-fair {
    width: 55%;
    background: #f59e0b;
  }
  .strength-fill.tier-good {
    width: 78%;
    background: #a3e635;
  }
  .strength-fill.tier-strong {
    width: 100%;
    background: #22c55e;
  }

  .strength-label-row {
    font-size: 13px;
    line-height: 1.45;
    text-align: left;
  }

  .strength-label {
    font-weight: 600;
    color: var(--foreground);
  }

  .form-feedback {
    padding: 12px 14px;
    border-radius: var(--radius-md);
    font-size: 14px;
    line-height: 1.45;
    background: color-mix(in srgb, #f87171, transparent 88%);
    color: #fecaca;
    border: 1px solid color-mix(in srgb, #f87171, transparent 55%);
  }

  .form-feedback[hidden] {
    display: none !important;
  }

  .form-input.input-error {
    border-color: #f87171;
    box-shadow: 0 0 0 3px color-mix(in srgb, #f87171, transparent 85%);
  }

  /* Buttons */
  .btn-primary,
  .btn-secondary {
    width: 100%;
    padding: 12px 16px;
    background: var(--foreground);
    color: var(--page-bg);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-secondary {
    background: var(--surface-hover);
    color: var(--foreground);
    border: 1px solid var(--border-subtle);
  }

  .btn-secondary:hover {
    background: var(--surface-muted);
  }

  /* State Icon Box */
  .state-icon-box {
    width: 64px;
    height: 64px;
    background: var(--surface-muted);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 32px;
    color: var(--foreground);
  }

  .state-icon-box.success {
    background: rgba(34, 197, 94, 0.1);
    color: #22C55E;
  }

  .state-icon-box.error {
    background: rgba(255, 107, 107, 0.1);
    color: #FF6B6B;
  }

  .state-icon-box svg {
    stroke: currentColor;
  }

  /* Back Link */
  .back-link {
    text-align: center;
    font-size: 14px;
    color: var(--brand-violet);
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 16px;
    transition: opacity 0.2s;
  }

  .back-link:hover {
    opacity: 0.7;
    text-decoration: underline;
  }

  .back-link svg {
    width: 16px;
    height: 16px;
    stroke: currentColor;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .centered-auth-layout {
      min-height: calc(100vh - 60px);
      padding: 24px 16px;
    }

    .centered-auth-card {
      padding: 32px 20px;
      border-radius: var(--radius-xl);
    }

    .centered-auth-card h2 {
      font-size: 24px;
    }

    .instructions {
      font-size: 14px;
    }
  }
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');

  const strengthFill = document.getElementById('strength-fill');
  const strengthLabel = document.getElementById('strength-label');
  const matchHint = document.getElementById('password-match-hint');
  const formFeedback = document.getElementById('form-feedback');

  function clearFormFeedback() {
    if (formFeedback) {
      formFeedback.textContent = '';
      formFeedback.hidden = true;
    }
  }

  function showFormFeedback(message: string) {
    if (!formFeedback) return;
    formFeedback.textContent = message;
    formFeedback.hidden = false;
    formFeedback.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }

  function scorePassword(password: string): number {
    let s = 0;
    if (password.length >= 8) s++;
    if (password.length >= 12) s++;
    if (/[A-Z]/.test(password)) s++;
    if (/[a-z]/.test(password)) s++;
    if (/\d/.test(password)) s++;
    if (/[^A-Za-z0-9]/.test(password)) s++;
    return s;
  }

  function renderStrength(password: string) {
    if (!strengthFill || !strengthLabel) return;

    if (!password) {
      strengthFill.className = 'strength-fill tier-none';
      strengthLabel.textContent = '';
      return;
    }

    const score = scorePassword(password);
    const tooShort = password.length < 8;

    if (tooShort || score <= 2) {
      strengthFill.className = 'strength-fill tier-weak';
      strengthLabel.textContent = 'Too weak';
      return;
    }

    if (score === 3) {
      strengthFill.className = 'strength-fill tier-fair';
      strengthLabel.textContent = 'Fair';
      return;
    }

    if (score === 4) {
      strengthFill.className = 'strength-fill tier-good';
      strengthLabel.textContent = 'Good';
      return;
    }

    strengthFill.className = 'strength-fill tier-strong';
    strengthLabel.textContent = 'Strong';
  }

  function updateMatchState() {
    const passwordInput = document.getElementById('password-input') as HTMLInputElement | null;
    const confirmPasswordInput = document.getElementById(
      'confirm-password-input',
    ) as HTMLInputElement | null;
    if (!passwordInput || !confirmPasswordInput || !matchHint) return;

    const p = passwordInput.value;
    const c = confirmPasswordInput.value;

    if (!c) {
      matchHint.hidden = true;
      matchHint.textContent = '';
      confirmPasswordInput.classList.remove('input-error');
      return;
    }

    if (p !== c) {
      matchHint.hidden = false;
      matchHint.textContent = 'Passwords do not match — check both fields.';
      confirmPasswordInput.classList.add('input-error');
      return;
    }

    matchHint.hidden = true;
    matchHint.textContent = '';
    confirmPasswordInput.classList.remove('input-error');
  }

  if (!token) {
    document.getElementById('reset-step')?.classList.remove('active');
    document.getElementById('reset-step')!.style.display = 'none';
    document.getElementById('error-step')?.classList.add('active');
    document.getElementById('error-step')!.style.display = 'block';
  }

  const togglePasswordBtn = document.getElementById('toggle-password');
  const passwordInput = document.getElementById('password-input') as HTMLInputElement;

  if (togglePasswordBtn && passwordInput) {
    togglePasswordBtn.addEventListener('click', (e) => {
      e.preventDefault();
      passwordInput.type = passwordInput.type === 'password' ? 'text' : 'password';
    });
  }

  const toggleConfirmPasswordBtn = document.getElementById('toggle-confirm-password');
  const confirmPasswordInput = document.getElementById(
    'confirm-password-input',
  ) as HTMLInputElement;

  if (toggleConfirmPasswordBtn && confirmPasswordInput) {
    toggleConfirmPasswordBtn.addEventListener('click', (e) => {
      e.preventDefault();
      confirmPasswordInput.type =
        confirmPasswordInput.type === 'password' ? 'text' : 'password';
    });
  }

  passwordInput?.addEventListener('input', () => {
    clearFormFeedback();
    renderStrength(passwordInput.value);
    updateMatchState();
  });

  confirmPasswordInput?.addEventListener('input', () => {
    clearFormFeedback();
    updateMatchState();
  });

  const resetForm = document.getElementById('reset-form');
  const resetSubmitBtn = document.getElementById('reset-submit-btn') as HTMLButtonElement | null;

  if (resetForm) {
    resetForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearFormFeedback();

      const password = (document.getElementById('password-input') as HTMLInputElement).value;
      const confirmPassword = (
        document.getElementById('confirm-password-input') as HTMLInputElement
      ).value;

      if (password !== confirmPassword) {
        showFormFeedback('Passwords do not match. Please enter the same password twice.');
        updateMatchState();
        confirmPasswordInput?.focus();
        return;
      }

      if (password.length < 8) {
        showFormFeedback('Password must be at least 8 characters long.');
        passwordInput?.focus();
        return;
      }

      if (!token) {
        showFormFeedback('This link is missing or invalid. Request a new reset link from the login page.');
        return;
      }

      if (resetSubmitBtn) {
        resetSubmitBtn.disabled = true;
        resetSubmitBtn.textContent = 'Resetting...';
      }

      try {
        const response = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, newPassword: password }),
          credentials: 'include',
        });

        if (response.ok) {
          document.getElementById('reset-step')?.classList.remove('active');
          document.getElementById('reset-step')!.style.display = 'none';
          document.getElementById('success-step')?.classList.add('active');
          document.getElementById('success-step')!.style.display = 'block';
        } else {
          const data = await response.json().catch(() => ({}));
          const msg =
            (data as { message?: string })?.message ||
            'Reset failed. The link may have expired.';
          if (response.status === 400 || response.status === 404) {
            document.getElementById('reset-step')?.classList.remove('active');
            document.getElementById('reset-step')!.style.display = 'none';
            document.getElementById('error-step')?.classList.add('active');
            document.getElementById('error-step')!.style.display = 'block';
          } else {
            showFormFeedback(msg);
          }
        }
      } catch {
        showFormFeedback(
          'Network error. Please check your connection and try again.',
        );
      } finally {
        if (resetSubmitBtn) {
          resetSubmitBtn.disabled = false;
          resetSubmitBtn.textContent = 'Reset Password';
        }
      }
    });
  }
</script>
