---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Sign In - Visupair">
  <Fragment slot="head">
    <script is:inline>
      (function () {
        try {
          var t = window.visupairGetTheme
            ? window.visupairGetTheme()
            : "dark";
          function preload(href) {
            var l = document.createElement("link");
            l.rel = "preload";
            l.as = "image";
            l.type = "image/webp";
            l.href = href;
            document.head.appendChild(l);
          }
          preload("/images/hero/login-" + t + ".webp");
        } catch (e) {}
      })();
    </script>
  </Fragment>

  <div class="auth-layout">
    <!-- Left Visual Island -->
    <div class="auth-visual-side">
      <div class="auth-visual-inner">
        <div class="auth-quote">
          <h1>Digital Craft <br /> Marketplace.</h1>
          <p>
            Join the community of creators, designers and innovators. Build your
            portfolio with Visupair.
          </p>
        </div>

        <div class="auth-visual-figure" aria-hidden="true">
          <img
            id="auth-hero-visual"
            class="auth-hero-img"
            alt=""
            width="800"
            height="800"
            loading="eager"
            decoding="async"
            draggable="false"
          />
        </div>
        <script is:inline>
          (function () {
            try {
              var t = window.visupairGetTheme
                ? window.visupairGetTheme()
                : "dark";
              var img = document.getElementById("auth-hero-visual");
              if (img) img.src = "/images/hero/login-" + t + ".webp";
            } catch (e) {}
          })();
        </script>
      </div>
    </div>

    <!-- Right Form Island -->
    <div class="auth-form-side">
      <div class="auth-container">
        <div class="auth-header">
          <h2 id="auth-title">Welcome back</h2>
          <p id="auth-subtitle">Login with your Google account</p>
        </div>

        <button class="btn-google" type="button">
          <svg width="18" height="18" viewBox="0 0 24 24"
            ><path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              fill="#4285F4"></path><path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              fill="#34A853"></path><path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
              fill="#FBBC05"></path><path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              fill="#EA4335"></path></svg
          >
          <span id="google-btn-text">Login with Google</span>
        </button>

        <div class="auth-separator"><span>Or continue with</span></div>

        <form id="auth-form" class="auth-form">
          <div id="name-group" class="form-group" style="display: none;">
            <div class="name-row">
              <div class="form-group">
                <label class="form-label">First Name</label>
                <input
                  type="text"
                  id="first-name"
                  class="form-input"
                  placeholder="John"
                />
                <span class="error-message" id="first-name-error"></span>
              </div>
              <div class="form-group">
                <label class="form-label">Last Name</label>
                <input
                  type="text"
                  id="last-name"
                  class="form-input"
                  placeholder="Doe"
                />
                <span class="error-message" id="last-name-error"></span>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Email</label>
            <input
              type="email"
              id="email-input"
              class="form-input"
              placeholder="m@example.com"
              required
            />
            <span class="error-message" id="email-error"></span>
          </div>

          <div class="form-group">
            <label class="form-label">Password</label>
            <div class="password-input-wrapper">
              <input
                type="password"
                id="password-input"
                class="form-input"
                placeholder="••••••••"
                required
                autocomplete="current-password"
                onpaste="return false"
                oncopy="return false"
                oncut="return false"
              />
              <button
                type="button"
                class="password-toggle"
                id="password-toggle"
                aria-label="Show password"
              >
                <svg
                  class="eye-icon"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    class="eye-open"
                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                  <circle class="eye-open" cx="12" cy="12" r="3"></circle>
                  <path
                    class="eye-closed"
                    d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"
                    style="display: none;"></path>
                  <line
                    class="eye-closed"
                    x1="1"
                    y1="1"
                    x2="23"
                    y2="23"
                    style="display: none;"></line>
                </svg>
              </button>
            </div>

            <div
              id="signup-password-extra"
              class="signup-password-extra"
              style="display: none;"
            >
              <p class="password-requirements">
                Use at least <strong>8 characters</strong>.
              </p>
              <div
                class="password-strength-panel"
                id="password-strength-panel"
                aria-live="polite"
              >
                <div class="strength-track">
                  <div
                    class="strength-fill tier-none"
                    id="signup-strength-fill"
                  >
                  </div>
                </div>
                <div class="strength-label-row">
                  <span class="strength-label" id="signup-strength-label"></span>
                </div>
              </div>
            </div>

            <div class="password-footer">
              <span class="error-message" id="password-error"></span>
              <a
                id="forgot-pwd"
                href="/forgot-password"
                class="forgot-password-link">Forgot your password?</a
              >
            </div>
          </div>

          <button type="submit" class="btn-primary" id="submit-btn"
            >Login</button
          >

          <div class="auth-toggle">
            <span id="toggle-text">Don't have an account?</span>
            <a href="#" id="toggle-link" class="toggle-link">Sign up</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style define:vars={{}}>
  /* Auth Page Specific Styles */
  .auth-layout {
    display: flex;
    width: calc(100% - 24px);
    height: calc(100vh - 100px);
    margin: 0 auto;
    gap: 12px;
    animation: fadeIn 0.6s ease-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes loginBlobDrift1 {
    0% {
      transform: translate(0%, 0%) scale(1);
    }
    20% {
      transform: translate(-12%, 18%) scale(1.08);
    }
    45% {
      transform: translate(8%, -20%) scale(1.04);
    }
    70% {
      transform: translate(-18%, -8%) scale(1.12);
    }
    100% {
      transform: translate(0%, 0%) scale(1);
    }
  }

  @keyframes loginBlobDrift2 {
    0% {
      transform: translate(0%, 0%) scale(1);
    }
    25% {
      transform: translate(15%, -15%) scale(1.06);
    }
    55% {
      transform: translate(-10%, 20%) scale(1.1);
    }
    80% {
      transform: translate(12%, 10%) scale(1.04);
    }
    100% {
      transform: translate(0%, 0%) scale(1);
    }
  }

  @keyframes authVisualFadeIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Left visual island — same treatment as contact page (light surface / dark + drifting blobs) */
  .auth-visual-side {
    flex: 1;
    min-height: 0;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    box-shadow:
      inset 0 0 100px rgba(0, 0, 0, 0.02),
      var(--shadow-island);
    transition: box-shadow 0.4s ease;
    animation: authVisualFadeIn 0.6s cubic-bezier(0.2, 0, 0, 1) both;
  }

  :global([data-theme="dark"]) .auth-visual-side {
    box-shadow:
      inset 0 0 100px rgba(0, 0, 0, 0.2),
      var(--shadow-island);
  }

  .auth-visual-side::before,
  .auth-visual-side::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: 0;
    border-radius: 50%;
    will-change: transform;
  }

  .auth-visual-side::before {
    top: -60%;
    right: -40%;
    width: clamp(520px, 95vw, 1400px);
    aspect-ratio: 1;
    background: transparent;
  }

  .auth-visual-side::after {
    bottom: -50%;
    left: -35%;
    width: clamp(480px, 85vw, 1200px);
    aspect-ratio: 1;
    background: transparent;
  }

  :global([data-theme="dark"]) .auth-visual-side::before {
    background: radial-gradient(
      closest-side,
      rgba(163, 142, 255, 0.4) 0%,
      rgba(163, 142, 255, 0.15) 35%,
      rgba(163, 142, 255, 0.02) 70%,
      rgba(163, 142, 255, 0) 100%
    );
    opacity: 0.5;
    animation: loginBlobDrift1 22s infinite alternate ease-in-out;
  }

  :global([data-theme="dark"]) .auth-visual-side::after {
    background: radial-gradient(
      closest-side,
      rgba(132, 128, 255, 0.35) 0%,
      rgba(132, 128, 255, 0.12) 35%,
      rgba(132, 128, 255, 0.02) 70%,
      rgba(132, 128, 255, 0) 100%
    );
    opacity: 0.5;
    animation: loginBlobDrift2 28s infinite alternate ease-in-out;
  }

  .auth-visual-inner {
    position: relative;
    z-index: 1;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: clamp(40px, 5vw, 60px) clamp(40px, 5vw, 60px) 0;
  }

  .auth-quote {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    max-width: 400px;
    color: var(--foreground);
  }

  .auth-quote h1 {
    font-size: 42px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 20px 0;
    letter-spacing: -0.02em;
    color: inherit;
  }

  .auth-quote p {
    font-size: 18px;
    margin: 0;
    line-height: 1.6;
    color: var(--foreground);
    opacity: 0.65;
  }

  :global([data-theme="dark"]) .auth-quote,
  :global([data-theme="dark"]) .auth-quote h1 {
    color: #ffffff;
  }

  :global([data-theme="dark"]) .auth-quote p {
    color: #ffffff;
    opacity: 0.7;
  }

  .auth-visual-figure {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    align-self: stretch;
    width: 100%;
    margin-top: clamp(16px, 3vw, 28px);
    pointer-events: none;
  }

  .auth-hero-img {
    display: block;
    width: min(130%, 760px);
    max-width: none;
    height: auto;
    object-fit: contain;
    object-position: bottom center;
    user-select: none;
    -webkit-user-drag: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .auth-visual-side::before,
    .auth-visual-side::after {
      animation: none !important;
    }

    .auth-visual-side {
      animation: none;
    }
  }

  /* Right Form Side */
  .auth-form-side {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-island);
    position: relative;
    padding: 40px;
  }

  /* Auth Container inside right side */
  .auth-container {
    width: 100%;
    max-width: 400px;
  }

  /* Auth Form Styles */
  .auth-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .auth-header h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .auth-header p {
    font-size: 15px;
    opacity: 0.6;
  }

  .btn-google {
    width: 100%;
    padding: 14px;
    background: var(--surface-muted);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: var(--foreground);
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    font-family: var(--font-family);
    font-size: 15px;
  }
  .btn-google:hover {
    background: var(--surface-hover);
  }

  .auth-separator {
    display: flex;
    align-items: center;
    margin: 32px 0;
    font-size: 13px;
    opacity: 0.5;
  }
  .auth-separator::before,
  .auth-separator::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }
  .auth-separator span {
    padding: 0 12px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-label {
    font-size: 14px;
    font-weight: 500;
  }

  .name-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .name-row .form-group {
    margin-bottom: 0;
  }

  .form-input {
    width: 100%;
    padding: 14px 16px;
    background: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-size: 15px;
    color: var(--foreground);
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }
  .form-input:focus {
    outline: none;
    border-color: var(--brand-violet);
    box-shadow: 0 0 0 3px rgba(132, 128, 255, 0.1);
  }

  .forgot-password-link {
    font-size: 13px;
    text-align: right;
    opacity: 0.7;
    text-decoration: none;
    color: var(--foreground);
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .forgot-password-link:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .signup-password-extra {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 2px;
    margin-bottom: 0;
  }

  .password-requirements {
    margin: 0;
    font-size: 12px;
    line-height: 1.5;
    opacity: 0.72;
    color: var(--foreground);
  }

  .password-requirements strong {
    font-weight: 600;
    opacity: 1;
  }

  .password-strength-panel {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .strength-track {
    height: 4px;
    background: var(--border-subtle);
    border-radius: 4px;
    overflow: hidden;
  }

  .strength-fill {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition:
      width 0.25s ease,
      background-color 0.25s ease;
    background: var(--border-subtle);
  }

  .strength-fill.tier-none {
    width: 8%;
    background: var(--border-subtle);
  }
  .strength-fill.tier-weak {
    width: 28%;
    background: #f87171;
  }
  .strength-fill.tier-fair {
    width: 55%;
    background: #f59e0b;
  }
  .strength-fill.tier-good {
    width: 78%;
    background: #a3e635;
  }
  .strength-fill.tier-strong {
    width: 100%;
    background: #22c55e;
  }

  .strength-label-row {
    font-size: 13px;
    line-height: 1.45;
    text-align: left;
    /* No min-height: empty label should not leave a large gap above the button */
  }

  .strength-label {
    font-weight: 600;
    color: var(--foreground);
  }

  .password-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-top: 4px;
    margin-bottom: 12px;
    min-height: 18px;
  }

  /* Sign up: forgot link is hidden — tighter stack above the submit button */
  .auth-form--signup .password-footer {
    margin-top: 0;
    margin-bottom: 4px;
    min-height: 0;
  }

  .auth-form--signup .btn-primary {
    margin-top: 4px;
  }

  .password-input-wrapper {
    position: relative;
    width: 100%;
  }

  .password-input-wrapper .form-input {
    padding-right: 45px;
  }

  .password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: var(--foreground);
    opacity: 0.5;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .password-toggle:hover {
    opacity: 0.8;
  }

  .password-toggle:active {
    opacity: 1;
  }

  .eye-icon {
    pointer-events: none;
  }

  .btn-primary {
    width: 100%;
    padding: 14px;
    background: var(--foreground);
    color: var(--page-bg);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    transition:
      transform 0.2s,
      opacity 0.2s;
    margin-top: 8px;
  }
  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .auth-toggle {
    text-align: center;
    font-size: 14px;
    margin-top: 24px;
  }

  .toggle-link {
    color: var(--foreground);
    text-decoration: underline;
    cursor: pointer;
    font-weight: 600;
    margin-left: 6px;
    transition: opacity 0.2s;
  }
  .toggle-link:hover {
    opacity: 0.7;
  }

  /* Error States */
  .form-input.error {
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
  }

  .form-input.error:focus {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  .error-message {
    font-size: 13px;
    color: #ef4444;
    display: block;
    flex: 0 1 auto;
    min-height: 0;
    height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      opacity 0.2s,
      height 0.2s;
  }

  .error-message:not(:empty) {
    opacity: 1;
    height: auto;
    min-height: 18px;
  }

  /* Responsive */
  @media (max-width: 968px) {
    .auth-layout {
      flex-direction: column;
      height: auto;
    }
    .auth-visual-side {
      min-height: 260px;
      border-radius: var(--radius-xl);
    }
    .auth-visual-inner {
      padding: 32px 32px 0;
    }
    .auth-quote h1 {
      font-size: 28px;
    }
    .auth-form-side {
      border-radius: var(--radius-xl);
    }
  }
</style>

<script>
  import { showVsToast } from "../../lib/vs-toast";

  const authForm = document.getElementById("auth-form") as HTMLFormElement;
  const toggleLink = document.getElementById("toggle-link");
  const authTitle = document.getElementById("auth-title");
  const authSubtitle = document.getElementById("auth-subtitle");
  const googleBtnText = document.getElementById("google-btn-text");
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const nameGroup = document.getElementById("name-group");
  const firstNameInput = document.getElementById(
    "first-name",
  ) as HTMLInputElement;
  const lastNameInput = document.getElementById(
    "last-name",
  ) as HTMLInputElement;
  const emailInput = document.getElementById("email-input") as HTMLInputElement;
  const passwordInput = document.getElementById(
    "password-input",
  ) as HTMLInputElement;
  const toggleText = document.getElementById("toggle-text");
  const forgotPwd = document.getElementById("forgot-pwd");

  // Error message elements
  const firstNameError = document.getElementById("first-name-error");
  const lastNameError = document.getElementById("last-name-error");
  const emailError = document.getElementById("email-error");
  const passwordError = document.getElementById("password-error");
  const signupPasswordExtra = document.getElementById("signup-password-extra");
  const signupStrengthFill = document.getElementById("signup-strength-fill");
  const signupStrengthLabel = document.getElementById("signup-strength-label");

  let isSignUp = false;

  const API_BASE = "/api/auth";

  function scorePassword(password: string): number {
    let s = 0;
    if (password.length >= 8) s++;
    if (password.length >= 12) s++;
    if (/[A-Z]/.test(password)) s++;
    if (/[a-z]/.test(password)) s++;
    if (/\d/.test(password)) s++;
    if (/[^A-Za-z0-9]/.test(password)) s++;
    return s;
  }

  function renderSignupStrength(password: string) {
    if (!signupStrengthFill || !signupStrengthLabel) return;

    if (!password) {
      signupStrengthFill.className = "strength-fill tier-none";
      signupStrengthLabel.textContent = "";
      return;
    }

    const score = scorePassword(password);
    const tooShort = password.length < 8;

    if (tooShort || score <= 2) {
      signupStrengthFill.className = "strength-fill tier-weak";
      signupStrengthLabel.textContent = "Too weak";
      return;
    }

    if (score === 3) {
      signupStrengthFill.className = "strength-fill tier-fair";
      signupStrengthLabel.textContent = "Fair";
      return;
    }

    if (score === 4) {
      signupStrengthFill.className = "strength-fill tier-good";
      signupStrengthLabel.textContent = "Good";
      return;
    }

    signupStrengthFill.className = "strength-fill tier-strong";
    signupStrengthLabel.textContent = "Strong";
  }

  // Password visibility toggle
  const passwordToggle = document.getElementById("password-toggle");
  if (passwordToggle && passwordInput) {
    const eyeOpen = passwordToggle.querySelectorAll(".eye-open");
    const eyeClosed = passwordToggle.querySelectorAll(".eye-closed");

    passwordToggle.addEventListener("mousedown", () => {
      passwordInput.type = "text";
      eyeOpen.forEach((el) => ((el as HTMLElement).style.display = "none"));
      eyeClosed.forEach((el) => ((el as HTMLElement).style.display = "block"));
    });

    passwordToggle.addEventListener("mouseup", () => {
      passwordInput.type = "password";
      eyeOpen.forEach((el) => ((el as HTMLElement).style.display = "block"));
      eyeClosed.forEach((el) => ((el as HTMLElement).style.display = "none"));
    });

    passwordToggle.addEventListener("mouseleave", () => {
      passwordInput.type = "password";
      eyeOpen.forEach((el) => ((el as HTMLElement).style.display = "block"));
      eyeClosed.forEach((el) => ((el as HTMLElement).style.display = "none"));
    });
  }

  passwordInput?.addEventListener("input", () => {
    if (isSignUp) renderSignupStrength(passwordInput.value);
  });

  // Clear all errors
  function clearErrors() {
    [emailInput, passwordInput, firstNameInput, lastNameInput].forEach(
      (input) => {
        if (input) input.classList.remove("error");
      },
    );
    [emailError, passwordError, firstNameError, lastNameError].forEach(
      (error) => {
        if (error) error.textContent = "";
      },
    );
  }

  // Show error on specific field
  function showError(
    input: HTMLInputElement | null,
    errorEl: HTMLElement | null,
    message: string,
  ) {
    if (input) input.classList.add("error");
    if (errorEl) errorEl.textContent = message;
  }

  /** Keep login / sign-up UI in sync with `isSignUp`. */
  function applyAuthMode(nextIsSignUp: boolean) {
    isSignUp = nextIsSignUp;
    authForm?.classList.toggle("auth-form--signup", isSignUp);

    if (isSignUp) {
      if (authTitle) authTitle.textContent = "Create an account";
      if (authSubtitle)
        authSubtitle.textContent =
          "Enter your details below to create your account";
      if (googleBtnText) googleBtnText.textContent = "Signup with Google";
      if (submitBtn) submitBtn.textContent = "Sign Up";
      if (nameGroup) nameGroup.style.display = "block";
      if (toggleText) toggleText.textContent = "Already have an account?";
      if (toggleLink) toggleLink.textContent = "Login";
      if (forgotPwd) forgotPwd.style.display = "none";
      if (signupPasswordExtra) signupPasswordExtra.style.display = "flex";
      if (passwordInput) {
        passwordInput.minLength = 8;
        passwordInput.placeholder = "At least 8 characters";
        passwordInput.autocomplete = "new-password";
      }
      if (firstNameInput) firstNameInput.required = true;
      if (lastNameInput) lastNameInput.required = true;
      renderSignupStrength(passwordInput?.value || "");
    } else {
      if (authTitle) authTitle.textContent = "Welcome back";
      if (authSubtitle)
        authSubtitle.textContent = "Login with your Google account";
      if (googleBtnText) googleBtnText.textContent = "Login with Google";
      if (submitBtn) submitBtn.textContent = "Login";
      if (nameGroup) nameGroup.style.display = "none";
      if (toggleText) toggleText.textContent = "Don't have an account?";
      if (toggleLink) toggleLink.textContent = "Sign up";
      if (forgotPwd) forgotPwd.style.display = "inline-block";
      if (signupPasswordExtra) signupPasswordExtra.style.display = "none";
      if (passwordInput) {
        passwordInput.minLength = 0;
        passwordInput.placeholder = "••••••••";
        passwordInput.autocomplete = "current-password";
      }
      renderSignupStrength("");
      if (firstNameInput) firstNameInput.required = false;
      if (lastNameInput) lastNameInput.required = false;
    }
  }

  toggleLink?.addEventListener("click", (e) => {
    e.preventDefault();
    clearErrors();
    applyAuthMode(!isSignUp);
  });

  authForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    const email = emailInput?.value || "";
    const password = passwordInput?.value || "";
    const firstName = firstNameInput?.value?.trim() || "";
    const lastName = lastNameInput?.value?.trim() || "";

    // Client-side validation
    let hasError = false;

    if (!email) {
      showError(emailInput, emailError, "Email is required");
      hasError = true;
    }

    if (!password) {
      showError(passwordInput, passwordError, "Password is required");
      hasError = true;
    }

    if (isSignUp) {
      if (password && password.length < 8) {
        showError(
          passwordInput,
          passwordError,
          "Password must be at least 8 characters.",
        );
        hasError = true;
      }
      if (!firstName) {
        showError(firstNameInput, firstNameError, "First name is required");
        hasError = true;
      }
      if (!lastName) {
        showError(lastNameInput, lastNameError, "Last name is required");
        hasError = true;
      }
    }

    if (hasError) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Loading...";
    }

    try {
      // Better Auth requires /email suffix for email/password authentication
      const endpoint = isSignUp ? "sign-up/email" : "sign-in/email";

      // Combine first and last name for Better Auth
      const fullName = isSignUp ? `${firstName} ${lastName}` : "";

      const verifyCallback = `${window.location.origin}/account/profile`;

      const payload = isSignUp
        ? {
            email,
            password,
            name: fullName,
            callbackURL: verifyCallback,
          }
        : { email, password, callbackURL: verifyCallback };

      const response = await fetch(`${API_BASE}/${endpoint}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
        credentials: "include",
      });

      // Guard: if the response is not JSON (e.g. Vite HTML error page in
      // dev), treat it as an auth failure instead of crashing on .json().
      const contentType = response.headers.get("content-type") || "";
      let data: Record<string, any>;
      if (contentType.includes("application/json")) {
        data = await response.json();
      } else {
        data = { message: "Invalid email or password" };
      }

      if (response.ok && contentType.includes("application/json")) {
        if (isSignUp) {
          showVsToast(
            "Check your email and open the verification link. After that, you can sign in here.",
            "success",
          );
          clearErrors();
          applyAuthMode(false);
          if (passwordInput) passwordInput.value = "";
          if (firstNameInput) firstNameInput.value = "";
          if (lastNameInput) lastNameInput.value = "";
        } else {
          window.location.href = "/account/profile";
        }
      } else {
        // Handle specific error messages from Better Auth
        const errorMessage =
          data.error || data.message || "Authentication failed";

        // Log for debugging
        console.log("Better Auth Error:", errorMessage, data);

        // Map common errors to specific fields
        // IMPORTANT: Check from most specific to least specific
        const errorLower = errorMessage.toLowerCase();

        if (
          response.status === 403 ||
          errorLower.includes("email not verified") ||
          errorLower.includes("not verified")
        ) {
          showError(
            emailInput,
            emailError,
            "Verify your email to sign in. Check your inbox for the link.",
          );
          showVsToast(
            "This email is not verified yet. Check your inbox (and spam) for the Visupair message.",
            "error",
          );
        } else if (errorLower === "invalid email or password") {
          if (emailInput) emailInput.classList.add("error");
          showError(passwordInput, passwordError, "Invalid email or password");
        } else if (errorLower === "invalid password") {
          showError(passwordInput, passwordError, "Incorrect password");
        } else if (errorLower.includes("user not found")) {
          showError(
            emailInput,
            emailError,
            "User with this email does not exist",
          );

          // 2. Compound checks (medium specificity)
        } else if (
          errorLower.includes("password") &&
          errorLower.includes("short")
        ) {
          showError(
            passwordInput,
            passwordError,
            "Password is too short (minimum 8 characters)",
          );
        } else if (
          errorLower.includes("already") &&
          errorLower.includes("exist")
        ) {
          showError(emailInput, emailError, "This email is already registered");
        } else if (
          errorLower.includes("invalid") &&
          errorLower.includes("email")
        ) {
          showError(emailInput, emailError, "Invalid email address");

          // 3. Generic fallback
        } else {
          showError(emailInput, emailError, errorMessage);
        }
      }
    } catch (error: any) {
      console.error("Auth error:", error);
      // If the fetch itself failed (network error / dev-env issue), still give
      // a useful hint rather than a cryptic message.
      const isNetworkError =
        error instanceof TypeError && error.message.toLowerCase().includes("fetch");
      showError(
        emailInput,
        emailError,
        isNetworkError
          ? "Network error — please check your connection and try again."
          : "Something went wrong. Please try again.",
      );
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = isSignUp ? "Sign Up" : "Login";
      }
    }
  });

  // Google Authentication Handler
  const googleBtn = document.querySelector(".btn-google");

  if (googleBtn) {
    googleBtn.addEventListener("click", async () => {
      try {
        const { signIn } = await import("~/lib/auth-client");

        await signIn.social({
          provider: "google",
          callbackURL: "/account/profile", // Where to redirect after successful login
        });
      } catch (error) {
        console.error("Google auth error:", error);
        showError(emailInput, emailError, "Failed to connect with Google. Please try again.");
      }
    });
  }

  const syncAuthHeroVisual = () => {
    const img = document.getElementById(
      "auth-hero-visual",
    ) as HTMLImageElement | null;
    if (!img) return;
    const theme = document.documentElement.hasAttribute("data-theme")
      ? "dark"
      : "light";
    img.src = `/images/hero/login-${theme}.webp`;
  };

  let authHeroThemeObserver: MutationObserver | null = null;

  const cleanupAuthHeroVisual = () => {
    authHeroThemeObserver?.disconnect();
    authHeroThemeObserver = null;
  };

  const initAuthHeroVisual = () => {
    cleanupAuthHeroVisual();
    syncAuthHeroVisual();
    authHeroThemeObserver = new MutationObserver(syncAuthHeroVisual);
    authHeroThemeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  };

  document.addEventListener("astro:page-load", initAuthHeroVisual);
  document.addEventListener("astro:before-preparation", cleanupAuthHeroVisual);
</script>
