---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CategoryCarousel from "../components/CategoryCarousel.astro";
import ServicePromoCard from "../components/ServicePromoCard.astro";
import { Image, getImage } from "astro:assets";
import bgDark from "../assets/hero/bg-dark.webp";
import bgLight from "../assets/hero/bg-light.webp";
import preloaderDark from "../assets/hero/preloader-dark-forslowdivaces.webp";
import preloaderLight from "../assets/hero/preloader-light-forslowdivaces.webp";
import coursesDark from "../assets/hero/courses-dark.webp";
import coursesLight from "../assets/hero/courses-light.webp";
import carouselFashion from "../assets/carousel/fashion_runway_scene.webp";
import carouselCube from "../assets/carousel/cube_rube_blender.webp";
import carouselScream from "../assets/carousel/scream_painting.webp";

export const prerender = true;

/** Canonical site origin for absolute legal URLs (Google OAuth / consent screen alignment). */
const siteOrigin = Astro.site?.origin ?? "https://visupair.com";
const privacyPolicyUrl = `${siteOrigin}/legal/privacy-policy/`;
const termsOfServiceUrl = `${siteOrigin}/legal/terms-of-service/`;

const heroBgDarkSrc = (await getImage({ src: bgDark })).src;
const heroBgLightSrc = (await getImage({ src: bgLight })).src;
const heroPreDarkSrc = (await getImage({ src: preloaderDark })).src;
const heroPreLightSrc = (await getImage({ src: preloaderLight })).src;

/** Inline only — avoids `define:vars` creating an empty Vite chunk on build. */
const heroImagePreloadScript = `(function(){try{var t=window.visupairGetTheme?window.visupairGetTheme():"dark";function p(h,m){var l=document.createElement("link");l.rel="preload";l.as="image";l.type="image/webp";l.href=h;if(m)l.media=m;document.head.appendChild(l)}var b=t==="dark"?${JSON.stringify(heroBgDarkSrc)}:${JSON.stringify(heroBgLightSrc)};var r=t==="dark"?${JSON.stringify(heroPreDarkSrc)}:${JSON.stringify(heroPreLightSrc)};p(b,"(min-width: 381px)");p(r,"(max-width: 380px)")}catch(e){}})();`;
---

<Layout
  title="Visupair - Design & Digital Creation"
  description="Creative portfolio and digital showcase. Explore unique designs, fashion, 3D models and artworks from Visupair studio."
>
  <Fragment slot="head">
    <script is:inline set:html={heroImagePreloadScript} />
  </Fragment>

  <div class="hero-wrapper">
    <div class="hero-island">
      <div class="hero-content">
        <div class="hero-badge">Creative Platform</div>

        <h1 class="hero-title animate-text above-fold-reveal" style="--anim-delay: 0s;">
          Welcome to<br />
          <span class="hero-accent">Visupair</span>
        </h1>

        <p class="hero-subtitle animate-text above-fold-reveal" style="--anim-delay: 0.1s;">
          Art, fashion, and digital design all in one <br /> place. We didn't start a business. We just never stopped making.
        </p>

        <div class="hero-actions animate-text above-fold-reveal" style="--anim-delay: 0.2s;">
          <Button href="/store" variant="primary" label="Visit Store" />
          <Button
            href="/portfolio"
            variant="secondary"
            label="Explore Portfolio"
          />
        </div>
      </div>

      <div class="hero-visual loading" id="hero-visual-wrapper">
        <Image
          src={bgDark}
          alt=""
          class="hero-bg hero-bg-theme hero-bg--dark"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          draggable={false}
          quality={88}
          sizes="(max-width: 380px) 0px, (max-width: 833px) 85vw, (max-width: 1024px) 52vw, 48vw"
        />
        <Image
          src={bgLight}
          alt=""
          class="hero-bg hero-bg-theme hero-bg--light"
          loading="eager"
          fetchpriority="low"
          decoding="async"
          draggable={false}
          quality={88}
          sizes="(max-width: 380px) 0px, (max-width: 833px) 85vw, (max-width: 1024px) 52vw, 48vw"
        />
        <Image
          src={preloaderDark}
          alt="Visupair"
          class="hero-static-mobile hero-static-theme hero-static--dark"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          draggable={false}
          quality={88}
          sizes="(max-width: 380px) 100vw, 0px"
        />
        <Image
          src={preloaderLight}
          alt="Visupair"
          class="hero-static-mobile hero-static-theme hero-static--light"
          loading="eager"
          fetchpriority="low"
          decoding="async"
          draggable={false}
          quality={88}
          sizes="(max-width: 380px) 100vw, 0px"
        />
        <div id="hero-lottie-container" aria-hidden="true"></div>
      </div>
    </div>
  </div>

  <!-- Services Promo Section -->
  <div class="services-wrapper">
    <div class="services-island">
      <div class="services-header">
        <h2 class="services-title animate-text">Our Creative Services</h2>
        <p class="services-subtitle animate-text" style="--anim-delay: 0.1s;">
          We help artists, independent designers, and brands build a visual presence that actually reflects their work. 
        </p>
      </div>

      <div class="services-grid">
        <div style="--anim-delay: 0.2s;">
          <ServicePromoCard
            title="Logo Design"
            description="Creating unique visual marks that represent your brand essence. "
            href="/services/logo-design"
            processSteps={[
              "Discovery & Research",
              "Conceptual Sketching",
              "Vector Refinement",
            ]}
          />
        </div>
        <div style="--anim-delay: 0.3s;">
          <ServicePromoCard
            title="Web Design"
            description="Creating high-performance, responsive websites with a focus on conversion and user engagement."
            href="/services/web-design"
            processSteps={[
              "UX Wireframing",
              "UI Visual Design",
              "Interactive Prototyping",
            ]}
          />
        </div>
        <div style="--anim-delay: 0.4s;">
          <ServicePromoCard
            title="Brand Identity"
            description="Building a cohesive visual language across all touchpoints to ensure brand recognition."
            href="/services/brand-identity"
            processSteps={[
              "Brand Strategy",
              "Visual System Design",
              "Brand Guidelines",
            ]}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Categories Section - Carousel -->
  <CategoryCarousel
    categories={[
      {
        title: "Garments & Accessories",
        description:
          "Digital and physical fashion pieces designed for real and virtual worlds.",
        image: carouselFashion,
        href: "/store/fashion-design",
      },
      {
        title: "3D Models",
        description:
          "High-quality 3D assets ready for integration and rendering.",
        image: carouselCube,
        href: "/store/3d-models",
      },
      {
        title: "Art Works",
        description: "Creative artworks and projects.",
        image: carouselScream,
        href: "/store/artworks",
      },
    ]}
  />
  <!-- Courses CTA Section -->
  <div class="courses-wrapper">
    <div class="courses-island">
      <!-- Left: Copy -->
      <div class="courses-content">
        <div class="courses-badge animate-text" style="--anim-delay: 0s;">
          Courses
        </div>

        <h2 class="courses-title animate-text" style="--anim-delay: 0.08s;">
          We learned by doing<br />
          <span class="courses-accent">Now we teach the same way</span>
        </h2>

        <p class="courses-subtitle animate-text" style="--anim-delay: 0.16s;">
          We trust that knowledge grows when it's shared. Just everything we've figured out, share as simply as we can.
        </p>

        <ul
          class="courses-features animate-text"
          style="--anim-delay: 0.24s;"
          aria-label="Course highlights"
        >
          <li>
            <span class="courses-feature-icon" aria-hidden="true">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </span>
            Oil Painting &amp; Mixed Media
          </li>
          <li>
            <span class="courses-feature-icon" aria-hidden="true">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </span>
            Pattern Making (Digital &amp; Traditional)
          </li>
          <li>
            <span class="courses-feature-icon" aria-hidden="true">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </span>
            3D Modelling in Blender
          </li>
          <li>
            <span class="courses-feature-icon" aria-hidden="true">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </span>
            Digital Fashion
          </li>
        </ul>

        <div class="courses-actions animate-text" style="--anim-delay: 0.32s;">
          <Button
            href="/courses"
            variant="primary"
            label="Browse Courses"
            icon={true}
          />
          <Button
            href="/contact"
            variant="secondary"
            label="Contact Us"
          />
        </div>
      </div>

      <!-- Right: Theme-aware image -->
      <div class="courses-visual" aria-hidden="true">
        <div class="courses-img-stack">
          <Image
            src={coursesDark}
            class="courses-img courses-img-theme courses-img--dark"
            alt="Courses — creative tools, painting palette and 3D modelling"
            loading="lazy"
            decoding="async"
            draggable={false}
            width={1200}
            height={896}
            quality={92}
            sizes="(max-width: 749px) 92vw, (max-width: 1200px) 45vw, 560px"
          />
          <Image
            src={coursesLight}
            class="courses-img courses-img-theme courses-img--light"
            alt="Courses — creative tools, painting palette and 3D modelling"
            loading="lazy"
            decoding="async"
            draggable={false}
            width={1200}
            height={896}
            quality={92}
            sizes="(max-width: 749px) 92vw, (max-width: 1200px) 45vw, 560px"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="faq-wrapper">
    <div class="faq-island">
      <div class="faq-header">
        <h2 class="faq-title animate-text">Frequently Asked Questions</h2>
        <p class="faq-subtitle animate-text" style="--anim-delay: 0.1s;">
          Find answers to common questions about our products, services, shipping, and more.
        </p>
      </div>

      <div class="faq-grid">
        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="1" aria-expanded="false" id="faq-trigger-1" aria-controls="faq-answer-1">
            <span class="faq-number" aria-hidden="true">01</span>
            <h3 class="faq-question">What exactly is VisuPair?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="1" id="faq-answer-1" role="region" aria-labelledby="faq-trigger-1">
            <p>VisuPair is a creative studio run by two multidisciplinary designers. We create our own art, fashion, and digital pieces, collaborate with artists and brands on their visual identity, and teach workshops</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="2" aria-expanded="false" id="faq-trigger-2" aria-controls="faq-answer-2">
            <span class="faq-number" aria-hidden="true">02</span>
            <h3 class="faq-question">What does "phygital" mean?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="2" id="faq-answer-2" role="region" aria-labelledby="faq-trigger-2">
            <p>"Phygital is how we describe work that exists in both the physical and digital world. A garment we design can be worn in real life and also exist as a 3D model or digital collectible. We move ideas between both realities without losing what makes them meaningful.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="3" aria-expanded="false" id="faq-trigger-3" aria-controls="faq-answer-3">
            <span class="faq-number" aria-hidden="true">03</span>
            <h3 class="faq-question">What is a digital collectible?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="3" id="faq-answer-3" role="region" aria-labelledby="faq-trigger-3">
            <p>A digital collectible is a piece that exists only in the digital world, it could be a wearable for an avatar, a 3D model, or a digital artwork. It is a real creative work, just without a physical form.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="4" aria-expanded="false" id="faq-trigger-4" aria-controls="faq-answer-4">
            <span class="faq-number" aria-hidden="true">04</span>
            <h3 class="faq-question">What kind of pieces do you sell?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="4" id="faq-answer-4" role="region" aria-labelledby="faq-trigger-4">
            <p>We sell garments, accessories, paintings, art works, and digital works, all designed and made by us. Some pieces exist physically, some digitally, and some in both forms. Certain works are one of a kind and will never be repeated. Others are released in very limited numbers. If something speaks to you, it is worth not waiting.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="5" aria-expanded="false" id="faq-trigger-5" aria-controls="faq-answer-5">
            <span class="faq-number" aria-hidden="true">05</span>
            <h3 class="faq-question">What kind of clients do you work with?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="5" id="faq-answer-5" role="region" aria-labelledby="faq-trigger-5">
            <p>We work with artists, independent designers, and brands of all sizes. If you have creative work that matters to you and you need help showing it to the world in a way that feels true, we are probably a good fit. We work with people from anywhere in the world fully remotely.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="6" aria-expanded="false" id="faq-trigger-6" aria-controls="faq-answer-6">
            <span class="faq-number" aria-hidden="true">06</span>
            <h3 class="faq-question">What services do you offer?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="6" id="faq-answer-6" role="region" aria-labelledby="faq-trigger-6">
            <p>
              We help with logos, visual identities, websites, color palettes, creative direction, look books, and more. Every project is different, so we always start with a conversation to understand what you actually need.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="7" aria-expanded="false" id="faq-trigger-7" aria-controls="faq-answer-7">
            <span class="faq-number" aria-hidden="true">07</span>
            <h3 class="faq-question">Do you only run your own workshops?               </h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="7" id="faq-answer-7" role="region" aria-labelledby="faq-trigger-7">
            <p>Not at all. Alongside our own workshops, we also invite experienced creators, artists, and designers to come and teach. We believe that learning from different voices and practices makes the experience richer for everyone. So whether a workshop is led by us or by a guest, the same values apply honest, open, and worth your time.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="8" aria-expanded="false" id="faq-trigger-8" aria-controls="faq-answer-8">
            <span class="faq-number" aria-hidden="true">08</span>
            <h3 class="faq-question">How do I start working with you?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="8" id="faq-answer-8" role="region" aria-labelledby="faq-trigger-8">
            <p>Just reach out and tell us a little about your project. We will get back to you to set up a conversation and go from there.</p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="9" aria-expanded="false" id="faq-trigger-9" aria-controls="faq-answer-9">
            <span class="faq-number" aria-hidden="true">09</span>
            <h3 class="faq-question">How do I track my orders?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="9" id="faq-answer-9" role="region" aria-labelledby="faq-trigger-9">
            <p>
              Log in to your account and open <strong>Purchases</strong> to see order status, tracking number when available, estimated delivery, and courier details. We also send tracking updates by email.
            </p>
          </div>
        </div>

        <div class="faq-panel">
          <button type="button" class="faq-item" data-faq="10" aria-expanded="false" id="faq-trigger-10" aria-controls="faq-answer-10">
            <span class="faq-number" aria-hidden="true">10</span>
            <h3 class="faq-question">Can I return or refund my orders?</h3>
            <div class="faq-toggle" aria-hidden="true">
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline points="6,15 12,9 18,15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </button>
          <div class="faq-answer" data-faq="10" id="faq-answer-10" role="region" aria-labelledby="faq-trigger-10">
            <p>
              Eligibility depends on product type and condition. Please read our
              <a href="/legal/refund-policy">Refund Policy</a>
              for timelines and rules. For help with a specific order, email
              <a href="mailto:info@visupair.com">info@visupair.com</a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- OAuth / branding verification — same outer gutters as FAQ/services (12px sides). -->
  <section
    class="home-trust-disclosure"
    aria-labelledby="home-trust-heading"
  >
    <div class="home-trust-inner">
      <h2 id="home-trust-heading" class="home-trust-title">
        What Visupair is and how we use account data
      </h2>
      <p class="home-trust-text">
        Visupair is a creative studio website and online store: portfolio, services, courses, and
        digital and physical products. You can explore most of the site without an account.
        <strong>Creating an account</strong> (email and password or optional
        <strong>Sign in with Google</strong>) lets you save favorites, manage purchases and
        orders, and keep a profile. We use your information only to provide those features,
        secure your account, and communicate about transactions and support, as explained in our
        <a href={privacyPolicyUrl}>Privacy Policy</a>.
      </p>
      <p class="home-trust-links">
        <a href={privacyPolicyUrl}>Privacy Policy</a>
        <span class="home-trust-sep" aria-hidden="true">·</span>
        <a href={termsOfServiceUrl}>Terms of Service</a>
      </p>
    </div>
  </section>

  <script>
    import lottieLight from "lottie-web/build/player/lottie_light";

    let lottie: typeof lottieLight | null = null;
    let anim: ReturnType<typeof lottieLight.loadAnimation> | null = null;
    let currentTheme: string | null = null;
    let themeObserver: MutationObserver | null = null;
    let intersectionObserver: IntersectionObserver | null = null;
    let prefersColorSchemeMedia: MediaQueryList | null = null;
    let narrowHeroMql: MediaQueryList | null = null;
    let hasCompletedHomeClientNav = false;
    let heroLottieLoadToken = 0;
    let heroLottieIntersectTimer: ReturnType<typeof setTimeout> | null = null;

    const getTheme = () =>
      document.documentElement.hasAttribute("data-theme") ? "dark" : "light";

    const NARROW_HERO_PX = 380;

    const isNarrowHero = () =>
      window.matchMedia(`(max-width: ${NARROW_HERO_PX}px)`).matches;

    const revealHeroWhenReady = () => {
      const wrapper = document.getElementById("hero-visual-wrapper");
      if (!wrapper?.classList.contains("loading")) return;
      const theme = getTheme();
      const narrow = isNarrowHero();
      const sel = narrow
        ? theme === "dark"
          ? ".hero-static--dark"
          : ".hero-static--light"
        : theme === "dark"
          ? ".hero-bg--dark"
          : ".hero-bg--light";
      const img = document.querySelector(sel) as HTMLImageElement | null;
      const done = () => wrapper.classList.remove("loading");
      if (img?.complete) done();
      else img?.addEventListener("load", done, { once: true });
    };

    const loadAnimation = async (theme: string) => {
      if (isNarrowHero()) return;

      const container = document.getElementById("hero-lottie-container");
      const wrapper = document.getElementById("hero-visual-wrapper");
      if (!container || !wrapper) return;

      if (
        currentTheme === theme &&
        anim &&
        container.querySelector("svg") !== null
      ) {
        wrapper.classList.add("lottie-loaded");
        return;
      }

      const myToken = ++heroLottieLoadToken;

      try {
        anim?.destroy();
      } catch {
        /* ignore */
      }
      anim = null;
      container.innerHTML = "";
      wrapper.classList.remove("lottie-loaded");

      try {
        if (!lottie) {
          lottie = lottieLight;
        }

        anim = lottie.loadAnimation({
          container,
          renderer: "svg",
          autoplay: true,
          loop: true,
          path: `/images/hero/visupairillustration-${theme}.json`,
        });

        anim.addEventListener("DOMLoaded", () => {
          if (myToken !== heroLottieLoadToken) return;
          wrapper.classList.add("lottie-loaded");
        });
        currentTheme = theme;
      } catch (error) {
        console.error("Failed to load Lottie:", error);
      }
    };

    const onThemeChange = () => {
      const theme = getTheme();
      if (!isNarrowHero() && theme !== currentTheme) loadAnimation(theme);
    };

    const onNarrowHeroMediaChange = () => {
      const theme = getTheme();
      const container = document.getElementById("hero-lottie-container");
      const wrapper = document.getElementById("hero-visual-wrapper");
      if (isNarrowHero()) {
        heroLottieLoadToken++;
        if (heroLottieIntersectTimer) {
          clearTimeout(heroLottieIntersectTimer);
          heroLottieIntersectTimer = null;
        }
        try {
          anim?.destroy();
        } catch {
          /* ignore */
        }
        anim = null;
        currentTheme = null;
        if (container) container.innerHTML = "";
        wrapper?.classList.remove("lottie-loaded");
      } else if (container && wrapper) {
        void loadAnimation(theme);
      }
      revealHeroWhenReady();
    };

    const cleanup = () => {
      themeObserver?.disconnect();
      intersectionObserver?.disconnect();
      prefersColorSchemeMedia?.removeEventListener("change", onThemeChange);
      narrowHeroMql?.removeEventListener("change", onNarrowHeroMediaChange);
      if (heroLottieIntersectTimer) {
        clearTimeout(heroLottieIntersectTimer);
        heroLottieIntersectTimer = null;
      }
      themeObserver = intersectionObserver = prefersColorSchemeMedia = null;
      narrowHeroMql = null;
    };

    /** CSS keyframe animations often do not restart after Astro view transitions — force reflow */
    const restartAboveFoldReveal = (selector: string) => {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        return;
      }
      document.querySelectorAll(selector).forEach((el) => {
        const h = el as HTMLElement;
        h.style.animation = "none";
        void h.offsetHeight;
        h.style.removeProperty("animation");
      });
    };

    const init = () => {
      cleanup();
      const theme = getTheme();
      revealHeroWhenReady();

      if (!isNarrowHero()) {
        const container = document.getElementById("hero-lottie-container");
        if (container) {
          // After Astro page swap the DOM is fresh — the old anim instance
          // is attached to the removed element and its SVG is gone.
          // Detect this and reset so loadAnimation() runs cleanly.
          const hasAnimationInDOM = container.querySelector("svg") !== null;
          if (anim && !hasAnimationInDOM) {
            anim.destroy();
            anim = null;
            currentTheme = null;
          }

          if (currentTheme === theme && hasAnimationInDOM) {
            document
              .getElementById("hero-visual-wrapper")
              ?.classList.add("lottie-loaded");
          }

          intersectionObserver = new IntersectionObserver(
            (entries) => {
              if (entries[0].isIntersecting) {
                const svgPresent = container.querySelector("svg") !== null;
                if (!anim || !svgPresent) {
                  if (heroLottieIntersectTimer) {
                    clearTimeout(heroLottieIntersectTimer);
                  }
                  heroLottieIntersectTimer = setTimeout(() => {
                    heroLottieIntersectTimer = null;
                    if (!isNarrowHero()) void loadAnimation(getTheme());
                  }, 100);
                } else {
                  anim.play();
                }
              } else {
                if (heroLottieIntersectTimer) {
                  clearTimeout(heroLottieIntersectTimer);
                  heroLottieIntersectTimer = null;
                }
                anim?.pause();
              }
            },
            { threshold: 0.35 },
          );
          intersectionObserver.observe(container);
        }
      }

      themeObserver = new MutationObserver(onThemeChange);
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });
      prefersColorSchemeMedia = window.matchMedia(
        "(prefers-color-scheme: dark)",
      );
      prefersColorSchemeMedia.addEventListener("change", onThemeChange);

      narrowHeroMql = window.matchMedia(
        `(max-width: ${NARROW_HERO_PX}px)`,
      );
      narrowHeroMql.addEventListener("change", onNarrowHeroMediaChange);

      // Text animation observer
      const textObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              textObserver.unobserve(entry.target);
            }
          });
        },
        { rootMargin: "0px 0px -50px 0px", threshold: 0.1 },
      );

      document.querySelectorAll(".animate-text").forEach((el) => {
        if (
          el.classList.contains("is-visible") ||
          el.classList.contains("above-fold-reveal")
        ) {
          return;
        }
        textObserver.observe(el);
      });

      // View transitions: replay keyframes when returning to home (first paint uses CSS only)
      if (hasCompletedHomeClientNav) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            restartAboveFoldReveal(
              ".hero-content .animate-text.above-fold-reveal",
            );
          });
        });
      }
      hasCompletedHomeClientNav = true;
    };

    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:before-preparation", cleanup);

    /**
     * FAQ accordion: document-level delegation so it keeps working after
     * Astro view transitions (new DOM replaces old; per-button listeners
     * would stay on detached elements).
     */
    function syncHomeFaqAria() {
      const wrapper = document.querySelector(".faq-wrapper");
      if (!wrapper) return;
      wrapper.querySelectorAll(".faq-answer").forEach((a) => {
        a.setAttribute(
          "aria-hidden",
          a.classList.contains("open") ? "false" : "true",
        );
      });
    }

    document.addEventListener("astro:page-load", syncHomeFaqAria);

    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;
      const item = target.closest(".faq-wrapper .faq-item");
      if (!(item instanceof HTMLButtonElement)) return;

      const wrapper = item.closest(".faq-wrapper");
      if (!wrapper) return;

      const faqId = item.getAttribute("data-faq");
      if (!faqId) return;

      const answer = wrapper.querySelector(
        `.faq-answer[data-faq="${CSS.escape(faqId)}"]`,
      );
      if (!answer) return;

      const faqItems = wrapper.querySelectorAll(".faq-item");
      const faqAnswers = wrapper.querySelectorAll(".faq-answer");

      const isOpen = answer.classList.contains("open");

      faqAnswers.forEach((a) => {
        a.classList.remove("open");
        a.setAttribute("aria-hidden", "true");
      });
      faqItems.forEach((btn) => {
        btn.setAttribute("aria-expanded", "false");
      });

      if (!isOpen) {
        answer.classList.add("open");
        answer.setAttribute("aria-hidden", "false");
        item.setAttribute("aria-expanded", "true");

        if (window.innerWidth < 768) {
          const panel = item.closest(".faq-panel");
          setTimeout(() => {
            (panel ?? answer).scrollIntoView({
              behavior: "smooth",
              block: "nearest",
            });
          }, 100);
        }
      }
    });
  </script>

