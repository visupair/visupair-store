    }

    .home-trust-sep {
      opacity: 0.45;
      user-select: none;
    }

    :global([data-theme="dark"]) .home-trust-title,
    :global([data-theme="dark"]) .home-trust-text {
      color: #fff;
    }

    /* ═══════════════════════════════════════
       SERVICES PROMO SECTION
       ═══════════════════════════════════════ */
    .services-wrapper {
      width: 100%;
      padding: 0 12px;
      box-sizing: border-box;
      margin-top: 12px;
      margin-bottom: 12px;
    }

    .services-island {
      width: 100%;
      border-radius: var(--radius-xl);
      border: 1px solid var(--border-subtle);
      padding: clamp(40px, 5vw, 64px) clamp(24px, 4vw, 56px);
      background: var(--surface);
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.02),
        var(--shadow-island);
      animation: heroFadeIn 0.6s cubic-bezier(0.2, 0, 0, 1) both;
      animation-delay: 0.15s;
      position: relative;
    }

    :global([data-theme="dark"]) .services-island {
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.2),
        var(--shadow-island);
    }

    .services-header {
      margin-bottom: 40px;
      text-align: center;
    }

    .services-title {
      font-size: clamp(32px, 5vw, 64px);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--foreground);
      margin: 0 0 12px 0;
    }

    .services-subtitle {
      font-size: clamp(16px, 1.5vw, 18px);
      color: var(--foreground);
      opacity: 0.7;
      margin: 0;
      max-width: 700px;
      margin-inline: auto;
      line-height: 1.6;
    }

    :global([data-theme="dark"]) .services-title,
    :global([data-theme="dark"]) .services-subtitle {
      color: #ffffff;
    }

    .services-grid {
      display: grid;
      /* minmax(0,1fr) keeps equal-width columns when content lengths differ */
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 24px;
      align-items: stretch;
    }

    /* Wrappers: flex shell for the card link */
    .services-grid > * {
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    @media (max-width: 1023px) {
      .services-grid {
        grid-template-columns: 1fr;
        justify-items: center;
      }

      .services-grid > * {
        width: 100%;
        max-width: 560px;
      }
    }

    /* Equal-height cards in one row: fill grid cell so short copy still matches tallest card */
    @media (min-width: 1024px) {
      .services-grid > * {
        min-height: 0;
        height: 100%;
        align-self: stretch;
      }

      :global(.services-grid .service-card) {
        flex: 1 1 auto;
        min-height: 0;
        height: 100%;
        align-self: stretch;
      }
    }

    /* ═══════════════════════════════════════
       COURSES CTA SECTION
       ═══════════════════════════════════════ */
    .courses-wrapper {
      width: 100%;
      padding: 0 12px;
      box-sizing: border-box;
    }

    .courses-island {
      width: 100%;
      border-radius: var(--radius-xl);
      border: 1px solid var(--border-subtle);
      overflow: hidden;
      display: flex;
      align-items: stretch;
      position: relative;
      animation: heroFadeIn 0.6s cubic-bezier(0.2, 0, 0, 1) 0.2s both;
      background: var(--surface);
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.02),
        var(--shadow-island);
    }

    :global([data-theme="dark"]) .courses-island {
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.2),
        var(--shadow-island);
    }

    /* Dark glow blobs — reuse the same keyframes from hero */
    .courses-island::before,
    .courses-island::after {
      content: "";
      position: absolute;
      pointer-events: none;
      z-index: 0;
      border-radius: 50%;
      will-change: transform;
    }

    :global([data-theme="dark"]) .courses-island::before {
      top: -60%;
      left: -30%;
      width: clamp(600px, 120vw, 1800px);
      aspect-ratio: 1;
      background: radial-gradient(
        closest-side,
        rgba(163, 142, 255, 0.35) 0%,
        rgba(163, 142, 255, 0.12) 35%,
        rgba(163, 142, 255, 0.02) 70%,
        rgba(163, 142, 255, 0) 100%
      );
      opacity: 0.5;
      animation: blobDrift2 26s infinite alternate ease-in-out;
    }

    :global([data-theme="dark"]) .courses-island::after {
      bottom: -50%;
      right: -25%;
      width: clamp(500px, 100vw, 1600px);
      aspect-ratio: 1;
      background: radial-gradient(
        closest-side,
        rgba(132, 128, 255, 0.3) 0%,
        rgba(132, 128, 255, 0.1) 35%,
        rgba(132, 128, 255, 0.02) 70%,
        rgba(132, 128, 255, 0) 100%
      );
      opacity: 0.45;
      animation: blobDrift1 32s infinite alternate ease-in-out;
    }

    /* ── Left content pane ── */
    .courses-content {
      flex: 0 0 50%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: clamp(20px, 3vw, 32px);
      padding: clamp(68px, 6vw, 100px) clamp(32px, 5vw, 64px);
      position: relative;
      z-index: 1;
    }

    /* ── Badge ── */
    .courses-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      padding: 6px 16px;
      background: rgba(132, 128, 255, 0.1);
      border: 1px solid rgba(132, 128, 255, 0.25);
      border-radius: 100px;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--brand-violet);
    }

    /* ── Title — modestly smaller than the original max (64px) ── */
    .courses-title {
      font-size: clamp(26px, 4vw, 56px);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--foreground);
      margin: 0;
    }

    /* Second line (“Now we teach…”) — slightly smaller than the first line */
    .courses-title .courses-accent {
      display: block;
      font-size: 0.88em;
      line-height: 1.15;
      margin-top: 0.06em;
    }

    :global([data-theme="dark"]) .courses-title {
      color: #ffffff;
    }

    .courses-accent {
      background: linear-gradient(135deg, var(--brand-violet) 0%, #a78bfa 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Subtitle ── */
    .courses-subtitle {
      font-size: clamp(14px, 1.5vw, 17px);
      line-height: 1.65;
      color: var(--foreground);
      opacity: 0.65;
      margin: 0;
      max-width: 520px;
    }

    :global([data-theme="dark"]) .courses-subtitle {
      color: #ffffff;
      opacity: 0.7;
    }

    /* ── Feature List ── */
    .courses-features {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 0;
      margin: 0;
    }

    .courses-features li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: clamp(13px, 1.2vw, 15px);
      font-weight: 500;
      color: var(--foreground);
      opacity: 0.85;
    }

    :global([data-theme="dark"]) .courses-features li {
      color: #ffffff;
    }

    .courses-feature-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 6px;
      background: rgba(132, 128, 255, 0.12);
      border: 1px solid rgba(132, 128, 255, 0.2);
      color: var(--brand-violet);
    }

    /* ── Action Buttons ── */
    .courses-actions {
      display: flex;
      gap: clamp(10px, 1.5vw, 14px);
      flex-wrap: wrap;
    }

    /* ── Right visual — nearly full column width for the illustration ── */
    .courses-visual {
      flex: 1;
      min-width: 0;
      z-index: 1;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      box-sizing: border-box;
    }

    /* Match source art (3000×2240) — a square box + square Image() dims were padding the raster with black bars */
    .courses-img-stack {
      position: relative;
      width: 98%;
      max-width: 100%;
      margin-inline: auto;
      aspect-ratio: 3000 / 2240;
      border-radius: var(--radius-lg);
      overflow: hidden;
      background: transparent;
    }

    /* Image — natural block flow, full width, 1:1 ratio preserved */
    .courses-img {
      display: block;
      width: 100%;
      height: auto;
      user-select: none;
      -webkit-user-select: none;
      -webkit-user-drag: none;
      pointer-events: none;
    }

    .courses-img-theme {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
    }

    .courses-img--dark {
      opacity: 0;
    }

    :global([data-theme="dark"]) .courses-img--dark {
      opacity: 1;
    }

    .courses-img--light {
      opacity: 1;
    }

    :global([data-theme="dark"]) .courses-img--light {
      opacity: 0;
    }

    /* ═══════════════════════════════════════
       RESPONSIVE — Courses CTA
       ═══════════════════════════════════════ */

    /* Large desktop */
    @media (min-width: 1281px) {
      .courses-content {
        flex: 0 0 48%;
      }
    }

    /* Medium desktop */
    @media (min-width: 1025px) and (max-width: 1280px) {
      .courses-title {
        font-size: clamp(24px, 3.5vw, 48px);
      }
      .courses-content {
        padding: clamp(40px, 5vw, 64px) clamp(28px, 4vw, 48px);
      }
    }

    /* Tablet landscape */
    @media (min-width: 750px) and (max-width: 1024px) {
      .courses-island {
        flex-direction: row;
      }
      .courses-content {
        flex: 0 0 52%;
        padding: 36px 28px;
        gap: 20px;
      }
      .courses-title {
        font-size: clamp(22px, 3.4vw, 40px);
      }
      .courses-subtitle {
        font-size: 14px;
      }
    }

    /* Mobile: stack vertically, image on top — natural flow, no rotation */
    @media (max-width: 749px) {
      .courses-island {
        flex-direction: column;
        align-items: stretch; /* restore full-width stacking */
      }

      .courses-visual {
        order: -1;
        width: 100%;
        overflow: hidden;
      }

      .courses-img {
        display: block;
        width: 100%;
        height: auto;
      }

      .courses-img-theme {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
      }

      .courses-content {
        flex: none;
        padding: 28px 24px 36px;
        align-items: center;
        text-align: center;
      }
      .courses-subtitle {
        max-width: 100%;
        text-align: center;
      }
      /* List block centered in the column; each row still reads left-to-right inside */
      .courses-features {
        align-self: center;
        width: fit-content;
        max-width: 100%;
        align-items: flex-start;
      }

      .courses-features li {
        text-align: left;
      }

      .courses-actions {
        justify-content: center;
      }
    }

    @media (max-width: 480px) {
      .courses-title {
        font-size: clamp(22px, 6.5vw, 32px);
      }
      .courses-content {
        padding: 24px 20px 32px;
        gap: 18px;
      }
      .courses-img-stack {
        width: 100%;
      }
    }

    /* ═══════════════════════════════════════
       FAQ SECTION
       ═══════════════════════════════════════ */
    .faq-wrapper {
      width: 100%;
      margin-top: 12px;
      padding: 0 12px;
      box-sizing: border-box;
    }

    .faq-island {
      width: 100%;
      border-radius: var(--radius-xl);
      border: 1px solid var(--border-subtle);
      padding: clamp(40px, 5vw, 64px) clamp(24px, 4vw, 56px);
      background: var(--surface);
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.02),
        var(--shadow-island);
      animation: heroFadeIn 0.6s cubic-bezier(0.2, 0, 0, 1) 0.3s both;
      position: relative;
    }

    :global([data-theme="dark"]) .faq-island {
      box-shadow:
        inset 0 0 100px rgba(0, 0, 0, 0.2),
        var(--shadow-island);
    }

    /* ── Header ── */
    .faq-header {
      margin-bottom: 40px;
      text-align: center;
    }

    .faq-title {
      font-size: clamp(32px, 5vw, 64px);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--foreground);
      margin: 0 0 12px 0;
    }

    .faq-subtitle {
      font-size: clamp(16px, 1.5vw, 18px);
      color: var(--foreground);
      opacity: 0.7;
      margin: 0;
      max-width: 700px;
      margin-inline: auto;
      line-height: 1.6;
    }

    :global([data-theme="dark"]) .faq-title,
    :global([data-theme="dark"]) .faq-subtitle {
      color: #ffffff;
    }

    /* ── Grid Layout ──
       Ten panels in DOM order 1–10; desktop pairs (1|5), (2|6), (3|7), (4|8), (9|10).
       align-items:start so only the opened panel grows. */
    .faq-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px 20px;
      align-items: start;
    }

    @media (min-width: 769px) {
      .faq-grid > .faq-panel:nth-child(1) {
        grid-column: 1;
        grid-row: 1;
      }
      .faq-grid > .faq-panel:nth-child(2) {
        grid-column: 1;
        grid-row: 2;
      }
      .faq-grid > .faq-panel:nth-child(3) {
        grid-column: 1;
        grid-row: 3;
      }
      .faq-grid > .faq-panel:nth-child(4) {
        grid-column: 1;
        grid-row: 4;
      }
      .faq-grid > .faq-panel:nth-child(5) {
        grid-column: 2;
        grid-row: 1;
      }
      .faq-grid > .faq-panel:nth-child(6) {
        grid-column: 2;
        grid-row: 2;
      }
      .faq-grid > .faq-panel:nth-child(7) {
        grid-column: 2;
        grid-row: 3;
      }
      .faq-grid > .faq-panel:nth-child(8) {
        grid-column: 2;
        grid-row: 4;
      }
      .faq-grid > .faq-panel:nth-child(9) {
        grid-column: 1;
        grid-row: 5;
      }
      .faq-grid > .faq-panel:nth-child(10) {
        grid-column: 2;
        grid-row: 5;
      }
    }

    /* One card per Q&A — answer expands inside the same shell */
    .faq-panel {
      border-radius: var(--radius-lg);
      border: 1px solid var(--border-subtle);
      background: color-mix(in srgb, var(--surface) 88%, transparent);
      overflow: hidden;
      isolation: isolate;
      transition:
        border-color 0.25s ease,
        box-shadow 0.25s ease,
        background-color 0.25s ease;
    }

    .faq-panel:has(.faq-item[aria-expanded="true"]) {
      border-color: color-mix(in srgb, var(--brand-violet) 35%, var(--border-subtle));
      box-shadow: 0 4px 24px color-mix(in srgb, var(--brand-violet) 12%, transparent);
    }

    :global([data-theme="dark"]) .faq-panel {
      background: color-mix(in srgb, var(--surface) 92%, #0c0b14 8%);
    }

    :global([data-theme="dark"]) .faq-panel:has(.faq-item[aria-expanded="true"]) {
      box-shadow: 0 4px 28px rgba(132, 128, 255, 0.18);
    }

    /* ── FAQ trigger row ── */
    .faq-item {
      all: unset;
      box-sizing: border-box;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 14px 18px;
      width: 100%;
      padding: clamp(16px, 2.2vw, 22px) clamp(18px, 2.5vw, 24px);
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .faq-item:hover {
      background: color-mix(in srgb, var(--surface-hover) 65%, transparent);
    }

    .faq-item:focus-visible {
      outline: 2px solid var(--brand-violet);
      outline-offset: -2px;
    }

    .faq-item:active {
      background: color-mix(in srgb, var(--surface-hover) 85%, transparent);
    }

    /* ── Question index ── */
    .faq-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2rem;
      height: 2rem;
      padding: 0 0.35rem;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: var(--brand-violet);
      background: color-mix(in srgb, var(--brand-violet) 14%, transparent);
      flex-shrink: 0;
    }

    /* ── Question text ── */
    .faq-question {
      font-size: clamp(14px, 1.05vw, 16px);
      font-weight: 600;
      line-height: 1.35;
      color: var(--foreground);
      margin: 0;
      letter-spacing: -0.015em;
      text-align: left;
      word-break: break-word;
    }

    :global([data-theme="dark"]) .faq-question {
      color: #ffffff;
    }

    /* Plus becomes minus when open */
    .faq-toggle {
      display: grid;
      place-items: center;
      width: 2rem;
      height: 2rem;
      flex-shrink: 0;
      border-radius: 999px;
      line-height: 0;
      overflow: hidden;
      color: var(--brand-violet);
      background: color-mix(in srgb, var(--brand-violet) 12%, transparent);
      transition: background 0.2s ease, color 0.2s ease;
    }

    .faq-item:hover .faq-toggle {
      background: color-mix(in srgb, var(--brand-violet) 20%, transparent);
    }

    .faq-toggle svg.faq-chevron {
      width: 14px;
      height: 14px;
      display: block;
      flex-shrink: 0;
      transform-origin: 50% 50%;
      transform: rotate(0deg);
      transition: transform 0.4s cubic-bezier(0.34, 1.3, 0.64, 1);
    }

    .faq-item[aria-expanded="true"] .faq-toggle {
      color: #fff;
      background: var(--brand-violet);
    }

    .faq-item[aria-expanded="true"] .faq-toggle svg.faq-chevron {
      transform: rotate(180deg);
    }

    /* ── Answer ── */
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition:
        max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        padding 0.35s ease;
      padding: 0 clamp(18px, 2.5vw, 24px);
      margin: 0;
      border: none;
    }

    /* Divider: pseudo-element avoids border + opacity compositing flicker on dark backgrounds */
    .faq-answer.open {
      position: relative;
      max-height: min(70vh, 760px);
      padding: 0 clamp(18px, 2.5vw, 24px) clamp(16px, 2vw, 22px);
      padding-top: 0;
    }

    .faq-answer.open::before {
      content: "";
      position: absolute;
      left: clamp(18px, 2.5vw, 24px);
      right: clamp(18px, 2.5vw, 24px);
      top: 0;
      height: 1px;
      background: color-mix(in srgb, var(--border-subtle) 70%, var(--surface));
      pointer-events: none;
    }

    .faq-answer p {
      font-size: clamp(13px, 0.95vw, 15px);
      line-height: 1.65;
      color: var(--foreground);
      opacity: 0.78;
      margin: 0;
      padding-top: clamp(14px, 1.8vw, 18px);
    }

    :global([data-theme="dark"]) .faq-answer p {
      color: #e9e8ff;
    }

    .faq-answer a {
      color: var(--brand-violet);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .faq-answer a:hover {
      opacity: 0.9;
    }

    /* ═══════════════════════════════════════
       RESPONSIVE — FAQ
       ═══════════════════════════════════════ */

    @media (max-width: 1024px) {
      .faq-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px 16px;
      }
    }

    @media (max-width: 768px) {
      .faq-grid {
        grid-template-columns: 1fr;
        gap: 12px;
      }

      .faq-grid > .faq-panel {
        grid-column: auto !important;
        grid-row: auto !important;
        height: auto;
      }
      .faq-island {
        padding: clamp(32px, 4vw, 48px) clamp(20px, 3vw, 32px);
      }
      .faq-title {
        font-size: clamp(28px, 5vw, 48px);
      }
      .faq-item {
        padding: clamp(14px, 2vw, 18px) clamp(16px, 2.2vw, 20px);
        gap: 12px 14px;
      }
      .faq-number {
        font-size: 10px;
        min-width: 1.75rem;
        height: 1.75rem;
      }
      .faq-question {
        font-size: clamp(13px, 1vw, 15px);
      }
      .faq-toggle {
        width: 1.85rem;
        height: 1.85rem;
      }

      .faq-toggle svg.faq-chevron {
        width: 13px;
        height: 13px;
      }
    }

    @media (max-width: 480px) {
      .faq-wrapper {
        padding: 0 12px;
      }
      .faq-island {
        padding: 24px 16px;
        border-radius: var(--radius-lg);
      }
      .faq-grid {
        grid-template-columns: 1fr;
        gap: 10px;
      }
      .faq-header {
        margin-bottom: 24px;
      }
      .faq-title {
        font-size: 24px;
      }
      .faq-subtitle {
        font-size: 14px;
      }
      .faq-item {
        padding: 13px 14px;
        gap: 10px 12px;
      }
      .faq-number {
        font-size: 9px;
        min-width: 1.6rem;
        height: 1.6rem;
      }
      .faq-question {
        font-size: 13px;
      }
      .faq-toggle {
        width: 1.75rem;
        height: 1.75rem;
      }

      .faq-toggle svg.faq-chevron {
        width: 12px;
        height: 12px;
      }

      .faq-answer {
