      width: 1.75rem;
      height: 1.75rem;
    }

    .support-faq-chevron {
      width: 12px;
      height: 12px;
    }

    .support-direct-links {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .support-direct-link-btn {
      padding: 14px;
      font-size: 13px;
    }

    .support-form {
      gap: 16px;
    }

