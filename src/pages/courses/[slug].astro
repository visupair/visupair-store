---
import Layout from "../../layouts/Layout.astro";
import CourseDetail from "../../components/CourseDetail.astro";

const { slug } = Astro.params;

// Get server-detected currency from middleware
const serverCurrency = Astro.locals.currency;

// Fetch course from Sanity via API
const response = await fetch(`${Astro.url.origin}/api/courses/${slug}`);
const course = await response.json();

if (!course || course.error) {
    return Astro.redirect("/courses");
}
---

<Layout>
    <div class="page-container">
        <div class="content-block">
            <CourseDetail course={course} onClose={() => {}} serverCurrency={serverCurrency} />
        </div>
    </div>
</Layout>

<style>
    .page-container {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 24px;
        padding: 0 12px;
        margin: 0 auto;
        min-height: calc(100vh - 420px);
    }

    .content-block {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-xl);
        padding: 32px;
        width: 100%;
        min-height: 600px;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-island);
        position: relative;
    }

    @media (max-width: 900px) {
        .page-container {
            padding: 16px;
            gap: 16px;
        }

        .content-block {
            padding: 20px;
        }
    }
</style>
