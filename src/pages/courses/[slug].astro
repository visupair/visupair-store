---
import Layout from "../../layouts/Layout.astro";
import CourseDetail from "../../components/CourseDetail.astro";
import type { Course } from "../../lib/store-data";

const { slug } = Astro.params;

// Get server-detected currency from middleware
const serverCurrency = Astro.locals.currency;

// Fetch course from Sanity via API
const response = await fetch(`${Astro.url.origin}/api/courses/${slug}`);
let raw: unknown;
try {
    if (!response.ok) {
        return Astro.redirect("/courses");
    }
    raw = await response.json();
} catch {
    return Astro.redirect("/courses");
}

if (
    !raw ||
    typeof raw !== "object" ||
    Array.isArray(raw) ||
    typeof (raw as { error?: unknown }).error === "string"
) {
    return Astro.redirect("/courses");
}

const course = raw as Course;
---

<Layout>
    <div class="page-container">
        <div class="content-block">
            <CourseDetail course={course} onClose={() => {}} serverCurrency={serverCurrency} />
        </div>
    </div>
</Layout>

<style>
    .page-container {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 24px;
        padding: 0 12px;
        margin: 0 auto;
        min-height: calc(100vh - 420px);
    }

    .content-block {
        background: var(--surface);
        border: 1px solid var(--border-subtle);
        border-radius: var(--radius-xl);
        padding: 32px;
        width: 100%;
        min-height: 600px;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-island);
        position: relative;
    }

    @media (max-width: 900px) {
        .page-container {
            padding: 12px;
            gap: 12px;
        }

        .content-block {
            padding: 16px 14px;
            border-radius: var(--radius-lg);
            min-height: auto;
        }
    }

    @media (max-width: 480px) {
        .page-container {
            padding: 0 12px;
            gap: 12px;
        }

        .content-block {
            padding: 14px 12px;
        }
    }
</style>
